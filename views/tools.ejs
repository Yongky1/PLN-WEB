<!DOCTYPE html>
<html lang="id" class="scroll-smooth overflow-x-hidden">
<head>
    <%- include('partials/head') %>
    <script type="module" src="https://ajax.googleapis.com/ajax/libs/model-viewer/3.4.0/model-viewer.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
</head>
<body class="antialiased" style="background-color: var(--color-bg-main); color: var(--color-text-primary);">

    <%- include('partials/navbar') %>

    <main style="padding-top:96px; padding-bottom:64px; min-height:100vh;" class="relative">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

            <!-- Header -->
            <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-8 mb-10 pb-8 border-b border-[var(--color-border)] relative">
                <div class="ambient-mesh mesh-left"></div>
                <div class="gsap-reveal">
                    <div class="mb-2">
                        <span class="text-sm font-semibold tracking-widest text-[var(--color-primary)] uppercase">Peralatan Lapangan · PLN</span>
                    </div>
                    <h1 class="text-4xl md:text-5xl font-extrabold brand-font mb-3 tracking-tight leading-tight text-[var(--color-text-primary)]">
                        Tools &amp; Alat K3
                    </h1>
                    <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed max-w-lg">
                        Katalog lengkap peralatan keselamatan kerja dan alat teknis yang digunakan teknisi lapangan PLN.
                    </p>
                </div>

                <!-- Search + Filter -->
                <div class="flex items-center gap-3 flex-shrink-0 min-w-[300px] lg:min-w-[380px]">
                    <div class="flex-1 relative">
                        <div class="absolute left-3.5 top-1/2 transform -translate-y-1/2 text-[var(--color-text-muted)] pointer-events-none">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
                        </div>
                        <input class="w-full bg-white border border-[var(--color-border)] rounded-xl py-2.5 pl-10 pr-4 text-sm text-[var(--color-text-primary)] placeholder-[var(--color-text-muted)] outline-none focus:border-[var(--color-primary)] focus:ring-2 focus:ring-[var(--color-primary)]/10 transition-all"
                            id="v3-tools-search" type="text" placeholder="Cari peralatan..." oninput="v3FilterTools()">
                    </div>
                    <div class="relative" id="tools-filter-dd">
                        <button type="button" class="flex items-center gap-2 bg-white border border-[var(--color-border)] rounded-xl py-2.5 px-4 text-xs font-semibold text-[var(--color-text-secondary)] hover:border-[var(--color-primary)] hover:text-[var(--color-primary)] transition-all cursor-pointer outline-none whitespace-nowrap" onclick="v3ToggleToolsFilter()">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="opacity:.5"><path d="M3 6h18M6 12h12M10 18h4"/></svg>
                            <span id="tools-filter-label">Semua</span>
                            <svg class="w-3 h-3 transition-transform duration-200" id="tools-filter-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
                        </button>
                        <div id="tools-filter-menu" class="absolute top-full right-0 mt-2 min-w-[160px] rounded-xl bg-white border border-[var(--color-border)] shadow-xl z-50 hidden overflow-hidden">
                            <div class="p-1.5">
                                <div class="px-3 py-2 rounded-lg text-xs font-semibold cursor-pointer transition-colors hover:bg-[var(--color-primary)]/5 hover:text-[var(--color-primary)] text-[var(--color-primary)] bg-[var(--color-primary)]/5" onclick="v3SelectToolsFilter('all','Semua')">Semua</div>
                                <% categories.forEach(function(cat) { %>
                                    <div class="px-3 py-2 rounded-lg text-xs font-semibold cursor-pointer transition-colors hover:bg-[var(--color-primary)]/5 hover:text-[var(--color-primary)] text-[var(--color-text-secondary)]" onclick="v3SelectToolsFilter('<%= cat.id %>','<%= cat.name %>')"><%= cat.name %></div>
                                <% }); %>
                            </div>
                        </div>
                    </div>
                    <button type="button" id="tools-sort-btn" onclick="v3ToggleToolsSort()"
                        class="flex items-center gap-2 bg-white border border-[var(--color-border)] rounded-xl py-2.5 px-4 text-xs font-semibold text-[var(--color-text-secondary)] hover:border-[var(--color-primary)] hover:text-[var(--color-primary)] transition-all cursor-pointer outline-none whitespace-nowrap">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h13M3 12h9M3 18h5"/><path d="M16 18l3 3 3-3M19 9V21"/></svg>
                        <span id="tools-sort-label">A→Z</span>
                    </button>
                </div>
            </div>

            <!-- Grid -->
            <div id="tools-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 gsap-stagger-container">
                <% if (!toolsData || toolsData.length === 0) { %>
                <div class="col-span-full flex flex-col items-center justify-center py-20 gap-4">
                    <div class="w-16 h-16 rounded-lg bg-[var(--color-bg-surface-alt)] flex items-center justify-center">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-text-muted)" stroke-width="1.5"><path d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                    </div>
                    <span class="text-sm text-[var(--color-text-muted)]">Belum ada peralatan tersedia.</span>
                </div>
                <% } %>
                <% (toolsData || []).forEach(function(tool, i) { %>
                <div class="gsap-stagger-item v3-card-item" data-id="<%= tool.id %>" data-name="<%= tool.name.toLowerCase() %>" data-category="<%= tool.category %>">
                    <div class="mv-card" data-id="<%= tool.id %>">
                        <div class="mv-card-img">
                            <% if (tool.image) { %>
                                <img src="<%= tool.image %>" alt="<%= tool.name %>">
                            <% } else { %>
                                <div class="mv-card-img-placeholder">
                                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="<%= i % 2 === 0 ? 'var(--color-primary)' : 'var(--color-cyan)' %>" stroke-width="1.5" opacity="0.4">
                                        <path d="M5 3h14a2 2 0 012 2v14a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2z"/><path d="M3 9l4-4 4 4 4-4 4 4"/><circle cx="8.5" cy="14.5" r="1.5"/>
                                    </svg>
                                    <span style="font-size:10px; font-weight:700; color:var(--color-text-muted); letter-spacing:0.1em; text-transform:uppercase;">Peralatan</span>
                                </div>
                            <% } %>
                        </div>
                        <div class="mv-card-body">
                            <div class="mv-card-title v3-card-title"><%= tool.name || '-' %></div>
                            <div class="mv-card-desc"><%= tool.description || 'Deskripsi belum tersedia.' %></div>
                            <div class="mv-card-divider"></div>
                            <div class="mv-card-stats">
                                <div class="mv-card-stat">
                                    <span class="mv-card-stat-label">Standar</span>
                                    <span class="mv-card-stat-val" style="color:var(--color-primary);"><%= tool.standard || '—' %></span>
                                </div>
                                <div class="mv-card-stat">
                                    <span class="mv-card-stat-label">Status</span>
                                    <span class="mv-card-stat-val" style="color:<%= tool.status === 'Wajib' ? 'var(--color-error)' : 'var(--color-success)' %>;"><%= tool.status || '-' %></span>
                                </div>
                                <div class="mv-go-btn">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                                </div>
                            </div>
                        </div>
                        <div class="mv-accent-line"></div>
                    </div>
                </div>
                <% }); %>
            </div>

            <!-- No results -->
            <div id="v3-tools-no-results" class="hidden flex-col items-center justify-center py-20 gap-4">
                <div class="w-16 h-16 rounded-2xl bg-[var(--color-bg-surface-alt)] border border-[var(--color-border)] flex items-center justify-center">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-text-muted)" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
                </div>
                <span class="text-sm text-[var(--color-text-muted)]">Tidak ada peralatan yang cocok.</span>
            </div>
        </div>
    </main>

    <%- include('partials/catalog-modal-tools') %>

    <script id="tools-data" type="text/template">
        <%- JSON.stringify(toolsData) %>
    </script>
    <script>
        var __TOOLS_DATA__ = JSON.parse(document.getElementById('tools-data').textContent);
    </script>
    <%- include('partials/footer') %>
    <script src="/js/main.js"></script>
    <script src="/js/catalog-modal.js"></script>
    <script src="/js/tools.js"></script>
    
</body>
</html>
