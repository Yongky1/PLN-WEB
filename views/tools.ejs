<!DOCTYPE html>
<html lang="id" class="scroll-smooth">
<head>
    <%- include('partials/head') %>
    <script type="module" src="https://ajax.googleapis.com/ajax/libs/model-viewer/3.4.0/model-viewer.min.js"></script>
    <style>
        .glass-panel {
            background: linear-gradient(135deg, rgba(255,255,255,0.10) 0%, rgba(255,255,255,0.03) 100%);
            backdrop-filter: blur(40px) saturate(150%);
            -webkit-backdrop-filter: blur(40px) saturate(150%);
            border: 1px solid rgba(255,255,255,0.10);
            border-top-color: rgba(255,255,255,0.25);
            border-left-color: rgba(255,255,255,0.18);
            box-shadow: 0 20px 40px rgba(0,0,0,0.2), inset 0 1px 0 rgba(255,255,255,0.1);
        }

        .tool-card-premium {
            background: linear-gradient(135deg, rgba(255,255,255,0.08) 0%, rgba(255,255,255,0.02) 100%);
            backdrop-filter: blur(30px);
            -webkit-backdrop-filter: blur(30px);
            border: 1px solid rgba(255,255,255,0.08);
            border-top-color: rgba(255,255,255,0.20);
            box-shadow: 0 8px 32px rgba(0,0,0,0.25), inset 0 1px 0 rgba(255,255,255,0.08);
            transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        }

        .tool-card-premium:hover {
            border-top-color: rgba(245,158,11,0.5);
            border-left-color: rgba(245,158,11,0.25);
            background: linear-gradient(135deg, rgba(255,255,255,0.12) 0%, rgba(245,158,11,0.04) 100%);
            box-shadow: 0 30px 60px rgba(0,0,0,0.35), 0 0 40px rgba(245,158,11,0.08), inset 0 1px 0 rgba(255,255,255,0.15);
            transform: translateY(-5px) scale(1.01);
        }

        .filter-pill-active {
            background: rgba(245,158,11,0.15);
            border-color: rgba(245,158,11,0.5);
            color: #F59E0B;
            box-shadow: 0 0 15px rgba(245,158,11,0.15);
        }

        .filter-pill {
            background: rgba(255,255,255,0.04);
            border-color: rgba(255,255,255,0.1);
            color: rgba(255,255,255,0.45);
            transition: all 0.2s ease;
        }

        .filter-pill:hover {
            border-color: rgba(245,158,11,0.35);
            color: #F59E0B;
        }

        /* Modal */
        #modal-overlay.active { display: flex !important; }

        .cat-badge-k3 { background: rgba(239,68,68,0.15); color: #F87171; border-color: rgba(239,68,68,0.3); }
        .cat-badge-teknis { background: rgba(59,130,246,0.15); color: #60A5FA; border-color: rgba(59,130,246,0.3); }
        .cat-badge-pengukuran { background: rgba(168,85,247,0.15); color: #C084FC; border-color: rgba(168,85,247,0.3); }
    </style>
</head>
<body class="bg-[var(--color-pln-darker)] text-white font-sans antialiased overflow-x-hidden">

    <%- include('partials/navbar') %>

    <main class="pt-32 pb-24 px-4 sm:px-6 bg-[var(--color-pln-darker)] min-h-screen relative">

        <!-- Ambient Glow -->
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[700px] h-[450px] bg-[var(--color-pln-yellow)]/5 rounded-full blur-[120px] pointer-events-none -z-10"></div>

        <div class="max-w-7xl mx-auto z-10 relative">

            <!-- Page Header -->
            <div class="hero-content mb-12 text-left border-b border-white/5 pb-8">
                <div class="max-w-2xl">
                    <span class="inline-flex items-center gap-2 py-1.5 px-3 rounded-full bg-[var(--color-pln-yellow)]/10 text-[var(--color-pln-yellow)] text-[10px] font-bold tracking-[0.15em] uppercase mb-4 border border-[var(--color-pln-yellow)]/20 shadow-[0_0_15px_rgba(255,213,0,0.1)]">
                        <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-pln-yellow)] animate-pulse"></span>
                        Peralatan Lapangan
                    </span>
                    <h1 class="text-4xl md:text-6xl font-black mb-4 font-['Space_Grotesk'] tracking-tight leading-tight">
                        Tools & <span class="text-transparent bg-clip-text bg-gradient-to-r from-[var(--color-pln-yellow)] to-yellow-200">Alat K3</span>
                    </h1>
                    <p class="text-sm md:text-base text-white/50 leading-relaxed font-light">
                        Katalog lengkap peralatan keselamatan kerja dan alat teknis yang digunakan teknisi lapangan PLN dalam setiap pekerjaan konstruksi dan pemeliharaan jaringan.
                    </p>
                </div>
            </div>



            <!-- Tools Grid -->
            <div id="tools-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">

                <% if (!toolsData || toolsData.length === 0) { %>
                <div class="col-span-4 flex flex-col items-center justify-center py-24 text-center glass-panel rounded-3xl">
                    <svg class="w-12 h-12 text-white/20 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                    <p class="text-white/40 font-medium font-['Space_Grotesk']">Belum ada peralatan tersedia.</p>
                    <p class="text-white/25 text-sm mt-1">Tambahkan melalui halaman admin.</p>
                </div>
                <% } else { %>
                <% toolsData.forEach(tool => { %>

                <!-- Tool Card — App Store Style (sama dengan Konstruksi) -->
                <div class="tool-card gsap-card group flex flex-col apple-glass-light rounded-[2.5rem] overflow-hidden hover:shadow-[0_30px_60px_-15px_rgba(255,255,255,0.2)] hover:border-white/40 hover:-translate-y-2 transition-all duration-500 cursor-pointer relative"
                     data-category="<%= tool.category %>"
                     data-id="<%= tool.id %>">

                    <!-- Image Container (Top Half) -->
                    <div class="h-[220px] relative overflow-hidden bg-black/20">
                        <!-- Gradient background (no image for tools) -->
                        <div class="absolute inset-0" style="background: <%= tool.bgGradient %>;"></div>
                        <div class="absolute inset-0 bg-gradient-to-br from-black/10 to-black/30 group-hover:opacity-70 transition-opacity duration-500"></div>

                        <!-- Center icon glow -->
                        <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(245,158,11,0.12)_0%,transparent_65%)] group-hover:opacity-100 opacity-60 transition-opacity duration-500"></div>

                        <!-- Category & 3D badges -->
                        <div class="absolute top-4 right-4 flex flex-col gap-1.5 items-end z-10">
                            <span class="text-[9px] font-bold uppercase tracking-wider px-2.5 py-1 rounded-full border
                                <%- tool.category === 'k3' ? 'cat-badge-k3' : tool.category === 'teknis' ? 'cat-badge-teknis' : 'cat-badge-pengukuran' %>">
                                <%= tool.categoryLabel %>
                            </span>
                            <% if (tool.file3d) { %>
                            <span class="inline-block px-2.5 py-1 bg-cyan-500/20 text-cyan-300 border border-cyan-500/30 text-[9px] font-bold rounded-full uppercase tracking-wider backdrop-blur-md">3D</span>
                            <% } %>
                        </div>

                        <!-- Tool icon (wrench) as placeholder center -->
                        <div class="w-full h-full flex items-center justify-center opacity-20 group-hover:opacity-30 transition-opacity duration-500">
                            <svg class="w-16 h-16 text-[var(--color-pln-yellow)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                            </svg>
                        </div>
                    </div>

                    <!-- Content Area (Bottom Half) -->
                    <div class="p-6 md:p-8 flex-grow flex flex-col relative z-10 bg-gradient-to-t from-black/60 via-black/10 to-transparent">
                        <h3 class="text-xl md:text-2xl font-bold mb-2 text-white/90 group-hover:text-[var(--color-pln-yellow)] transition-colors leading-snug font-['Space_Grotesk'] tracking-tight">
                            <%= tool.name %>
                        </h3>
                        <p class="text-white/40 text-[13px] leading-relaxed mb-8 font-['Inter'] line-clamp-2">
                            <%= tool.description || 'Deskripsi belum tersedia.' %>
                        </p>

                        <div class="mt-auto flex justify-between items-end">
                            <!-- Stats: Standar & Status -->
                            <div class="flex items-center gap-5">
                                <div>
                                    <p class="text-[10px] uppercase tracking-wider text-white/40 mb-1 font-semibold">Standar</p>
                                    <p class="text-base font-bold text-[var(--color-pln-yellow)] font-['Outfit']"><%= tool.standard || '-' %></p>
                                </div>
                                <div class="w-px h-8 bg-white/10"></div>
                                <div>
                                    <p class="text-[10px] uppercase tracking-wider text-white/40 mb-1 font-semibold">Status</p>
                                    <p class="text-base font-bold font-['Outfit'] <%- tool.status === 'Wajib' ? 'text-red-400' : 'text-emerald-400' %>"><%= tool.status %></p>
                                </div>
                            </div>

                            <!-- Action Button -->
                            <div class="w-10 h-10 rounded-full bg-[var(--color-pln-yellow)]/10 flex items-center justify-center text-[var(--color-pln-yellow)] group-hover:bg-[var(--color-pln-yellow)] group-hover:text-black transition-colors">
                                <svg class="w-5 h-5 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                            </div>
                        </div>
                    </div>
                </div>

                <% }); %>
                <% } %>
            </div>
        </div>
    </main>

    <!-- ====================================================
         MODAL – Tool Detail & 3D Viewer (Apple Style)
    ==================================================== -->
    <div id="modal-overlay" class="fixed inset-0 z-50 hidden items-center justify-center p-4 sm:p-6" style="display: none; background: rgba(0,4,15,0.80); backdrop-filter: blur(28px) saturate(160%); -webkit-backdrop-filter: blur(28px) saturate(160%);">

        <div id="modal-card" class="relative w-full max-w-5xl flex flex-col md:flex-row rounded-[2.5rem] overflow-hidden shadow-[0_40px_80px_rgba(0,0,0,0.6),0_0_0_1px_rgba(255,255,255,0.08)] border border-white/10" style="height: 560px; background: linear-gradient(160deg, rgba(12,22,42,0.98) 0%, rgba(6,12,26,0.98) 100%); backdrop-filter: blur(40px);">

            <!-- ========== LEFT: 3D Viewer ========== -->
            <div id="modal-canvas-wrap" class="w-full md:w-[52%] shrink-0 relative overflow-hidden flex items-center justify-center group"
                 style="height: 100%; background: radial-gradient(circle at 40% 40%, #0A2045 0%, #030812 100%);">

                <!-- Ambient top glow -->
                <div class="absolute top-0 left-1/2 -translate-x-1/2 w-3/4 h-32 bg-[var(--color-pln-yellow)]/8 blur-[60px] pointer-events-none"></div>

                <!-- model-viewer -->
                <model-viewer
                    id="modal-model-viewer"
                    src=""
                    camera-controls
                    auto-rotate
                    rotation-per-second="25deg"
                    interaction-prompt="none"
                    shadow-intensity="1.5"
                    environment-image="neutral"
                    exposure="1.1"
                    class="w-full h-full z-0 outline-none cursor-grab active:cursor-grabbing">
                    <!-- Loading poster -->
                    <div slot="poster" class="absolute inset-0 flex flex-col items-center justify-center bg-[#030812]/60 backdrop-blur-sm">
                        <div id="modal-loading-spinner" class="animate-spin rounded-full h-10 w-10 border-2 border-t-[var(--color-pln-yellow)] border-r-[var(--color-pln-yellow)]/50 border-b-transparent border-l-transparent mb-4"></div>
                        <span id="modal-loading-text" class="text-[11px] uppercase tracking-[0.2em] font-semibold text-white/40">Memuat Model 3D...</span>
                    </div>
                </model-viewer>

                <!-- Empty state -->
                <div id="modal-empty-state" class="absolute inset-0 flex-col items-center justify-center text-white/25 z-10 hidden" style="display:none;">
                    <svg class="w-16 h-16 mb-4 text-white/10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path></svg>
                    <span class="text-sm font-medium tracking-wide font-['Space_Grotesk']">Belum ada file 3D</span>
                </div>

                <!-- Hint pill (bottom center) -->
                <div id="modal-hint-text" class="absolute bottom-5 left-1/2 -translate-x-1/2 bg-black/70 backdrop-blur-2xl border border-white/8 text-white/60 text-[11px] font-medium tracking-wide px-4 py-2 rounded-full pointer-events-none z-10 opacity-0 group-hover:opacity-100 transition-all duration-500 flex items-center gap-2 shadow-xl">
                    <svg class="w-3.5 h-3.5 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5"></path></svg>
                    Rotasi 360° · Zoom via Scroll
                </div>

                <!-- Fullscreen button -->
                <button id="modal-fullscreen-btn" title="Layar Penuh" class="absolute top-4 right-4 w-10 h-10 bg-black/50 backdrop-blur-xl rounded-full flex items-center justify-center text-white/50 hover:text-white hover:bg-black/80 transition-all z-20 border border-white/10 opacity-0 group-hover:opacity-100">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4"></path></svg>
                </button>
            </div>

            <!-- ========== RIGHT: Info Panel ========== -->
            <div id="modal-info-wrap" class="flex-1 flex flex-col overflow-hidden relative" style="height: 100%;">

                <!-- STATIC HEADER: Badge, Icon, Name, Code (tidak ikut scroll) -->
                <div class="shrink-0 px-7 md:px-9 pt-5 md:pt-7 pb-3 relative">

                    <!-- Close button -->
                    <div class="absolute top-5 right-5 z-20">
                        <button id="modal-btn-close" class="w-9 h-9 flex items-center justify-center rounded-full transition-all border border-white/10 hover:border-white/25"
                                style="background: rgba(255,255,255,0.06); backdrop-filter: blur(12px);">
                            <svg class="w-4 h-4 text-white/50 hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/>
                            </svg>
                        </button>
                    </div>

                    <!-- Category Badge + Icon -->
                    <div class="flex items-center gap-3 mb-4 pr-12">
                        <span id="modal-icon" class="text-3xl select-none shrink-0 leading-none"></span>
                        <span id="modal-category-label" class="text-[9px] font-black uppercase tracking-[0.2em] px-3 py-1.5 rounded-full border inline-flex items-center gap-1.5"
                              style="background: rgba(255,213,0,0.1); border-color: rgba(255,213,0,0.25); color: #FFD500;">
                        </span>
                    </div>

                    <!-- Name -->
                    <h2 id="modal-name" class="text-2xl font-black text-white leading-tight mb-1 font-['Space_Grotesk'] tracking-tight"></h2>

                    <!-- Specs (Standard & Status) -->
                    <div class="flex items-center gap-3 mb-4">
                        <div class="flex items-center gap-1.5">
                            <span class="text-[10px] uppercase tracking-wider text-white/30 font-semibold">Standar:</span>
                            <span id="modal-standard" class="text-[11px] font-bold text-[var(--color-pln-yellow)]"></span>
                        </div>
                        <div class="w-px h-3 bg-white/20"></div>
                        <div class="flex items-center gap-1.5">
                            <span class="text-[10px] uppercase tracking-wider text-white/30 font-semibold">Status:</span>
                            <span id="modal-status" class="text-[11px] font-bold"></span>
                        </div>
                    </div>

                    <!-- Divider -->
                    <div class="mt-3" style="height:1px; background: linear-gradient(to right, rgba(255,213,0,0.25), rgba(255,255,255,0.08), transparent);"></div>
                </div>

                <!-- SCROLLABLE BODY: Deskripsi + Procedure -->
                <div class="flex-1 overflow-y-auto px-7 md:px-9 pb-7 pt-3"
                     style="scrollbar-width: thin; scrollbar-color: rgba(255,255,255,0.1) transparent;">

                    <!-- Description -->
                    <p id="modal-desc" class="text-[13px] text-white/50 leading-relaxed mb-5 font-['Inter']"></p>

                    <!-- Procedure title -->
                    <p class="text-[9px] font-black uppercase tracking-[0.25em] text-white/25 mb-3 font-['Inter']">Prosedur Penggunaan</p>

                    <!-- Procedure list -->
                    <ol id="modal-procedure" class="flex flex-col gap-2.5"></ol>
                </div>
            </div>
        </div>
    </div>

    <script>
        var __TOOLS_DATA__ = <%- JSON.stringify(toolsData) %>;
    </script>
    <script src="/js/main.js"></script>
    <script src="/js/tools.js"></script>
</body>
</html>
