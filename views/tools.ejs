<!DOCTYPE html>
<html lang="id" class="scroll-smooth">

<head>
    <%- include('partials/head') %>
</head>

<body
    class="bg-brand-light dark:bg-brand-dark text-gray-900 dark:text-white transition-colors duration-700 font-sans antialiased overflow-x-hidden selection:bg-brand-accent selection:text-brand-dark">

    <%- include('partials/navbar') %>

        <main class="pt-32 pb-24 px-6 bg-brand-light dark:bg-[#030914] transition-colors duration-700 min-h-screen">
            <div class="max-w-7xl mx-auto">

                <div class="mb-10 text-center reveal-on-scroll">
                    <span
                        class="inline-block py-1 px-3 rounded-full bg-blue-100 dark:bg-blue-900/30 text-brand-blue dark:text-brand-accent text-[10px] font-semibold tracking-widest uppercase mb-3 border border-blue-200 dark:border-blue-800">
                        Peralatan Lapangan
                    </span>
                    <h1 class="text-4xl md:text-6xl font-display font-bold mb-3 tracking-tight">
                        Tools & <span
                            class="bg-gradient-text bg-gradient-to-r from-blue-600 to-brand-accent dark:from-cyan-400 dark:to-blue-600">Alat
                            K3</span>
                    </h1>
                    <p
                        class="text-sm md:text-lg text-gray-600 dark:text-gray-400 max-w-2xl mx-auto font-medium leading-relaxed">
                        Katalog lengkap peralatan keselamatan kerja dan alat teknis yang digunakan teknisi lapangan PLN
                        dalam setiap pekerjaan konstruksi dan pemeliharaan jaringan.
                    </p>
                </div>

                <div class="flex flex-wrap gap-3 mb-10 justify-center">
                    <button data-filter="all"
                        class="filter-btn px-6 py-2 rounded-full text-xs font-semibold shadow-sm border transition-all border-brand-accent bg-brand-accent/10 text-brand-blue dark:text-brand-accent">
                        Semua
                    </button>
                    <button data-filter="k3"
                        class="filter-btn px-6 py-2 rounded-full text-xs font-semibold shadow-sm border transition-all border-gray-200 dark:border-white/10 text-gray-500 dark:text-gray-400 hover:border-brand-accent hover:text-brand-blue dark:hover:text-brand-accent">
                        Alat K3
                    </button>
                    <button data-filter="teknis"
                        class="filter-btn px-6 py-2 rounded-full text-xs font-semibold shadow-sm border transition-all border-gray-200 dark:border-white/10 text-gray-500 dark:text-gray-400 hover:border-brand-accent hover:text-brand-blue dark:hover:text-brand-accent">
                        Alat Teknis
                    </button>
                    <button data-filter="pengukuran"
                        class="filter-btn px-6 py-2 rounded-full text-xs font-semibold shadow-sm border transition-all border-gray-200 dark:border-white/10 text-gray-500 dark:text-gray-400 hover:border-brand-accent hover:text-brand-blue dark:hover:text-brand-accent">
                        Pengukuran
                    </button>
                </div>

                <div id="tools-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
                    <!-- Grid items will be rendered by tools.js to avoid EJS linter conflicts -->
                </div>

            </div>
        </main>

        <div id="modal-overlay" class="fixed inset-0 z-[100] hidden items-center justify-center p-6"
            style="background: rgba(0,0,0,0.8); backdrop-filter: blur(12px);">
            <div class="relative bg-white dark:bg-[#030914] rounded-[2rem] shadow-2xl max-w-lg w-full overflow-hidden border border-gray-100 dark:border-white/10 opacity-0 transform scale-95 transition-all duration-300"
                id="modal-container">
                <div id="modal-header" class="w-full h-48 flex items-center justify-center relative overflow-hidden">
                    <div
                        class="absolute inset-0 opacity-40 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-white/30 via-transparent to-transparent">
                    </div>
                    <span id="modal-icon" class="text-8xl relative z-10"
                        style="filter: drop-shadow(0 10px 20px rgba(0,0,0,0.5));"></span>
                </div>
                <div class="p-8">
                    <div class="flex items-start justify-between mb-4">
                        <div>
                            <span id="modal-category-label"
                                class="text-[10px] font-bold uppercase tracking-wider px-3 py-1 rounded-full bg-brand-light dark:bg-white/5 border border-black/5 dark:border-white/10 text-brand-blue dark:text-brand-accent mb-3 inline-block"></span>
                            <h2 id="modal-name"
                                class="text-3xl font-display font-bold text-gray-900 dark:text-white leading-tight tracking-tight">
                            </h2>
                        </div>
                        <button id="modal-close"
                            class="p-2.5 rounded-full bg-gray-100 dark:bg-white/5 hover:bg-gray-200 dark:hover:bg-white/10 transition text-gray-500 dark:text-gray-400 flex-shrink-0">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M6 18L18 6M6 6l12 12" />
                            </svg>
                        </button>
                    </div>
                    <p id="modal-desc"
                        class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed mb-6 font-medium"></p>
                    <div class="grid grid-cols-2 gap-4 mb-6">
                        <div
                            class="rounded-2xl border border-gray-100 dark:border-white/10 bg-white dark:bg-[#081729] p-4">
                            <p
                                class="text-[10px] font-bold uppercase tracking-widest text-gray-400 dark:text-gray-500 mb-1.5">
                                Standar</p>
                            <p id="modal-standard" class="text-sm font-bold text-brand-blue dark:text-cyan-400"></p>
                        </div>
                        <div
                            class="rounded-2xl border border-gray-100 dark:border-white/10 bg-white dark:bg-[#081729] p-4">
                            <p
                                class="text-[10px] font-bold uppercase tracking-widest text-gray-400 dark:text-gray-500 mb-1.5">
                                Status Penggunaan</p>
                            <p id="modal-status" class="text-sm font-bold text-red-400"></p>
                        </div>
                    </div>
                    <p
                        class="text-[10px] font-bold uppercase tracking-widest text-gray-400 dark:text-gray-500 mb-4 pl-1">
                        Prosedur Penggunaan</p>
                    <ol id="modal-procedure" class="flex flex-col gap-3"></ol>
                </div>
            </div>
        </div>

        <%- include('partials/footer') %>

        <div id="app-data" data-tools="<%= JSON.stringify(toolsData) %>" style="display: none;"></div>
        <script>
            // Mengambil data JSON dengan aman dari atribut HTML untuk menghindari "red error" dari code formatter VSCode (Prettier)
            var __TOOLS_DATA__ = JSON.parse(document.getElementById('app-data').getAttribute('data-tools'));
        </script>
        <script src="/js/main.js"></script>
        <script src="/js/tools.js"></script>
</body>

</html>