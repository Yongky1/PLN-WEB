<!-- ═══ AWWWARDS-LEVEL NAVBAR — JALA (Refined) ═══ -->
<% const current = typeof currentPage !== 'undefined' ? currentPage : (typeof isLanding !== 'undefined' && isLanding ? 'home' : ''); %>
<%
  const navItems = [
    { href: '/', label: 'Beranda', key: 'home', desc: 'Halaman utama platform' },
    { href: '/tools', label: 'Peralatan', key: 'tools', desc: 'Katalog peralatan 3D' },
    { href: '/ModulKonstruksi', label: 'Konstruksi', key: 'konstruksi', desc: 'Modul pembelajaran konstruksi' },
    { href: '/material', label: 'Material', key: 'material', desc: 'Database material kelistrikan' }
  ];
%>

<!-- ═══ FLOATING PILL NAVBAR ═══ -->
<div id="jl-nav-wrap" class="jl-nav-wrap">
  <nav id="jl-navbar" class="jl-navbar">

    <!-- Scroll Progress Bar (inside pill) -->
    <div class="jl-nav-progress-track">
      <div id="jl-nav-progress" class="jl-nav-progress-bar"></div>
    </div>

    <!-- Brand -->
    <a href="/" class="jl-brand" data-magnetic>
      <div class="jl-brand-mark">
        <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="16" cy="16" r="14" stroke="currentColor" stroke-width="1.5" opacity="0.3"/>
          <path d="M16 6L16 20" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          <path d="M12 20C12 22.2091 13.7909 24 16 24C18.2091 24 20 22.2091 20 20" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </div>
      <span class="jl-brand-text">JALA</span>
    </a>

    <!-- Divider (desktop) -->
    <div class="jl-nav-divider"></div>

    <!-- Desktop Links -->
    <div class="jl-nav-links">
      <!-- Sliding pill background -->
      <div id="jl-link-pill" class="jl-link-pill"></div>

      <% navItems.forEach((item, idx) => { %>
        <a href="<%= item.href %>"
           class="jl-nav-link <%= current === item.key ? 'is-active' : '' %>"
           data-idx="<%= idx %>"
           data-magnetic>
          <span class="jl-nav-link-text"><%= item.label %></span>
        </a>
      <% }); %>
    </div>

    <!-- Right Section -->
    <div class="jl-nav-right">
      <!-- Divider (desktop only) -->
      <div class="jl-nav-divider"></div>

      <!-- CTA Button (desktop only) -->
      <a href="/ModulKonstruksi" class="jl-nav-cta" data-magnetic>
        <span class="jl-cta-text">Mulai Belajar</span>
        <span class="jl-cta-icon">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
            <path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </a>

      <!-- Hamburger Toggle (mobile only) -->
      <button id="jl-menu-toggle" class="jl-menu-toggle" aria-label="Menu">
        <div class="jl-toggle-inner">
          <div class="jl-toggle-icon">
            <span></span>
            <span></span>
          </div>
        </div>
      </button>
    </div>
  </nav>
</div>

<!-- ═══ FULLSCREEN OVERLAY MENU ═══ -->
<div id="jl-overlay" class="jl-overlay">

  <!-- Background layers -->
  <div class="jl-overlay-bg">
    <div class="jl-overlay-bg-layer" style="--delay: 0;"></div>
    <div class="jl-overlay-bg-layer" style="--delay: 1;"></div>
    <div class="jl-overlay-bg-layer" style="--delay: 2;"></div>
  </div>

  <!-- Overlay Content -->
  <div class="jl-overlay-content">

    <!-- Left: Navigation -->
    <div class="jl-overlay-nav">
      <p class="jl-overlay-label">Navigasi</p>

      <% navItems.forEach((item, idx) => { %>
        <a href="<%= item.href %>"
           class="jl-overlay-link <%= current === item.key ? 'is-active' : '' %>"
           data-desc="<%= item.desc %>"
           style="--i: <%= idx %>;">
          <span class="jl-ol-num">0<%= idx + 1 %></span>
          <span class="jl-ol-text-wrap">
            <span class="jl-ol-text"><%= item.label %></span>
          </span>
          <span class="jl-ol-desc"><%= item.desc %></span>
          <span class="jl-ol-arrow">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
              <path d="M7 17L17 7M17 7H7M17 7V17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
          <% if (current === item.key) { %>
            <span class="jl-ol-active-dot"></span>
          <% } %>
        </a>
      <% }); %>
    </div>

    <!-- Right: Info Column -->
    <div class="jl-overlay-info">
      <div class="jl-overlay-info-block">
        <p class="jl-overlay-label">Platform</p>
        <p class="jl-overlay-desc">
          Platform pembelajaran kelistrikan berbasis 3D interaktif untuk karyawan & teknisi PT PLN (Persero).
        </p>
      </div>

      <div class="jl-overlay-info-block">
        <p class="jl-overlay-label">Kontak</p>
        <a href="mailto:pusdiklat@pln.co.id" class="jl-overlay-contact">pusdiklat@pln.co.id</a>
      </div>

      <a href="/ModulKonstruksi" class="jl-overlay-cta">
        <span>Mulai Belajar</span>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
          <path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>

  <!-- Footer -->
  <div class="jl-overlay-footer">
    <span>&copy; 2026 PT PLN (Persero)</span>
    <span>JALA — Visualisasi 3D Kelistrikan</span>
  </div>
</div>
