<% if (typeof isLanding !== 'undefined' && isLanding) { %>
<!-- ═══ LANDING NAV ═══ -->
<nav class="landing-nav">
  <div class="logo-area">
    <a href="/" class="logo">
      JALA
    </a>
    <div class="nav-links">
      <a href="/" class="active">Beranda</a>
      <a href="/tools">Peralatan</a>
      <a href="/ModulKonstruksi">Konstruksi</a>
      <a href="/material">Material</a>
    </div>
  </div>
  <div class="nav-right">
    <a href="/ModulKonstruksi" class="nav-cta">
      <span>Mulai Belajar</span>
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
    </a>
    <button class="mobile-btn" id="landing-mobile-btn" aria-label="Menu">
      <svg class="icon-open" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
      <svg class="icon-close" style="display:none;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>
  </div>
</nav>

<% } else { %>
<!-- ═══ STANDARD NAV (Light Theme) ═══ -->
<nav id="main-navbar"
  class="fixed w-full z-50 glass-nav transition-all duration-500">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">

      <!-- Brand Logo -->
      <div class="flex-shrink-0">
        <a href="/" class="flex items-center gap-3 group">
          <span class="font-bold text-xl tracking-wide text-gray-900 brand-font leading-none">JALA</span>
        </a>
      </div>

      <!-- Desktop Menu -->
      <div class="hidden md:block">
        <div class="ml-10 flex items-center space-x-1">
          <a href="/"
            class="<%= typeof currentPage !== 'undefined' && currentPage === 'home' ? 'text-[var(--color-primary)] bg-[var(--color-primary)]/5 font-bold' : 'text-[var(--color-text-secondary)] hover:text-[var(--color-primary)] hover:bg-[var(--color-primary)]/5' %> px-4 py-2 rounded-xl text-sm font-semibold tracking-wide transition-all duration-300">Beranda</a>
          <a href="/tools"
            class="<%= typeof currentPage !== 'undefined' && currentPage === 'tools' ? 'text-[var(--color-primary)] bg-[var(--color-primary)]/5 font-bold' : 'text-[var(--color-text-secondary)] hover:text-[var(--color-primary)] hover:bg-[var(--color-primary)]/5' %> px-4 py-2 rounded-xl text-sm font-semibold tracking-wide transition-all duration-300">Peralatan</a>
          <a href="/ModulKonstruksi"
            class="<%= typeof currentPage !== 'undefined' && currentPage === 'konstruksi' ? 'text-[var(--color-primary)] bg-[var(--color-primary)]/5 font-bold' : 'text-[var(--color-text-secondary)] hover:text-[var(--color-primary)] hover:bg-[var(--color-primary)]/5' %> px-4 py-2 rounded-xl text-sm font-semibold tracking-wide transition-all duration-300">Konstruksi</a>
          <a href="/material"
            class="<%= typeof currentPage !== 'undefined' && currentPage === 'material' ? 'text-[var(--color-primary)] bg-[var(--color-primary)]/5 font-bold' : 'text-[var(--color-text-secondary)] hover:text-[var(--color-primary)] hover:bg-[var(--color-primary)]/5' %> px-4 py-2 rounded-xl text-sm font-semibold tracking-wide transition-all duration-300">Material</a>
        </div>
      </div>

      <!-- CTA Button -->
      <div class="hidden md:block">
        <a href="/ModulKonstruksi"
          class="btn-primary text-sm px-6 py-2.5 inline-flex items-center gap-2 rounded-xl">
          <span>Mulai Belajar</span>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
          </svg>
        </a>
      </div>

      <!-- Mobile menu button -->
      <div class="-mr-2 flex md:hidden">
        <button type="button" id="mobile-menu-btn"
          class="inline-flex items-center justify-center p-2 rounded-xl text-[var(--color-text-secondary)] hover:text-[var(--color-primary)] hover:bg-[var(--color-primary)]/5 focus:outline-none transition-colors"
          aria-controls="mobile-menu" aria-expanded="false">
          <span class="sr-only">Open main menu</span>
          <svg id="menu-icon-open" class="block h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="menu-icon-close" class="hidden h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div class="md:hidden hidden" id="mobile-menu">
    <div class="bg-white/95 backdrop-blur-xl border-t border-[var(--color-border-light)] shadow-xl">
      <div class="px-4 pt-4 pb-6 space-y-1">
        <a href="/"
          class="<%= typeof currentPage !== 'undefined' && currentPage === 'home' ? 'text-[var(--color-primary)] bg-[var(--color-primary)]/5 font-bold' : 'text-[var(--color-text-secondary)]' %> block px-4 py-3 rounded-xl text-base font-semibold transition-colors">Beranda</a>
        <a href="/tools"
          class="<%= typeof currentPage !== 'undefined' && currentPage === 'tools' ? 'text-[var(--color-primary)] bg-[var(--color-primary)]/5 font-bold' : 'text-[var(--color-text-secondary)]' %> block px-4 py-3 rounded-xl text-base font-semibold transition-colors">Peralatan</a>
        <a href="/ModulKonstruksi"
          class="<%= typeof currentPage !== 'undefined' && currentPage === 'konstruksi' ? 'text-[var(--color-primary)] bg-[var(--color-primary)]/5 font-bold' : 'text-[var(--color-text-secondary)]' %> block px-4 py-3 rounded-xl text-base font-semibold transition-colors">Konstruksi</a>
        <a href="/material"
          class="<%= typeof currentPage !== 'undefined' && currentPage === 'material' ? 'text-[var(--color-primary)] bg-[var(--color-primary)]/5 font-bold' : 'text-[var(--color-text-secondary)]' %> block px-4 py-3 rounded-xl text-base font-semibold transition-colors">Material</a>
        <div class="pt-3">
          <a href="/ModulKonstruksi"
            class="btn-primary block text-center text-sm py-3 rounded-xl">Mulai Belajar</a>
        </div>
      </div>
    </div>
  </div>
</nav>

<!-- Navbar Scripts -->
<script>
  document.addEventListener("DOMContentLoaded", () => {
    const navbar = document.getElementById("main-navbar");
    const mobileMenuBtn = document.getElementById("mobile-menu-btn");
    const mobileMenu = document.getElementById("mobile-menu");
    const iconOpen = document.getElementById("menu-icon-open");
    const iconClose = document.getElementById("menu-icon-close");
    let lastScrollY = window.scrollY;
    let ticking = false;

    if (mobileMenuBtn) {
      mobileMenuBtn.addEventListener("click", () => {
        const isHidden = mobileMenu.classList.contains("hidden");
        mobileMenu.classList.toggle("hidden");
        iconOpen.classList.toggle("hidden", !isHidden);
        iconOpen.classList.toggle("block", isHidden);
        iconClose.classList.toggle("hidden", isHidden);
        iconClose.classList.toggle("block", !isHidden);
      });
    }

    window.addEventListener("scroll", () => {
      if (!ticking) {
        window.requestAnimationFrame(() => {
          if (window.scrollY > 20) {
            navbar.classList.add("glass-nav-scrolled");
          } else {
            navbar.classList.remove("glass-nav-scrolled");
          }
          if (window.scrollY > 100) {
            if (window.scrollY > lastScrollY) {
              navbar.style.transform = "translateY(-100%)";
            } else {
              navbar.style.transform = "translateY(0)";
            }
          } else {
            navbar.style.transform = "translateY(0)";
          }
          lastScrollY = window.scrollY;
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });
  });
</script>
<% } %>