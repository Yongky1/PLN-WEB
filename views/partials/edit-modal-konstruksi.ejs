<%
var _modalId  = typeof modalId            !== 'undefined' ? modalId            : 'edit-modal';
var _viewerId = typeof previewViewerId    !== 'undefined' ? previewViewerId    : 'admin-preview-viewer';
var _emptyId  = typeof previewEmptyId     !== 'undefined' ? previewEmptyId     : 'admin-preview-empty';
var _selId    = typeof previewSelectorId  !== 'undefined' ? previewSelectorId  : 'admin-preview-selector';
var _onChange = typeof previewOnChange    !== 'undefined' ? previewOnChange    : 'changeAdminPreview()';
%>
<style>
  #<%= _modalId %> { display: none; }
  #<%= _modalId %>.active { display: flex !important; }
</style>
<div id="<%= _modalId %>" class="rd-modal-overlay" onclick="if(event.target===this)closeEditModal()">
  <div class="rd-modal">

    <div class="rd-modal-header">
      <div class="rd-modal-title-block">
        <div class="rd-modal-eyebrow">Edit · Konstruksi</div>
        <h2 class="rd-modal-title">Edit Modul &amp; Live Preview</h2>
      </div>
      <button class="rd-modal-close" onclick="closeEditModal()">
        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>

    <div class="rd-modal-body" style="overflow-y:auto;">

      <div class="rd-section-block">
        <div class="rd-section-head"><div class="rd-section-title"><span class="num">1</span> Informasi Modul</div></div>
        <div class="rd-field-row cols-2">
          <div class="rd-field-group">
            <label class="rd-field-label">Nama Modul <span class="req">*</span></label>
            <input type="text" id="edit-modul-name" class="rd-input" placeholder="Contoh: Tower SUTT 150kV" style="background: #ffffff;" />
          </div>
          <div class="rd-field-group">
            <label class="rd-field-label">Status</label>
            <select id="edit-modul-status" class="rd-select" style="background: #ffffff;">
              <option value="Aktif">Aktif</option>
              <option value="Draft">Draft</option>
              <option value="Nonaktif">Nonaktif</option>
            </select>
          </div>
        </div>

        <div class="rd-field-row cols-3">
          <div class="rd-field-group">
            <label class="rd-field-label">Kategori Konstruksi (Level 1)</label>
            <select id="edit-modul-construction-level1" class="rd-select" style="background: #ffffff;" onchange="handleLevelChange(1, true)">
              <option value="">-- Pilih Level 1 --</option>
            </select>
          </div>
          <div class="rd-field-group">
            <label class="rd-field-label">Kategori (Level 2)</label>
            <select id="edit-modul-construction-level2" class="rd-select" style="background: #ffffff;" onchange="handleLevelChange(2, true)" disabled>
              <option value="">-- Pilih Level 2 --</option>
            </select>
          </div>
          <div class="rd-field-group">
            <label class="rd-field-label">Kategori (Level 3)</label>
            <select id="edit-modul-construction-level3" class="rd-select" style="background: #ffffff;" disabled>
              <option value="">-- Pilih Level 3 --</option>
            </select>
          </div>
        </div>
        <div class="rd-field-group">
          <label class="rd-field-label" style="justify-content:space-between;">Deskripsi <span class="rd-field-counter" id="edit-modul-desc-counter">0/2000</span></label>
          <textarea id="edit-modul-desc" class="rd-textarea" rows="2" maxlength="2000" style="resize:vertical; background: #ffffff;" oninput="document.getElementById('edit-modul-desc-counter').textContent=this.value.length+'/2000'"></textarea>
        </div>

        <div class="rd-field-group">
          <label class="rd-field-label">Cover Gambar</label>
          <div id="edit-modul-image-wrapper" style="display:grid;grid-template-columns:1fr;gap:12px;">
            <div id="edit-modul-image-drop-zone" class="rd-drop-zone" style="background: #ffffff;" onclick="document.getElementById('edit-modul-image').click()">
              <div class="dz-icon">
                <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
              </div>
              <div class="dz-text">
                <div id="edit-img-empty"><div class="dz-title">Pilih foto baru</div><div class="dz-sub">PNG · JPG · WEBP · maks 5MB</div></div>
                <div id="edit-img-filled" style="display:none;"><div class="dz-title" style="color:var(--accent);">Thumbnail terpasang</div><div class="dz-sub">Klik untuk ganti</div></div>
              </div>
              <button class="rd-btn rd-btn-secondary rd-btn-sm" onclick="event.stopPropagation();document.getElementById('edit-modul-image').click()">Pilih file</button>
            </div>
            <input type="file" id="edit-modul-image" accept="image/png,image/jpeg,image/webp" style="display:none" onchange="
              if(this.files&&this.files[0]){
                const reader=new FileReader();
                reader.onload=function(e){
                  document.getElementById('edit-modul-image-wrapper').style.gridTemplateColumns='1fr 1fr';
                  document.getElementById('edit-modul-image-preview-container').style.display='block';
                  document.getElementById('edit-modul-image-preview').src=e.target.result;
                  document.getElementById('edit-modul-image-deleted').value='false';
                  document.getElementById('edit-img-empty').style.display='none';
                  document.getElementById('edit-img-filled').style.display='block';
                  document.getElementById('edit-modul-image-drop-zone').classList.add('has-file');
                };
                reader.readAsDataURL(this.files[0]);
              }
            " />
            <div id="edit-modul-image-preview-container" style="display:none;position:relative;aspect-ratio:16/9;border-radius:8px;overflow:hidden;border:1px solid var(--border-default);">
              <img id="edit-modul-image-preview" src="" style="width:100%;height:100%;object-fit:cover;" />
              <div style="position:absolute;inset:0;background:rgba(0,0,0,0.4);display:flex;align-items:center;justify-content:center;opacity:0;transition:opacity .2s" onmouseover="this.style.opacity=1" onmouseout="this.style.opacity=0">
                <button class="rd-btn rd-btn-danger rd-btn-sm" onclick="
                  document.getElementById('edit-modul-image').value='';
                  document.getElementById('edit-modul-image-preview').src='';
                  document.getElementById('edit-modul-image-wrapper').style.gridTemplateColumns='1fr';
                  document.getElementById('edit-modul-image-preview-container').style.display='none';
                  document.getElementById('edit-modul-image-deleted').value='true';
                  document.getElementById('edit-img-empty').style.display='block';
                  document.getElementById('edit-img-filled').style.display='none';
                  document.getElementById('edit-modul-image-drop-zone').classList.remove('has-file');
                ">Hapus Thumbnail</button>
              </div>
            </div>
            <input type="hidden" id="edit-modul-image-deleted" value="false" />
          </div>
        </div>

        <div class="rd-field-row cols-2">
          <div class="rd-field-group">
            <label class="rd-field-label">Material</label>
            <div id="edit-modul-materials-list" style="max-height:160px;overflow-y:auto;display:flex;flex-direction:column;gap:4px;padding:8px;background:#ffffff;border:1px solid var(--border-default);border-radius:8px;"></div>
          </div>
          <div class="rd-field-group">
            <label class="rd-field-label">Peralatan</label>
            <div id="edit-modul-tools-list" style="max-height:160px;overflow-y:auto;display:flex;flex-direction:column;gap:4px;padding:8px;background:#ffffff;border:1px solid var(--border-default);border-radius:8px;"></div>
          </div>
        </div>
      </div>

      <div class="rd-section-block" style="margin-top:14px;">
        <div class="rd-section-head"><div class="rd-section-title"><span class="num">2</span> Varian &amp; Preview 3D</div></div>
        <div style="display:flex;gap:20px;flex-wrap:wrap;">

          <div style="flex:1;min-width:280px;display:flex;flex-direction:column;gap:12px;">
            <div id="edit-konstruksi-cards" style="display:flex;flex-direction:column;gap:12px;max-height:320px;overflow-y:auto;padding-right:4px;"></div>
            <button class="rd-btn rd-btn-ghost" style="border:1px dashed var(--border-strong);width:100%;justify-content:center;padding:10px;" onclick="addEditKonstruksiCard()">
              <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              Tambah Varian
            </button>
          </div>

          <div style="flex:1;min-width:280px;background:#ffffff;border-radius:12px;overflow:hidden;border:1px solid var(--border-default);position:relative;min-height:320px;">
            <script type="module" src="https://ajax.googleapis.com/ajax/libs/model-viewer/3.4.0/model-viewer.min.js"></script>
            <model-viewer id="<%= _viewerId %>" src="" camera-controls auto-rotate rotation-per-second="30deg"
              interaction-prompt="none" shadow-intensity="1.5" environment-image="neutral" exposure="1"
              style="width:100%;height:100%;min-height:320px;outline:none;background:#ffffff;"></model-viewer>
            <div id="<%= _emptyId %>" style="position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;color:var(--text-muted);pointer-events:none;gap:8px;">
              <svg width="36" height="36" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/></svg>
              <span style="font-size:12px;font-weight:600;">Belum ada file GLB terpilih</span>
            </div>
            <div style="position:absolute;bottom:12px;left:12px;right:12px;z-index:10;">
              <select id="<%= _selId %>" onchange="<%= _onChange %>" class="rd-select" style="background:#ffffff; color:#1b2b4b;">
                <option value="">-- Pilih Varian untuk Preview --</option>
              </select>
            </div>
          </div>

        </div>
      </div>

    </div><!-- /.rd-modal-body -->

    <div class="rd-modal-footer">
      <div class="rd-footer-meta"></div>
      <div class="rd-footer-actions">
        <button class="rd-btn rd-btn-ghost" onclick="closeEditModal()">Batal</button>
        <button class="rd-btn rd-btn-primary" onclick="submitEditKonstruksi()">
          <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
          Simpan Perubahan
        </button>
      </div>
    </div>

  </div>
</div>
