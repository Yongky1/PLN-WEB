<% if (typeof isLanding !== 'undefined' && isLanding) { %>
<!-- ═══ LANDING FOOTER (JALA Light) ═══ -->
<footer id="landing-footer">
  <div class="footer-inner">
    <div class="footer-top">
      <!-- Brand -->
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          <span>JALA</span>
        </a>
        <p class="footer-desc">
          Platform pembelajaran kelistrikan berbasis 3D interaktif untuk karyawan,
          teknisi, dan masyarakat. Oleh PT PLN (Persero).
        </p>
      </div>

      <!-- Link columns -->
      <div class="footer-cols">
        <div class="footer-col">
          <h4>Modul</h4>
          <a href="/tools">Peralatan</a>
          <a href="/ModulKonstruksi">Konstruksi</a>
          <a href="/material">Material</a>
        </div>
        <div class="footer-col">
          <h4>Informasi</h4>
          <a href="#">Tentang Platform</a>
          <a href="#">Kebijakan Privasi</a>
          <a href="#">Syarat Penggunaan</a>
        </div>
        <div class="footer-col">
          <h4>Kontak</h4>
          <a href="mailto:pusdiklat@pln.co.id">pusdiklat@pln.co.id</a>
          <span>Jl. HR. Rasuna Said, Jakarta Selatan</span>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="footer-bottom">
      <p class="footer-copy">&copy; 2026 PT PLN (Persero) — JALA</p>
      <p class="footer-note">Didukung oleh Divisi TI &amp; Transformasi Digital</p>
    </div>
  </div>
</footer>

<% } else { %>
<!-- ═══ STANDARD FOOTER (Light Theme) ═══ -->
<footer class="glass-panel border-t-0 mt-12 pt-16 pb-8 relative z-10" style="background: rgba(255, 255, 255, 0.4); backdrop-filter: blur(24px); border-top: 1px solid rgba(255,255,255,0.6);">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-12">
      <!-- Brand -->
      <div class="md:col-span-1">
        <a href="/" class="flex flex-col mb-4 text-decoration-none">
          <span class="font-bold text-xl tracking-wide text-[var(--color-text-primary)] brand-font leading-none">JALA</span>
          <span class="text-[10px] font-semibold tracking-[0.2em] text-[var(--color-primary)] uppercase leading-none mt-1">Platform</span>
        </a>
        <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">
          Platform pembelajaran kelistrikan berbasis 3D interaktif untuk karyawan, teknisi, dan masyarakat.
        </p>
      </div>

      <!-- Links -->
      <div>
        <h4 class="text-[var(--color-text-primary)] font-bold mb-4 text-sm">Modul</h4>
        <ul class="space-y-2">
          <li><a href="/tools" class="text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] transition-colors">Peralatan</a></li>
          <li><a href="/ModulKonstruksi" class="text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] transition-colors">Konstruksi</a></li>
          <li><a href="/material" class="text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] transition-colors">Material</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-[var(--color-text-primary)] font-bold mb-4 text-sm">Informasi</h4>
        <ul class="space-y-2">
          <li><a href="#" class="text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] transition-colors">Tentang Platform</a></li>
          <li><a href="#" class="text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] transition-colors">Kebijakan Privasi</a></li>
          <li><a href="#" class="text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] transition-colors">Syarat Penggunaan</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-[var(--color-text-primary)] font-bold mb-4 text-sm">Kontak</h4>
        <ul class="space-y-2">
          <li><a href="mailto:pusdiklat@pln.co.id" class="text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] transition-colors">pusdiklat@pln.co.id</a></li>
          <li class="text-sm text-[var(--color-text-secondary)]">Jl. HR. Rasuna Said, Jakarta Selatan</li>
        </ul>
      </div>
    </div>

    <!-- Bottom -->
    <div class="border-t border-[var(--color-border)] pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-xs text-[var(--color-text-secondary)]">
        &copy; 2026 PT PLN (Persero) — JALA
      </p>
      <p class="text-xs text-[var(--color-text-secondary)]">
        Didukung oleh Divisi TI & Transformasi Digital
      </p>
    </div>
  </div>
</footer>

<% } %>