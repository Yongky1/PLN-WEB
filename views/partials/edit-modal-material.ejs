<%
var _modalId  = typeof modalId            !== 'undefined' ? modalId            : 'edit-modal';
var _viewerId = typeof previewViewerId    !== 'undefined' ? previewViewerId    : 'admin-preview-viewer';
var _emptyId  = typeof previewEmptyId     !== 'undefined' ? previewEmptyId     : 'admin-preview-empty';
var _selId    = typeof previewSelectorId  !== 'undefined' ? previewSelectorId  : 'admin-preview-selector';
var _onChange = typeof previewOnChange    !== 'undefined' ? previewOnChange    : 'changeAdminPreview()';
%>
<style>
  #<%= _modalId %> { display: none; }
  #<%= _modalId %>.active { display: flex !important; }
</style>
<div id="<%= _modalId %>" class="rd-modal-overlay" onclick="if(event.target===this)closeEditModal()">
  <div class="rd-modal">

    <div class="rd-modal-header">
      <div class="rd-modal-title-block">
        <div class="rd-modal-eyebrow">Edit · Material</div>
        <h2 class="rd-modal-title">Edit Material &amp; Live Preview</h2>
      </div>
      <button class="rd-modal-close" onclick="closeEditModal()">
        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>

    <div class="rd-modal-body">
      <div class="rd-section-block">
        <div class="rd-section-head"><div class="rd-section-title"><span class="num">1</span> Informasi Material</div></div>
        <div class="rd-field-row cols-2">
          <div class="rd-field-group">
            <label class="rd-field-label">Nama Material <span class="req">*</span></label>
            <input type="text" id="edit-mat-modul-name" class="rd-input" placeholder="Contoh: Baut HDG" />
          </div>
          <div class="rd-field-group">
            <label class="rd-field-label">Kode / Standar <span class="req">*</span></label>
            <input type="text" id="edit-mat-modul-code" class="rd-input rd-mono" placeholder="Contoh: BT-HDG" />
          </div>
        </div>
        <div class="rd-field-group">
          <label class="rd-field-label" style="justify-content:space-between;">
            Deskripsi <span class="rd-field-counter" id="desc-char-count">0/2000</span>
          </label>
          <textarea id="edit-mat-modul-desc" class="rd-textarea" maxlength="2000" rows="2" oninput="document.getElementById('desc-char-count').textContent=this.value.length+'/2000'"></textarea>
        </div>
        <div class="rd-field-group">
          <label class="rd-field-label">Kategori</label>
          <select id="edit-mat-modul-cat" class="rd-select" style="max-width:60%;">
            <option value="">Memuat kategori...</option>
          </select>
        </div>
        <div class="rd-field-group">
          <label class="rd-field-label">Cover Gambar</label>
          <div id="edit-mat-modul-image-wrapper" style="display:grid;grid-template-columns:1fr;gap:12px;">
            <div id="edit-mat-modul-image-drop-zone" class="rd-drop-zone" onclick="document.getElementById('edit-mat-modul-image').click()">
              <div class="dz-icon"><svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg></div>
              <div class="dz-text">
                <div id="edit-mat-img-empty"><div class="dz-title">Pilih Foto Baru</div><div class="dz-sub">PNG · JPG · WEBP · maks 5MB</div></div>
                <div id="edit-mat-img-filled" style="display:none;"><div class="dz-title" style="color:var(--accent);">Thumbnail terpasang</div><div class="dz-sub">Klik untuk ganti</div></div>
              </div>
              <button class="rd-btn rd-btn-secondary rd-btn-sm" onclick="event.stopPropagation();document.getElementById('edit-mat-modul-image').click()">Pilih</button>
            </div>
            <input type="file" id="edit-mat-modul-image" accept="image/png,image/jpeg,image/webp" style="display:none" onchange="
              if(this.files&&this.files[0]){const reader=new FileReader();reader.onload=function(e){document.getElementById('edit-mat-modul-image-wrapper').style.gridTemplateColumns='1fr 1fr';document.getElementById('edit-mat-modul-image-preview-container').style.display='block';document.getElementById('edit-mat-modul-image-preview').src=e.target.result;document.getElementById('edit-mat-modul-image-deleted').value='false';document.getElementById('edit-mat-img-empty').style.display='none';document.getElementById('edit-mat-img-filled').style.display='block';document.getElementById('edit-mat-modul-image-drop-zone').classList.add('has-file');};reader.readAsDataURL(this.files[0]);}
            " />
            <div id="edit-mat-modul-image-preview-container" style="display:none;position:relative;aspect-ratio:16/9;border-radius:8px;overflow:hidden;border:1px solid var(--border-default);">
              <img id="edit-mat-modul-image-preview" src="" style="width:100%;height:100%;object-fit:cover;" />
              <div style="position:absolute;inset:0;background:rgba(0,0,0,0.4);display:flex;align-items:center;justify-content:center;opacity:0;transition:opacity .2s" onmouseover="this.style.opacity=1" onmouseout="this.style.opacity=0">
                <button class="rd-btn rd-btn-danger rd-btn-sm" onclick="document.getElementById('edit-mat-modul-image').value='';document.getElementById('edit-mat-modul-image-preview').src='';document.getElementById('edit-mat-modul-image-wrapper').style.gridTemplateColumns='1fr';document.getElementById('edit-mat-modul-image-preview-container').style.display='none';document.getElementById('edit-mat-modul-image-deleted').value='true';document.getElementById('edit-mat-img-empty').style.display='block';document.getElementById('edit-mat-img-filled').style.display='none';document.getElementById('edit-mat-modul-image-drop-zone').classList.remove('has-file');">Hapus</button>
              </div>
            </div>
            <input type="hidden" id="edit-mat-modul-image-deleted" value="false" />
          </div>
        </div>
      </div>

      <div class="rd-section-block" style="margin-top:14px;">
        <div class="rd-section-head"><div class="rd-section-title"><span class="num">2</span> Varian &amp; Preview 3D</div></div>
        <div style="display:flex;gap:20px;flex-wrap:wrap;">
          <div style="flex:1;min-width:280px;display:flex;flex-direction:column;gap:12px;">
            <div id="edit-material-cards" style="display:flex;flex-direction:column;gap:14px;max-height:320px;overflow-y:auto;padding-right:4px;"></div>
            <button class="rd-btn rd-btn-ghost" style="border:1px dashed var(--border-strong);width:100%;justify-content:center;padding:10px;" onclick="addEditMaterialCard()">
              <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              Tambah Varian
            </button>
          </div>
          <div style="flex:1;min-width:280px;background:rgba(0,0,0,0.2);border-radius:12px;overflow:hidden;border:1px solid var(--border-default);position:relative;min-height:320px;">
            <script type="module" src="https://ajax.googleapis.com/ajax/libs/model-viewer/3.4.0/model-viewer.min.js"></script>
            <model-viewer id="<%= _viewerId %>" src="" camera-controls auto-rotate rotation-per-second="30deg"
              interaction-prompt="none" shadow-intensity="1.5" environment-image="neutral" exposure="1"
              style="width:100%;height:100%;min-height:320px;outline:none;background:#0A1520;"></model-viewer>
            <div id="<%= _emptyId %>" style="position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;color:var(--text-muted);pointer-events:none;gap:8px;">
              <svg width="36" height="36" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
              <span style="font-size:12px;font-weight:600;">Belum ada file GLB terpilih</span>
            </div>
            <div style="position:absolute;bottom:12px;left:12px;right:12px;z-index:10;">
              <select id="<%= _selId %>" onchange="<%= _onChange %>" class="rd-select" style="background:rgba(0,0,0,0.65);backdrop-filter:blur(6px);">
                <option value="">-- Pilih Varian untuk Preview --</option>
              </select>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="rd-modal-footer">
      <div class="rd-footer-meta"></div>
      <div class="rd-footer-actions">
        <button class="rd-btn rd-btn-ghost" onclick="closeEditModal()">Batal</button>
        <button class="rd-btn rd-btn-primary" onclick="submitEditMaterial()">
          <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
          Simpan Perubahan
        </button>
      </div>
    </div>

  </div>
</div>
