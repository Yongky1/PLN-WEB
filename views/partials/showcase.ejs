<!-- ═══ STATISTICS + SHOWCASE SECTION ═══ -->
<section class="py-24 relative overflow-hidden">
  <!-- Gradient background -->
  <div class="absolute inset-0 bg-gradient-to-br from-[#0052A3] via-[#003D7A] to-[#0A2A5C]"></div>
  <!-- Decorative elements -->
  <div class="absolute top-0 right-0 w-96 h-96 rounded-full bg-white/5 blur-3xl pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 w-80 h-80 rounded-full bg-[var(--color-cyan)]/10 blur-3xl pointer-events-none"></div>
  <!-- Grid pattern overlay -->
  <div class="absolute inset-0 opacity-[0.03]">
    <svg width="100%" height="100%"><defs><pattern id="showcase-grid" width="60" height="60" patternUnits="userSpaceOnUse"><path d="M 60 0 L 0 0 0 60" fill="none" stroke="white" stroke-width="0.5"/></pattern></defs><rect width="100%" height="100%" fill="url(#showcase-grid)"/></svg>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    
    <!-- Stats Counter Row -->
    <div class="text-center mb-20">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/10 border border-white/15 mb-6">
        <div class="w-2 h-2 rounded-full bg-[var(--color-accent)] animate-pulse"></div>
        <span class="text-xs font-bold tracking-[0.15em] text-white/80 uppercase">Data Platform</span>
      </div>
      <h2 class="text-4xl md:text-5xl font-extrabold text-white brand-font mb-6">
        Statistik <span class="text-[var(--color-accent)]">PLN</span>
      </h2>
    </div>

    <!-- Counter Cards -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-20 gsap-stagger-container">
      <div class="gsap-stagger-item text-center p-6 rounded-2xl bg-white/5 border border-white/10 backdrop-blur-sm hover:bg-white/10 transition-all duration-300">
        <div class="text-4xl md:text-5xl font-extrabold text-white brand-font mb-2 counter-value" data-target="500" data-suffix="+">0</div>
        <p class="text-sm text-white/50 font-medium">Peralatan</p>
      </div>
      <div class="gsap-stagger-item text-center p-6 rounded-2xl bg-white/5 border border-white/10 backdrop-blur-sm hover:bg-white/10 transition-all duration-300">
        <div class="text-4xl md:text-5xl font-extrabold text-white brand-font mb-2 counter-value" data-target="100" data-suffix="+">0</div>
        <p class="text-sm text-white/50 font-medium">Tipe Konstruksi</p>
      </div>
      <div class="gsap-stagger-item text-center p-6 rounded-2xl bg-white/5 border border-white/10 backdrop-blur-sm hover:bg-white/10 transition-all duration-300">
        <div class="text-4xl md:text-5xl font-extrabold text-white brand-font mb-2 counter-value" data-target="1000" data-suffix="+">0</div>
        <p class="text-sm text-white/50 font-medium">Material</p>
      </div>
      <div class="gsap-stagger-item text-center p-6 rounded-2xl bg-white/5 border border-white/10 backdrop-blur-sm hover:bg-white/10 transition-all duration-300">
        <div class="text-4xl md:text-5xl font-extrabold text-[var(--color-accent)] brand-font mb-2 counter-value" data-target="3" data-suffix="D">0</div>
        <p class="text-sm text-white/50 font-medium">Visualisasi Interaktif</p>
      </div>
    </div>

    <!-- Feature Showcase -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center gsap-reveal">
      <div>
        <div class="flex items-center gap-2 mb-6">
          <div class="w-1 h-5 bg-[var(--color-accent)] rounded-full"></div>
          <span class="text-[var(--color-accent)] text-sm tracking-widest uppercase font-bold">Simulasi Operasional</span>
        </div>
        <h3 class="text-3xl md:text-4xl font-extrabold text-white mb-6 brand-font leading-tight">
          Standar Industri<br><span class="text-white/60">Tinggi</span>
        </h3>
        <p class="text-white/50 leading-relaxed mb-8">
          Setiap fasilitas dirancang presisi untuk mengemulasi kondisi realita, meminimalisir risiko operasional sebelum personel terjun ke lapangan.
        </p>
        <ul class="space-y-4">
          <li class="flex items-start gap-3">
            <div class="w-6 h-6 rounded-full bg-[var(--color-success)]/20 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-3.5 h-3.5 text-[var(--color-success)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"></path></svg>
            </div>
            <span class="text-white/70 text-sm leading-relaxed">Simulasi respons proteksi tegangan dan deteksi anomali</span>
          </li>
          <li class="flex items-start gap-3">
            <div class="w-6 h-6 rounded-full bg-[var(--color-success)]/20 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-3.5 h-3.5 text-[var(--color-success)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"></path></svg>
            </div>
            <span class="text-white/70 text-sm leading-relaxed">Sistem telekontrol terintegrasi standar SCADA</span>
          </li>
          <li class="flex items-start gap-3">
            <div class="w-6 h-6 rounded-full bg-[var(--color-success)]/20 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-3.5 h-3.5 text-[var(--color-success)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"></path></svg>
            </div>
            <span class="text-white/70 text-sm leading-relaxed">Exploded View 3D untuk analisis komponen konstruksi</span>
          </li>
        </ul>
        <div class="mt-8">
          <div class="inline-flex items-center px-5 py-2.5 border border-[var(--color-accent)]/50 text-[var(--color-accent)] text-xs font-bold tracking-widest uppercase rounded-xl hover:bg-[var(--color-accent)]/10 transition-colors">
            ISO 9001:2015 Certified
          </div>
        </div>
      </div>
      
      <!-- Visual -->
      <div class="relative h-80 md:h-96 w-full rounded-2xl overflow-hidden border border-white/10 bg-white/5 backdrop-blur-sm">
        <div class="absolute inset-0 flex items-center justify-center">
          <div class="text-center">
            <div class="w-20 h-20 mx-auto rounded-2xl bg-white/10 border border-white/15 flex items-center justify-center mb-4">
              <svg class="w-10 h-10 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 7.5l-2.25-1.313M21 7.5v2.25m0-2.25l-2.25 1.313M3 7.5l2.25-1.313M3 7.5l2.25 1.313M3 7.5v2.25m9 3l2.25-1.313M12 12.75l-2.25-1.313M12 12.75V15m0 6.75l2.25-1.313M12 21.75V19.5m0 2.25l-2.25-1.313m0-16.875L12 2.25l2.25 1.313M21 14.25v2.25l-2.25 1.313m-13.5 0L3 16.5v-2.25"/>
              </svg>
            </div>
            <p class="text-white/30 text-xs tracking-[0.3em] uppercase font-bold brand-font">Simulasi 3D Aktif</p>
          </div>
        </div>
        <!-- Decorative grid -->
        <div class="absolute inset-0 opacity-5">
          <svg width="100%" height="100%"><defs><pattern id="inner-grid" width="40" height="40" patternUnits="userSpaceOnUse"><path d="M 40 0 L 0 0 0 40" fill="none" stroke="white" stroke-width="0.5"/></pattern></defs><rect width="100%" height="100%" fill="url(#inner-grid)"/></svg>
        </div>
      </div>
    </div>
  </div>
</section>
