        </div>
      </div>

      <!-- Step 3 -->
      <div class="gsap-stagger-item group">
        <div class="card-elevated p-8 text-center h-full relative">
          <div class="absolute top-4 right-4 text-6xl font-extrabold text-[var(--color-accent)]/5 brand-font leading-none">03</div>
          <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-[var(--color-accent)]/10 to-[var(--color-warning)]/10 flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform duration-500">
            <svg class="w-8 h-8 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"/>
