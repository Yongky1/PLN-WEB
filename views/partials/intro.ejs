      <!-- Visual Side -->
      <div class="relative">
        <div class="aspect-square relative rounded-3xl overflow-hidden bg-gradient-to-br from-[var(--color-bg-surface-alt)] to-[var(--color-bg-main)] border border-[var(--color-border-light)] shadow-lg">
          <!-- Decorative ring -->
          <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[85%] h-[85%] border border-[var(--color-primary)]/8 rounded-full" style="animation: spin 20s linear infinite;"></div>
          
          <div class="absolute inset-6 rounded-2xl bg-white/80 backdrop-blur-sm border border-[var(--color-border)] flex items-center justify-center p-8 text-center group transition-all duration-500 hover:border-[var(--color-primary)]/30 hover:shadow-xl">
            <div class="relative z-10">
              <div class="w-20 h-20 mx-auto rounded-2xl bg-gradient-to-br from-[var(--color-primary)] to-[var(--color-primary-light)] flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-500 shadow-lg shadow-[var(--color-primary)]/20">
