      <p class="text-lg text-[var(--color-text-secondary)] max-w-2xl mx-auto leading-relaxed">
        Platform dirancang untuk pengalaman belajar yang intuitif dan interaktif bagi semua kalangan.
      </p>
    </div>

    <!-- 3 Steps -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-24 gsap-stagger-container">
      <!-- Step 1 -->
      <div class="gsap-stagger-item group">
        <div class="card-elevated p-8 text-center h-full relative">
          <div class="absolute top-4 right-4 text-6xl font-extrabold text-[var(--color-primary)]/5 brand-font leading-none">01</div>
