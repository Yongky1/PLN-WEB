                </svg>
              </div>
              <h4 class="text-xl font-bold text-[var(--color-text-primary)] mb-2 tracking-wide brand-font">PENGEMBANGAN SDM</h4>
              <p class="text-[var(--color-text-secondary)] text-sm leading-relaxed">Infrastruktur pembelajaran canggih yang mereplikasi kondisi lapangan sebenarnya.</p>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>

  <style>
    @keyframes spin { to { transform: translate(-50%, -50%) rotate(360deg); } }
  </style>
</section>
