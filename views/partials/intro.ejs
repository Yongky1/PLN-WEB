          <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">Navigasi ke modul Peralatan, Konstruksi, atau Material sesuai kebutuhan pembelajaran Anda.</p>
        </div>
      </div>

      <!-- Step 2 -->
      <div class="gsap-stagger-item group">
        <div class="card-elevated p-8 text-center h-full relative">
          <div class="absolute top-4 right-4 text-6xl font-extrabold text-[var(--color-cyan)]/5 brand-font leading-none">02</div>
          <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-[var(--color-cyan)]/10 to-[var(--color-primary)]/10 flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform duration-500">
            <svg class="w-8 h-8 text-[var(--color-cyan)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
