<!-- ═══ MODULE HIGHLIGHTS — 3 Kartu ═══ -->
<section id="explore" class="py-24 relative" style="background-color: var(--color-bg-main);">
  <!-- Decorative -->
  <div class="absolute bottom-0 left-0 w-80 h-80 rounded-full bg-gradient-to-tr from-[var(--color-cyan)]/5 to-transparent blur-3xl pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <!-- Section Header -->
    <div class="text-center mb-16 gsap-reveal">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[var(--color-accent)]/8 border border-[var(--color-accent)]/15 mb-6">
        <svg class="w-4 h-4 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path></svg>
        <span class="text-xs font-bold tracking-[0.15em] text-[var(--color-accent-dark)] uppercase">Pusat Keahlian</span>
      </div>
      <h2 class="text-4xl md:text-5xl font-extrabold text-[var(--color-text-primary)] brand-font mb-4">
        Fokus <span class="gradient-text-blue">Pembelajaran</span>
      </h2>
      <p class="text-lg text-[var(--color-text-secondary)] max-w-xl mx-auto">Tiga modul utama yang saling terhubung dalam satu ekosistem pembelajaran interaktif.</p>
    </div>

    <!-- 3 Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 gsap-stagger-container">
      
      <!-- Card 1: Peralatan -->
      <a href="/tools" class="gsap-stagger-item group block">
        <div class="card-elevated overflow-hidden h-full">
          <!-- Card Image Area -->
          <div class="aspect-[4/3] relative overflow-hidden bg-gradient-to-br from-[var(--color-primary)]/5 to-[var(--color-cyan)]/5">
            <div class="absolute inset-0 flex items-center justify-center">
              <div class="w-24 h-24 rounded-3xl bg-gradient-to-br from-[var(--color-primary)]/15 to-[var(--color-cyan)]/10 flex items-center justify-center group-hover:scale-110 transition-transform duration-700">
                <svg class="w-12 h-12 text-[var(--color-primary)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17l-5.3-3.07a1 1 0 00-.92-.04l-3.72 1.86a1 1 0 00-.56.9V19a1 1 0 001 1h16a1 1 0 001-1v-4.25a1 1 0 00-.56-.9l-3.72-1.86a1 1 0 00-.92.04l-5.3 3.07z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/>
                </svg>
              </div>
            </div>
            <!-- Accent line -->
            <div class="absolute bottom-0 left-0 right-0 h-1 bg-gradient-to-r from-[var(--color-primary)] to-[var(--color-cyan)] transform scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left"></div>
          </div>
          <!-- Card Body -->
          <div class="p-6">
            <h3 class="text-xl font-bold text-[var(--color-text-primary)] brand-font mb-2 group-hover:text-[var(--color-primary)] transition-colors">Peralatan K3</h3>
            <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed mb-4">Eksplorasi perangkat keselamatan dan alat kerja standar PLN dalam visualisasi 3D interaktif.</p>
            <div class="flex items-center text-sm font-semibold text-[var(--color-primary)] group-hover:gap-3 gap-2 transition-all">
              <span>Eksplorasi</span>
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
            </div>
          </div>
        </div>
      </a>

      <!-- Card 2: Konstruksi -->
      <a href="/ModulKonstruksi" class="gsap-stagger-item group block">
        <div class="card-elevated overflow-hidden h-full">
          <div class="aspect-[4/3] relative overflow-hidden bg-gradient-to-br from-[var(--color-cyan)]/5 to-[var(--color-primary)]/5">
            <div class="absolute inset-0 flex items-center justify-center">
              <div class="w-24 h-24 rounded-3xl bg-gradient-to-br from-[var(--color-cyan)]/15 to-[var(--color-primary)]/10 flex items-center justify-center group-hover:scale-110 transition-transform duration-700">
                <svg class="w-12 h-12 text-[var(--color-cyan)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 0h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008z"/>
                </svg>
              </div>
            </div>
            <div class="absolute bottom-0 left-0 right-0 h-1 bg-gradient-to-r from-[var(--color-cyan)] to-[var(--color-primary)] transform scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left"></div>
          </div>
          <div class="p-6">
            <h3 class="text-xl font-bold text-[var(--color-text-primary)] brand-font mb-2 group-hover:text-[var(--color-cyan)] transition-colors">Konstruksi Jaringan</h3>
            <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed mb-4">Analisis dan simulasi pembangunan struktur tegangan tinggi, menara transmisi, dan gardu induk.</p>
            <div class="flex items-center text-sm font-semibold text-[var(--color-cyan)] group-hover:gap-3 gap-2 transition-all">
              <span>Eksplorasi</span>
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
            </div>
          </div>
        </div>
      </a>

      <!-- Card 3: Material -->
      <a href="/material" class="gsap-stagger-item group block">
        <div class="card-elevated overflow-hidden h-full">
          <div class="aspect-[4/3] relative overflow-hidden bg-gradient-to-br from-[var(--color-accent)]/5 to-[var(--color-warning)]/5">
            <div class="absolute inset-0 flex items-center justify-center">
              <div class="w-24 h-24 rounded-3xl bg-gradient-to-br from-[var(--color-accent)]/15 to-[var(--color-warning)]/10 flex items-center justify-center group-hover:scale-110 transition-transform duration-700">
                <svg class="w-12 h-12 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125"/>
                </svg>
              </div>
            </div>
            <div class="absolute bottom-0 left-0 right-0 h-1 bg-gradient-to-r from-[var(--color-accent)] to-[var(--color-warning)] transform scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left"></div>
          </div>
          <div class="p-6">
            <h3 class="text-xl font-bold text-[var(--color-text-primary)] brand-font mb-2 group-hover:text-[var(--color-accent)] transition-colors">Material Teknis</h3>
            <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed mb-4">Katalog material kelistrikan lengkap dengan spesifikasi, cara pemasangan, dan standar SNI/IEC.</p>
            <div class="flex items-center text-sm font-semibold text-[var(--color-accent)] group-hover:gap-3 gap-2 transition-all">
              <span>Eksplorasi</span>
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
            </div>
          </div>
        </div>
      </a>

    </div>
  </div>
</section>
