    <style>
      #mat-modal-overlay { background: rgba(27,43,75,0.4); backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px); }
      #mat-modal-overlay.active { display: flex !important; }
      @keyframes modalIn { from { opacity:0; transform:scale(0.94) translateY(20px); } to { opacity:1; transform:scale(1) translateY(0); } }
      #mat-modal-card { animation: modalIn 0.3s cubic-bezier(0.22,1,0.36,1) forwards; height: auto; max-height: 90vh; }
      @media (min-width: 768px) { #mat-modal-card { height: 560px; max-height: unset; } }
      #mat-canvas-wrap { position: relative; overflow: hidden; }
      #mat-canvas-wrap model-viewer { width: 100%; height: 100%; display: block; }
      #mat-info-wrap { overflow-y: auto; }
      #mat-info-wrap::-webkit-scrollbar { width: 4px; }
      #mat-info-wrap::-webkit-scrollbar-track { background: transparent; }
      #mat-info-wrap::-webkit-scrollbar-thumb { background: rgba(0,82,163,0.1); border-radius: 999px; }
      #mat-info-wrap::-webkit-scrollbar-thumb:hover { background: rgba(0,82,163,0.25); }
    </style>
    <!-- ====================================================
         MODAL – Material Detail & 3D Viewer
    ==================================================== -->
    <div id="mat-modal-overlay" class="fixed inset-0 z-50 hidden items-center justify-center p-4 sm:p-6" style="display: none;">

        <div id="mat-modal-card" class="relative w-full max-w-5xl flex flex-col md:flex-row rounded-[2.5rem] overflow-hidden shadow-2xl border border-[var(--color-border)] bg-[var(--color-bg-surface)]">

            <!-- LEFT: 3D Viewer -->
            <div id="mat-canvas-wrap" class="w-full md:w-[52%] shrink-0 relative overflow-hidden flex items-center justify-center group h-[260px] md:h-auto bg-gradient-to-br from-[var(--color-bg-surface-alt)] to-[var(--color-bg-main)]">
                <div class="absolute top-0 left-1/2 -translate-x-1/2 w-3/4 h-32 blur-[60px] pointer-events-none bg-[var(--color-accent)]/5"></div>
                <model-viewer id="mat-model-viewer" src="" camera-controls auto-rotate rotation-per-second="25deg"
                    interaction-prompt="none" shadow-intensity="1" environment-image="neutral" exposure="1"
                    class="w-full h-full z-0 outline-none cursor-grab active:cursor-grabbing">
                </model-viewer>
                <div id="mat-loading-overlay" class="pln-3d-loading absolute inset-0 z-10">
                    <div id="mat-loading-spinner" class="pln-3d-loader">
                        <span class="pln-dot bg-[var(--color-accent)]"></span>
                        <span class="pln-dot bg-[var(--color-accent)]"></span>
                        <span class="pln-dot bg-[var(--color-accent)]"></span>
                    </div>
                    <span id="mat-loading-text" class="pln-3d-label text-[var(--color-text-secondary)]"></span>
                </div>
                <div id="mat-empty-state" class="absolute inset-0 flex-col items-center justify-center text-[var(--color-text-muted)] z-10 hidden" style="display:none;">
                    <svg class="w-16 h-16 mb-4 text-[var(--color-text-muted)] opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                    <span class="text-sm font-medium tracking-wide brand-font">Belum ada file 3D</span>
                </div>
                <div id="mat-hint-text" class="absolute bottom-5 left-1/2 -translate-x-1/2 bg-white/90 backdrop-blur-md border border-[var(--color-border)] text-[var(--color-text-secondary)] text-[11px] font-medium tracking-wide px-4 py-2 rounded-full pointer-events-none z-10 opacity-0 group-hover:opacity-100 transition-all duration-500 flex items-center gap-2 shadow-lg">
                    <svg class="w-3.5 h-3.5 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5"/></svg>
                    Rotasi 360° · Zoom via Scroll
                </div>
                <button id="mat-fullscreen-btn" title="Layar Penuh" class="absolute top-4 right-4 w-10 h-10 bg-white/80 backdrop-blur-md rounded-full flex items-center justify-center text-[var(--color-text-secondary)] hover:text-[var(--color-primary)] hover:bg-white transition-all z-20 border border-[var(--color-border)] shadow-sm opacity-0 group-hover:opacity-100">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4"/></svg>
                </button>

                <!-- Variant Navigation Arrows -->
                <button id="mat-viewer-prev-btn" onclick="prevMatVariant()" class="absolute left-3 md:left-6 top-1/2 -translate-y-1/2 w-10 h-10 md:w-12 md:h-12 bg-white/80 backdrop-blur-md rounded-full flex items-center justify-center text-[var(--color-text-secondary)] hover:text-[var(--color-primary)] hover:bg-white transition-all hidden z-20 border border-[var(--color-border)] shadow-md group-hover:scale-105">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
                </button>
                <button id="mat-viewer-next-btn" onclick="nextMatVariant()" class="absolute right-3 md:right-6 top-1/2 -translate-y-1/2 w-10 h-10 md:w-12 md:h-12 bg-white/80 backdrop-blur-md rounded-full flex items-center justify-center text-[var(--color-text-secondary)] hover:text-[var(--color-primary)] hover:bg-white transition-all hidden z-20 border border-[var(--color-border)] shadow-md group-hover:scale-105">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                </button>

                <!-- Variant Display Name -->
                <div id="mat-viewer-variant-name" class="absolute top-4 left-1/2 -translate-x-1/2 px-5 py-2 bg-white/90 backdrop-blur-md text-[var(--color-text-primary)] text-[10px] font-bold rounded-full pointer-events-none z-10 hidden shadow-md border border-[var(--color-border)] uppercase tracking-[0.2em]">
                    Varian -
                </div>
            </div>

            <!-- RIGHT: Info Panel -->
            <div id="mat-info-wrap" class="flex-1 flex flex-col min-h-0 relative" style="overflow-y: auto;">
                <div class="shrink-0 px-7 md:px-9 pt-5 md:pt-7 pb-3 relative">
                    <div class="absolute top-5 right-5 z-20">
                        <button id="mat-btn-close" class="w-9 h-9 flex items-center justify-center rounded-full transition-all border border-[var(--color-border)] hover:border-[var(--color-primary)] bg-[var(--color-bg-surface-alt)] hover:bg-[var(--color-primary)]/5">
                            <svg class="w-4 h-4 text-[var(--color-text-secondary)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/></svg>
                        </button>
                    </div>
                    <div class="flex items-center gap-3 mb-4 pr-12">
                        <span id="mat-modal-category" class="text-[9px] font-black uppercase tracking-[0.2em] px-3 py-1.5 rounded-full border inline-flex items-center gap-1.5 bg-[var(--color-accent)]/10 border-[var(--color-accent)]/20 text-[var(--color-accent-dark)]">
                            <span class="w-1 h-1 rounded-full animate-pulse bg-[var(--color-accent)] opacity-80"></span>
                        </span>
                    </div>
                    <h2 id="mat-modal-name" class="text-2xl font-bold text-[var(--color-text-primary)] leading-tight mb-1 brand-font tracking-tight"></h2>
                    <p id="mat-modal-code" class="text-[11px] font-mono tracking-wider text-[var(--color-cyan)] font-semibold"></p>
                    <div class="mt-3 h-px bg-[var(--color-border-light)]"></div>
                </div>
                <div class="flex-1 overflow-y-auto px-7 md:px-9 pb-7 pt-3">
                    <p id="mat-modal-desc" class="text-[13px] text-[var(--color-text-secondary)] leading-relaxed mb-5"></p>
                </div>
            </div>
        </div>
    </div>
