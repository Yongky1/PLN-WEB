<!-- views/admin/settings.ejs -->
<div class="rd-page-head" style="margin-bottom: 24px;">
    <h1 class="rd-page-title" style="font-size: 26px; font-weight: 700; color: var(--text-primary); margin: 0;">
        Pengaturan Akun</h1>
</div>

<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(400px, 1fr)); gap: 24px; align-items: stretch;">

    <!-- Profil Card -->
    <div class="rd-data-card" style="padding: 32px 28px; display: flex; flex-direction: column; height: 100%;">
        <div style="display: flex; align-items: center; gap: 16px; margin-bottom: 32px;">
            <div id="profile-card-avatar"
                style="width: 64px; height: 64px; border-radius: 50%; background: var(--pln-blue); display: flex; align-items: center; justify-content: center; color: #FFFFFF; font-size: 24px; font-weight: 600;">
                <%= typeof adminProfile !=='undefined' && adminProfile && adminProfile.name ?
                    adminProfile.name[0].toUpperCase() : 'A' %>
            </div>
            <div>
                <div id="profile-card-name" style="font-weight: 700; font-size: 18px; color: var(--text-primary);">
                    <%= typeof adminProfile !=='undefined' && adminProfile ? adminProfile.name : 'Super Admin' %>
                </div>
                <div id="profile-card-unit" style="font-size: 13.5px; color: var(--text-secondary); margin-top: 4px;">
                    <%= typeof adminProfile !=='undefined' && adminProfile && adminProfile.unit ? adminProfile.unit
                        : 'Administrator' %>
                </div>
            </div>
        </div>

        <div style="display:flex; flex-direction:column; gap:20px; flex: 1;">
            <div class="rd-field-group">
                <label class="rd-field-label">Nama Lengkap</label>
                <input id="s-name" type="text" class="rd-input"
                    value="<%= typeof adminProfile !== 'undefined' && adminProfile ? adminProfile.name : '' %>"
                    placeholder="Nama lengkap">
            </div>
            <div class="rd-field-group">
                <label class="rd-field-label">Email</label>
                <input id="s-email" type="email" class="rd-input"
                    value="<%= typeof adminProfile !== 'undefined' && adminProfile ? adminProfile.email : '' %>"
                    placeholder="Alamat email">
            </div>
            <div class="rd-field-group">
                <label class="rd-field-label">Unit Kerja</label>
                <input id="s-unit" type="text" class="rd-input"
                    value="<%= typeof adminProfile !== 'undefined' && adminProfile ? adminProfile.unit : '' %>"
                    placeholder="Unit kerja">
            </div>
            <div style="margin-top: auto; padding-top: 12px;">
                <button class="rd-btn rd-btn-primary" onclick="saveProfile()"
                    style="width: 100%; justify-content: center; padding: 12px; font-size: 14.5px; font-weight: 600; border-radius: 8px;">Simpan
                    Perubahan</button>
            </div>
        </div>
    </div>

    <!-- Security Card -->
    <div class="rd-data-card" style="padding: 32px 28px; display: flex; flex-direction: column; height: 100%;">
        <h2 style="font-size: 20px; font-weight: 700; color: var(--text-primary); margin: 0 0 32px 0;">Ganti Password
        </h2>

        <div style="display:flex; flex-direction:column; gap:20px; flex: 1;">
            <div class="rd-field-group">
                <label class="rd-field-label">Password Lama</label>
                <input id="pw-old" type="password" class="rd-input" placeholder="••••••••">
            </div>
            <div class="rd-field-group">
                <label class="rd-field-label">Password Baru</label>
                <input id="pw-new" type="password" class="rd-input" placeholder="••••••••">
            </div>
            <div class="rd-field-group">
                <label class="rd-field-label">Konfirmasi Password</label>
                <input id="pw-confirm" type="password" class="rd-input" placeholder="••••••••">
            </div>
            <div id="pw-error" style="font-size:12.5px; color:var(--status-danger, #EF4444); display:none;">Password
                baru dan konfirmasi tidak cocok.</div>
            <div style="margin-top: auto; padding-top: 12px;">
                <button class="rd-btn rd-btn-primary" onclick="savePassword()"
                    style="width: 100%; justify-content: center; padding: 12px; font-size: 14.5px; font-weight: 600; border-radius: 8px;">Ganti
                    Password</button>
            </div>
        </div>
    </div>
</div>
<script src="/js/admin/settings.js"></script>