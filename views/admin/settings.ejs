<!-- views/admin/settings.ejs -->
<div class="rd-page-head" style="margin-bottom: 24px;">
  <div class="rd-page-title-block">
    <div class="rd-page-eyebrow">Pengaturan</div>
    <h1 class="rd-page-title">Settings</h1>
    <p class="rd-page-subtitle">Kelola informasi profil dan pengaturan keamanan akun Anda di sini.</p>
  </div>
</div>

<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(400px, 1fr)); gap: 24px; align-items: start;">

    <!-- Profil Card -->
    <div class="rd-section-block">
        <div class="rd-section-head" style="margin-bottom: 8px;">
            <div class="rd-section-title">
               <div class="num">
                  <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
               </div>
               Profil Administrator
            </div>
        </div>
        
        <div style="display: flex; align-items: center; gap: 16px; margin-bottom: 16px; padding-bottom: 16px; border-bottom: 1px solid var(--border-subtle);">
            <div style="width: 64px; height: 64px; border-radius: 50%; background: linear-gradient(135deg, var(--pln-blue), var(--pln-blue-strong)); display: flex; align-items: center; justify-content: center; color: white; font-size: 24px; font-weight: bold; box-shadow: 0 4px 12px rgba(0,82,163,0.2);">
                <%= typeof adminProfile !== 'undefined' && adminProfile && adminProfile.name ? adminProfile.name[0].toUpperCase() : 'A' %>
            </div>
            <div>
                <div style="font-weight: 600; font-size: 15px; color: var(--text-primary);"><%= typeof adminProfile !== 'undefined' && adminProfile ? adminProfile.name : 'Super Admin' %></div>
                <div style="font-size: 13px; color: var(--text-tertiary);"><%= typeof adminProfile !== 'undefined' && adminProfile ? adminProfile.email : 'admin@pln.co.id' %></div>
            </div>
        </div>

        <div style="display:flex; flex-direction:column; gap:16px;">
            <div class="rd-field-group">
                <label class="rd-field-label">Nama Lengkap</label>
                <input id="s-name" type="text" class="rd-input" value="<%= typeof adminProfile !== 'undefined' && adminProfile ? adminProfile.name : '' %>" placeholder="Masukkan nama lengkap">
            </div>
            <div class="rd-field-group">
                <label class="rd-field-label">Email <span class="req">*</span></label>
                <input id="s-email" type="email" class="rd-input" value="<%= typeof adminProfile !== 'undefined' && adminProfile ? adminProfile.email : '' %>" placeholder="Masukkan alamat email">
            </div>
            <div class="rd-field-group">
                <label class="rd-field-label">Unit Kerja</label>
                <input id="s-unit" type="text" class="rd-input" value="<%= typeof adminProfile !== 'undefined' && adminProfile ? adminProfile.unit : '' %>" placeholder="Misal: Pusat, UID Jakarta">
            </div>
            <div style="margin-top: 8px;">
                <button class="rd-btn rd-btn-primary" onclick="saveProfile()">
                    <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                    Simpan Perubahan
                </button>
            </div>
        </div>
    </div>

    <!-- Security Card -->
    <div class="rd-section-block">
        <div class="rd-section-head" style="margin-bottom: 8px;">
            <div class="rd-section-title">
               <div class="num" style="background: rgba(239, 68, 68, 0.1); color: #EF4444;">
                  <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
               </div>
               Keamanan Akun
            </div>
        </div>
        
        <div style="font-size: 13px; color: var(--text-tertiary); margin-bottom: 16px; padding-bottom: 16px; border-bottom: 1px solid var(--border-subtle);">
            Pastikan password Anda panjang, unik, dan tidak digunakan di aplikasi lain untuk menjaga keamanan akun Anda.
        </div>

        <div style="display:flex; flex-direction:column; gap:16px;">
            <div class="rd-field-group">
                <label class="rd-field-label">Password Lama</label>
                <input id="pw-old" type="password" class="rd-input" placeholder="Masukkan password lama Anda">
            </div>
            <div class="rd-field-group">
                <label class="rd-field-label">Password Baru</label>
                <input id="pw-new" type="password" class="rd-input" placeholder="Buat password baru">
                <div class="rd-field-help">Minimal 8 karakter.</div>
            </div>
            <div class="rd-field-group">
                <label class="rd-field-label">Konfirmasi Password Baru</label>
                <input id="pw-confirm" type="password" class="rd-input" placeholder="Ketik ulang password baru">
            </div>
            <div id="pw-error" style="font-size:12.5px; color:var(--status-danger, #EF4444); background: rgba(239, 68, 68, 0.1); padding: 8px 12px; border-radius: 6px; display:none; align-items: center; gap: 6px;">
                <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                <span>Password baru dan konfirmasi tidak cocok.</span>
            </div>
            <div style="margin-top: 8px;">
                <button class="rd-btn rd-btn-secondary" onclick="savePassword()" style="color: var(--status-danger, #EF4444); border-color: rgba(239, 68, 68, 0.3);">
                    <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"></path></svg>
                    Ganti Password
                </button>
            </div>
        </div>
    </div>
</div>
<script src="/js/admin/settings.js"></script>
