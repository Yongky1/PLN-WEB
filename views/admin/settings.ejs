<!-- views/admin/settings.ejs -->
<div class="rd-page-head" style="margin-bottom: 24px;">
  <div class="rd-page-title-block">
    <h1 class="rd-page-title">Pengaturan Akun</h1>
  </div>
</div>

<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(400px, 1fr)); gap: 24px; align-items: start;">

    <!-- Profil Card -->
    <div class="rd-section-block">
        <div class="rd-section-head" style="margin-bottom: 8px;">
            <div class="rd-section-title">Profil Administrator</div>
        </div>
        
        <div style="display: flex; align-items: center; gap: 16px; margin-bottom: 16px; padding-bottom: 16px; border-bottom: 1px solid var(--border-subtle);">
            <div style="width: 56px; height: 56px; border-radius: 8px; background: var(--bg-surface-2); border: 1px solid var(--border-default); display: flex; align-items: center; justify-content: center; color: var(--text-secondary); font-size: 20px; font-weight: 600;">
                <%= typeof adminProfile !== 'undefined' && adminProfile && adminProfile.name ? adminProfile.name[0].toUpperCase() : 'A' %>
            </div>
            <div>
                <div style="font-weight: 600; font-size: 14px; color: var(--text-primary);"><%= typeof adminProfile !== 'undefined' && adminProfile ? adminProfile.name : 'Super Admin' %></div>
                <div style="font-size: 13px; color: var(--text-tertiary);"><%= typeof adminProfile !== 'undefined' && adminProfile ? adminProfile.email : 'admin@pln.co.id' %></div>
            </div>
        </div>

        <div style="display:flex; flex-direction:column; gap:16px;">
            <div class="rd-field-group">
                <label class="rd-field-label">Nama Lengkap</label>
                <input id="s-name" type="text" class="rd-input" value="<%= typeof adminProfile !== 'undefined' && adminProfile ? adminProfile.name : '' %>" placeholder="Nama lengkap">
            </div>
            <div class="rd-field-group">
                <label class="rd-field-label">Email</label>
                <input id="s-email" type="email" class="rd-input" value="<%= typeof adminProfile !== 'undefined' && adminProfile ? adminProfile.email : '' %>" placeholder="Alamat email">
            </div>
            <div class="rd-field-group">
                <label class="rd-field-label">Unit Kerja</label>
                <input id="s-unit" type="text" class="rd-input" value="<%= typeof adminProfile !== 'undefined' && adminProfile ? adminProfile.unit : '' %>" placeholder="Unit kerja">
            </div>
            <div style="margin-top: 8px;">
                <button class="rd-btn rd-btn-primary" onclick="saveProfile()">Simpan Perubahan</button>
            </div>
        </div>
    </div>

    <!-- Security Card -->
    <div class="rd-section-block">
        <div class="rd-section-head" style="margin-bottom: 16px;">
            <div class="rd-section-title">Ganti Password</div>
        </div>

        <div style="display:flex; flex-direction:column; gap:16px;">
            <div class="rd-field-group">
                <label class="rd-field-label">Password Lama</label>
                <input id="pw-old" type="password" class="rd-input" placeholder="Password lama">
            </div>
            <div class="rd-field-group">
                <label class="rd-field-label">Password Baru</label>
                <input id="pw-new" type="password" class="rd-input" placeholder="Password baru">
            </div>
            <div class="rd-field-group">
                <label class="rd-field-label">Konfirmasi Password Baru</label>
                <input id="pw-confirm" type="password" class="rd-input" placeholder="Konfirmasi password baru">
            </div>
            <div id="pw-error" style="font-size:12.5px; color:var(--status-danger, #EF4444); background: rgba(239, 68, 68, 0.1); padding: 8px 12px; border-radius: 6px; display:none; align-items: center; gap: 6px;">
                <span>Password baru dan konfirmasi tidak cocok.</span>
            </div>
            <div style="margin-top: 8px;">
                <button class="rd-btn rd-btn-secondary" onclick="savePassword()">Ganti Password</button>
            </div>
        </div>
    </div>
</div>
<script src="/js/admin/settings.js"></script>
