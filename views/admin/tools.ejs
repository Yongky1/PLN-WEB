<!-- views/admin/tools.ejs -->
<div style="max-width:720px;">
    <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:24px;">
        <div>
            <h3 style="font-size:16px; font-weight:700; color:#fff; margin:0;">Manajemen Peralatan</h3>
            <p style="font-size:12px; color:rgba(255,255,255,0.35); margin:4px 0 0;">Tambah dan kelola katalog alat lapangan & K3</p>
        </div>
        <span style="font-size:11px; font-weight:600; padding:4px 12px; border-radius:999px; background:rgba(245,158,11,0.1); color:#F59E0B; border:1px solid rgba(245,158,11,0.25);">Peralatan</span>
    </div>

    <div id="tools-list" style="display:flex; flex-direction:column; gap:10px; margin-bottom:20px;">
        <div class="item-row">
            <div style="font-size:24px; flex-shrink:0;">⛑️</div>
            <div style="flex:1;"><div style="font-size:13px; font-weight:600; color:#fff;">Helm Safety</div><div style="font-size:11px; color:rgba(255,255,255,0.35); margin-top:2px;">Alat K3 · SNI 8400:2017 · Wajib</div></div>
            <span class="badge badge-red">K3</span>
            <button class="btn-danger" onclick="deleteRow(this)">Hapus</button>
        </div>
        <div class="item-row">
            <div style="font-size:24px; flex-shrink:0;">🪜</div>
            <div style="flex:1;"><div style="font-size:13px; font-weight:600; color:#fff;">Tangga Fiberglass</div><div style="font-size:11px; color:rgba(255,255,255,0.35); margin-top:2px;">Alat Teknis · SPLN D3.013 · Wajib</div></div>
            <span class="badge badge-blue">Teknis</span>
            <button class="btn-danger" onclick="deleteRow(this)">Hapus</button>
        </div>
    </div>

    <div class="admin-card">
        <h4 style="font-size:13px; font-weight:600; color:#fff; margin:0 0 18px; display:flex; align-items:center; gap:8px;">
            <svg style="width:15px;height:15px;color:#F59E0B;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            Tambah Alat Baru
        </h4>
        <div style="display:flex; flex-direction:column; gap:14px;">
            <div style="display:grid; grid-template-columns:1fr 80px; gap:14px;">
                <div><label class="admin-label">Nama Alat *</label><input id="t-name" type="text" class="admin-input" placeholder="Contoh: Kunci Torsi"></div>
                <div><label class="admin-label">Ikon</label><input id="t-icon" type="text" class="admin-input" placeholder="🔧" style="font-size:20px;"></div>
            </div>
            <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:14px;">
                <div><label class="admin-label">Kategori</label><select id="t-cat" class="admin-select"><option value="k3">Alat K3</option><option value="teknis">Alat Teknis</option><option value="pengukuran">Pengukuran</option></select></div>
                <div><label class="admin-label">Standar</label><input id="t-standard" type="text" class="admin-input" placeholder="SNI / IEC / ISO"></div>
                <div><label class="admin-label">Status</label><select id="t-status" class="admin-select"><option>Wajib</option><option>Situasional</option></select></div>
            </div>
            <div><label class="admin-label">Deskripsi</label><textarea id="t-desc" class="admin-input" rows="3" placeholder="Jelaskan fungsi alat..." style="resize:vertical;"></textarea></div>
            <div>
                <label class="admin-label">Prosedur Penggunaan</label>
                <div id="proc-container" style="display:flex; flex-direction:column; gap:8px; margin-bottom:8px;">
                    <div style="display:grid; grid-template-columns:24px 1fr 32px; gap:8px; align-items:center;">
                        <span style="font-size:11px; font-weight:700; color:rgba(255,255,255,0.3); text-align:center;">1</span>
                        <input type="text" class="admin-input" placeholder="Langkah prosedur..." style="padding:9px 12px; font-size:12px;">
                        <button type="button" onclick="if(document.getElementById('proc-container').children.length>1) this.parentElement.remove()" class="btn-danger" style="width:32px; height:32px; display:flex; align-items:center; justify-content:center; font-size:16px;">×</button>
                    </div>
                </div>
                <button type="button" onclick="addProcRow('proc-container')" style="font-size:12px; color:rgba(255,255,255,0.4); border:none; background:none; cursor:pointer; font-family:inherit; display:flex; align-items:center; gap:6px;">
                    <span style="font-size:16px; color:#F59E0B;">+</span> Tambah Langkah
                </button>
            </div>
            <div style="display:flex; gap:10px;">
                <button class="btn-primary" onclick="submitTools()">Simpan Alat</button>
                <button class="btn-secondary" onclick="resetForm('t')">Reset</button>
            </div>
        </div>
    </div>
</div>
<script src="/js/admin/tools-admin.js"></script>
