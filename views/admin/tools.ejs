<!-- views/admin/tools.ejs — Admin Redesign -->
<link rel="stylesheet" href="/css/upload-card.css">
<style>
  #add-tool-modal:not(.active),
  #edit-modal:not(.active) {
    display: none !important;
  }
  #add-tool-modal.active,
  #edit-modal.active {
    display: flex !important;
  }
  #add-tool-modal .rd-modal {
    position: relative;
    isolation: isolate;
  }
  #add-tool-modal .rd-modal-body {
    position: relative;
    z-index: 2;
    overflow-y: auto;
    overscroll-behavior: contain;
  }
  #add-tool-modal .rd-step-panel.active,
  #add-tool-modal .rd-section-block,
  #tools-cards,
  #tools-cards .upload-card {
    width: 100%;
    min-width: 0;
  }
  #tools-cards .upload-card-body > div > div[style*="grid-template-columns:1fr 1fr"] > div {
    min-width: 0;
  }
  #add-tool-modal input,
  #add-tool-modal select,
  #add-tool-modal textarea,
  #add-tool-modal button,
  #add-tool-modal .file-drop-zone {
    position: relative;
    z-index: 3;
    pointer-events: auto;
  }
  #add-tool-modal .t-image-preview-container > div {
    pointer-events: none;
  }
  #add-tool-modal .t-image-preview-container:hover > div {
    opacity: 1 !important;
    pointer-events: auto;
  }
  #add-tool-modal .card-model-viewer-container model-viewer {
    pointer-events: auto;
  }
  @media (max-width: 760px) {
    #tools-cards .upload-card-body > div > div[style*="grid-template-columns:1fr 1fr"] {
      grid-template-columns: 1fr !important;
    }
  }
</style>

<!-- ======================== PAGE HEAD ======================== -->
<div class="rd-page-head">
  <div class="rd-page-title-block">
    <span class="rd-page-eyebrow">Manajemen Komponen</span>
    <h1 class="rd-page-title">Peralatan</h1>
    <p class="rd-page-subtitle">Kelola katalog peralatan kerja, K3, dan instrumen pengukuran.</p>
  </div>
  <div class="rd-page-actions">
    <button class="rd-btn rd-btn-secondary" onclick="showToast('Export fitur akan segera tersedia.','info')">
      <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
      Export
    </button>
    <button class="rd-btn rd-btn-primary" onclick="openAddToolModal()">
      <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      Tambah Peralatan
    </button>
  </div>
</div>

<!-- ======================== TOOLBAR ======================== -->
<div class="rd-toolbar">
  <div class="rd-search">
    <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    <input id="search-saved-tools" placeholder="Cari peralatan..." />
  </div>
  <div class="rd-divider-v"></div>
  <div class="rd-dropdown" id="tool-cat-dd">
    <button type="button" class="rd-dropdown-btn" onclick="toggleAdminDropdown('tool-cat-dd')">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="opacity:.5;flex-shrink:0;"><path d="M3 6h18M6 12h12M10 18h4"/></svg>
      <span id="tool-cat-label">Semua</span>
      <svg class="rd-dropdown-chev" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
    </button>
    <div class="rd-dropdown-menu">
      <div class="rd-dropdown-item selected" data-cat-id="" onclick="setToolFilter('','Semua')">Semua</div>
      <div id="tool-cat-dd-items"></div>
    </div>
  </div>
</div>

<!-- ======================== LIST ======================== -->
<div class="rd-data-card rd-data-card--tool">
  <div class="rd-table-head" id="t-table-head">
    <div style="width:36px;flex-shrink:0;"></div>
    <div style="flex:1;">Peralatan</div>
    <div style="width:130px;">Kategori</div>
    <div style="width:110px;text-align:center;">Standar</div>
    <div style="width:100px;text-align:center;">Status</div>
    <div style="width:80px;text-align:center;">3D</div>
    <div style="width:130px;text-align:center;">Aksi</div>
  </div>
  <div id="tools-saved"></div>
</div>

<!-- ======================== ADD MODAL ======================== -->
<div id="add-tool-modal" class="rd-modal-overlay" onclick="if(event.target===this)closeAddToolModal()">
  <div class="rd-modal" style="max-width:920px;width:min(920px,calc(100vw - 48px));">

    <div class="rd-modal-header">
      <div class="rd-modal-title-block">
        <div class="rd-modal-eyebrow">Tambah Baru · Peralatan</div>
        <h2 class="rd-modal-title">Buat Peralatan Baru</h2>
      </div>
      <button class="rd-modal-close" onclick="closeAddToolModal()">
        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>

    <!-- Stepper -->
    <div class="rd-stepper" id="add-t-stepper">
      <div class="rd-step active" data-step="0" onclick="goAddTStep(0)">
        <div class="step-num">1</div>
        <div class="step-info"><span class="step-label">Informasi</span><span class="step-name">Detail peralatan</span></div>
      </div>
      <div class="rd-step" data-step="1" onclick="goAddTStep(1)">
        <div class="step-num">2</div>
        <div class="step-info"><span class="step-label">Review</span><span class="step-name">Konfirmasi</span></div>
      </div>
    </div>

    <div class="rd-modal-body">

      <!-- Step 1: Info -->
      <div class="rd-step-panel active" id="add-t-panel-0">
        <div class="rd-section-block">
          <div class="rd-section-head"><div class="rd-section-title"><span class="num">1</span> Informasi Peralatan</div></div>
          <!-- tools-cards renders individual cards including info fields when initToolsCard is called -->
          <!-- We put the cards container here so addToolsCard() works, first card auto-added on DOMContentLoaded -->
          <div id="tools-cards" style="display:flex;flex-direction:column;gap:12px;"></div>
          <button class="rd-btn rd-btn-ghost" style="border:1px dashed var(--border-strong);width:100%;justify-content:center;padding:12px;border-radius:var(--radius-md);margin-top:4px;" onclick="addToolsCard()">
            <svg width="15" height="15" fill="none" stroke="currentColor" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Tambah Peralatan Lagi
          </button>
        </div>
      </div>

      <!-- Step 2: Review -->
      <div class="rd-step-panel" id="add-t-panel-1">
        <div class="rd-section-block">
          <div class="rd-section-head">
            <div>
              <div class="rd-section-title"><span class="num">2</span> Review &amp; Konfirmasi</div>
              <p class="rd-section-desc">Periksa kembali semua data peralatan sebelum menyimpan.</p>
            </div>
          </div>
          <div class="rd-review-grid" style="margin-top:14px;">
            <div class="rd-review-tile full"><div class="label">Jumlah Peralatan</div><div class="value" id="review-t-count">-</div></div>
          </div>
          <div id="review-t-items" style="display:flex;flex-direction:column;gap:12px;margin-top:14px;"></div>
        </div>
      </div>

    </div>

    <div class="rd-modal-footer">
      <div class="rd-footer-meta">
        <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
        <span id="add-t-footer-info">Step 1 dari 3 · Detail peralatan</span>
      </div>
      <div class="rd-footer-actions">
        <button class="rd-btn rd-btn-ghost" onclick="closeAddToolModal()">Batal</button>
        <button id="add-t-prev-btn" class="rd-btn rd-btn-secondary" style="display:none;" onclick="addTStepPrev()">
          <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
          Sebelumnya
        </button>
        <button id="add-t-next-btn" class="rd-btn rd-btn-primary" onclick="addTStepNext()">
          Lanjutkan <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </button>
      </div>
    </div>

  </div>
</div>

<%- include('../partials/edit-modal-tools') %>

<script src="/js/admin/upload-card.js"></script>
<script src="/js/admin/tools-admin.js"></script>
<script>
/* Add tool wizard */
let _addTStep = 0;
const _addTSteps = [{ label: 'Detail peralatan' }, { label: 'Konfirmasi' }];

function openAddToolModal() {
  _addTStep = 0; renderAddTStep();
  document.getElementById('add-tool-modal').classList.add('active');
}
function closeAddToolModal() { document.getElementById('add-tool-modal').classList.remove('active'); }
function renderAddTStep() {
  document.querySelectorAll('#add-tool-modal .rd-step-panel').forEach((p,i) => p.classList.toggle('active', i === _addTStep));
  document.querySelectorAll('#add-t-stepper .rd-step').forEach((s,i) => {
    s.classList.toggle('active', i === _addTStep);
    s.classList.toggle('done', i < _addTStep);
    const num = s.querySelector('.step-num');
    num.innerHTML = i < _addTStep ? '<svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>' : (i+1);
  });
  document.getElementById('add-t-prev-btn').style.display = _addTStep > 0 ? '' : 'none';
  const nextBtn = document.getElementById('add-t-next-btn');
  if (_addTStep === _addTSteps.length - 1) {
    nextBtn.innerHTML = '<svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg> Simpan Peralatan';
    nextBtn.onclick = () => submitSemuaTools();
  } else {
    nextBtn.innerHTML = 'Lanjutkan <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>';
    nextBtn.onclick = addTStepNext;
  }
  document.getElementById('add-t-footer-info').textContent = `Step ${_addTStep+1} dari ${_addTSteps.length} - ${_addTSteps[_addTStep].label}`;
  if (_addTStep === _addTSteps.length - 1) {
    renderToolReview();
  }
}
function goAddTStep(i) { _addTStep = i; renderAddTStep(); }
function addTStepNext() { if (_addTStep < _addTSteps.length - 1) { _addTStep++; renderAddTStep(); } }
function addTStepPrev() { if (_addTStep > 0) { _addTStep--; renderAddTStep(); } }

function escapeReviewText(value) {
  return String(value || '').replace(/[&<>"']/g, char => ({
    '&': '&amp;',
    '<': '&lt;',
    '>': '&gt;',
    '"': '&quot;',
    "'": '&#039;'
  }[char]));
}

function renderToolReview() {
  const cards = Array.from(document.querySelectorAll('#tools-cards .upload-card'));
  const countEl = document.getElementById('review-t-count');
  const itemsEl = document.getElementById('review-t-items');
  if (!countEl || !itemsEl) return;

  if (renderToolReview._objectUrls) {
    renderToolReview._objectUrls.forEach(u => URL.revokeObjectURL(u));
  }
  renderToolReview._objectUrls = [];

  countEl.textContent = `${cards.length} peralatan`;

  if (cards.length === 0) {
    itemsEl.innerHTML = '<div class="rd-review-tile"><div class="value" style="font-size:13px;color:var(--text-secondary);">Belum ada data peralatan.</div></div>';
    return;
  }

  itemsEl.innerHTML = cards.map((card, index) => {
    const name = card.querySelector('.t-name')?.value.trim() || '-';
    const standard = card.querySelector('.t-standard')?.value.trim() || '-';
    const catEl = card.querySelector('.t-cat');
    const category = catEl ? catEl.options[catEl.selectedIndex].text : '-';
    const status = card.querySelector('.t-status')?.value || '-';
    const description = card.querySelector('.t-desc')?.value.trim() || '-';

    return `
      <div class="rd-review-tile full" style="display:grid;grid-template-columns:1fr 1fr;gap:12px;" data-review-idx="${index}">
        <div style="grid-column:1 / -1;display:flex;align-items:center;justify-content:space-between;gap:12px;border-bottom:1px solid var(--border-default);padding-bottom:10px;">
          <div>
            <div class="label">Peralatan #${index + 1}</div>
            <div class="value">${escapeReviewText(name)}</div>
          </div>
          <span class="rd-badge rd-badge-warning">${escapeReviewText(status)}</span>
        </div>
        <div><div class="label">Kategori</div><div class="value">${escapeReviewText(category)}</div></div>
        <div><div class="label">Standar</div><div class="value rd-mono">${escapeReviewText(standard)}</div></div>
        <div style="grid-column:1 / -1;"><div class="label">Deskripsi</div><div class="value" style="font-size:13px;font-weight:400;color:var(--text-secondary);line-height:1.55;">${escapeReviewText(description)}</div></div>
        <div>
          <div class="label">Cover Gambar</div>
          <div id="review-t-img-wrap-${index}" style="margin-top:8px;border-radius:8px;overflow:hidden;border:1px solid var(--border-default);aspect-ratio:16/9;display:flex;align-items:center;justify-content:center;background:var(--bg-base);">
            <img id="review-t-img-${index}" src="" style="width:100%;height:100%;object-fit:cover;display:none;" />
            <span id="review-t-img-empty-${index}" style="font-size:12px;color:var(--text-muted);display:flex;align-items:center;gap:6px;">
              <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
              Tidak ada cover
            </span>
          </div>
        </div>
        <div>
          <div class="label">Preview 3D</div>
          <div id="review-t-3d-wrap-${index}" style="margin-top:8px;border-radius:8px;overflow:hidden;border:1px solid var(--border-default);aspect-ratio:16/9;display:flex;align-items:center;justify-content:center;background:radial-gradient(circle at center,#0F1E3A 0%,#030812 100%);position:relative;">
            <span id="review-t-3d-empty-${index}" style="font-size:12px;color:var(--text-muted);display:flex;align-items:center;gap:6px;">
              <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/></svg>
              Tidak ada 3D
            </span>
          </div>
        </div>
      </div>
    `;
  }).join('');

  // Populate image & 3D previews after HTML is rendered
  cards.forEach((card, index) => {
    // Image preview — use existing data URL from card's preview img
    const previewContainer = card.querySelector('.t-image-preview-container');
    const imageVisible = previewContainer && previewContainer.style.display !== 'none';
    if (imageVisible) {
      const imageSrc = card.querySelector('.t-image-preview-img')?.getAttribute('src');
      if (imageSrc) {
        const reviewImg = document.getElementById(`review-t-img-${index}`);
        const reviewImgEmpty = document.getElementById(`review-t-img-empty-${index}`);
        if (reviewImg) { reviewImg.src = imageSrc; reviewImg.style.display = 'block'; }
        if (reviewImgEmpty) reviewImgEmpty.style.display = 'none';
      }
    }

    // 3D preview — create object URL from file input
    const fileInput = card.querySelector('.t-file-3d');
    const modelFile = fileInput && (fileInput._confirmedFile || (fileInput.files && fileInput.files[0]));
    if (modelFile) {
      const url = URL.createObjectURL(modelFile);
      renderToolReview._objectUrls.push(url);
      const wrap = document.getElementById(`review-t-3d-wrap-${index}`);
      const empty = document.getElementById(`review-t-3d-empty-${index}`);
      if (wrap) {
        const mv = document.createElement('model-viewer');
        mv.setAttribute('src', url);
        mv.setAttribute('auto-rotate', '');
        mv.setAttribute('camera-controls', '');
        mv.setAttribute('interaction-prompt', 'none');
        mv.style.cssText = 'width:100%;height:100%;display:block;';
        wrap.insertBefore(mv, empty);
        if (empty) empty.style.display = 'none';
        if (mv.dismissPoster) mv.dismissPoster();
      }
    }
  });
}

/* Filter & view */
function setToolFilter(categoryId, label) {
  // Update dropdown label
  const labelEl = document.getElementById('tool-cat-label');
  if (labelEl) labelEl.textContent = label || 'Semua';
  // Update selected state using data attributes
  document.querySelectorAll('#tool-cat-dd .rd-dropdown-item').forEach(el => {
    const id = el.dataset.catId || '';
    el.classList.toggle('selected', id === (categoryId || ''));
  });
  // Close dropdown
  document.getElementById('tool-cat-dd')?.classList.remove('open');
  loadToolsSaved(categoryId);
}
function setToolView(view) {
  const saved = document.getElementById('tools-saved');
  const head = document.getElementById('t-table-head');
  document.getElementById('t-view-table').classList.toggle('active', view === 'table');
  document.getElementById('t-view-grid').classList.toggle('active', view === 'grid');
  saved.classList.toggle('grid-view', view === 'grid');
  if (head) head.style.display = view === 'grid' ? 'none' : '';
}

document.addEventListener('DOMContentLoaded', () => {
  if (new URLSearchParams(location.search).get('openAdd')) openAddToolModal();
});
</script>
