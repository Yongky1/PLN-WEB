<!-- views/admin/material.ejs — Admin Redesign -->
<link rel="stylesheet" href="/css/upload-card.css">

<!-- ======================== PAGE HEAD ======================== -->
<div class="rd-page-head">
  <div class="rd-page-title-block">
    <span class="rd-page-eyebrow">Manajemen Komponen</span>
    <h1 class="rd-page-title">Material</h1>
    <p class="rd-page-subtitle">Kelola katalog material dengan kategori, kode, dan varian model 3D.</p>
  </div>
  <div class="rd-page-actions">
    <button class="rd-btn rd-btn-secondary" onclick="showToast('Export fitur akan segera tersedia.','info')">
      <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
      Export
    </button>
    <button class="rd-btn rd-btn-primary" onclick="openAddMatModal()">
      <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      Tambah Material
    </button>
  </div>
</div>

<div class="rd-toolbar">
  <div class="rd-search">
    <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    <input id="search-saved-material" placeholder="Cari material..." />
  </div>
  <div class="rd-divider-v"></div>
  <div class="rd-dropdown" id="mat-cat-dd">
    <button type="button" class="rd-dropdown-btn" onclick="toggleAdminDropdown('mat-cat-dd')">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="opacity:.5;flex-shrink:0;"><path d="M3 6h18M6 12h12M10 18h4"/></svg>
      <span id="mat-cat-label">Semua</span>
      <svg class="rd-dropdown-chev" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
    </button>
    <div class="rd-dropdown-menu">
      <div class="rd-dropdown-item selected" data-cat-id="" onclick="setMatFilter('','Semua')">Semua</div>
      <div id="mat-cat-dd-items"></div>
    </div>
  </div>
</div>

<!-- ======================== LIST ======================== -->
<div class="rd-data-card rd-data-card--material">
  <div class="rd-table-head" id="m-table-head">
    <div style="width:36px;flex-shrink:0;"></div>
    <div style="flex:1;">Material</div>
    <div style="width:140px;">Kategori</div>
    <div style="width:100px;text-align:center;">Varian</div>
    <div style="width:130px;text-align:center;">Aksi</div>
  </div>
  <div id="material-saved"></div>
</div>

<!-- ======================== ADD MODAL ======================== -->
<div id="add-material-modal" class="rd-modal-overlay" onclick="if(event.target===this)closeAddMatModal()">
  <div class="rd-modal">

    <div class="rd-modal-header">
      <div class="rd-modal-title-block">
        <div class="rd-modal-eyebrow">Tambah Baru · Material</div>
        <h2 class="rd-modal-title">Buat Material Baru</h2>
      </div>
      <button class="rd-modal-close" onclick="closeAddMatModal()">
        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>

    <!-- Stepper -->
    <div class="rd-stepper" id="add-m-stepper">
      <div class="rd-step active" data-step="0" onclick="goAddMStep(0)">
        <div class="step-num">1</div>
        <div class="step-info"><span class="step-label">Informasi</span><span class="step-name">Detail material</span></div>
      </div>
      <div class="rd-step" data-step="1" onclick="goAddMStep(1)">
        <div class="step-num">2</div>
        <div class="step-info"><span class="step-label">Varian 3D</span><span class="step-name">Upload model</span></div>
      </div>
      <div class="rd-step" data-step="2" onclick="goAddMStep(2)">
        <div class="step-num">3</div>
        <div class="step-info"><span class="step-label">Review</span><span class="step-name">Konfirmasi</span></div>
      </div>
    </div>

    <div class="rd-modal-body">

      <!-- Step 1: Info -->
      <div class="rd-step-panel active" id="add-m-panel-0">
        <div class="rd-section-block">
          <div class="rd-section-head"><div class="rd-section-title"><span class="num">1</span> Informasi Material</div></div>
          <div class="rd-field-row cols-2">
            <div class="rd-field-group">
              <label class="rd-field-label">Nama Material <span class="req">*</span></label>
              <input type="text" id="mat-modul-name" class="rd-input" placeholder="Contoh: Baut HDG M16" />
            </div>
            <div class="rd-field-group">
              <label class="rd-field-label">Kode / Standar <span class="req">*</span></label>
              <input type="text" id="mat-modul-code" class="rd-input rd-mono" placeholder="MAT-101" />
            </div>
          </div>
          <div class="rd-field-group">
            <label class="rd-field-label">Kategori</label>
            <select id="mat-modul-cat" class="rd-select" style="max-width:60%;">
              <option value="">Memuat kategori...</option>
            </select>
          </div>
          <div class="rd-field-group">
            <label class="rd-field-label" style="justify-content:space-between;">
              Deskripsi
              <span class="rd-field-counter" id="add-desc-char-count">0/2000</span>
            </label>
            <textarea id="mat-modul-desc" class="rd-textarea" maxlength="2000" rows="3" placeholder="Spesifikasi singkat material..." oninput="document.getElementById('add-desc-char-count').textContent=this.value.length+'/2000'"></textarea>
          </div>
          <div class="rd-field-group">
            <label class="rd-field-label">Cover Gambar (Opsional)</label>
            <div id="mat-modul-image-drop-zone" class="rd-drop-zone" onclick="document.getElementById('mat-modul-image').click()">
              <div class="dz-icon"><svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg></div>
              <div class="dz-text">
                <div id="mat-add-img-empty"><div class="dz-title">Tarik &amp; lepas atau klik</div><div class="dz-sub">PNG · JPG · WEBP · maks 5MB</div></div>
                <div id="mat-add-img-filled" style="display:none;"><div class="dz-title" style="color:var(--accent);">Thumbnail terpasang</div><div class="dz-sub">Klik untuk ganti</div></div>
              </div>
              <button class="rd-btn rd-btn-secondary rd-btn-sm" onclick="event.stopPropagation();document.getElementById('mat-modul-image').click()">Pilih file</button>
            </div>
            <input type="file" id="mat-modul-image" accept="image/png,image/jpeg,image/webp" style="display:none" onchange="
              if(this.files&&this.files[0]){const reader=new FileReader();reader.onload=function(e){document.getElementById('mat-modul-image-preview-container').style.display='block';document.getElementById('mat-modul-image-preview-img').src=e.target.result;document.getElementById('mat-add-img-empty').style.display='none';document.getElementById('mat-add-img-filled').style.display='block';document.getElementById('mat-modul-image-drop-zone').classList.add('has-file');};reader.readAsDataURL(this.files[0]);}
            " />
            <div id="mat-modul-image-preview-container" style="display:none;margin-top:10px;border-radius:8px;overflow:hidden;border:1px solid var(--border-default);aspect-ratio:16/9;max-height:200px;position:relative;">
              <img id="mat-modul-image-preview-img" src="" style="width:100%;height:100%;object-fit:cover;" />
              <div style="position:absolute;inset:0;background:rgba(0,0,0,0.5);display:flex;align-items:center;justify-content:center;gap:8px;opacity:0;transition:opacity .2s" onmouseover="this.style.opacity=1" onmouseout="this.style.opacity=0">
                <button class="rd-btn rd-btn-secondary rd-btn-sm" onclick="document.getElementById('mat-modul-image').click()">Ganti Foto</button>
                <button class="rd-btn rd-btn-danger rd-btn-sm" onclick="document.getElementById('mat-modul-image').value='';document.getElementById('mat-modul-image-preview-img').src='';document.getElementById('mat-modul-image-preview-container').style.display='none';document.getElementById('mat-add-img-empty').style.display='block';document.getElementById('mat-add-img-filled').style.display='none';document.getElementById('mat-modul-image-drop-zone').classList.remove('has-file');">Hapus</button>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Step 2: Varian 3D -->
      <div class="rd-step-panel" id="add-m-panel-1">
        <div class="rd-section-block">
          <div class="rd-section-head">
            <div>
              <div class="rd-section-title"><span class="num">2</span> Varian Model 3D</div>
              <p class="rd-section-desc">Upload varian 3D untuk material ini.</p>
            </div>
          </div>
          <div id="material-cards" style="display:flex;flex-direction:column;gap:12px;"></div>
          <button class="rd-btn rd-btn-ghost" style="border:1px dashed var(--border-strong);width:100%;justify-content:center;padding:12px;border-radius:var(--radius-md);margin-top:4px;" onclick="addMaterialCard()">
            <svg width="15" height="15" fill="none" stroke="currentColor" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Tambah varian baru
          </button>
        </div>
      </div>

      <!-- Step 3: Review -->
      <div class="rd-step-panel" id="add-m-panel-2">
        <div class="rd-section-block">
          <div class="rd-section-head">
            <div>
              <div class="rd-section-title"><span class="num">3</span> Review &amp; Konfirmasi</div>
              <p class="rd-section-desc">Periksa kembali sebelum menyimpan.</p>
            </div>
            <span class="rd-badge rd-badge-success">Siap disimpan</span>
          </div>
          <div class="rd-review-grid">
            <div class="rd-review-tile full"><div class="label">Nama Material</div><div class="value" id="review-m-name">—</div></div>
            <div class="rd-review-tile"><div class="label">Kode</div><div class="value rd-mono" id="review-m-code">—</div></div>
            <div class="rd-review-tile"><div class="label">Kategori</div><div class="value" id="review-m-cat">—</div></div>
            <div class="rd-review-tile"><div class="label">Jumlah Varian</div><div class="value" id="review-m-variants">—</div></div>
          </div>
          <div class="rd-review-previews" style="display:grid; grid-template-columns:1fr 1fr; gap:14px; margin-top:14px;">
            <div class="rd-review-tile" style="padding:10px;">
              <div class="label">Cover Gambar</div>
              <div id="review-m-image-container" style="margin-top:8px; border-radius:8px; overflow:hidden; border:1px solid var(--border-default); aspect-ratio:16/9; display:flex; align-items:center; justify-content:center; background:var(--bg-base);">
                <img id="review-m-image" src="" style="width:100%; height:100%; object-fit:cover; display:none;" />
                <span id="review-m-image-empty" class="rd-muted" style="font-size:12px; display:flex; align-items:center; gap:6px;">
                  <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                  Tidak ada cover
                </span>
              </div>
            </div>
            <div class="rd-review-tile" style="padding:10px;">
              <div class="label">Preview 3D (Varian Pertama)</div>
              <div id="review-m-3d-container" style="margin-top:8px; border-radius:8px; overflow:hidden; border:1px solid var(--border-default); aspect-ratio:16/9; display:flex; align-items:center; justify-content:center; background:var(--bg-base); position:relative;">
                <model-viewer id="review-m-3d" src="" auto-rotate camera-controls interaction-prompt="none" style="width:100%; height:100%; display:none; background: radial-gradient(circle at center, #0F1E3A 0%, #030812 100%);"></model-viewer>
                <span id="review-m-3d-empty" class="rd-muted" style="font-size:12px; display:flex; align-items:center; gap:6px;">
                  <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/></svg>
                  Tidak ada 3D Varian
                </span>
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>

    <div class="rd-modal-footer">
      <div class="rd-footer-meta">
        <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
        <span id="add-m-footer-info">Step 1 dari 3 · Detail material</span>
      </div>
      <div class="rd-footer-actions">
        <button class="rd-btn rd-btn-ghost" onclick="closeAddMatModal()">Batal</button>
        <button id="add-m-prev-btn" class="rd-btn rd-btn-secondary" style="display:none;" onclick="addMStepPrev()">
          <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
          Sebelumnya
        </button>
        <button id="add-m-next-btn" class="rd-btn rd-btn-primary" onclick="addMStepNext()">
          Lanjutkan <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </button>
      </div>
    </div>

  </div>
</div>

<%- include('../partials/edit-modal-material') %>

<script src="/js/admin/upload-card.js"></script>
<script src="/js/admin/material-admin.js"></script>
<script>
/* Wizard for material add */
let _addMStep = 0;
const _addMSteps = [{ label: 'Detail material' }, { label: 'Upload model' }, { label: 'Konfirmasi' }];

function openAddMatModal() {
  _addMStep = 0; renderAddMStep();
  document.getElementById('add-material-modal').classList.add('active');
}
function closeAddMatModal() {
  document.getElementById('add-material-modal').classList.remove('active');
  if (typeof resetMaterialForm === 'function') resetMaterialForm();
  _addMStep = 0;
  renderAddMStep();
}
function renderAddMStep() {
  document.querySelectorAll('#add-material-modal .rd-step-panel').forEach((p,i) => p.classList.toggle('active', i === _addMStep));
  document.querySelectorAll('#add-m-stepper .rd-step').forEach((s,i) => {
    s.classList.toggle('active', i === _addMStep);
    s.classList.toggle('done', i < _addMStep);
    const num = s.querySelector('.step-num');
    num.innerHTML = i < _addMStep ? '<svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>' : (i+1);
  });
  document.getElementById('add-m-prev-btn').style.display = _addMStep > 0 ? '' : 'none';
  const nextBtn = document.getElementById('add-m-next-btn');
  if (_addMStep === _addMSteps.length - 1) {
    nextBtn.innerHTML = '<svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg> Simpan Material';
    nextBtn.onclick = () => submitSemuaMaterial();
  } else {
    nextBtn.innerHTML = 'Lanjutkan <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>';
    nextBtn.onclick = addMStepNext;
  }
  document.getElementById('add-m-footer-info').textContent = `Step ${_addMStep+1} dari ${_addMSteps.length} · ${_addMSteps[_addMStep].label}`;
  if (_addMStep === 2) {
    document.getElementById('review-m-name').textContent = document.getElementById('mat-modul-name')?.value || '—';
    document.getElementById('review-m-code').textContent = document.getElementById('mat-modul-code')?.value || '—';
    document.getElementById('review-m-cat').textContent = document.getElementById('mat-modul-cat')?.value || '—';
    const cards = document.querySelectorAll('#material-cards .upload-card');
    document.getElementById('review-m-variants').textContent = cards.length + ' varian';

    // Preview Cover Image
    const coverImgInput = document.getElementById('mat-modul-image');
    const reviewImg = document.getElementById('review-m-image');
    const reviewImgEmpty = document.getElementById('review-m-image-empty');
    if (coverImgInput && coverImgInput.files && coverImgInput.files.length > 0) {
      reviewImg.src = URL.createObjectURL(coverImgInput.files[0]);
      reviewImg.style.display = 'block';
      reviewImgEmpty.style.display = 'none';
    } else {
      reviewImg.src = '';
      reviewImg.style.display = 'none';
      reviewImgEmpty.style.display = 'flex';
    }

    // Preview 3D
    const review3d = document.getElementById('review-m-3d');
    const review3dEmpty = document.getElementById('review-m-3d-empty');
    let found3d = false;
    
    if (review3d._objectUrl) {
      URL.revokeObjectURL(review3d._objectUrl);
      review3d._objectUrl = null;
    }

    for (let i = 0; i < cards.length; i++) {
      const fileInput = cards[i].querySelector('.m-file-3d');
      const selectedFile = fileInput && (fileInput._confirmedFile || (fileInput.files && fileInput.files[0]));
      if (selectedFile) {
        const url = URL.createObjectURL(selectedFile);
        review3d._objectUrl = url;
        review3d.src = url;
        review3d.style.display = 'block';
        review3dEmpty.style.display = 'none';
        if(review3d.dismissPoster) review3d.dismissPoster();
        found3d = true;
        break;
      }
    }

    if (!found3d) {
      review3d.removeAttribute('src');
      review3d.style.display = 'none';
      review3dEmpty.style.display = 'flex';
    }
  }
}
function goAddMStep(i) { _addMStep = i; renderAddMStep(); }
function addMStepNext() { if (_addMStep < _addMSteps.length - 1) { _addMStep++; renderAddMStep(); } }
function addMStepPrev() { if (_addMStep > 0) { _addMStep--; renderAddMStep(); } }

/* Filter & view */
function setMatFilter(categoryId, label) {
  // Update dropdown label
  const labelEl = document.getElementById('mat-cat-label');
  if (labelEl) labelEl.textContent = label || 'Semua';
  // Update selected state using data attributes
  document.querySelectorAll('#mat-cat-dd .rd-dropdown-item').forEach(el => {
    const id = el.dataset.catId || '';
    el.classList.toggle('selected', id === (categoryId || ''));
  });
  // Close dropdown
  document.getElementById('mat-cat-dd')?.classList.remove('open');
  loadMaterialSaved(categoryId);
}
function setMatView(view) {
  const saved = document.getElementById('material-saved');
  const head = document.getElementById('m-table-head');
  document.getElementById('m-view-table').classList.toggle('active', view === 'table');
  document.getElementById('m-view-grid').classList.toggle('active', view === 'grid');
  saved.classList.toggle('grid-view', view === 'grid');
  if (head) head.style.display = view === 'grid' ? 'none' : '';
}

/* Image Drag and Drop Initialization */
function initImageDropZone(dropZoneId, inputId) {
  const zone = document.getElementById(dropZoneId);
  const input = document.getElementById(inputId);
  if (!zone || !input) return;

  zone.addEventListener('dragover', (e) => {
    e.preventDefault();
    zone.classList.add('dragover');
  });
  zone.addEventListener('dragleave', (e) => {
    e.preventDefault();
    zone.classList.remove('dragover');
  });
  zone.addEventListener('drop', (e) => {
    e.preventDefault();
    zone.classList.remove('dragover');
    if (e.dataTransfer.files && e.dataTransfer.files.length > 0) {
      const file = e.dataTransfer.files[0];
      if (file.type.startsWith('image/')) {
        const dt = new DataTransfer();
        dt.items.add(file);
        input.files = dt.files;
        input.dispatchEvent(new Event('change'));
      } else {
        if (typeof showToast === 'function') showToast('Format file harus gambar', 'error');
      }
    }
  });
}

document.addEventListener('DOMContentLoaded', () => {
  initImageDropZone('mat-modul-image-drop-zone', 'mat-modul-image');
  initImageDropZone('edit-mat-modul-image-drop-zone', 'edit-mat-modul-image');

  if (new URLSearchParams(location.search).get('openAdd')) openAddMatModal();
});
</script>
