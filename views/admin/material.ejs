<!-- views/admin/material.ejs -->
<link rel="stylesheet" href="/css/upload-card.css">
<style>
    :root { --m-accent: #818CF8; --m-accent-raw: 129,140,248; }

    #material-saved { display: flex; flex-direction: column; gap: 8px; max-height: 520px; overflow-y: auto; padding-right: 4px; }

    #material-cards .upload-card-header { background: rgba(var(--m-accent-raw), 0.04); }
    #material-cards .file-drop-zone { --zone-color: rgba(var(--m-accent-raw), 0.5); --zone-bg: rgba(var(--m-accent-raw), 0.04); }
    #material-cards .add-card-btn  { border: 2px dashed rgba(var(--m-accent-raw), 0.3); color: var(--m-accent); }
    #material-cards .add-card-btn:hover { background: rgba(var(--m-accent-raw), 0.06); border-color: rgba(var(--m-accent-raw), 0.55); }
</style>

<!-- Header -->
<div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:24px;">
    <div>
        <h3 style="font-size:16px; font-weight:700; color:#fff; margin:0;">Manajemen Material</h3>
        <p style="font-size:12px; color:rgba(255,255,255,0.35); margin:4px 0 0;">Tambah dan kelola katalog material jaringan</p>
    </div>
    <span style="font-size:11px; font-weight:600; padding:4px 12px; border-radius:999px; background:rgba(129,140,248,0.12); color:#818CF8; border:1px solid rgba(129,140,248,0.3);">Material</span>
</div>

<!-- Split Layout -->
<div style="display: flex; gap: 20px; align-items: flex-start; flex-wrap: wrap;">

    <!-- ===== KOLOM KIRI – LIST DATA TERSIMPAN ===== -->
    <div style="flex: 1 1 0; min-width: 0;">
        <div class="admin-card" style="height:100%;">
            <h4 class="section-title" style="margin: 0 0 14px; display:flex; align-items:center; gap:8px;">
                <svg style="width:14px;height:14px;color:#818CF8;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"/></svg>
                Data Tersimpan
            </h4>
            <!-- Search Saved Data -->
            <div style="margin-bottom: 12px; position: relative;">
                <input type="text" id="search-saved-material" class="admin-input" placeholder="Cari material..." 
                    style="font-size: 11px; padding: 6px 10px 6px 30px; height: 32px;">
                <svg style="width: 12px; height: 12px; position: absolute; left: 10px; top: 50%; transform: translateY(-50%); color: rgba(255,255,255,0.3);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                </svg>
            </div>
            <div id="material-saved"></div>
        </div>
    </div>

    <!-- ===== KOLOM KANAN – FORM TAMBAH ===== -->
    <div style="flex: 1 1 0; min-width: 0;">
        <div class="admin-card">
            <h4 style="font-size:13px; font-weight:600; color:#fff; margin:0 0 16px; display:flex; align-items:center; gap:8px;">
                <svg style="width:14px;height:14px;color:#818CF8;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                Tambah Material Baru
            </h4>

            <!-- Info Utama -->
            <div style="display:flex; flex-direction:column; gap:12px; margin-bottom:16px; padding-bottom:16px; border-bottom:1px solid rgba(255,255,255,0.08);">
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:10px;">
                    <div>
                        <label class="admin-label">Nama Material *</label>
                        <input type="text" id="mat-modul-name" class="admin-input" placeholder="Contoh: Baut HDG">
                    </div>
                    <div>
                        <label class="admin-label">Kode / Standar *</label>
                        <input type="text" id="mat-modul-code" class="admin-input" placeholder="Contoh: BT-HDG">
                    </div>
                </div>
                <div>
                    <label class="admin-label">Deskripsi <span id="add-desc-char-count" style="font-size:10px; color:rgba(255,255,255,0.3); font-weight:400;">0/200</span></label>
                    <textarea id="mat-modul-desc" class="admin-input" rows="2" maxlength="200" placeholder="Deskripsi material ini..." style="resize:vertical;" oninput="document.getElementById('add-desc-char-count').textContent = this.value.length + '/200'"></textarea>
                </div>
                <div>
                    <label class="admin-label">Kategori</label>
                    <select id="mat-modul-cat" class="admin-select" style="max-width:60%;">
                        <option value="Pengencang">Pengencang</option>
                        <option value="Insulasi">Insulasi</option>
                        <option value="Kabel">Kabel</option>
                        <option value="Penyangga">Penyangga</option>
                        <option value="Lainnya">Lainnya</option>
                    </select>
                </div>
                <div>
                    <label class="admin-label">Cover Gambar (Opsional)</label>
                    <div id="mat-modul-image-drop-zone" class="file-drop-zone" onclick="document.getElementById('mat-modul-image').click()" style="cursor: pointer; position: relative; overflow: hidden; padding: 20px; text-align: center; border: 1px dashed rgba(255,255,255,0.2); border-radius: 8px; background: rgba(0,0,0,0.15); transition: all 0.2s;">
                        <div id="mat-add-img-empty" style="display:flex; flex-direction:column; align-items:center; justify-content:center; height: 100%;">
                            <svg class="drop-icon" style="width:24px;height:24px;color:rgba(255,255,255,0.25); margin-bottom: 8px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                            </svg>
                            <div class="drop-label" style="font-size: 14px; color: rgba(255,255,255,0.6);">Pilih Foto Thumbnail</div>
                            <span style="font-size:11px; color:rgba(255,255,255,0.3); margin-top:4px;">PNG, JPG, WEBP • Maks. 5MB</span>
                        </div>
                        <div id="mat-add-img-filled" style="display:none; flex-direction:column; align-items:center; justify-content:center; height: 100%;">
                            <svg style="width:28px;height:28px;color:#00E5FF; margin-bottom: 8px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                            </svg>
                            <div style="font-size: 14px; color: #00E5FF; font-weight:600;">Thumbnail Terpasang</div>
                            <div style="font-size:12px; color:rgba(255,255,255,0.5); margin-top:4px;">Klik untuk ganti foto</div>
                        </div>
                    </div>

                    <input type="file" id="mat-modul-image" accept="image/png, image/jpeg, image/jpg" style="display:none;" onchange="
                        if(this.files && this.files[0]) {
                            const reader = new FileReader();
                            reader.onload = function(e) {
                                document.getElementById('mat-modul-image-preview-container').style.display = 'block';
                                document.getElementById('mat-modul-image-preview-img').src = e.target.result;
                                document.getElementById('mat-add-img-empty').style.display = 'none';
                                document.getElementById('mat-add-img-filled').style.display = 'flex';
                                document.getElementById('mat-modul-image-drop-zone').style.borderColor = 'rgba(0,229,255,0.3)';
                            };
                            reader.readAsDataURL(this.files[0]);
                        }
                    ">

                    <div id="mat-modul-image-preview-container" style="display:none; margin-top: 10px; position: relative; width: 100%; aspect-ratio: 16/9; max-height: 280px; border-radius: 8px; overflow: hidden; border: 1px solid rgba(255,255,255,0.1);">
                        <img id="mat-modul-image-preview-img" src="" style="width: 100%; height: 100%; object-fit: cover;">
                        <div style="position: absolute; inset: 0; background: rgba(0,0,0,0.5); display: flex; align-items: center; justify-content: center; opacity: 0; transition: opacity 0.2s;" onmouseover="this.style.opacity=1" onmouseout="this.style.opacity=0">
                            <div style="display: flex; gap: 10px;">
                                <button type="button" onclick="document.getElementById('mat-modul-image').click()" style="background: rgba(0, 229, 255, 0.2); border: 1px solid #00E5FF; color: #00E5FF; padding: 6px 12px; border-radius: 6px; font-size: 12px; cursor: pointer; transition: all 0.2s; font-weight:600;">Ganti Foto</button>
                                <button type="button" onclick="
                                    document.getElementById('mat-modul-image').value = '';
                                    document.getElementById('mat-modul-image-preview-img').src = '';
                                    document.getElementById('mat-modul-image-preview-container').style.display = 'none';
                                    document.getElementById('mat-add-img-empty').style.display = 'flex';
                                    document.getElementById('mat-add-img-filled').style.display = 'none';
                                    document.getElementById('mat-modul-image-drop-zone').style.borderColor = 'rgba(255,255,255,0.2)';
                                " style="background: rgba(239, 68, 68, 0.2); border: 1px solid #EF4444; color: #EF4444; padding: 6px 12px; border-radius: 6px; font-size: 12px; cursor: pointer; transition: all 0.2s; font-weight:600;">Hapus Thumbnail</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Asset 3D Cards -->
            <div style="font-size:11px; font-weight:600; color:rgba(255,255,255,0.4); margin-bottom:10px; text-transform:uppercase; letter-spacing:.08em;">Varian / Asset 3D</div>
            <div id="material-cards" style="display:flex; flex-direction:column; gap:12px; margin-bottom:12px;"></div>

            <button class="add-card-btn" onclick="addMaterialCard()" style="margin-bottom:14px; border:2px dashed rgba(129,140,248,0.3); color:#818CF8;">
                <svg style="width:14px;height:14px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                Tambah Varian
            </button>

            <div style="display:flex; gap:10px;">
                <button class="btn-primary" onclick="submitSemuaMaterial()">Simpan Semua</button>
                <button class="btn-secondary" onclick="resetMaterialForm()">Reset</button>
            </div>
        </div>
    </div>

</div>

<!-- Library Model Viewer untuk Preview Admin -->
<script type="module" src="https://ajax.googleapis.com/ajax/libs/model-viewer/3.4.0/model-viewer.min.js"></script>

<!-- MODAL EDIT -->
<div id="edit-modal" class="modal-overlay">
    <div class="modal-content" style="max-width: 900px;">
        <div class="modal-header">
            <h4 style="margin:0; font-size:16px; color:#fff;">Edit Material</h4>
            <button class="modal-close-btn" onclick="closeEditModal()">×</button>
        </div>

        <div style="display:flex; flex-direction:column; gap:12px; margin-bottom:20px; padding-bottom:20px; border-bottom:1px solid rgba(255,255,255,0.1);">
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px;">
                <div>
                    <label class="admin-label">Nama Material *</label>
                    <input type="text" id="edit-mat-modul-name" class="admin-input" placeholder="Contoh: Baut HDG">
                </div>
                <div>
                    <label class="admin-label">Kode / Standar *</label>
                    <input type="text" id="edit-mat-modul-code" class="admin-input" placeholder="Contoh: BT-HDG">
                </div>
            </div>
            <div>
                <label class="admin-label">Deskripsi <span id="desc-char-count" style="font-size:10px; color:rgba(255,255,255,0.3); font-weight:400;">0/200</span></label>
                <textarea id="edit-mat-modul-desc" class="admin-input" rows="2" maxlength="200" style="resize:vertical;" oninput="document.getElementById('desc-char-count').textContent = this.value.length + '/200'"></textarea>
            </div>
            <div>
                <label class="admin-label">Kategori</label>
                <select id="edit-mat-modul-cat" class="admin-select" style="max-width:60%;">
                    <option value="Pengencang">Pengencang</option>
                    <option value="Insulasi">Insulasi</option>
                    <option value="Kabel">Kabel</option>
                    <option value="Penyangga">Penyangga</option>
                    <option value="Lainnya">Lainnya</option>
                </select>
            </div>
            <div>
                <label class="admin-label">Cover Gambar (Opsional)</label>
                <div id="edit-mat-modul-image-wrapper" style="display: grid; grid-template-columns: 1fr; gap: 12px; min-height: 140px;">
                    <div id="edit-mat-modul-image-drop-zone" class="file-drop-zone" onclick="document.getElementById('edit-mat-modul-image').click()" style="cursor: pointer; padding: 20px; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; border: 1px dashed rgba(255,255,255,0.2); border-radius: 8px; background: rgba(0,0,0,0.15); transition: all 0.2s;">
                        <div id="edit-mat-img-empty" style="display:flex; flex-direction:column; align-items:center;">
                            <svg class="drop-icon" style="width:24px;height:24px;color:rgba(255,255,255,0.25); margin-bottom: 8px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                            </svg>
                            <div class="drop-label" style="font-size: 14px; color: rgba(255,255,255,0.6);">Pilih Foto Baru</div>
                            <span style="font-size:11px; color:rgba(255,255,255,0.3); margin-top:4px;">PNG, JPG, WEBP • Maks. 5MB</span>
                        </div>
                        <div id="edit-mat-img-filled" style="display:none; flex-direction:column; align-items:center;">
                            <svg style="width:28px;height:28px;color:#00E5FF; margin-bottom: 8px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                            </svg>
                            <div style="font-size: 14px; color: #00E5FF; font-weight:600;">Thumbnail Terpasang</div>
                            <div style="font-size:12px; color:rgba(255,255,255,0.5); margin-top:4px;">Klik untuk ganti foto</div>
                        </div>
                    </div>

                    <input type="file" id="edit-mat-modul-image" accept="image/png, image/jpeg, image/jpg" style="display:none;" onchange="
                        if(this.files && this.files[0]) {
                            const reader = new FileReader();
                            reader.onload = function(e) {
                                document.getElementById('edit-mat-modul-image-wrapper').style.gridTemplateColumns = '1fr 1fr';
                                document.getElementById('edit-mat-modul-image-preview-container').style.display = 'block';
                                document.getElementById('edit-mat-modul-image-preview').src = e.target.result;
                                document.getElementById('edit-mat-modul-image-deleted').value = 'false';
                                
                                document.getElementById('edit-mat-img-empty').style.display = 'none';
                                document.getElementById('edit-mat-img-filled').style.display = 'flex';
                                document.getElementById('edit-mat-modul-image-drop-zone').style.borderColor = 'rgba(0,229,255,0.3)';
                            };
                            reader.readAsDataURL(this.files[0]);
                        }
                    ">

                    <div id="edit-mat-modul-image-preview-container" style="display:none; position: relative; aspect-ratio: 16/9; border-radius: 8px; overflow: hidden; border: 1px solid rgba(255,255,255,0.1);">
                        <img id="edit-mat-modul-image-preview" src="" style="width: 100%; height: 100%; object-fit: cover;">
                        <div style="position: absolute; inset: 0; background: rgba(0,0,0,0.4); display: flex; align-items: center; justify-content: center; opacity: 0; transition: opacity 0.2s;" onmouseover="this.style.opacity=1" onmouseout="this.style.opacity=0">
                            <button type="button" onclick="
                                document.getElementById('edit-mat-modul-image').value = '';
                                document.getElementById('edit-mat-modul-image-preview').src = '';
                                document.getElementById('edit-mat-modul-image-wrapper').style.gridTemplateColumns = '1fr';
                                document.getElementById('edit-mat-modul-image-preview-container').style.display = 'none';
                                document.getElementById('edit-mat-modul-image-deleted').value = 'true';
                                
                                document.getElementById('edit-mat-img-empty').style.display = 'flex';
                                document.getElementById('edit-mat-img-filled').style.display = 'none';
                                document.getElementById('edit-mat-modul-image-drop-zone').style.borderColor = 'rgba(255,255,255,0.2)';
                            " style="background: rgba(239, 68, 68, 0.2); border: 1px solid #EF4444; color: #EF4444; padding: 6px 16px; border-radius: 6px; font-size: 12px; cursor: pointer; font-weight:600; transition: all 0.2s;">Hapus Thumbnail</button>
                        </div>
                    </div>
                </div>
                <input type="hidden" id="edit-mat-modul-image-deleted" value="false">
            </div>
        </div>

        <!-- Split: Varian + 3D Preview -->
        <div style="display:flex; gap:20px; flex-wrap:wrap;">

            <!-- Kiri: Varian -->
            <div style="flex:1; min-width:280px; display:flex; flex-direction:column;">
                <div style="font-size:11px; font-weight:600; color:rgba(255,255,255,0.4); margin-bottom:10px; text-transform:uppercase; letter-spacing:.08em;">Varian / Asset 3D</div>
                <div id="edit-material-cards" style="display:flex; flex-direction:column; gap:14px; margin-bottom:14px; max-height:340px; overflow-y:auto; padding-right:8px;"></div>
                <button class="add-card-btn" onclick="addEditMaterialCard()" style="margin-bottom:14px; border:2px dashed rgba(129,140,248,0.3); color:#818CF8;">
                    <svg style="width:14px;height:14px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                    Tambah Varian
                </button>
            </div>

            <!-- Kanan: 3D Preview -->
            <div style="flex:1; min-width:280px; display:flex; flex-direction:column; background:rgba(0,0,0,0.2); border-radius:12px; overflow:hidden; border:1px solid rgba(255,255,255,0.05); position:relative; min-height:340px;">
                <model-viewer
                    id="admin-preview-viewer"
                    src=""
                    camera-controls
                    auto-rotate
                    rotation-per-second="30deg"
                    interaction-prompt="none"
                    shadow-intensity="1.5"
                    environment-image="neutral"
                    exposure="1"
                    style="width:100%; height:100%; min-height:340px; outline:none; background:#0A1520;">
                </model-viewer>

                <div id="admin-preview-empty" style="position:absolute; inset:0; display:flex; flex-direction:column; align-items:center; justify-content:center; color:rgba(255,255,255,0.3); pointer-events:none;">
                    <svg style="width:36px;height:36px;margin-bottom:8px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
                    <div style="font-size:12px; font-weight:600;">Belum ada file GLB terpilih</div>
                </div>

                <!-- Dropdown Selector Varian -->
                <div style="position:absolute; bottom:12px; left:12px; right:12px; z-index:10;">
                    <select id="admin-preview-selector" onchange="changeAdminPreview()" style="width:100%; padding:8px 12px; background:rgba(0,0,0,0.65); color:#fff; border:1px solid rgba(255,255,255,0.1); border-radius:8px; font-size:12px; outline:none; backdrop-filter:blur(6px);">
                        <option value="">-- Pilih Varian untuk Preview --</option>
                    </select>
                </div>
            </div>

        </div>

        <div style="display:flex; justify-content:flex-end; gap:10px; margin-top:20px; padding-top:16px; border-top:1px solid rgba(255,255,255,0.08);">
            <button class="btn-secondary" onclick="closeEditModal()">Batal</button>
            <button class="btn-primary" onclick="submitEditMaterial()">Simpan Perubahan</button>
        </div>
    </div>
</div>

<script src="/js/admin/upload-card.js"></script>
<script src="/js/admin/material-admin.js"></script>
