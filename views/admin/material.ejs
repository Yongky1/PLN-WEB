<!-- views/admin/material.ejs -->
<link rel="stylesheet" href="/css/upload-card.css">
<style>
    #material-cards .upload-card-header { background: rgba(129,140,248,0.04); }
    #material-cards .file-drop-zone {
        --zone-color: rgba(129,140,248,0.5);
        --zone-bg:    rgba(129,140,248,0.04);
    }
    #material-cards .add-card-btn {
        border: 2px dashed rgba(129,140,248,0.3);
        color: #818CF8;
    }
    #material-cards .add-card-btn:hover {
        background: rgba(129,140,248,0.06);
        border-color: rgba(129,140,248,0.55);
    }
</style>

<div style="max-width:760px;">

    <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:24px;">
        <div>
            <h3 style="font-size:16px; font-weight:700; color:#fff; margin:0;">Manajemen Material</h3>
            <p style="font-size:12px; color:rgba(255,255,255,0.35); margin:4px 0 0;">Tambah dan kelola katalog material jaringan</p>
        </div>
        <span style="font-size:11px; font-weight:600; padding:4px 12px; border-radius:999px; background:rgba(129,140,248,0.12); color:#818CF8; border:1px solid rgba(129,140,248,0.3);">Material</span>
    </div>

    <!-- Data tersimpan -->
    <div class="admin-card" style="margin-bottom:24px;">
        <h4 class="section-title" style="margin:0 0 16px;">Data Material Tersimpan</h4>
        <div id="material-saved" style="display:flex; flex-direction:column; gap:10px;">
            <div class="item-row">
                <div class="item-icon" style="background:rgba(129,140,248,0.1);">
                    <svg style="width:16px;height:16px;color:#818CF8;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                </div>
                <div style="flex:1;">
                    <div style="font-size:13px; font-weight:600; color:#fff;">Baut M20 HDG</div>
                    <div style="font-size:11px; color:rgba(255,255,255,0.35); margin-top:2px;">BT-M20-HDG · baut-m20.glb · Pengencang</div>
                </div>
                <span class="badge badge-green">Aktif</span>
                <button class="btn-danger" onclick="this.closest('.item-row').remove(); showToast('Item dihapus')">Hapus</button>
            </div>
            <div class="item-row">
                <div class="item-icon" style="background:rgba(129,140,248,0.1);">
                    <svg style="width:16px;height:16px;color:#818CF8;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                </div>
                <div style="flex:1;">
                    <div style="font-size:13px; font-weight:600; color:#fff;">Ring Per (Spring Washer)</div>
                    <div style="font-size:11px; color:rgba(255,255,255,0.35); margin-top:2px;">WS-M20-SPR · ring-per.glb · Pengencang</div>
                </div>
                <span class="badge badge-green">Aktif</span>
                <button class="btn-danger" onclick="this.closest('.item-row').remove(); showToast('Item dihapus')">Hapus</button>
            </div>
        </div>
    </div>

    <!-- Form tambah baru -->
    <div class="admin-card">
        <h4 style="font-size:13px; font-weight:600; color:#fff; margin:0 0 18px; display:flex; align-items:center; gap:8px;">
            <svg style="width:15px;height:15px;color:#818CF8;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            Tambah Material Baru
        </h4>

        <div id="material-cards" style="display:flex; flex-direction:column; gap:14px; margin-bottom:14px;"></div>

        <button class="add-card-btn" onclick="addMaterialCard()" style="margin-bottom:16px;">
            <svg style="width:16px;height:16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            Tambah Material Lagi
        </button>

        <div style="display:flex; gap:10px;">
            <button class="btn-primary" onclick="submitSemuaMaterial()">Simpan Semua</button>
            <button class="btn-secondary" onclick="resetMaterialForm()">Reset</button>
        </div>
    </div>
</div>

<script src="/js/admin/upload-card.js"></script>
<script src="/js/admin/material-admin.js"></script>
