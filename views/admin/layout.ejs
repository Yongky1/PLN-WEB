<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %> — PLN Pusdiklat</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/output.css">
  <link rel="stylesheet" href="/css/custom.css">
  <link rel="stylesheet" href="/css/admin.css">
  <link rel="stylesheet" href="/css/admin-redesign.css">
</head>
<body class="rd-body">

<!-- ===================== APP SHELL ===================== -->
<div id="rd-app" class="rd-app" data-module="<%= typeof page !== 'undefined' ? page : 'default' %>">

  <!-- ===================== SIDEBAR ===================== -->
  <aside class="rd-sidebar">

    <!-- Brand -->
    <div class="rd-brand">
      <div class="rd-brand-mark">PB</div>
      <div class="rd-brand-text">
        <span class="name">Pembelajaran 3D</span>
        <span class="sub">PLN Admin</span>
      </div>
    </div>

    <!-- Nav -->
    <nav class="rd-nav">
      <div>
        <div class="rd-nav-group-label">Overview</div>
        <a href="/admin/overview" class="rd-nav-item <%= page==='overview' ? 'active' : '' %>">
          <svg class="nav-i" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="9"/><rect x="14" y="3" width="7" height="5"/><rect x="14" y="12" width="7" height="9"/><rect x="3" y="16" width="7" height="5"/></svg>
          <span class="nav-label">Dashboard</span>
        </a>
        <a href="/admin/laporan" class="rd-nav-item <%= page==='laporan' ? 'active' : '' %>">
          <svg class="nav-i" fill="none" stroke="currentColor" viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          <span class="nav-label">Laporan</span>
        </a>
      </div>

      <div>
        <div class="rd-nav-group-label">Manajemen Modul</div>
        <a href="/admin/konstruksi" class="rd-nav-item <%= page==='konstruksi' ? 'active' : '' %>">
          <svg class="nav-i" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
          <span class="nav-label">Konstruksi</span>
        </a>
        <a href="/admin/material" class="rd-nav-item <%= page==='material' ? 'active' : '' %>">
          <svg class="nav-i" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
          <span class="nav-label">Material</span>
        </a>
        <a href="/admin/tools" class="rd-nav-item <%= page==='tools' ? 'active' : '' %>">
          <svg class="nav-i" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
          <span class="nav-label">Peralatan</span>
        </a>
        <a href="/admin/modules" class="rd-nav-item <%= page==='modules' ? 'active' : '' %>">
          <svg class="nav-i" fill="none" stroke="currentColor" viewBox="0 0 24 24"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>
          <span class="nav-label">Kategori / Modul</span>
        </a>
        <a href="/admin/categories" class="rd-nav-item <%= page==='categories' ? 'active' : '' %>">
          <svg class="nav-i" fill="none" stroke="currentColor" viewBox="0 0 24 24"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
          <span class="nav-label">Kategori Tag</span>
        </a>
      </div>

      <div>
        <div class="rd-nav-group-label">Pengaturan</div>
        <a href="/admin/users" class="rd-nav-item <%= page==='users' ? 'active' : '' %>">
          <svg class="nav-i" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
          <span class="nav-label">Pengguna</span>
        </a>
        <a href="/admin/settings" class="rd-nav-item <%= page==='settings' ? 'active' : '' %>">
          <svg class="nav-i" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 11-2.83 2.83l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 11-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 11-2.83-2.83l.06-.06a1.65 1.65 0 00.33-1.82 1.65 1.65 0 00-1.51-1H3a2 2 0 110-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 112.83-2.83l.06.06a1.65 1.65 0 001.82.33H9a1.65 1.65 0 001-1.51V3a2 2 0 114 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 112.83 2.83l-.06.06a1.65 1.65 0 00-.33 1.82V9a1.65 1.65 0 001.51 1H21a2 2 0 110 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
          <span class="nav-label">Settings</span>
        </a>
      </div>
    </nav>

    <!-- Footer user card -->
    <div class="rd-sidebar-footer">
      <div class="rd-user-card">
        <div class="rd-avatar">A</div>
        <div class="rd-user-info">
          <div class="uname">Admin PLN</div>
          <div class="urole">Super Admin</div>
        </div>
      </div>
      <button class="rd-logout" onclick="handleLogout()">
        <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
        <span class="logout-label">Keluar</span>
      </button>
    </div>
  </aside>

  <!-- ===================== MAIN ===================== -->
  <div class="rd-main">

    <!-- Header -->
    <header class="rd-header">
      <button class="rd-collapse-btn" id="sidebar-collapse-btn" onclick="toggleSidebarCollapse()" title="Toggle sidebar">
        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
      </button>

      <div class="rd-breadcrumb">
        <span class="crumb">Admin</span>
        <span class="sep">/</span>
        <span class="crumb">Manajemen</span>
        <span class="sep">/</span>
        <span class="crumb active"><%= title %></span>
      </div>

      <div class="rd-header-spacer"></div>

      <div class="rd-header-search">
        <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input placeholder="Cari di seluruh sistem..." />
        <span class="kbd">⌘K</span>
      </div>

      <button class="rd-icon-btn" title="Notifikasi">
        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg>
        <span class="dot"></span>
      </button>
      <button class="rd-icon-btn" title="Info">
        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
      </button>
    </header>

    <!-- Page Content -->
    <div class="rd-page">
      <%- body %>
    </div>

  </div><!-- /.rd-main -->
</div><!-- /.rd-app -->

<!-- Confirm Dialog Global -->
<div id="confirm-dialog-overlay" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.72); z-index:999999; align-items:center; justify-content:center; backdrop-filter:blur(5px);">
  <div style="background:#0D1B2A; border:1px solid rgba(255,255,255,0.1); border-radius:16px; padding:28px 28px 24px; max-width:400px; width:90%; box-shadow:0 24px 64px rgba(0,0,0,0.6); text-align:center;">
    <div id="confirm-dialog-icon" style="width:48px; height:48px; border-radius:12px; background:rgba(239,68,68,0.13); display:flex; align-items:center; justify-content:center; margin:0 auto 16px;">
      <svg width="22" height="22" fill="none" stroke="#EF4444" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
    </div>
    <div id="confirm-dialog-title" style="font-size:15px; font-weight:700; color:#fff; line-height:1.3; margin-bottom:8px;"></div>
    <div id="confirm-dialog-message" style="font-size:12.5px; color:rgba(255,255,255,0.48); line-height:1.6; margin-bottom:24px;"></div>
    <div style="display:flex; gap:10px; justify-content:center;">
      <button onclick="dismissConfirmDialog()" style="padding:9px 20px; border-radius:8px; border:1px solid rgba(255,255,255,0.12); background:rgba(255,255,255,0.05); color:rgba(255,255,255,0.6); font-size:13px; font-weight:600; cursor:pointer; transition:all .15s;" onmouseover="this.style.background='rgba(255,255,255,0.09)'" onmouseout="this.style.background='rgba(255,255,255,0.05)'">Batal</button>
      <button id="confirm-dialog-ok" style="padding:9px 20px; border-radius:8px; border:1px solid; font-size:13px; font-weight:600; cursor:pointer; transition:all .15s;"></button>
    </div>
  </div>
</div>

<!-- Toast Notification Global -->
<div id="toast" style="
  display:none;
  position:fixed;
  bottom:28px;
  right:28px;
  padding:12px 20px;
  border-radius:10px;
  font-size:13px;
  font-weight:600;
  letter-spacing:0.01em;
  z-index:99999;
  box-shadow:0 4px 24px rgba(0,0,0,0.35);
  opacity:0;
  transition:opacity 0.25s ease;
  pointer-events:none;
  max-width:360px;
  line-height:1.4;
"></div>

<script src="/js/main.js"></script>
<script src="/js/admin/core.js"></script>
<script>
  /* Sidebar collapse toggle */
  function toggleSidebarCollapse() {
    const app = document.getElementById('rd-app');
    const btn = document.getElementById('sidebar-collapse-btn');
    const collapsed = app.classList.toggle('sidebar-collapsed');
    localStorage.setItem('rd-sidebar-collapsed', collapsed ? '1' : '0');
    // Flip chevron icon
    btn.querySelector('svg polyline').setAttribute('points', collapsed ? '9 18 15 12 9 6' : '15 18 9 12 15 6');
  }

  /* Restore saved state */
  (function() {
    if (localStorage.getItem('rd-sidebar-collapsed') === '1') {
      const app = document.getElementById('rd-app');
      if (app) {
        app.classList.add('sidebar-collapsed');
        const btn = document.getElementById('sidebar-collapse-btn');
        if (btn) btn.querySelector('svg polyline').setAttribute('points', '9 18 15 12 9 6');
      }
    }
  })();

  /* Date in header (legacy compat) */
  const topbarDate = document.getElementById('topbar-date');
  if (topbarDate) {
    topbarDate.textContent = new Date().toLocaleDateString('id-ID', { weekday:'short', day:'numeric', month:'short', year:'numeric' });
  }

  /* ---- Shared dropdown utility for admin filter dropdowns ---- */
  window.toggleAdminDropdown = function(id) {
    const dd = document.getElementById(id);
    if (!dd) return;
    const isOpen = dd.classList.contains('open');
    // Close all other dropdowns first
    document.querySelectorAll('.rd-dropdown.open').forEach(el => el.classList.remove('open'));
    if (!isOpen) dd.classList.add('open');
  };

  // Close dropdown when clicking outside
  document.addEventListener('click', function(e) {
    if (!e.target.closest('.rd-dropdown')) {
      document.querySelectorAll('.rd-dropdown.open').forEach(el => el.classList.remove('open'));
    }
  });
</script>
<%- scripts %>
</body>
</html>
