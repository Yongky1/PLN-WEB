<!-- views/admin/modules.ejs -->
<div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:22px;">
    <h3 style="font-size:15px; font-weight:600; color:#fff; margin:0;">Daftar Modul Konten</h3>
    <button class="btn-primary">+ Tambah Modul</button>
</div>
<div class="grid-cols-2" style="display:grid; grid-template-columns:repeat(2,1fr); gap:14px;">
    <% if (modules && modules.length > 0) { %>
        <% modules.forEach(m => { 
            // Format ulang status agar cocok dengan badge class UI
            let statusClass = 'badge-blue';
            if (m.status === 'Aktif') statusClass = 'badge-green';
            else if (m.status === 'Draft' || m.status === 'Nonaktif') statusClass = 'badge-yellow';
            
            const totalItems = (m.materials ? m.materials.length : 0) + (m.tools ? m.tools.length : 0) + (m.assets ? m.assets.length : 0);
            
            // Format tanggal yang bagus
            const dateObj = new Date(m.created_at || Date.now());
            const dateStr = dateObj.toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' });
        %>
        <div class="item-row">
            <div class="item-icon"><svg style="width:18px;height:18px;color:#00E5FF;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg></div>
            <div style="flex:1; min-width:0;">
                <div style="font-size:13px; font-weight:600; color:#fff; margin-bottom:3px;"><%= m.title %></div>
                <div style="font-size:11px; color:rgba(255,255,255,0.35);">Dibuat <%= dateStr %> · <%= totalItems %> komponen terkait</div>
            </div>
            <span class="badge <%= statusClass %>"><%= m.status %></span>
        </div>
        <% }); %>
    <% } else { %>
        <div style="grid-column: 1 / -1; padding: 20px; text-align: center; color: rgba(255,255,255,0.5); font-size: 13px;">
            Belum ada modul yang terdaftar dalam database.
        </div>
    <% } %>
</div>
