<script>
  const __AM_MATERIALS__ = <%- JSON.stringify(materials || []) %>;
  const __AM_TOOLS__     = <%- JSON.stringify(tools     || []) %>;

  const AMQV_IDS = {
    overlay:        'amqv-overlay',
    card:           'amqv-card',
    modelViewer:    'amqv-model-viewer',
    canvasWrap:     'amqv-canvas-wrap',
    emptyState:     'amqv-empty-state',
    loadingOverlay: 'amqv-loading-overlay',
    spinner:        'amqv-loading-spinner',
    loadingText:    'amqv-loading-text',
  };

  function openModuleItemModal(type, id) {
    const isMat  = type === 'material';
    const data   = isMat
      ? __AM_MATERIALS__.find(m => m.id === id)
      : __AM_TOOLS__.find(t => t.id === id);
    if (!data) return;

    const accentColor = isMat ? '#FFD700' : '#60A5FA';
    const accentBg    = isMat ? 'rgba(255,215,0,0.1)'   : 'rgba(96,165,250,0.1)';
    const accentBorder= isMat ? 'rgba(255,215,0,0.25)'  : 'rgba(96,165,250,0.25)';

    // Category badge
    const catEl = document.getElementById('amqv-modal-category');
    catEl.textContent = '';
    catEl.style.cssText = `font-size:9px; font-weight:900; text-transform:uppercase; letter-spacing:0.2em; padding:4px 12px 4px 10px; border-radius:999px; border:1px solid ${accentBorder}; background:${accentBg}; color:${accentColor}; display:inline-flex; align-items:center; gap:6px;`;
    const dot = document.createElement('span');
    dot.style.cssText = `width:4px; height:4px; border-radius:50%; background:currentColor; opacity:.7; animation:pulse 2s infinite;`;
    catEl.appendChild(dot);
    catEl.appendChild(document.createTextNode(data.category?.name || (isMat ? 'Material' : 'Peralatan')));

    document.getElementById('amqv-modal-icon').textContent = data.icon || (isMat ? '🔩' : '🔧');
    document.getElementById('amqv-modal-name').textContent = data.name || '';

    // Sub line: code (material) or standard (tools)
    const subEl = document.getElementById('amqv-modal-sub');
    subEl.style.color = isMat ? 'rgba(255,215,0,0.5)' : 'rgba(96,165,250,0.5)';
    subEl.textContent = isMat ? (data.code || '') : (data.standard ? `Standar: ${data.standard}` : '');

    // Status (tools only)
    const toolsMeta = document.getElementById('amqv-tools-meta');
    if (!isMat && data.status) {
      const statusEl = document.getElementById('amqv-modal-status');
      statusEl.textContent = data.status;
      statusEl.style.color = data.status === 'Wajib' ? '#f87171' : '#34d399';
      toolsMeta.style.display = 'flex';
    } else {
      toolsMeta.style.display = 'none';
    }

    // Description
    const rawDesc = data.description || '';
    document.getElementById('amqv-modal-desc').textContent = rawDesc || '—';

    // File 3D: material ambil dari assets[0], tools langsung dari file3d
    const file3d = isMat
      ? (data.assets && data.assets[0] ? data.assets[0].file : '')
      : (data.file3d || '');

    openCatalogModal(AMQV_IDS, file3d, 'Memuat Model 3D...', () => {});
  }

  function deleteFromModules(type, id, btn) {
    const labels    = { material: 'Material', tool: 'Peralatan', module: 'Modul Konstruksi' };
    const endpoints = { material: `/api/materials/${id}`, tool: `/api/tools/${id}`, module: `/api/modules/${id}` };
    const notes     = {
      material: 'File 3D terkait juga akan ikut terhapus dari server.',
      tool:     'File 3D (jika ada) juga akan ikut terhapus dari server.',
      module:   'Semua varian dan file 3D terkait juga akan ikut terhapus dari server.',
    };
    showConfirmDialog({
      title:       `Hapus ${labels[type]}?`,
      message:     `Tindakan ini permanen dan tidak dapat dibatalkan. ${notes[type]}`,
      confirmText: 'Ya, Hapus',
      onConfirm: async () => {
        try {
          await fetchBackend(endpoints[type], { method: 'DELETE' });
          showToast(`${labels[type]} berhasil dihapus!`);
          btn.closest('.am-card').remove();
        } catch (err) {
          showToast(`Gagal menghapus: ${err.message}`, 'error');
        }
      },
    });
  }

  document.getElementById('amqv-btn-close').addEventListener('click', () => closeCatalogModal(AMQV_IDS));
  document.getElementById('amqv-overlay').addEventListener('click', function(e) {
    if (e.target === this) closeCatalogModal(AMQV_IDS);
  });
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeCatalogModal(AMQV_IDS);
  });
  document.getElementById('amqv-fullscreen-btn').addEventListener('click', () => toggleCatalogFullscreen('amqv-canvas-wrap'));
  initCatalogFullscreen('amqv-canvas-wrap');
</script>

