<!-- views/admin/modules.ejs -->
<div class="rd-page-head">
    <div class="rd-page-title-block">
        <span class="rd-page-eyebrow">Manajemen Sistem</span>
        <h1 class="rd-page-title">Modul</h1>
        <p class="rd-page-subtitle">Kelola modul konstruksi, material, dan peralatan.</p>
    </div>
</div>

<style>
  /* ── Shared card grid ── */
  .am-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  @media (max-width: 1200px) { .am-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 720px)  { .am-grid { grid-template-columns: 1fr; } }

  /* ── Glass card base ── */
  .am-card {
    border-radius: 28px;
    overflow: hidden;
    position: relative;
    display: flex;
    flex-direction: column;
    background: linear-gradient(135deg, rgba(255,255,255,0.06) 0%, rgba(255,255,255,0.02) 100%);
    backdrop-filter: blur(24px) saturate(160%);
    -webkit-backdrop-filter: blur(24px) saturate(160%);
    border: 1px solid rgba(255,255,255,0.08);
    border-top-color: rgba(255,255,255,0.15);
    border-left-color: rgba(255,255,255,0.1);
    transition: transform .35s cubic-bezier(0.34,1.5,0.64,1), box-shadow .35s;
    cursor: pointer;
  }
  .am-card:hover {
    transform: translateY(-10px) scale(1.02);
    box-shadow: 0 28px 72px rgba(0,0,0,0.6), 0 0 48px rgba(255,215,0,0.07);
  }

  /* Image area */
  .am-card-img {
    width: 100%; height: 190px;
    position: relative; overflow: hidden;
    background: rgba(0,0,0,0.25);
    flex-shrink: 0;
  }
  .am-card-img img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform .5s ease-out;
  }
  .am-card:hover .am-card-img img { transform: scale(1.06); }
  .am-card-img-placeholder {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
    flex-direction: column; gap: 8px;
    background: repeating-linear-gradient(
      45deg,
      rgba(255,255,255,0.015) 0px, rgba(255,255,255,0.015) 1px,
      transparent 1px, transparent 14px
    );
  }
  .am-card-img-grad {
    position: absolute; bottom: 0; left: 0; right: 0; height: 60px;
    background: linear-gradient(to top, rgba(5,5,15,0.85), transparent);
    pointer-events: none;
  }

  /* Status badge on image */
  .am-card-badge {
    position: absolute; top: 10px; right: 10px;
    padding: 3px 9px; border-radius: 999px;
    font-size: 9.5px; font-weight: 700; letter-spacing: 0.06em;
    text-transform: uppercase; font-family: 'JetBrains Mono', monospace;
  }
  .am-badge-green  { background: rgba(34,197,94,0.18);  color: #4ade80; border: 1px solid rgba(34,197,94,0.3); }
  .am-badge-yellow { background: rgba(251,191,36,0.18); color: #fbbf24; border: 1px solid rgba(251,191,36,0.3); }
  .am-badge-gray   { background: rgba(148,163,184,0.15); color: #94a3b8; border: 1px solid rgba(148,163,184,0.2); }
  .am-badge-blue   { background: rgba(96,165,250,0.15); color: #60A5FA; border: 1px solid rgba(96,165,250,0.25); }

  /* Card body */
  .am-card-body {
    padding: 16px 18px 18px;
    display: flex; flex-direction: column; gap: 6px;
    flex: 1;
  }
  .am-card-eyebrow {
    font-size: 9px; font-family: 'JetBrains Mono', monospace;
    color: rgba(255,255,255,0.28); letter-spacing: 0.1em; text-transform: uppercase;
  }
  .am-card-title {
    font-weight: 700; font-size: 16px; color: #f0f0f0;
    line-height: 1.3; letter-spacing: -0.2px;
    transition: color .2s;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .am-card:hover .am-card-title { color: #00E5FF; }
  .am-card-desc {
    font-size: 11px; color: rgba(255,255,255,0.32); line-height: 1.55;
    display: -webkit-box; -webkit-line-clamp: 2;
    -webkit-box-orient: vertical; overflow: hidden;
  }
  .am-card-divider { height: 1px; background: rgba(255,255,255,0.07); margin: 4px 0; }
  .am-card-stats {
    display: flex; align-items: center; justify-content: space-between;
  }
  .am-stat { display: flex; flex-direction: column; gap: 1px; }
  .am-stat-label {
    font-size: 8.5px; font-family: 'JetBrains Mono', monospace;
    color: rgba(255,255,255,0.25); letter-spacing: 0.1em; text-transform: uppercase;
  }
  .am-stat-val {
    font-size: 17px; font-weight: 700; font-family: 'Space Grotesk', 'Inter', sans-serif;
  }
  .am-stat-text {
    font-size: 12px; font-weight: 600; color: rgba(255,255,255,0.55);
    font-family: 'Inter', sans-serif;
  }
  .am-go-btn {
    width: 32px; height: 32px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    background: rgba(0,229,255,0.1); color: #00E5FF;
    border: 1px solid rgba(0,229,255,0.18);
    transition: background .2s, transform .2s;
    flex-shrink: 0;
  }
  .am-card:hover .am-go-btn {
    background: #00E5FF; color: #000;
    transform: rotate(-45deg) scale(1.1);
  }

  /* Electric accent line */
  .am-electric-line {
    position: absolute; bottom: 0; left: 0; right: 0; height: 2px;
    opacity: 0; transition: opacity .3s;
  }
  .am-card:hover .am-electric-line { opacity: 1; }

  /* Action buttons */
  .am-card-actions {
    position: absolute; top: 10px; left: 10px;
    display: flex; gap: 6px;
    opacity: 0.55; transform: translateY(-2px);
    transition: opacity .2s, transform .2s;
    z-index: 10;
  }
  .am-card:hover .am-card-actions { opacity: 1; transform: none; }
  .am-action-btn {
    width: 40px; height: 40px; border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    border: 1px solid rgba(255,255,255,0.15); cursor: pointer;
    transition: background .15s, border-color .15s, transform .15s;
    backdrop-filter: blur(8px);
  }
  .am-action-btn:hover { transform: scale(1.08); }
  .am-action-edit  { background: rgba(0,0,0,0.45); }
  .am-action-edit:hover  { background: rgba(0,229,255,0.22); border-color: rgba(0,229,255,0.4); }
  .am-action-delete { background: rgba(0,0,0,0.45); }
  .am-action-delete:hover { background: rgba(239,68,68,0.25); border-color: rgba(239,68,68,0.4); }

  /* Section header */
  .am-section {
    margin-bottom: 36px;
  }
  .am-section-head {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 18px; padding-bottom: 14px;
    border-bottom: 1px solid rgba(255,255,255,0.07);
  }
  .am-section-title-wrap { display: flex; align-items: center; gap: 10px; }
  .am-section-icon {
    width: 36px; height: 36px; border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .am-section-title {
    font-size: 14px; font-weight: 700; color: #fff; margin: 0;
  }
  .am-section-count {
    font-size: 11px; color: rgba(255,255,255,0.35); margin: 2px 0 0;
  }

  /* Empty state */
  .am-empty {
    grid-column: 1 / -1;
    display: flex; flex-direction: column; align-items: center;
    justify-content: center; padding: 48px 0; gap: 12px;
  }
  .am-empty-icon {
    width: 48px; height: 48px; border-radius: 50%;
    background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.07);
    display: flex; align-items: center; justify-content: center;
  }
  .am-empty-text {
    font-size: 12.5px; color: rgba(255,255,255,0.35);
  }
</style>

<!-- ═══════════════════════════════════════
     SECTION 1: MODUL
══════════════════════════════════════════ -->
<div class="am-section">
  <div class="am-section-head">
    <div class="am-section-title-wrap">
      <div class="am-section-icon" style="background:rgba(0,229,255,0.1); border:1px solid rgba(0,229,255,0.18);">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#00E5FF" stroke-width="2">
          <polygon points="12 2 2 7 12 12 22 7 12 2"/>
          <polyline points="2 17 12 22 22 17"/>
          <polyline points="2 12 12 17 22 12"/>
        </svg>
      </div>
      <div>
        <div class="am-section-title">Modul Konstruksi</div>
        <div class="am-section-count"><%= modules && modules.length ? modules.length : 0 %> modul</div>
      </div>
    </div>
    <button class="btn-primary" onclick="window.location.href='/admin/konstruksi?openAdd=1'">+ Tambah Modul</button>
  </div>

  <div class="am-grid">
    <% if (modules && modules.length > 0) { %>
      <% modules.forEach(function(m, i) {
          let badgeClass = 'am-badge-gray';
          if (m.status === 'Aktif') badgeClass = 'am-badge-green';
          else if (m.status === 'Draft') badgeClass = 'am-badge-yellow';
          const accentColor = i % 2 === 0 ? '#00E5FF' : '#FFD700';
      %>
      <div class="am-card" onclick="window.location.href='/ModulKonstruksi/<%= m.id %>?back=/admin/modules'" style="cursor:pointer;">
        <div class="am-card-actions">
          <button class="am-action-btn am-action-edit" title="Edit" onclick="event.stopPropagation(); openItemEdit('module','<%= m.id %>')">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#00E5FF" stroke-width="2"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
          </button>
          <button class="am-action-btn am-action-delete" title="Hapus" onclick="event.stopPropagation(); deleteFromModules('module', '<%= m.id %>', this)">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4a1 1 0 011-1h4a1 1 0 011 1v2"/></svg>
          </button>
        </div>
        <div class="am-card-img">
          <% if (m.image) { %><img src="<%= m.image %>" alt="<%= m.title %>">
          <% } else { %>
            <div class="am-card-img-placeholder">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="<%= accentColor %>" stroke-width="1.2" opacity=".4">
                <polygon points="12 2 2 7 12 12 22 7 12 2"/>
                <polyline points="2 17 12 22 22 17"/>
                <polyline points="2 12 12 17 22 12"/>
              </svg>
              <span style="font-size:8px; font-family:'JetBrains Mono',monospace; color:<%= accentColor %>; opacity:.35; letter-spacing:0.1em;">MODULE</span>
            </div>
          <% } %>
          <div class="am-card-img-grad"></div>
          <span class="am-card-badge <%= badgeClass %>"><%= m.status || 'Draft' %></span>
        </div>
        <div class="am-card-body">
          <div class="am-card-title"><%= m.title %></div>
          <% if (m.description) { %><div class="am-card-desc"><%= m.description %></div><% } %>
          <div class="am-card-divider"></div>
          <div class="am-card-stats">
            <div style="display:flex; gap:14px; align-items:center;">
              <div class="am-stat">
                <span class="am-stat-label">Material</span>
                <span class="am-stat-val" style="color:#FFD700;"><%= m.materialCount || 0 %></span>
              </div>
              <div style="width:1px; height:28px; background:rgba(255,255,255,0.07);"></div>
              <div class="am-stat">
                <span class="am-stat-label">Peralatan</span>
                <span class="am-stat-val" style="color:#60A5FA;"><%= m.equipmentCount || 0 %></span>
              </div>
            </div>
            <div class="am-go-btn">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </div>
          </div>
        </div>
        <div class="am-electric-line" style="background:linear-gradient(90deg,transparent,#00E5FF,rgba(255,215,0,.8),transparent);"></div>
      </div>
      <% }); %>
    <% } else { %>
      <div class="am-empty">
        <div class="am-empty-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.35)" stroke-width="1.5"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>
        </div>
        <span class="am-empty-text">Belum ada modul yang terdaftar.</span>
      </div>
    <% } %>
  </div>
</div>

<!-- ═══════════════════════════════════════
     SECTION 2: MATERIAL
══════════════════════════════════════════ -->
<div class="am-section">
  <div class="am-section-head">
    <div class="am-section-title-wrap">
      <div class="am-section-icon" style="background:rgba(255,215,0,0.1); border:1px solid rgba(255,215,0,0.2);">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#FFD700" stroke-width="2">
          <path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
        </svg>
      </div>
      <div>
        <div class="am-section-title">Material</div>
        <div class="am-section-count"><%= materials && materials.length ? materials.length : 0 %> item</div>
      </div>
    </div>
    <button class="btn-primary" onclick="window.location.href='/admin/material?openAdd=1'">+ Tambah Material</button>
  </div>

  <div class="am-grid">
    <% if (materials && materials.length > 0) { %>
      <% materials.forEach(function(m, i) {
          const accentColor = i % 2 === 0 ? '#FFD700' : '#00E5FF';
          const variantCount = m.assets ? m.assets.length : 0;
      %>
      <div class="am-card" data-type="material" data-id="<%= m.id %>" onclick="openModuleItemModal('material', '<%= m.id %>')">
        <div class="am-card-actions">
          <button class="am-action-btn am-action-edit" title="Edit" onclick="event.stopPropagation(); openItemEdit('material','<%= m.id %>')">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#00E5FF" stroke-width="2"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
          </button>
          <button class="am-action-btn am-action-delete" title="Hapus" onclick="event.stopPropagation(); deleteFromModules('material', '<%= m.id %>', this)">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4a1 1 0 011-1h4a1 1 0 011 1v2"/></svg>
          </button>
        </div>
        <div class="am-card-img">
          <% if (m.image) { %><img src="<%= m.image %>" alt="<%= m.name %>">
          <% } else { %>
            <div class="am-card-img-placeholder">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="<%= accentColor %>" stroke-width="1.2" opacity=".4">
                <path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
              </svg>
              <span style="font-size:8px; font-family:'JetBrains Mono',monospace; color:<%= accentColor %>; opacity:.35; letter-spacing:0.1em;">MATERIAL</span>
            </div>
          <% } %>
          <div class="am-card-img-grad"></div>
          <% if (m.category && m.category.name) { %>
            <span class="am-card-badge am-badge-blue"><%= m.category.name %></span>
          <% } %>
        </div>
        <div class="am-card-body">
          <% if (m.code) { %><div class="am-card-eyebrow"><%= m.code %></div><% } %>
          <div class="am-card-title"><%= m.name %></div>
          <% if (m.description) { %><div class="am-card-desc"><%= m.description %></div><% } %>
          <div class="am-card-divider"></div>
          <div class="am-card-stats">
            <div class="am-stat">
              <span class="am-stat-label">Varian 3D</span>
              <span class="am-stat-val" style="color:#FFD700;"><%= variantCount %></span>
            </div>
            <div class="am-go-btn">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </div>
          </div>
        </div>
        <div class="am-electric-line" style="background:linear-gradient(90deg,transparent,#FFD700,rgba(0,229,255,.8),transparent);"></div>
      </div>
      <% }); %>
    <% } else { %>
      <div class="am-empty">
        <div class="am-empty-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.35)" stroke-width="1.5"><path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
        </div>
        <span class="am-empty-text">Belum ada material yang terdaftar.</span>
      </div>
    <% } %>
  </div>
</div>

<!-- ═══════════════════════════════════════
     SECTION 3: PERALATAN
══════════════════════════════════════════ -->
<div class="am-section">
  <div class="am-section-head">
    <div class="am-section-title-wrap">
      <div class="am-section-icon" style="background:rgba(96,165,250,0.1); border:1px solid rgba(96,165,250,0.2);">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#60A5FA" stroke-width="2">
          <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
        </svg>
      </div>
      <div>
        <div class="am-section-title">Peralatan</div>
        <div class="am-section-count"><%= tools && tools.length ? tools.length : 0 %> item</div>
      </div>
    </div>
    <button class="btn-primary" onclick="window.location.href='/admin/tools?openAdd=1'">+ Tambah Peralatan</button>
  </div>

  <div class="am-grid">
    <% if (tools && tools.length > 0) { %>
      <% tools.forEach(function(t, i) {
          let badgeClass = 'am-badge-gray';
          if (t.status === 'Aktif') badgeClass = 'am-badge-green';
          else if (t.status === 'Draft') badgeClass = 'am-badge-yellow';
          const accentColor = i % 2 === 0 ? '#60A5FA' : '#00E5FF';
      %>
      <div class="am-card" data-type="tool" data-id="<%= t.id %>" onclick="openModuleItemModal('tool', '<%= t.id %>')">
        <div class="am-card-actions">
          <button class="am-action-btn am-action-edit" title="Edit" onclick="event.stopPropagation(); openItemEdit('tool','<%= t.id %>')">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#00E5FF" stroke-width="2"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
          </button>
          <button class="am-action-btn am-action-delete" title="Hapus" onclick="event.stopPropagation(); deleteFromModules('tool', '<%= t.id %>', this)">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4a1 1 0 011-1h4a1 1 0 011 1v2"/></svg>
          </button>
        </div>
        <div class="am-card-img">
          <% if (t.image) { %><img src="<%= t.image %>" alt="<%= t.name %>">
          <% } else { %>
            <div class="am-card-img-placeholder">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="<%= accentColor %>" stroke-width="1.2" opacity=".4">
                <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
              </svg>
              <span style="font-size:8px; font-family:'JetBrains Mono',monospace; color:<%= accentColor %>; opacity:.35; letter-spacing:0.1em;">PERALATAN</span>
            </div>
          <% } %>
          <div class="am-card-img-grad"></div>
          <% if (t.status) { %>
            <span class="am-card-badge <%= badgeClass %>"><%= t.status %></span>
          <% } %>
        </div>
        <div class="am-card-body">
          <% if (t.category && t.category.name) { %><div class="am-card-eyebrow"><%= t.category.name %></div><% } %>
          <div class="am-card-title"><%= t.name %></div>
          <% if (t.description) { %><div class="am-card-desc"><%= t.description %></div><% } %>
          <div class="am-card-divider"></div>
          <div class="am-card-stats">
            <div style="display:flex; gap:14px; align-items:center;">
              <% if (t.standard) { %>
                <div class="am-stat">
                  <span class="am-stat-label">Standar</span>
                  <span class="am-stat-text"><%= t.standard %></span>
                </div>
              <% } %>
              <% if (t.file3d) { %>
                <div class="am-stat">
                  <span class="am-stat-label">3D</span>
                  <span style="font-size:10px; font-weight:700; color:#4ade80;">✓ Ada</span>
                </div>
              <% } %>
            </div>
            <div class="am-go-btn">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
