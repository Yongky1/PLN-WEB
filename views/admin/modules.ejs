<script>
  /* ── Preview helpers: changer dan refresher per modal type ── */
  function _previewChanger(viewerId, selectorId, emptyId) {
    var viewer   = document.getElementById(viewerId);
    var selector = document.getElementById(selectorId);
    var empty    = document.getElementById(emptyId);
    if (!selector || !viewer || !empty) return;
    if (selector.value) {
      viewer.setAttribute('src', selector.value);
      viewer.style.display = 'block';
      empty.style.display  = 'none';
      viewer.dismissPoster && viewer.dismissPoster();
    } else {
      viewer.removeAttribute('src');
      viewer.style.display = 'none';
      empty.style.display  = 'flex';
    }
  }

  function toolChangeAdminPreview() { _previewChanger('tool-preview-viewer', 'tool-preview-selector', 'tool-preview-empty'); }
  function konChangeAdminPreview()  { _previewChanger('kon-preview-viewer',  'kon-preview-selector',  'kon-preview-empty');  }

  function _makePreviewRefresher(viewerId, selectorId, emptyId, changeFn) {
    return function (assets) {
      var viewer   = document.getElementById(viewerId);
      var selector = document.getElementById(selectorId);
      var empty    = document.getElementById(emptyId);
      if (!selector || !viewer || !empty) return;
      selector.innerHTML = '<option value="">-- Pilih File untuk Preview --</option>';
      if (assets && assets.length > 0) {
        assets.forEach(function (a, idx) {
          if (a.file && a.file !== '-') {
            var opt = document.createElement('option');
            opt.value = a.file;
            opt.textContent = a.name || ('File ' + (idx + 1));
            selector.appendChild(opt);
          }
        });
        if (selector.options.length > 1) { selector.selectedIndex = 1; changeFn(); }
        else { viewer.style.display = 'none'; empty.style.display = 'flex'; }
      } else {
        viewer.style.display = 'none';
        empty.style.display  = 'flex';
      }
    };
  }

  var _toolRefresh = _makePreviewRefresher('tool-preview-viewer', 'tool-preview-selector', 'tool-preview-empty', toolChangeAdminPreview);
  var _konRefresh  = _makePreviewRefresher('kon-preview-viewer',  'kon-preview-selector',  'kon-preview-empty',  konChangeAdminPreview);

  /* ── Wrapper: buka edit modal yang benar berdasarkan tipe ── */
  async function openItemEdit(type, id) {
    var origRefresh = window.refreshAdminPreviewSelector;

    if (type === 'material') {
      await editMaterial(id);
      document.getElementById('mat-edit-modal').classList.add('active');
    } else if (type === 'tool') {
      window.refreshAdminPreviewSelector = _toolRefresh;
      editTool(id);
      window.refreshAdminPreviewSelector = origRefresh;
      document.getElementById('tool-edit-modal').classList.add('active');
    } else if (type === 'module') {
      window.refreshAdminPreviewSelector = _konRefresh;
      await editKonstruksi(id);
      window.refreshAdminPreviewSelector = origRefresh;
      document.getElementById('kon-edit-modal').classList.add('active');
    }
  }

  /* ── Override closeEditModal dari core.js agar tutup semua modal embedded ── */
  window.closeEditModal = function () {
    window.currentEditingId = null;
    var m1 = document.getElementById('mat-edit-modal');
    if (m1) m1.classList.remove('active');
    var m2 = document.getElementById('tool-edit-modal');
    if (m2) m2.classList.remove('active');
    var m3 = document.getElementById('kon-edit-modal');
    if (m3) m3.classList.remove('active');
  };

  /* ── Override syncAdminPreviewDropdown agar routing ke modal yang aktif ── */
  document.addEventListener('DOMContentLoaded', function () {
    var origSync = window.syncAdminPreviewDropdown;
    window.syncAdminPreviewDropdown = function () {
      var konActive  = document.getElementById('kon-edit-modal');
      var toolActive = document.getElementById('tool-edit-modal');
      if (konActive && konActive.classList.contains('active')) {
        _konSyncFromCards();
      } else if (toolActive && toolActive.classList.contains('active')) {
        _toolSyncFromCards();
      } else if (origSync) {
        origSync.apply(this, arguments);
      }
    };
  });

  function _toolSyncFromCards() {
    var selector = document.getElementById('tool-preview-selector');
    var viewer   = document.getElementById('tool-preview-viewer');
    var empty    = document.getElementById('tool-preview-empty');
    if (!selector || !viewer || !empty) return;
    var cards   = document.querySelectorAll('#edit-tools-cards .upload-card');
    var current = selector.value;
    selector.innerHTML = '<option value="">-- Pilih File untuk Preview --</option>';
    var hasValid = false;
    cards.forEach(function (card, idx) {
      var nameEl = card.querySelector('.t-name');
      var name   = nameEl && nameEl.value.trim() ? nameEl.value.trim() : ('Peralatan ' + (idx + 1));
      var fi     = card.querySelector('input.t-file-3d');
      var url    = '';
      var local  = fi && fi.files && fi.files[0];
      if (local) { url = URL.createObjectURL(fi.files[0]); }
      else if (card.dataset.oldFile && card.dataset.oldFile !== '-') { url = card.dataset.oldFile; }
      if (url) {
        var opt = document.createElement('option');
        opt.value = url;
        opt.textContent = local ? ('[Baru] ' + name) : name;
        selector.appendChild(opt);
        hasValid = true;
      }
    });
    if (hasValid) {
      var found = current && Array.from(selector.options).find(function (o) { return o.value === current; });
      selector.value = found ? current : (selector.options.length > 1 ? selector.options[1].value : '');
    } else { selector.value = ''; }
    toolChangeAdminPreview();
  }

  function _konSyncFromCards() {
    var selector = document.getElementById('kon-preview-selector');
    var viewer   = document.getElementById('kon-preview-viewer');
    var empty    = document.getElementById('kon-preview-empty');
    if (!selector || !viewer || !empty) return;
    var cards   = document.querySelectorAll('#edit-konstruksi-cards .upload-card');
    var current = selector.value;
    selector.innerHTML = '<option value="">-- Pilih Varian untuk Preview --</option>';
    var hasValid = false;
    cards.forEach(function (card, idx) {
      var nameEl = card.querySelector('.k-name');
      var name   = nameEl ? (nameEl.value.trim() || ('Varian ' + (idx + 1))) : ('Varian ' + (idx + 1));
      var fi     = card.querySelector('input[type="file"]');
      var url    = '';
      var local  = fi && (fi._confirmedFile || (fi.files && fi.files[0]));
      if (local) { url = URL.createObjectURL(local); }
      else if (card.dataset.oldFile && card.dataset.oldFile !== '-') { url = card.dataset.oldFile; }
      if (url) {
        var opt = document.createElement('option');
        opt.value = url;
        opt.textContent = local ? ('[Baru] ' + name) : name;
        if (url === current) opt.selected = true;
        selector.appendChild(opt);
        hasValid = true;
      }
    });
    if (hasValid) {
      if (!selector.value && selector.options.length > 1) selector.selectedIndex = 1;
    } else { selector.value = ''; }
    konChangeAdminPreview();
  }

  /* ── Reload halaman setelah save agar card terupdate ── */
  document.addEventListener('DOMContentLoaded', function () {
    var fns = ['submitEditMaterial', 'submitEditTool', 'submitEditKonstruksi'];
    fns.forEach(function (name) {
      var orig = window[name];
      if (typeof orig !== 'function') return;
      window[name] = async function () {
        await orig.apply(this, arguments);
        location.reload();
      };
    });
  });

  /* ── Pre-fetch allTools (editTool butuh ini) ── */
  document.addEventListener('DOMContentLoaded', async () => {
    try {
      if (!window.allTools || !window.allTools.length) {
        window.allTools = await fetchBackend('/api/tools?all=true');
      }
    } catch (e) { /* gagal silent */ }
  });

</script>
