<!-- views/admin/konstruksi.ejs -->
<link rel="stylesheet" href="/css/upload-card.css">
<style>
    #konstruksi-cards .upload-card-header { background: rgba(0,229,255,0.04); }
    #konstruksi-cards .file-drop-zone {
        --zone-color: rgba(0,229,255,0.5);
        --zone-bg:    rgba(0,229,255,0.04);
    }
    #konstruksi-cards .add-card-btn {
        border: 2px dashed rgba(0,229,255,0.3);
        color: #00E5FF;
    }
    #konstruksi-cards .add-card-btn:hover {
        background: rgba(0,229,255,0.06);
        border-color: rgba(0,229,255,0.55);
    }
</style>

<div style="max-width:760px;">

    <!-- Header -->
    <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:24px;">
        <div>
            <h3 style="font-size:16px; font-weight:700; color:#fff; margin:0;">Manajemen Konstruksi</h3>
            <p style="font-size:12px; color:rgba(255,255,255,0.35); margin:4px 0 0;">Tambah dan kelola data konstruksi jaringan</p>
        </div>
        <span style="font-size:11px; font-weight:600; padding:4px 12px; border-radius:999px; background:rgba(0,229,255,0.1); color:#00E5FF; border:1px solid rgba(0,229,255,0.25);">Konstruksi</span>
    </div>

    <!-- Data tersimpan -->
    <div class="admin-card" style="margin-bottom:24px;">
        <h4 class="section-title" style="margin:0 0 16px;">Data Konstruksi Tersimpan</h4>
        <div id="konstruksi-saved" style="display:flex; flex-direction:column; gap:10px;">
            <div class="item-row">
                <div class="item-icon">
                    <svg style="width:16px;height:16px;color:#00E5FF;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
                </div>
                <div style="flex:1;">
                    <div style="font-size:13px; font-weight:600; color:#fff;">Konstruksi Tiang Listrik</div>
                    <div style="font-size:11px; color:rgba(255,255,255,0.35); margin-top:2px;">anchor-block.glb · 15 komponen · Aktif</div>
                </div>
                <span class="badge badge-green">Aktif</span>
                <button class="btn-danger" onclick="this.closest('.item-row').remove(); showToast('Item dihapus')">Hapus</button>
            </div>
            <div class="item-row">
                <div class="item-icon">
                    <svg style="width:16px;height:16px;color:#00E5FF;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
                </div>
                <div style="flex:1;">
                    <div style="font-size:13px; font-weight:600; color:#fff;">Gardu Portal</div>
                    <div style="font-size:11px; color:rgba(255,255,255,0.35); margin-top:2px;">gardu-portal.glb · 6 komponen · Aktif</div>
                </div>
                <span class="badge badge-green">Aktif</span>
                <button class="btn-danger" onclick="this.closest('.item-row').remove(); showToast('Item dihapus')">Hapus</button>
            </div>
        </div>
    </div>

    <!-- Form tambah baru -->
    <div class="admin-card">
        <h4 style="font-size:13px; font-weight:600; color:#fff; margin:0 0 18px; display:flex; align-items:center; gap:8px;">
            <svg style="width:15px;height:15px;color:#00E5FF;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            Tambah Konstruksi Baru
        </h4>

        <div id="konstruksi-cards" style="display:flex; flex-direction:column; gap:14px; margin-bottom:14px;"></div>

        <button class="add-card-btn" onclick="addKonstruksiCard()" style="margin-bottom:16px;">
            <svg style="width:16px;height:16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            Tambah Konstruksi Lagi
        </button>

        <div style="display:flex; gap:10px;">
            <button class="btn-primary" onclick="submitSemuaKonstruksi()">Simpan Semua</button>
            <button class="btn-secondary" onclick="resetKonstruksiForm()">Reset</button>
        </div>
    </div>
</div>

<script src="/js/admin/upload-card.js"></script>
<script src="/js/admin/konstruksi.js"></script>
