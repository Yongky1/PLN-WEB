<script src="/js/admin/upload-card.js"></script>
<script src="/js/admin/konstruksi.js"></script>
<script>
/* ── Wizard Step Logic ── */
let _addKStep = 0;
const _addKSteps = [
  { label: 'Detail dasar' },
  { label: 'Upload model' },
  { label: 'Pilih komponen' },
  { label: 'Konfirmasi' },
];

function openAddKonstruksiModal() {
  _addKStep = 0;
  renderAddKStep();
  document.getElementById('add-konstruksi-modal').classList.add('active');
}

function closeAddKonstruksiModal() {
  document.getElementById('add-konstruksi-modal').classList.remove('active');
}

function renderAddKStep() {
  // Panels
  document.querySelectorAll('#add-konstruksi-modal .rd-step-panel').forEach((p, i) => {
    p.classList.toggle('active', i === _addKStep);
  });
  // Stepper indicators
  document.querySelectorAll('#add-k-stepper .rd-step').forEach((s, i) => {
    s.classList.toggle('active', i === _addKStep);
    s.classList.toggle('done', i < _addKStep);
    const num = s.querySelector('.step-num');
    if (i < _addKStep) {
      num.innerHTML = '<svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>';
    } else {
      num.textContent = i + 1;
    }
  });
  // Footer
  document.getElementById('add-k-prev-btn').style.display = _addKStep > 0 ? '' : 'none';
  const nextBtn = document.getElementById('add-k-next-btn');
  if (_addKStep === _addKSteps.length - 1) {
    nextBtn.innerHTML = '<svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg> Buat Modul';
    nextBtn.onclick = () => submitSemuaKonstruksi();
  } else {
    nextBtn.innerHTML = 'Lanjutkan <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>';
    nextBtn.onclick = addKStepNext;
  }
  document.getElementById('add-k-footer-info').textContent = `Step ${_addKStep + 1} dari ${_addKSteps.length} · ${_addKSteps[_addKStep].label}`;
  // Populate review on last step
  if (_addKStep === 3) populateKReview();
}

function goAddKStep(i) { _addKStep = i; renderAddKStep(); }
function addKStepNext() { if (_addKStep < _addKSteps.length - 1) { _addKStep++; renderAddKStep(); } }
function addKStepPrev() { if (_addKStep > 0) { _addKStep--; renderAddKStep(); } }

function populateKReview() {
  const name = document.getElementById('modul-name')?.value || '—';
  const status = document.getElementById('modul-status')?.value || '—';
  const cards = document.querySelectorAll('#konstruksi-cards .upload-card');
  const matChecked = document.querySelectorAll('#modul-materials-list .mat-checkbox:checked').length;
  const toolChecked = document.querySelectorAll('#modul-tools-list .tool-checkbox:checked').length;
  document.getElementById('review-k-name').textContent = name;
  document.getElementById('review-k-status').textContent = status;
  document.getElementById('review-k-variants').textContent = cards.length + ' varian';
  document.getElementById('review-k-materials').textContent = matChecked + ' material';
  document.getElementById('review-k-tools').textContent = toolChecked + ' peralatan';

  // Preview Cover Image
  const coverImgInput = document.getElementById('modul-image');
  const reviewImg = document.getElementById('review-k-image');
  const reviewImgEmpty = document.getElementById('review-k-image-empty');
  if (coverImgInput && coverImgInput.files && coverImgInput.files.length > 0) {
    reviewImg.src = URL.createObjectURL(coverImgInput.files[0]);
    reviewImg.style.display = 'block';
    reviewImgEmpty.style.display = 'none';
  } else {
    reviewImg.src = '';
    reviewImg.style.display = 'none';
    reviewImgEmpty.style.display = 'flex';
  }

  // Preview 3D (first valid file)
  const review3d = document.getElementById('review-k-3d');
  const review3dEmpty = document.getElementById('review-k-3d-empty');
  let found3d = false;
  
  if (review3d._objectUrl) {
    URL.revokeObjectURL(review3d._objectUrl);
    review3d._objectUrl = null;
  }

  for (let i = 0; i < cards.length; i++) {
    const fileInput = cards[i].querySelector('.k-file-3d');
    if (fileInput && fileInput.files && fileInput.files.length > 0) {
      const url = URL.createObjectURL(fileInput.files[0]);
      review3d._objectUrl = url;
      review3d.src = url;
      review3d.style.display = 'block';
      review3dEmpty.style.display = 'none';
      if(review3d.dismissPoster) review3d.dismissPoster();
      found3d = true;
      break;
    }
  }

  if (!found3d) {
    review3d.removeAttribute('src');
    review3d.style.display = 'none';
    review3dEmpty.style.display = 'flex';
  }
}

/* Image helpers */
function handleModulImageChange(input, dropId, emptyId, filledId, previewContainerId, previewImgId) {
  if (input.files && input.files[0]) {
    const reader = new FileReader();
    reader.onload = function(e) {
      document.getElementById(previewContainerId).style.display = 'block';
      document.getElementById(previewImgId).src = e.target.result;
      document.getElementById(emptyId).style.display = 'none';
      document.getElementById(filledId).style.display = 'block';
      document.getElementById(dropId).classList.add('has-file');
    };
    reader.readAsDataURL(input.files[0]);
  }
}
function clearModulImage(inputId, dropId, emptyId, filledId, previewContainerId, previewImgId) {
  document.getElementById(inputId).value = '';
  document.getElementById(previewImgId).src = '';
  document.getElementById(previewContainerId).style.display = 'none';
  document.getElementById(emptyId).style.display = 'block';
  document.getElementById(filledId).style.display = 'none';
  document.getElementById(dropId).classList.remove('has-file');
}

function initImageDropZone(dropZoneId, inputId) {
  const zone = document.getElementById(dropZoneId);
  const input = document.getElementById(inputId);
  if (!zone || !input) return;

  zone.addEventListener('dragover', (e) => {
    e.preventDefault();
    zone.classList.add('dragover');
  });
  zone.addEventListener('dragleave', (e) => {
    e.preventDefault();
    zone.classList.remove('dragover');
  });
  zone.addEventListener('drop', (e) => {
    e.preventDefault();
    zone.classList.remove('dragover');
    if (e.dataTransfer.files && e.dataTransfer.files.length > 0) {
      const file = e.dataTransfer.files[0];
      if (file.type.startsWith('image/')) {
        const dt = new DataTransfer();
        dt.items.add(file);
        input.files = dt.files;
        input.dispatchEvent(new Event('change'));
      } else {
        if (typeof showToast === 'function') showToast('Format file harus gambar', 'error');
      }
    }
  });
}

document.addEventListener('DOMContentLoaded', () => {
  initImageDropZone('modul-image-drop-zone', 'modul-image');
  initImageDropZone('edit-modul-image-drop-zone', 'edit-modul-image');
});

/* Filter chips */
let _kFilter = 'all';
function setKFilter(btn, val) {
  _kFilter = val;
  document.querySelectorAll('.rd-toolbar .rd-filter-chip').forEach(b => b.classList.toggle('active', b === btn));
  loadKonstruksiSaved(_kFilter === 'all' ? '' : _kFilter);
}

/* View toggle */
function setKView(view) {
  const saved = document.getElementById('konstruksi-saved');
  const tableHead = document.getElementById('k-table-head');
  const tableBtn = document.getElementById('k-view-table');
  const gridBtn = document.getElementById('k-view-grid');
  if (view === 'grid') {
    saved.classList.add('grid-view');
    tableHead.style.display = 'none';
    tableBtn.classList.remove('active');
    gridBtn.classList.add('active');
  } else {
    saved.classList.remove('grid-view');
    tableHead.style.display = '';
    tableBtn.classList.add('active');
    gridBtn.classList.remove('active');
  }
}

function exportKonstruksi() {
  showToast('Export fitur akan segera tersedia.', 'info');
}
</script>
