<!-- views/admin/konstruksi.ejs — Admin Redesign -->
<link rel="stylesheet" href="/css/upload-card.css">

<!-- ======================== PAGE HEAD ======================== -->
<div class="rd-page-head">
  <div class="rd-page-title-block">
    <span class="rd-page-eyebrow">Manajemen Modul Pembelajaran</span>
    <h1 class="rd-page-title">Konstruksi 3D</h1>
    <p class="rd-page-subtitle">Kelola modul konstruksi listrik dengan varian model 3D, material, dan peralatan terkait.</p>
  </div>
  <div class="rd-page-actions">
    <button class="rd-btn rd-btn-secondary" onclick="exportKonstruksi()">
      <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
      Export
    </button>
    <button class="rd-btn rd-btn-primary" onclick="openAddKonstruksiModal()">
      <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      Tambah Konstruksi
    </button>
  </div>
</div>

<!-- ======================== TOOLBAR ======================== -->
<div class="rd-toolbar">
  <div class="rd-search">
    <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    <input id="search-saved-konstruksi" placeholder="Cari konstruksi..." />
  </div>
  <div class="rd-divider-v"></div>
  <button class="rd-filter-chip active" data-filter="all" onclick="setKFilter(this,'all')">Semua</button>
  <button class="rd-filter-chip" data-filter="Aktif" onclick="setKFilter(this,'Aktif')">Aktif</button>
  <button class="rd-filter-chip" data-filter="Draft" onclick="setKFilter(this,'Draft')">Draft</button>
  <button class="rd-filter-chip" data-filter="Arsip" onclick="setKFilter(this,'Arsip')">Arsip</button>
  <div class="rd-divider-v"></div>
  <div class="rd-view-toggle">
    <button id="k-view-table" class="active" onclick="setKView('table')" title="Tampilan tabel">
      <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
    </button>
    <button id="k-view-grid" onclick="setKView('grid')" title="Tampilan grid">
      <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
    </button>
  </div>
</div>

<!-- ======================== LIST ======================== -->
<div class="rd-data-card">
  <div class="rd-table-head" id="k-table-head">
    <div style="width:36px; flex-shrink:0;"></div>
    <div style="flex:1;">Modul</div>
    <div style="width:100px; text-align:center;">Status</div>
    <div style="width:90px; text-align:center;">Varian</div>
    <div style="width:90px; text-align:center;">Material</div>
    <div style="width:90px; text-align:center;">Peralatan</div>
    <div style="width:130px; text-align:center;">Aksi</div>
  </div>
  <div id="konstruksi-saved"></div>
</div>

<!-- ======================== ADD WIZARD MODAL ======================== -->
<div id="add-konstruksi-modal" class="rd-modal-overlay" onclick="if(event.target===this)closeAddKonstruksiModal()">
  <div class="rd-modal">

    <!-- Header -->
    <div class="rd-modal-header">
      <div class="rd-modal-title-block">
        <div class="rd-modal-eyebrow">Tambah Baru · Konstruksi</div>
        <h2 class="rd-modal-title">Buat Modul Konstruksi Baru</h2>
      </div>
      <button class="rd-modal-close" onclick="closeAddKonstruksiModal()">
        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>

    <!-- Stepper -->
    <div class="rd-stepper" id="add-k-stepper">
      <div class="rd-step active" data-step="0" onclick="goAddKStep(0)">
        <div class="step-num">1</div>
        <div class="step-info">
          <span class="step-label">Informasi Modul</span>
          <span class="step-name">Detail dasar</span>
        </div>
      </div>
      <div class="rd-step" data-step="1" onclick="goAddKStep(1)">
        <div class="step-num">2</div>
        <div class="step-info">
          <span class="step-label">Varian 3D</span>
          <span class="step-name">Upload model</span>
        </div>
      </div>
      <div class="rd-step" data-step="2" onclick="goAddKStep(2)">
        <div class="step-num">3</div>
        <div class="step-info">
          <span class="step-label">Material &amp; Alat</span>
          <span class="step-name">Pilih komponen</span>
        </div>
      </div>
      <div class="rd-step" data-step="3" onclick="goAddKStep(3)">
        <div class="step-num">4</div>
        <div class="step-info">
          <span class="step-label">Review</span>
          <span class="step-name">Konfirmasi</span>
        </div>
      </div>
    </div>

    <!-- Body -->
    <div class="rd-modal-body">

      <!-- Step 1: Info -->
      <div class="rd-step-panel active" id="add-k-panel-0">
        <div class="rd-section-block">
          <div class="rd-section-head">
            <div class="rd-section-title"><span class="num">1</span> Informasi Modul Konstruksi</div>
          </div>
          <div class="rd-field-row cols-2">
            <div class="rd-field-group">
              <label class="rd-field-label">Nama Modul <span class="req">*</span></label>
              <input type="text" id="modul-name" class="rd-input" placeholder="Contoh: Tower SUTT 150kV Tipe AA" />
            </div>
            <div class="rd-field-group">
              <label class="rd-field-label">Status</label>
              <select id="modul-status" class="rd-select">
                <option value="Aktif">Aktif</option>
                <option value="Draft">Draft</option>
                <option value="Nonaktif">Nonaktif</option>
              </select>
            </div>
          </div>
          <div class="rd-field-group">
            <label class="rd-field-label" style="justify-content:space-between;">
              Deskripsi
              <span class="rd-field-counter" id="modul-desc-counter">0/300</span>
            </label>
            <textarea id="modul-desc" class="rd-textarea" rows="3" maxlength="300" placeholder="Jelaskan tujuan dan cakupan modul..." oninput="document.getElementById('modul-desc-counter').textContent=this.value.length+'/300'"></textarea>
          </div>
          <div class="rd-field-group">
            <label class="rd-field-label">Cover Gambar</label>
            <div id="modul-image-drop-zone" class="rd-drop-zone" onclick="document.getElementById('modul-image').click()">
              <div class="dz-icon">
                <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
              </div>
              <div class="dz-text">
                <div id="add-img-empty">
                  <div class="dz-title">Tarik &amp; lepas atau klik untuk upload</div>
                  <div class="dz-sub">PNG · JPG · WEBP · maks 5MB · 16:9 disarankan</div>
                </div>
                <div id="add-img-filled" style="display:none;">
                  <div class="dz-title" style="color:var(--accent);">Thumbnail terpasang</div>
                  <div class="dz-sub">Klik untuk ganti foto</div>
                </div>
              </div>
              <button class="rd-btn rd-btn-secondary rd-btn-sm" onclick="event.stopPropagation();document.getElementById('modul-image').click()">Pilih file</button>
            </div>
            <input type="file" id="modul-image" accept="image/png,image/jpeg,image/webp" style="display:none" onchange="handleModulImageChange(this,'modul-image-drop-zone','add-img-empty','add-img-filled','modul-image-preview-container','modul-image-preview-img')" />
            <div id="modul-image-preview-container" style="display:none; margin-top:10px; border-radius:8px; overflow:hidden; border:1px solid var(--border-default); aspect-ratio:16/9; max-height:220px; position:relative;">
              <img id="modul-image-preview-img" src="" style="width:100%;height:100%;object-fit:cover;" />
              <div style="position:absolute;inset:0;background:rgba(0,0,0,0.5);display:flex;align-items:center;justify-content:center;opacity:0;transition:opacity .2s" onmouseover="this.style.opacity=1" onmouseout="this.style.opacity=0">
                <button class="rd-btn rd-btn-danger rd-btn-sm" onclick="clearModulImage('modul-image','modul-image-drop-zone','add-img-empty','add-img-filled','modul-image-preview-container','modul-image-preview-img')">Hapus Thumbnail</button>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Step 2: Varian 3D -->
      <div class="rd-step-panel" id="add-k-panel-1">
        <div class="rd-section-block">
          <div class="rd-section-head">
            <div>
              <div class="rd-section-title"><span class="num">2</span> Varian Model 3D</div>
              <p class="rd-section-desc">Tambahkan varian model 3D untuk modul ini.</p>
            </div>
          </div>
          <div id="konstruksi-cards" style="display:flex;flex-direction:column;gap:12px;"></div>
          <button class="rd-btn rd-btn-ghost" style="border:1px dashed var(--border-strong);width:100%;justify-content:center;padding:12px;border-radius:var(--radius-md);" onclick="addKonstruksiCard()">
            <svg width="15" height="15" fill="none" stroke="currentColor" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Tambah varian baru
          </button>
        </div>
      </div>

      <!-- Step 3: Material & Tools — berdampingan -->
      <div class="rd-step-panel" id="add-k-panel-2">
        <div class="rd-section-block">
          <div class="rd-section-head">
            <div>
              <div class="rd-section-title"><span class="num">3</span> Material &amp; Peralatan Terkait</div>
              <p class="rd-section-desc">Pilih material dan peralatan yang dibutuhkan untuk konstruksi ini.</p>
            </div>
          </div>

          <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px;">

            <!-- Kolom Material -->
            <div style="display:flex; flex-direction:column; gap:8px;">
              <div style="font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.8px; color:#818CF8; display:flex; align-items:center; gap:6px;">
                <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                Material
              </div>
              <div style="position:relative;">
                <input type="text" id="search-select-material" class="rd-input" placeholder="Cari material..." style="padding-left:36px;" />
                <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="position:absolute;left:12px;top:50%;transform:translateY(-50%);color:var(--text-muted);pointer-events:none;"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
              </div>
              <div id="modul-materials-list" style="max-height:280px;overflow-y:auto;display:flex;flex-direction:column;gap:4px;padding:6px;background:var(--bg-base);border:1px solid var(--border-default);border-radius:8px;">
                <div class="rd-muted" style="font-size:12px;padding:12px 0;">Memuat material...</div>
              </div>
            </div>

            <!-- Kolom Peralatan -->
            <div style="display:flex; flex-direction:column; gap:8px;">
              <div style="font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.8px; color:#F59E0B; display:flex; align-items:center; gap:6px;">
                <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                Peralatan
              </div>
              <div style="position:relative;">
                <input type="text" id="search-select-tools" class="rd-input" placeholder="Cari peralatan..." style="padding-left:36px;" />
                <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="position:absolute;left:12px;top:50%;transform:translateY(-50%);color:var(--text-muted);pointer-events:none;"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
              </div>
              <div id="modul-tools-list" style="max-height:280px;overflow-y:auto;display:flex;flex-direction:column;gap:4px;padding:6px;background:var(--bg-base);border:1px solid var(--border-default);border-radius:8px;">
                <div class="rd-muted" style="font-size:12px;padding:12px 0;">Memuat peralatan...</div>
              </div>
            </div>

          </div>
        </div>
      </div>

      <!-- Step 4: Review -->
      <div class="rd-step-panel" id="add-k-panel-3">
        <div class="rd-section-block">
          <div class="rd-section-head">
            <div>
              <div class="rd-section-title"><span class="num">4</span> Review &amp; Konfirmasi</div>
              <p class="rd-section-desc">Periksa kembali sebelum menyimpan.</p>
            </div>
            <span class="rd-badge rd-badge-success">Siap disimpan</span>
          </div>
          <div class="rd-review-grid">
            <div class="rd-review-tile full">
              <div class="label">Nama Modul</div>
              <div class="value" id="review-k-name">—</div>
            </div>
            <div class="rd-review-tile">
              <div class="label">Status</div>
              <div class="value" id="review-k-status">—</div>
            </div>
            <div class="rd-review-tile">
              <div class="label">Jumlah Varian</div>
              <div class="value" id="review-k-variants">—</div>
            </div>
            <div class="rd-review-tile">
              <div class="label">Material Dipilih</div>
              <div class="value" id="review-k-materials">—</div>
            </div>
            <div class="rd-review-tile">
              <div class="label">Peralatan Dipilih</div>
              <div class="value" id="review-k-tools">—</div>
            </div>
          </div>
          <div class="rd-review-previews" style="display:grid; grid-template-columns:1fr 1fr; gap:14px; margin-top:14px;">
            <div class="rd-review-tile" style="padding:10px;">
              <div class="label">Cover Gambar</div>
              <div id="review-k-image-container" style="margin-top:8px; border-radius:8px; overflow:hidden; border:1px solid var(--border-default); aspect-ratio:16/9; display:flex; align-items:center; justify-content:center; background:var(--bg-base);">
                <img id="review-k-image" src="" style="width:100%; height:100%; object-fit:cover; display:none;" />
                <span id="review-k-image-empty" class="rd-muted" style="font-size:12px; display:flex; align-items:center; gap:6px;">
                  <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                  Tidak ada cover
                </span>
              </div>
            </div>
            <div class="rd-review-tile" style="padding:10px;">
              <div class="label">Preview 3D (Varian Pertama)</div>
              <div id="review-k-3d-container" style="margin-top:8px; border-radius:8px; overflow:hidden; border:1px solid var(--border-default); aspect-ratio:16/9; display:flex; align-items:center; justify-content:center; background:var(--bg-base); position:relative;">
                <model-viewer id="review-k-3d" src="" auto-rotate camera-controls interaction-prompt="none" style="width:100%; height:100%; display:none; background: radial-gradient(circle at center, #0F1E3A 0%, #030812 100%);"></model-viewer>
                <span id="review-k-3d-empty" class="rd-muted" style="font-size:12px; display:flex; align-items:center; gap:6px;">
                  <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/></svg>
                  Tidak ada 3D Varian
                </span>
              </div>
            </div>
          </div>
        </div>
      </div>

    </div><!-- /.rd-modal-body -->

    <!-- Footer -->
    <div class="rd-modal-footer">
      <div class="rd-footer-meta">
        <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
        <span id="add-k-footer-info">Step 1 dari 4 · Detail dasar</span>
      </div>
      <div class="rd-footer-actions">
        <button class="rd-btn rd-btn-ghost" onclick="closeAddKonstruksiModal()">Batal</button>
        <button id="add-k-prev-btn" class="rd-btn rd-btn-secondary" style="display:none;" onclick="addKStepPrev()">
          <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
          Sebelumnya
        </button>
        <button id="add-k-next-btn" class="rd-btn rd-btn-primary" onclick="addKStepNext()">
          Lanjutkan
          <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </button>
      </div>
    </div>

  </div><!-- /.rd-modal -->
</div><!-- /.rd-modal-overlay -->


<!-- ======================== EDIT MODAL (restyled) ======================== -->
<div id="edit-modal" class="rd-modal-overlay" onclick="if(event.target===this)closeEditModal()">
  <div class="rd-modal">

    <div class="rd-modal-header">
      <div class="rd-modal-title-block">
        <div class="rd-modal-eyebrow">Edit · Konstruksi</div>
        <h2 class="rd-modal-title">Edit Modul &amp; Live Preview</h2>
      </div>
      <button class="rd-modal-close" onclick="closeEditModal()">
        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>

    <div class="rd-modal-body" style="overflow-y:auto;">

      <!-- Info Utama Edit -->
      <div class="rd-section-block">
        <div class="rd-section-head"><div class="rd-section-title"><span class="num">1</span> Informasi Modul</div></div>
        <div class="rd-field-row cols-2">
          <div class="rd-field-group">
            <label class="rd-field-label">Nama Modul <span class="req">*</span></label>
            <input type="text" id="edit-modul-name" class="rd-input" placeholder="Contoh: Tower SUTT 150kV" />
          </div>
          <div class="rd-field-group">
            <label class="rd-field-label">Status</label>
            <select id="edit-modul-status" class="rd-select">
              <option value="Aktif">Aktif</option>
              <option value="Draft">Draft</option>
              <option value="Nonaktif">Nonaktif</option>
            </select>
          </div>
        </div>
        <div class="rd-field-group">
          <label class="rd-field-label">Deskripsi</label>
          <textarea id="edit-modul-desc" class="rd-textarea" rows="2" style="resize:vertical;"></textarea>
        </div>

        <!-- Cover image edit -->
        <div class="rd-field-group">
          <label class="rd-field-label">Cover Gambar</label>
          <div id="edit-modul-image-wrapper" style="display:grid;grid-template-columns:1fr;gap:12px;">
            <div id="edit-modul-image-drop-zone" class="rd-drop-zone" onclick="document.getElementById('edit-modul-image').click()">
              <div class="dz-icon">
                <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
              </div>
              <div class="dz-text">
                <div id="edit-img-empty"><div class="dz-title">Pilih foto baru</div><div class="dz-sub">PNG · JPG · WEBP · maks 5MB</div></div>
                <div id="edit-img-filled" style="display:none;"><div class="dz-title" style="color:var(--accent);">Thumbnail terpasang</div><div class="dz-sub">Klik untuk ganti</div></div>
              </div>
              <button class="rd-btn rd-btn-secondary rd-btn-sm" onclick="event.stopPropagation();document.getElementById('edit-modul-image').click()">Pilih file</button>
            </div>
            <input type="file" id="edit-modul-image" accept="image/png,image/jpeg,image/webp" style="display:none" onchange="
              if(this.files&&this.files[0]){
                const reader=new FileReader();
                reader.onload=function(e){
                  document.getElementById('edit-modul-image-wrapper').style.gridTemplateColumns='1fr 1fr';
                  document.getElementById('edit-modul-image-preview-container').style.display='block';
                  document.getElementById('edit-modul-image-preview').src=e.target.result;
                  document.getElementById('edit-modul-image-deleted').value='false';
                  document.getElementById('edit-img-empty').style.display='none';
                  document.getElementById('edit-img-filled').style.display='block';
                  document.getElementById('edit-modul-image-drop-zone').classList.add('has-file');
                };
                reader.readAsDataURL(this.files[0]);
              }
            " />
            <div id="edit-modul-image-preview-container" style="display:none;position:relative;aspect-ratio:16/9;border-radius:8px;overflow:hidden;border:1px solid var(--border-default);">
              <img id="edit-modul-image-preview" src="" style="width:100%;height:100%;object-fit:cover;" />
              <div style="position:absolute;inset:0;background:rgba(0,0,0,0.4);display:flex;align-items:center;justify-content:center;opacity:0;transition:opacity .2s" onmouseover="this.style.opacity=1" onmouseout="this.style.opacity=0">
                <button class="rd-btn rd-btn-danger rd-btn-sm" onclick="
                  document.getElementById('edit-modul-image').value='';
                  document.getElementById('edit-modul-image-preview').src='';
                  document.getElementById('edit-modul-image-wrapper').style.gridTemplateColumns='1fr';
                  document.getElementById('edit-modul-image-preview-container').style.display='none';
                  document.getElementById('edit-modul-image-deleted').value='true';
                  document.getElementById('edit-img-empty').style.display='block';
                  document.getElementById('edit-img-filled').style.display='none';
                  document.getElementById('edit-modul-image-drop-zone').classList.remove('has-file');
                ">Hapus Thumbnail</button>
              </div>
            </div>
            <input type="hidden" id="edit-modul-image-deleted" value="false" />
          </div>
        </div>

        <!-- Material & Tools selection in edit -->
        <div class="rd-field-row cols-2">
          <div class="rd-field-group">
            <label class="rd-field-label">Material</label>
            <div id="edit-modul-materials-list" style="max-height:160px;overflow-y:auto;display:flex;flex-direction:column;gap:4px;padding:8px;background:var(--bg-base);border:1px solid var(--border-default);border-radius:8px;"></div>
          </div>
          <div class="rd-field-group">
            <label class="rd-field-label">Peralatan</label>
            <div id="edit-modul-tools-list" style="max-height:160px;overflow-y:auto;display:flex;flex-direction:column;gap:4px;padding:8px;background:var(--bg-base);border:1px solid var(--border-default);border-radius:8px;"></div>
          </div>
        </div>
      </div>

      <!-- Varian + 3D Preview -->
      <div class="rd-section-block" style="margin-top:14px;">
        <div class="rd-section-head"><div class="rd-section-title"><span class="num">2</span> Varian &amp; Preview 3D</div></div>
        <div style="display:flex;gap:20px;flex-wrap:wrap;">

          <!-- Kiri: Varian cards -->
          <div style="flex:1;min-width:280px;display:flex;flex-direction:column;gap:12px;">
            <div id="edit-konstruksi-cards" style="display:flex;flex-direction:column;gap:12px;max-height:320px;overflow-y:auto;padding-right:4px;"></div>
            <button class="rd-btn rd-btn-ghost" style="border:1px dashed var(--border-strong);width:100%;justify-content:center;padding:10px;" onclick="addEditKonstruksiCard()">
              <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              Tambah Varian
            </button>
          </div>

          <!-- Kanan: 3D Preview -->
          <div style="flex:1;min-width:280px;background:rgba(0,0,0,0.2);border-radius:12px;overflow:hidden;border:1px solid var(--border-default);position:relative;min-height:320px;">
            <script type="module" src="https://ajax.googleapis.com/ajax/libs/model-viewer/3.4.0/model-viewer.min.js"></script>
            <model-viewer id="admin-preview-viewer" src="" camera-controls auto-rotate rotation-per-second="30deg"
              interaction-prompt="none" shadow-intensity="1.5" environment-image="neutral" exposure="1"
              style="width:100%;height:100%;min-height:320px;outline:none;background:#0A1520;">
            </model-viewer>
            <div id="admin-preview-empty" style="position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;color:var(--text-muted);pointer-events:none;gap:8px;">
              <svg width="36" height="36" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/></svg>
              <span style="font-size:12px;font-weight:600;">Belum ada file GLB terpilih</span>
            </div>
            <div style="position:absolute;bottom:12px;left:12px;right:12px;z-index:10;">
              <select id="admin-preview-selector" onchange="changeAdminPreview()" class="rd-select" style="background:rgba(0,0,0,0.65);backdrop-filter:blur(6px);">
