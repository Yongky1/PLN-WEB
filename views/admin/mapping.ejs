<!-- views/admin/mapping.ejs -->
<style>
  /* ── Page layout override ── */
  [data-module="mapping"] .rd-page {
    padding: 0;
    overflow: hidden;
    max-width: 100%;
    gap: 0;
  }

  [data-module="mapping"] .rd-main {
    overflow: hidden;
    height: 100vh;
  }

  /* ── Split layout ── */
  .mp-layout {
    display: grid;
    grid-template-columns: 1fr 560px;
    height: calc(100vh - var(--header-height));
    overflow: hidden;
  }

  /* ── LEFT: 3D Viewer ── */
  .mp-viewer {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    background: var(--bg-base);
    border-right: 1px solid var(--border-default);
  }

  .mp-viewer-topbar {
    height: 48px;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 0 16px;
    border-bottom: 1px solid var(--border-subtle);
    flex-shrink: 0;
    background: var(--bg-surface);
  }

  .mp-back-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    color: var(--text-tertiary);
    text-decoration: none;
    font-size: 12px;
    font-weight: 500;
    padding: 5px 10px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border-subtle);
    transition: all .15s;
    flex-shrink: 0;
  }

  .mp-back-btn:hover {
    color: var(--text-primary);
    border-color: var(--border-default);
    background: rgba(255, 255, 255, 0.04);
  }

  .mp-viewer-module-title {
    font-size: 13px;
    font-weight: 600;
    color: var(--text-secondary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    flex: 1;
  }

  .mp-asset-nav {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-shrink: 0;
  }

  .mp-asset-nav-btn {
    width: 28px;
    height: 28px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border-default);
    background: transparent;
    color: var(--text-secondary);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all .15s;
  }

  .mp-asset-nav-btn:hover:not(:disabled) {
    background: rgba(255, 255, 255, 0.05);
    color: var(--text-primary);
  }

  .mp-asset-nav-btn:disabled {
    opacity: 0.35;
    cursor: default;
  }

  .mp-asset-label {
    font-size: 11px;
    color: var(--text-tertiary);
    font-family: var(--font-mono);
    white-space: nowrap;
  }

  .mp-canvas-wrap {
    flex: 1;
    position: relative;
    overflow: hidden;
  }

  #mp-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    cursor: grab;
    outline: none;
  }

  .mp-loading-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    background: rgba(10, 14, 20, 0.7);
    backdrop-filter: blur(4px);
    z-index: 10;
    font-size: 13px;
    color: var(--text-secondary);
  }

  .mp-spinner {
    width: 28px;
    height: 28px;
    border: 2px solid rgba(255, 255, 255, 0.08);
    border-top-color: var(--accent);
    border-radius: 50%;
    animation: mp-spin 0.7s linear infinite;
  }

  @keyframes mp-spin {
    to {
      transform: rotate(360deg);
    }
  }

  .mp-viewer-footer {
    height: 52px;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 0 16px;
    border-top: 1px solid var(--border-subtle);
    background: var(--bg-surface);
    flex-shrink: 0;
  }

  .mp-cursor-icon {
    color: var(--text-muted);
    flex-shrink: 0;
  }

  .mp-selected-info {
    flex: 1;
    min-width: 0;
  }

  .mp-selected-label {
    font-size: 10px;
    color: var(--text-muted);
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    line-height: 1;
    margin-bottom: 2px;
  }

  .mp-selected-mesh-name {
    font-size: 13px;
    font-weight: 600;
    color: var(--text-secondary);
    font-family: var(--font-mono);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .mp-selected-mesh-name.has-selection {
    color: #fbbf24;
  }

  .mp-apply-btn {
    display: none;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    border-radius: var(--radius-md);
    border: 1px solid rgba(251, 191, 36, 0.3);
    background: rgba(251, 191, 36, 0.08);
    color: #fbbf24;
    font-size: 12px;
    font-weight: 600;
    transition: all .15s;
    flex-shrink: 0;
  }

  .mp-apply-btn.visible {
    display: flex;
  }

  .mp-apply-btn:hover {
    background: rgba(251, 191, 36, 0.14);
    border-color: rgba(251, 191, 36, 0.5);
  }

  /* ── RIGHT: Mapping Panel ── */
  .mp-panel {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    background: var(--bg-surface);
  }

  .mp-panel-header {
    padding: 16px 20px;
    border-bottom: 1px solid var(--border-default);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    flex-shrink: 0;
  }

  .mp-panel-title {
    font-size: 14px;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0 0 2px;
  }

  .mp-panel-subtitle {
    font-size: 11.5px;
    color: var(--text-tertiary);
    margin: 0;
  }

  .mp-save-all-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    border-radius: var(--radius-md);
    border: 1px solid var(--border-strong);
    background: rgba(255, 255, 255, 0.05);
    color: var(--text-primary);
    font-size: 12.5px;
    font-weight: 600;
    transition: all .15s;
    flex-shrink: 0;
  }

  .mp-save-all-btn:hover {
    background: rgba(255, 255, 255, 0.09);
    border-color: rgba(255, 255, 255, 0.2);
  }

  .mp-save-all-btn:disabled {
    opacity: 0.5;
    cursor: default;
  }

  .mp-panel-body {
    flex: 1;
    overflow-y: auto;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .mp-panel-body::-webkit-scrollbar {
    width: 4px;
  }

  .mp-panel-body::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.07);
    border-radius: 4px;
  }

  /* ── Section ── */
  .mp-section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 10px;
  }

  .mp-section-label {
    font-size: 10.5px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-tertiary);
    font-family: var(--font-mono);
  }

  .mp-section-count {
    font-size: 10px;
    font-family: var(--font-mono);
    color: var(--text-muted);
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--border-subtle);
    border-radius: 999px;
    padding: 1px 7px;
  }

  /* ── Item card ── */
  .mp-item {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: border-color .15s;
    margin-bottom: 8px;
  }

  .mp-item:last-child {
    margin-bottom: 0;
  }

  .mp-item:hover {
    border-color: var(--border-default);
  }

  .mp-item-header {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 12px 8px;
  }

  .mp-item-thumb {
    width: 36px;
    height: 36px;
    border-radius: var(--radius-sm);
    object-fit: cover;
    flex-shrink: 0;
    background: rgba(255, 255, 255, 0.04);
  }

  .mp-item-thumb-placeholder {
    width: 36px;
    height: 36px;
    border-radius: var(--radius-sm);
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--border-subtle);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    flex-shrink: 0;
  }

  .mp-item-meta {
    flex: 1;
    min-width: 0;
  }

  .mp-item-name {
    font-size: 13px;
    font-weight: 600;
    color: var(--text-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .mp-item-sub {
    font-size: 11px;
    color: var(--text-muted);
    margin-top: 1px;
  }

  .mp-status-badge {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    font-weight: 700;
    flex-shrink: 0;
  }

  .mp-status-badge.ok {
    background: rgba(74, 222, 128, 0.12);
    color: #4ade80;
    border: 1px solid rgba(74, 222, 128, 0.25);
  }

  .mp-status-badge.empty {
    background: rgba(248, 113, 113, 0.12);
    color: #f87171;
    border: 1px solid rgba(248, 113, 113, 0.25);
  }

  .mp-item-control {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 8px 12px 10px;
    border-top: 1px solid var(--border-subtle);
    background: rgba(0, 0, 0, 0.1);
  }

  .mp-item-actions {
    display: flex;
    gap: 6px;
  }

  .mp-mesh-input {
    width: 100%;
    box-sizing: border-box;
    height: 32px;
    padding: 0 10px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-md);
    color: var(--text-primary);
    font-size: 12px;
    font-family: var(--font-mono);
    outline: none;
    transition: border-color .15s, box-shadow .15s;
    min-width: 0;
  }

  .mp-mesh-input:focus {
    border-color: var(--border-focus);
    box-shadow: 0 0 0 2px rgba(89, 145, 255, 0.12);
  }

  .mp-mesh-input::placeholder {
    color: var(--text-muted);
    font-family: var(--font-sans);
    font-size: 11.5px;
  }

  .mp-save-item-btn {
    flex: 1;
    height: 32px;
    padding: 0 12px;
    border-radius: var(--radius-md);
    border: 1px solid var(--border-default);
    background: rgba(255, 255, 255, 0.05);
    color: var(--text-secondary);
    font-size: 12px;
    font-weight: 600;
    transition: all .15s;
    white-space: nowrap;
  }

  .mp-save-item-btn:hover {
    background: rgba(255, 255, 255, 0.09);
    color: var(--text-primary);
    border-color: var(--border-strong);
  }

  .mp-save-item-btn.saving {
    opacity: 0.6;
    cursor: default;
  }

  .mp-cancel-item-btn {
    flex: 1;
    height: 32px;
    padding: 0 10px;
    border-radius: var(--radius-md);
    border: 1px solid rgba(248, 113, 113, 0.2);
    background: rgba(248, 113, 113, 0.06);
    color: rgba(248, 113, 113, 0.7);
    font-size: 12px;
    font-weight: 600;
    transition: all .15s;
    white-space: nowrap;
  }

  .mp-cancel-item-btn:hover {
    background: rgba(248, 113, 113, 0.12);
    color: #f87171;
    border-color: rgba(248, 113, 113, 0.4);
  }

  .mp-mesh-list {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .mp-mesh-row {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .mp-mesh-row .mp-mesh-input {
    flex: 1;
  }

  .mp-mesh-remove-btn {
    flex-shrink: 0;
    width: 28px;
    height: 32px;
    border-radius: var(--radius-md);
    border: 1px solid rgba(248, 113, 113, 0.25);
    background: rgba(248, 113, 113, 0.07);
    color: rgba(248, 113, 113, 0.7);
    font-size: 16px;
    line-height: 1;
    cursor: pointer;
    transition: all .15s;
  }

  .mp-mesh-remove-btn:hover {
    background: rgba(248, 113, 113, 0.15);
    color: #f87171;
    border-color: rgba(248, 113, 113, 0.45);
  }

  .mp-mesh-add-btn {
    width: 100%;
    height: 26px;
    padding: 0 10px;
    border-radius: var(--radius-md);
    border: 1px dashed var(--border-default);
    background: transparent;
    color: var(--text-muted);
    font-size: 11px;
    font-weight: 600;
    cursor: pointer;
    transition: all .15s;
  }

  .mp-mesh-add-btn:hover {
    border-color: var(--border-strong);
    color: var(--text-secondary);
    background: rgba(255, 255, 255, 0.04);
  }

  .mp-display-name-row {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .mp-display-name-actions {
    display: flex;
    gap: 4px;
  }

  .mp-dn-save-btn,
  .mp-dn-cancel-btn {
    flex: 1;
    height: 24px;
    padding: 0 7px;
    border-radius: var(--radius-sm);
    font-size: 10.5px;
    font-weight: 600;
    transition: all .15s;
    white-space: nowrap;
  }

  .mp-dn-save-btn {
    border: 1px solid var(--border-default);
    background: rgba(255, 255, 255, 0.05);
    color: var(--text-secondary);
  }

  .mp-dn-save-btn:hover {
    background: rgba(255, 255, 255, 0.09);
    color: var(--text-primary);
  }

  .mp-dn-cancel-btn {
    border: 1px solid rgba(248, 113, 113, 0.2);
    background: rgba(248, 113, 113, 0.06);
    color: rgba(248, 113, 113, 0.7);
  }

  .mp-dn-cancel-btn:hover {
    background: rgba(248, 113, 113, 0.12);
    color: #f87171;
    border-color: rgba(248, 113, 113, 0.4);
  }

  /* ── Empty state ── */
  .mp-empty-state {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 40px 20px;
    text-align: center;
    color: var(--text-muted);
  }

  .mp-empty-state p {
    font-size: 13px;
    margin: 0;
  }

  .mp-empty-state a {
    font-size: 12px;
    color: var(--accent);
    text-decoration: none;
  }

  .mp-empty-state a:hover {
    text-decoration: underline;
  }

  /* ── Mesh hint bar ── */
  .mp-hint {
    position: absolute;
    bottom: 16px;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(10, 14, 20, 0.8);
    backdrop-filter: blur(8px);
    border: 1px solid var(--border-default);
    border-radius: 999px;
    padding: 6px 16px;
    font-size: 11.5px;
    color: var(--text-tertiary);
    pointer-events: none;
    white-space: nowrap;
  }

  /* ── Mesh Overview ── */
  .mp-overview-hint {
    font-size: 11.5px;
    color: var(--text-muted);
    font-style: italic;
    padding: 2px 0 4px;
  }

  .mp-mesh-group-label {
    font-size: 9.5px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    font-family: var(--font-mono);
    padding: 6px 0 3px;
  }

  .mp-mesh-group-label:first-child {
    padding-top: 0;
  }

  .mp-mesh-row {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    padding: 5px 7px;
    border-radius: var(--radius-sm);
    margin-bottom: 2px;
    border: 1px solid transparent;
    transition: background .12s, border-color .12s;
    scroll-margin-top: 8px;
    cursor: pointer;
  }

  .mp-mesh-row:hover {
    background: rgba(255, 255, 255, 0.03);
  }

  .mp-mesh-row.is-focused {
    background: rgba(251, 191, 36, 0.07);
    border-color: rgba(251, 191, 36, 0.22);
  }

  .mp-mesh-row.is-focused .mp-mesh-row-name {
    color: #fbbf24;
  }

  .mp-mesh-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 3px;
  }

  .mp-mesh-dot.connected {
    background: #4ade80;
    box-shadow: 0 0 4px rgba(74, 222, 128, 0.5);
  }

  .mp-mesh-dot.unconnected {
    background: transparent;
    border: 1.5px solid rgba(255, 255, 255, 0.2);
  }

  .mp-mesh-row-info {
    flex: 1;
    min-width: 0;
  }

  .mp-mesh-row-name {
    font-size: 11.5px;
    font-weight: 600;
    font-family: var(--font-mono);
    color: var(--text-secondary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    line-height: 1.35;
  }

  .mp-mesh-row-sub {
    font-size: 10.5px;
    color: var(--text-muted);
    margin-top: 1px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .mp-mesh-row-sub.connected {
    color: rgba(74, 222, 128, 0.65);
  }

  .mp-cfg-divider {
    height: 1px;
    background: var(--border-subtle);
    margin: 4px 0;
  }

  /* ── Display name input inside mesh rows ── */
  .mp-display-name-wrap {
    margin-top: 5px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .mp-display-name-label {
    font-size: 9.5px;
    color: var(--text-muted);
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .mp-display-name-input {
    height: 24px;
    padding: 0 7px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-sm);
    color: var(--text-secondary);
    font-size: 11px;
    outline: none;
    transition: border-color .15s;
    width: 100%;
    box-sizing: border-box;
  }

  .mp-display-name-input:focus {
    border-color: var(--border-focus);
    box-shadow: 0 0 0 2px rgba(89, 145, 255, 0.10);
  }

  .mp-display-name-input::placeholder {
    color: var(--text-muted);
    font-size: 10.5px;
    font-style: italic;
  }

  /* ── Two-column panel layout ── */
  .mp-panel-cols {
    flex: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    overflow: hidden;
    min-height: 0;
  }

  .mp-col {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    min-height: 0;
  }

  .mp-col:first-child {
    border-right: 1px solid var(--border-subtle);
  }

  .mp-col-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 14px;
    border-bottom: 1px solid var(--border-subtle);
    background: rgba(255, 255, 255, 0.015);
    flex-shrink: 0;
  }

  .mp-col-label {
    font-size: 10.5px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-tertiary);
    font-family: var(--font-mono);
  }

  .mp-col-count {
    font-size: 10px;
    font-family: var(--font-mono);
    color: var(--text-muted);
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--border-subtle);
    border-radius: 999px;
    padding: 1px 7px;
  }

  .mp-col-body {
    flex: 1;
    overflow-y: auto;
    padding: 12px;
    min-height: 0;
  }

  .mp-col-body::-webkit-scrollbar {
    width: 4px;
  }

  .mp-col-body::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.07);
    border-radius: 4px;
  }

  /* ── Search bar ── */
  .mp-col-search-wrap {
    padding: 8px 12px;
    border-bottom: 1px solid var(--border-subtle);
    flex-shrink: 0;
    background: rgba(255, 255, 255, 0.01);
  }

  .mp-col-search {
    width: 100%;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 8px;
    padding: 6px 10px 6px 30px;
    font-size: 11.5px;
    color: var(--text-primary);
    font-family: var(--font-sans);
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
    box-sizing: border-box;
  }

  .mp-col-search::placeholder {
    color: var(--text-muted);
  }

  .mp-col-search:focus {
    border-color: rgba(255, 215, 0, 0.35);
    box-shadow: 0 0 0 3px rgba(255, 215, 0, 0.06);
  }

  .mp-col-search-wrap-inner {
    position: relative;
  }

  .mp-col-search-icon {
    position: absolute;
    left: 8px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-muted);
    pointer-events: none;
    display: flex;
    align-items: center;
  }

  .mp-item.mp-hidden {
    display: none !important;
  }

  .mp-mesh-row-item.mp-hidden {
    display: none !important;
  }

  .mp-mesh-row.mp-hidden {
    display: none !important;
  }

  .mp-mesh-group-label.mp-hidden {
    display: none !important;
  }
</style>

<!-- Embedded module data for JS -->
<script type="application/json" id="mapping-module-data"><%- JSON.stringify(moduleData) %></script>

<!-- Add Material Modal -->
<div id="mp-add-mat-modal" class="rd-modal-overlay" style="z-index:9999;">
  <div class="rd-modal"
    style="background:#131824; border:1px solid rgba(255,255,255,0.1); border-radius:16px; width:400px; max-width:90%; padding:20px; box-shadow:0 20px 40px rgba(0,0,0,0.5);">
    <h3 style="margin:0 0 16px; font-size:16px; font-weight:700; color:#fff;">Tambah Material ke Modul</h3>
    <input type="text" id="mp-add-mat-search" placeholder="Cari material..." class="rd-input"
      style="margin-bottom:12px; background:rgba(255,255,255,0.05); border-color:rgba(255,255,255,0.1);"
       autocomplete="off">
    <div id="mp-add-mat-list"
      style="max-height:260px; overflow-y:auto; display:flex; flex-direction:column; gap:6px; padding-right:4px; margin-bottom:16px;">
      <div style="color:rgba(255,255,255,0.5); font-size:12px; text-align:center; padding:20px 0;">Memuat data
        material...</div>
    </div>
    <div style="display:flex; justify-content:flex-end; gap:10px;">
      <button onclick="document.getElementById('mp-add-mat-modal').classList.remove('active')"
        style="background:transparent; border:1px solid rgba(255,255,255,0.2); color:#fff; padding:8px 16px; border-radius:6px; cursor:pointer;">Batal</button>
      <button id="mp-add-mat-submit" 
        style="background:#FFD700; border:none; color:#000; font-weight:600; padding:8px 16px; border-radius:6px; cursor:pointer;">Tambahkan</button>
    </div>
  </div>
</div>

<!-- Split layout -->
<div class="mp-layout">

  <!-- ═══════════════ LEFT: 3D VIEWER ═══════════════ -->
  <div class="mp-viewer">

    <!-- Top bar -->
    <div class="mp-viewer-topbar">
      <a href="/admin/modules" class="mp-back-btn">
        <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <polyline points="15 18 9 12 15 6" />
        </svg>
        Modul
      </a>
      <span class="mp-viewer-module-title"><%- moduleData.title %></span>

      <div class="mp-asset-nav" id="mp-asset-nav" style="display:none">
        <button class="mp-asset-nav-btn" id="mp-prev-btn" onclick="window.mpPrevAsset && window.mpPrevAsset()"
          title="Varian sebelumnya">
          <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <polyline points="15 18 9 12 15 6" />
          </svg>
        </button>
        <span class="mp-asset-label" id="mp-asset-label">1 / 1</span>
        <button class="mp-asset-nav-btn" id="mp-next-btn" onclick="window.mpNextAsset && window.mpNextAsset()"
          title="Varian berikutnya">
          <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <polyline points="9 18 15 12 9 6" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Canvas -->
    <div class="mp-canvas-wrap" id="mp-canvas-wrap">
      <button id="mp-toggle-rotate-btn" title="Pause/Play Rotation"
        style="position: absolute; top: 1.5rem; right: 1.5rem; width: 2.75rem; height: 2.75rem; background-color: rgba(29, 29, 31, 0.6); backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px); border-radius: 9999px; display: flex; align-items: center; justify-content: center; color: var(--color-pln-yellow, #ffd700); border: 1px solid rgba(255, 255, 255, 0.1); box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04); transition: all 0.2s; z-index: 20; cursor: pointer;"
        onmouseover="this.style.transform='scale(1.05)'; this.style.backgroundColor='rgba(0,0,0,0.8)';"
        onmouseout="this.style.transform='scale(1)'; this.style.backgroundColor='rgba(29, 29, 31, 0.6)';">
        <svg id="mp-icon-pause" style="width: 1.25rem; height: 1.25rem;" fill="none" stroke="currentColor"
          viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 9v6m4-6v6"></path>
        </svg>
        <svg id="mp-icon-play" style="width: 1.25rem; height: 1.25rem; display: none;" fill="none" stroke="currentColor"
          viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"></path>
        </svg>
      </button>

      <canvas id="mp-canvas"></canvas>
      <div class="mp-hint">Drag untuk rotasi · Scroll untuk zoom · Klik mesh untuk memilih</div>

      <div class="mp-loading-overlay" id="mp-loading">
        <div class="mp-spinner"></div>
        <span id="mp-loading-text">Memuat model 3D...</span>
      </div>
    </div>

    <!-- Footer: selected mesh info -->
    <div class="mp-viewer-footer">
      <svg class="mp-cursor-icon" width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5" />
      </svg>
      <div class="mp-selected-info">
        <div class="mp-selected-label">Mesh terpilih</div>
        <div class="mp-selected-mesh-name" id="mp-selected-mesh-name">Klik mesh untuk memilih</div>
      </div>
      <button class="mp-apply-btn" id="mp-apply-btn">
        <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z" />
        </svg>
        Isi ke item kosong
      </button>
    </div>
  </div>

  <!-- ═══════════════ RIGHT: MAPPING PANEL ═══════════════ -->
  <div class="mp-panel">

    <!-- Panel header -->
    <div class="mp-panel-header">
      <div>
        <h3 class="mp-panel-title">Mapping Mesh</h3>
        <p class="mp-panel-subtitle">Hubungkan mesh ke material</p>
      </div>
      <button class="mp-save-all-btn" id="mp-save-all-btn">
        <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4" />
        </svg>
        Simpan Semua
      </button>
    </div>

    <!-- Two-column panel layout -->
    <% const hasMaterials=moduleData.materials && moduleData.materials.length> 0;
      const hasTools = moduleData.tools && moduleData.tools.length > 0;
      %>
      <div class="mp-panel-cols">

        <!-- Left column: Material -->
        <div class="mp-col">
          <div class="mp-col-header" style="padding-right:8px;">
            <div style="display:flex; align-items:center; gap:8px;">
              <span class="mp-col-label">Material</span>
              <span class="mp-col-count">
                <%= hasMaterials ? moduleData.materials.length : 0 %>
              </span>
            </div>
            <button class="mp-add-mat-btn"  title="Tambah Material ke Modul"
              style="background:rgba(255,215,0,0.1); border:1px solid rgba(255,215,0,0.25); color:#FFD700; border-radius:6px; width:24px; height:24px; display:flex; align-items:center; justify-content:center; cursor:pointer; transition:all 0.2s;"
              onmouseover="this.style.background='rgba(255,215,0,0.2)'"
              onmouseout="this.style.background='rgba(255,215,0,0.1)'">
              <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
              </svg>
            </button>
          </div>
          <div class="mp-col-search-wrap">
            <div class="mp-col-search-wrap-inner">
              <span class="mp-col-search-icon">
                <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <circle cx="11" cy="11" r="8" />
                  <path d="m21 21-4.35-4.35" />
                </svg>
              </span>
              <input type="text" id="mp-material-search" class="mp-col-search" placeholder="Cari material..."
                 autocomplete="off" spellcheck="false">
            </div>
          </div>
          <div class="mp-col-body">
            <% if (hasMaterials) { %>
              <% moduleData.materials.forEach(function(row) { const mat=row.material || {}; const meshes=row.meshes ||
                []; const hasMesh=meshes.length> 0;
                const originalsJson = JSON.stringify(meshes.map(function(m){ return m.mesh_name; }));
                %>
                <div class="mp-item" data-id="<%= row.id %>" data-type="material">
                  <div class="mp-item-header">
                    <% if (mat.image) { %>
                      <img class="mp-item-thumb" src="<%= mat.image %>" alt="">
                      <% } else { %>
                        <div class="mp-item-thumb-placeholder">📦</div>
                        <% } %>
                          <div class="mp-item-meta">
                            <div class="mp-item-name"><%- mat.name || '-' %></div>
                            <div class="mp-item-sub">Qty: <%= row.quantity || 1 %>
                                <% if (mat.code) { %> · <%= mat.code %>
                                    <% } %>
                            </div>
                          </div>
                          <span class="mp-status-badge <%= hasMesh ? 'ok' : 'empty' %>" id="mp-status-<%= row.id %>">
                            <%= hasMesh ? '✓' : '✗' %>
                          </span>
                  </div>
                  <div class="mp-item-control">
                    <div class="mp-mesh-list" data-originals="<%= originalsJson %>">
                      <% if (meshes.length> 0) { %>
                        <% meshes.forEach(function(mesh) { %>
                          <div class="mp-mesh-row">
                            <input type="text" class="mp-mesh-input" list="mp-mesh-datalist"
                              value="<%= mesh.mesh_name %>" placeholder="Pilih atau ketik nama mesh..."
                              autocomplete="off" spellcheck="false" />
                            <button class="mp-mesh-remove-btn" 
                              title="Hapus baris ini">−</button>
                          </div>
                          <% }); %>
                            <% } else { %>
                              <div class="mp-mesh-row">
                                <input type="text" class="mp-mesh-input" list="mp-mesh-datalist" value=""
                                  placeholder="Pilih atau ketik nama mesh..." autocomplete="off" spellcheck="false" />
                                <button class="mp-mesh-remove-btn" 
                                  title="Hapus baris ini">−</button>
                              </div>
                              <% } %>
                    </div>
                    <button class="mp-mesh-add-btn" >+ Tambah Mesh</button>
                    <div class="mp-item-actions">
                      <button class="mp-save-item-btn" >Simpan</button>
                      <button class="mp-cancel-item-btn" >Batal</button>
                    </div>
                  </div>
                </div>
                <% }); %>
                  <% } else { %>
                    <div class="mp-empty-state">
                      <svg width="36" height="36" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                        style="color:var(--text-muted);opacity:0.5">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                          d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                      </svg>
                      <p>Belum ada material yang<br>terhubung ke modul ini.</p>
                      <a href="/admin/modules">Kelola di halaman Modul →</a>
                    </div>
                    <% } %>
          </div>
        </div>

        <!-- Right column: Mesh Status (populated by JS after GLB load) -->
        <div class="mp-col">
          <div class="mp-col-header">
            <span class="mp-col-label">Status Mesh</span>
            <span class="mp-col-count" id="mp-mesh-overview-count">—</span>
          </div>
          <div class="mp-col-search-wrap">
            <div class="mp-col-search-wrap-inner">
              <span class="mp-col-search-icon">
                <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <circle cx="11" cy="11" r="8" />
                  <path d="m21 21-4.35-4.35" />
                </svg>
              </span>
              <input type="text" id="mp-mesh-search" class="mp-col-search" placeholder="Cari nama mesh..."
                 autocomplete="off" spellcheck="false">
            </div>
          </div>
          <div class="mp-col-body">
            <p class="mp-overview-hint" id="mp-overview-hint">Menunggu model 3D dimuat...</p>
            <div id="mp-mesh-overview-body"></div>
          </div>
        </div>

      </div>
  </div>
</div>

<!-- Shared datalist — diisi oleh Three.js setelah GLB load -->
<datalist id="mp-mesh-datalist"></datalist>

<!-- ═══════════════ API & UI LOGIC ═══════════════ -->
<script src="/js/admin/mapping-ui.js"></script>

<!-- ═══════════════ THREE.JS — 3D VIEWER ═══════════════ -->
<script type="importmap">
{
  "imports": {
    "three": "/scripts/three/three.module.js"
  }
}
</script>
<script type="module" src="/js/admin/mapping-viewer.js"></script>
