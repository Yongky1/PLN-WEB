<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('partials/head', { title }) %>
</head>
<body style="background:#F5F8FC; color:#1A2B4A; min-height:100vh; display:flex; align-items:center; justify-content:center; font-family:'Inter',system-ui,sans-serif; margin:0;">
    <div style="text-align:center; padding:24px 32px; max-width:480px; margin:0 auto;">
        <p style="font-size:72px; font-weight:800; color:#0052A3; margin:0 0 16px;"><%= status %></p>
        <h1 style="font-size:24px; font-weight:700; margin:0 0 12px;">Terjadi Kesalahan</h1>
        <p style="color:#5A6F8F; margin:0 0 32px;"><%= message %></p>
        <a href="/" style="display:inline-block; padding:12px 28px; background:#0052A3; color:#fff; font-weight:700; border-radius:12px; text-decoration:none; transition:background 0.2s;">
            Kembali ke Beranda
        </a>
    </div>
</body>
</html>
