<!DOCTYPE html>
<html lang="id">

<head>
  <%- include('partials/head', { isLanding: true }) %>
</head>

<body class="landing-page">

  <!-- JALA Loader -->
  <div id="jala-loader" style="position: fixed; inset: 0; background: #ffffff; z-index: 9999; display: flex; flex-direction: column; align-items: center; justify-content: center; transition: opacity 0.5s ease;">
    <h2 style="font-family: 'Inter', sans-serif; font-weight: 700; color: #111827; font-size: 24px; letter-spacing: -0.025em; margin-bottom: 1rem;">JALA</h2>
    <div style="width: 200px; height: 2px; background: rgba(0,0,0,0.05); border-radius: 2px; overflow: hidden;">
      <div style="width: 100%; height: 100%; background: #2C5C88; animation: load-progress 1.5s ease-in-out infinite;"></div>
    </div>
    <style>
      @keyframes load-progress {
        0% { transform: translateX(-100%); }
        100% { transform: translateX(100%); }
      }
    </style>
  </div>

  <!-- Importmap untuk Three.js (sama seperti halaman 3D lain) -->
  <script type="importmap">
  {
    "imports": {
      "three": "/scripts/three/three.module.js",
      "three/addons/": "/scripts/three/jsm/"
    }
  }
  </script>

  <!-- Scroll 3D Background (model GLB di-scrub oleh scroll) -->
  <div id="scroll-video-container">
    <!-- Gradient placeholder (tampil saat model loading / fallback bila WebGL gagal) -->
    <div class="video-placeholder"></div>
    <canvas id="hero-3d-canvas"></canvas>
    <div class="overlay"></div>
  </div>

  <!-- Particles -->
  <canvas id="particles-canvas"></canvas>

  <!-- Fixed Cards Overlay -->
  <%- include('partials/categories') %>

  <!-- Navigation -->
  <%- include('partials/navbar', { isLanding: true }) %>

  <!-- Mobile Menu -->
  <div class="landing-mobile-menu" id="landing-mobile-menu">
    <a href="/">Beranda</a>
    <a href="/tools">Peralatan</a>
    <a href="/ModulKonstruksi">Konstruksi</a>
    <a href="/material">Material</a>
    <a href="/ModulKonstruksi" class="nav-cta" style="margin-top:1rem;">Mulai Belajar →</a>
  </div>

  <!-- Main Content -->
  <div id="content">
    <!-- Section 1: Hero -->
    <%- include('partials/hero') %>

    <!-- Spacer for scroll video -->
    <div style="height:150vh;"></div>

    <!-- Cards Trigger Zone -->
    <%- include('partials/intro') %>

    <!-- Spacer -->
    <div style="height:100vh;"></div>

    <!-- Section 3: Brand Reveal -->
    <%- include('partials/showcase') %>

    <!-- Footer (minimal) -->
    <%- include('partials/footer', { isLanding: true }) %>
  </div>

  <!-- Landing Page JS -->
  <script src="/js/landing.js"></script>
  <!-- Landing Page Animations -->
  <script src="/js/landing-animations.js"></script>
  <!-- Hero 3D scroll engine (model GLB) -->
  <script type="module" src="/js/hero-3d.js"></script>
</body>

</html>