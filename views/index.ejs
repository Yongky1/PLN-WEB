<!DOCTYPE html>
<html lang="id" class="scroll-smooth">
<head>
    <%- include('partials/head') %>
</head>
<body class="bg-brand-light dark:bg-brand-dark text-gray-900 dark:text-white transition-colors duration-700 font-sans antialiased overflow-x-hidden selection:bg-brand-accent selection:text-brand-dark">

    <%- include('partials/navbar') %>

    <!-- HERO SECTION -->
    <header id="hero" class="relative w-full h-screen overflow-hidden flex items-center">
        <!-- 3D Canvas Container -->
        <div id="canvas-container" class="absolute inset-0 z-0"></div>

        <!-- Hero Content overlay -->
        <div class="relative z-10 max-w-7xl mx-auto px-6 w-full flex flex-col justify-center pointer-events-none">
            <div class="max-w-2xl pointer-events-auto mix-blend-normal">
                <span class="inline-block py-1 px-3 rounded-full bg-black/10 dark:bg-white/10 backdrop-blur-md text-xs font-semibold tracking-wider uppercase mb-6 border border-black/5 dark:border-white/10 reveal-item">Digital Showcase</span>
                
                <h1 class="text-5xl md:text-7xl font-display font-bold leading-tight mb-6 reveal-item delay-100 text-shadow-sm">
                    Membangun Talenta <br />
                    <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-brand-accent dark:from-blue-400 dark:to-brand-accent">Energi Masa Depan</span>
                </h1>
                
                <p class="text-lg md:text-xl text-gray-800 dark:text-gray-200 mb-10 max-w-lg leading-relaxed reveal-item delay-200 font-medium text-shadow-sm">
                    Tempat pembelajaran, inovasi, dan transformasi bertemu. Ekosistem masa depan untuk membentuk pemimpin energi global.
                </p>
                
                <div class="flex flex-col sm:flex-row gap-4 reveal-item delay-300">
                    <a href="#pillars" class="px-8 py-4 bg-brand-blue dark:bg-white text-white dark:text-brand-blue rounded-full font-bold text-center hover:scale-105 transition-transform shadow-xl">
                        Jelajahi Pengalaman
                    </a>
                </div>
            </div>
        </div>

        <!-- Scroll Indicator -->
        <div class="absolute bottom-10 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center animate-bounce text-gray-600 dark:text-gray-300 pointer-events-none">
            <span class="text-xs tracking-widest uppercase mb-2">Scroll</span>
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path></svg>
        </div>
    </header>

    <!-- SECTION 1: MANIFESTO -->
    <section id="manifesto" class="py-32 px-6 bg-white dark:bg-[#081729] transition-colors duration-700">
        <div class="max-w-5xl mx-auto text-center reveal-on-scroll">
            <h2 class="text-3xl md:text-5xl font-display font-light leading-snug">
                Kami tidak sekadar melatih kompetensi. <br/>
                <span class="font-bold">Kami mendesain ekosistem inovasi.</span>
            </h2>
            <div class="w-24 h-1 bg-brand-accent mx-auto mt-12 rounded-full"></div>
        </div>
    </section>

    <!-- SECTION 2: KEY PILLARS -->
    <section id="pillars" class="py-32 px-6 bg-brand-light dark:bg-brand-dark transition-colors duration-700">
        <div class="max-w-7xl mx-auto">
            <div class="text-left mb-16 reveal-on-scroll">
                <h3 class="text-sm font-bold uppercase tracking-widest text-brand-accent mb-2">Pilar Utama</h3>
                <h2 class="text-4xl md:text-5xl font-display font-bold">Fondasi Ekosistem</h2>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
                <!-- Pillar 1 -->
                <div class="group p-8 rounded-3xl bg-white dark:bg-[#0d2238] shadow-lg hover:shadow-2xl transition-all duration-300 reveal-on-scroll border border-transparent dark:border-white/5">
                    <div class="w-14 h-14 rounded-2xl bg-blue-100 dark:bg-blue-900/50 flex items-center justify-center mb-6 text-brand-blue dark:text-brand-accent group-hover:scale-110 transition-transform">
                        <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
                    </div>
                    <h4 class="text-xl font-bold mb-3">Pembelajaran</h4>
                    <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed">Kurikulum futuristik yang mengintegrasikan pengetahuan praktis dan visi masa depan energi.</p>
                </div>
                <!-- Pillar 2 -->
                <div class="group p-8 rounded-3xl bg-white dark:bg-[#0d2238] shadow-lg hover:shadow-2xl transition-all duration-300 reveal-on-scroll delay-100 border border-transparent dark:border-white/5">
                    <div class="w-14 h-14 rounded-2xl bg-blue-100 dark:bg-blue-900/50 flex items-center justify-center mb-6 text-brand-blue dark:text-brand-accent group-hover:scale-110 transition-transform">
                        <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                    </div>
                    <h4 class="text-xl font-bold mb-3">Inovasi</h4>
                    <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed">Fasilitas eksperimen dan ruang kolaborasi untuk menciptakan solusi energi berkelanjutan.</p>
                </div>
                <!-- Pillar 3 -->
                <div class="group p-8 rounded-3xl bg-white dark:bg-[#0d2238] shadow-lg hover:shadow-2xl transition-all duration-300 reveal-on-scroll delay-200 border border-transparent dark:border-white/5">
                    <div class="w-14 h-14 rounded-2xl bg-blue-100 dark:bg-blue-900/50 flex items-center justify-center mb-6 text-brand-blue dark:text-brand-accent group-hover:scale-110 transition-transform">
                        <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
                    </div>
                    <h4 class="text-xl font-bold mb-3">Kepemimpinan</h4>
                    <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed">Membentuk karakter pemimpin yang adaptif, visioner, dan berwawasan global.</p>
                </div>
                <!-- Pillar 4 -->
                <div class="group p-8 rounded-3xl bg-white dark:bg-[#0d2238] shadow-lg hover:shadow-2xl transition-all duration-300 reveal-on-scroll delay-300 border border-transparent dark:border-white/5">
                    <div class="w-14 h-14 rounded-2xl bg-blue-100 dark:bg-blue-900/50 flex items-center justify-center mb-6 text-brand-blue dark:text-brand-accent group-hover:scale-110 transition-transform">
                        <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                    </div>
                    <h4 class="text-xl font-bold mb-3">Transformasi Digital</h4>
                    <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed">Mengadopsi teknologi terdepan untuk metode pembelajaran interaktif dan simulasi mendalam.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- SECTION 3: PROGRAM & ECOSYSTEM -->
    <section id="ecosystem" class="py-32 px-6 bg-white dark:bg-[#081729] transition-colors duration-700">
        <div class="max-w-7xl mx-auto flex flex-col lg:flex-row gap-16 items-center">
            <div class="lg:w-1/2 reveal-on-scroll">
                <div class="aspect-square rounded-3xl overflow-hidden relative shadow-2xl bg-gray-200 dark:bg-gray-800">
                    <!-- Placeholder for ecosystem image/rendering, using abstract shapes for now -->
                    <div class="absolute inset-0 bg-gradient-to-tr from-brand-blue to-blue-400 dark:from-brand-dark dark:to-blue-900 opacity-90"></div>
                    <div class="absolute inset-0 flex items-center justify-center p-8">
                        <div class="w-full h-full border border-white/20 rounded-2xl relative">
                            <div class="absolute top-1/4 left-1/4 w-32 h-32 bg-white/10 rounded-full blur-xl animate-pulse"></div>
                            <div class="absolute bottom-1/3 right-1/4 w-40 h-40 bg-brand-accent/20 rounded-full blur-2xl animate-pulse delay-1000"></div>
                            <div class="absolute inset-0 flex items-center justify-center text-white/50 font-display font-bold text-2xl text-center">Fasilitas Masa Depan</div>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="lg:w-1/2 reveal-on-scroll delay-200">
                <h3 class="text-sm font-bold uppercase tracking-widest text-brand-accent mb-2">Program Unggulan</h3>
                <h2 class="text-4xl md:text-5xl font-display font-bold mb-8">Eksplorasi Skala Penuh.</h2>
                
                <div class="space-y-8">
                    <div class="border-b border-gray-200 dark:border-white/10 pb-6">
                        <h4 class="text-2xl font-bold mb-2">Pelatihan Teknis Transisi Energi</h4>
                        <p class="text-gray-600 dark:text-gray-400">Simulasi langsung dengan infrastruktur mikro grid terkini.</p>
                    </div>
                    <div class="border-b border-gray-200 dark:border-white/10 pb-6">
                        <h4 class="text-2xl font-bold mb-2">Leadership Development Program</h4>
                        <p class="text-gray-600 dark:text-gray-400">Mempersiapkan eksekutif PLN untuk tantangan industri global.</p>
                    </div>
                    <div class="border-b border-gray-200 dark:border-white/10 pb-6">
                        <h4 class="text-2xl font-bold mb-2">Energy Innovation Experience</h4>
                        <p class="text-gray-600 dark:text-gray-400">Ruang inkubator untuk talenta muda mengembangkan gagasan disruptif.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- SECTION 4: CTA -->
    <section id="cta" class="py-32 px-6 bg-brand-blue relative overflow-hidden text-center text-white">
        <!-- Abstract background elements -->
        <div class="absolute top-0 left-0 w-full h-full overflow-hidden pointer-events-none">
            <div class="absolute -top-24 -left-24 w-96 h-96 bg-blue-600 rounded-full mix-blend-multiply filter blur-3xl opacity-50 animate-blob"></div>
            <div class="absolute top-1/2 right-12 w-72 h-72 bg-brand-accent rounded-full mix-blend-multiply filter blur-3xl opacity-20 animate-blob animation-delay-2000"></div>
            <div class="absolute -bottom-24 left-1/3 w-80 h-80 bg-purple-600 rounded-full mix-blend-multiply filter blur-3xl opacity-30 animate-blob animation-delay-4000"></div>
        </div>
        
        <div class="max-w-4xl mx-auto relative z-10 reveal-on-scroll">
            <h2 class="text-5xl md:text-6xl font-display font-bold mb-8">Siap Memulai Perjalanan Anda?</h2>
            <p class="text-xl text-blue-100 mb-12 max-w-2xl mx-auto font-light">Bergabunglah dalam ekosistem pembelajaran kami dan jadilah bagian dari transformasi energi global.</p>
            <div class="flex flex-col sm:flex-row gap-6 justify-center">
                <a href="#" class="px-10 py-5 bg-white text-brand-blue rounded-full font-bold text-lg hover:shadow-[0_0_30px_rgba(255,255,255,0.3)] transition-all">
                    Lihat Ekosistem
                </a>
                <a href="#" class="px-10 py-5 border border-white/30 rounded-full font-bold text-lg hover:bg-white/10 transition-all backdrop-blur-sm">
                    Mulai Pengalaman Baru
                </a>
            </div>
        </div>
    </section>

    <%- include('partials/footer') %>

    <!-- Scripts -->
    <!-- Preload Three.js for performance -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <!-- Post-processing for Bloom -->
    <script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/postprocessing/EffectComposer.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/postprocessing/RenderPass.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/postprocessing/ShaderPass.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/shaders/CopyShader.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/shaders/LuminosityHighPassShader.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/postprocessing/UnrealBloomPass.js"></script>
    
    <script src="/js/scene.js"></script>
    <script src="/js/main.js"></script>
    <script src="/js/scroll.js"></script>
</body>
</html>
