<!DOCTYPE html>
<html lang="id" class="scroll-smooth">
<head>
    <%- include('partials/head') %>
</head>
<body class="bg-brand-light dark:bg-brand-dark text-gray-900 dark:text-white transition-colors duration-700 font-sans antialiased overflow-x-hidden selection:bg-brand-accent selection:text-brand-dark">

    <%- include('partials/navbar') %>

    <!-- HERO SECTION -->
    <header id="hero" class="relative w-full h-screen overflow-hidden flex items-center">
        <!-- 3D Canvas Container -->
        <div id="canvas-container" class="absolute inset-0 z-0"></div>

        <!-- Hero Content overlay -->
        <div class="relative z-10 max-w-7xl mx-auto px-6 w-full flex flex-col justify-center pointer-events-none">
            <div class="max-w-2xl pointer-events-auto mix-blend-normal">
                <span class="inline-block py-1 px-3 rounded-full bg-black/10 dark:bg-white/10 backdrop-blur-md text-xs font-semibold tracking-wider uppercase mb-6 border border-black/5 dark:border-white/10 reveal-item">Digital Showcase</span>
                
                <h1 class="text-5xl md:text-7xl font-display font-bold leading-tight mb-6 reveal-item delay-100 text-shadow-sm">
                    Membangun Talenta <br />
                    <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-brand-accent dark:from-blue-400 dark:to-brand-accent">Energi Masa Depan</span>
                </h1>
                
                <p class="text-lg md:text-xl text-gray-800 dark:text-gray-200 mb-10 max-w-lg leading-relaxed reveal-item delay-200 font-medium text-shadow-sm">
                    Tempat pembelajaran, inovasi, dan transformasi bertemu. Ekosistem masa depan untuk membentuk pemimpin energi global.
                </p>
                
                <div class="flex flex-col sm:flex-row gap-4 reveal-item delay-300">
                    <a href="#pillars" class="px-8 py-4 bg-brand-blue dark:bg-white text-white dark:text-brand-blue rounded-full font-bold text-center hover:scale-105 transition-transform shadow-xl">
                        Jelajahi Pengalaman
                    </a>
                </div>
            </div>
        </div>

        <!-- Scroll Indicator -->
        <div class="absolute bottom-10 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center animate-bounce text-gray-600 dark:text-gray-300 pointer-events-none">
            <span class="text-xs tracking-widest uppercase mb-2">Scroll</span>
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path></svg>
        </div>
    </header>

    <!-- SECTION 1: KINETIC MARQUEE -->
    <section id="marquee" class="py-12 bg-white dark:bg-[#010409] border-y border-gray-100 dark:border-white/5 relative z-20 overflow-hidden">
        <div class="marquee-container">
            <div class="marquee-content items-center">
                <!-- Text block repeated for infinity illusion -->
                <span class="text-6xl md:text-8xl font-display font-black text-transparent bg-clip-text bg-gradient-to-r from-gray-200 to-gray-300 dark:from-white/5 dark:to-white/10 uppercase mx-8">FUTURE ENERGY</span>
                <span class="w-4 h-4 bg-brand-accent rounded-full mx-8"></span>
                <span class="text-6xl md:text-8xl font-display font-black text-transparent bg-clip-text bg-gradient-to-r from-gray-200 to-gray-300 dark:from-white/5 dark:to-white/10 uppercase mx-8">INNOVATION</span>
                <span class="w-4 h-4 bg-brand-accent rounded-full mx-8"></span>
                <span class="text-6xl md:text-8xl font-display font-black text-transparent bg-clip-text bg-gradient-to-r from-gray-200 to-gray-300 dark:from-white/5 dark:to-white/10 uppercase mx-8">LEADERSHIP</span>
                <span class="w-4 h-4 bg-brand-accent rounded-full mx-8"></span>
                <span class="text-6xl md:text-8xl font-display font-black text-transparent bg-clip-text bg-gradient-to-r from-gray-200 to-gray-300 dark:from-white/5 dark:to-white/10 uppercase mx-8">PLN PUSDIKLAT</span>
                <span class="w-4 h-4 bg-brand-accent rounded-full mx-8"></span>
                
                <!-- Duplicate for seamless loop -->
                <span class="text-6xl md:text-8xl font-display font-black text-transparent bg-clip-text bg-gradient-to-r from-gray-200 to-gray-300 dark:from-white/5 dark:to-white/10 uppercase mx-8">FUTURE ENERGY</span>
                <span class="w-4 h-4 bg-brand-accent rounded-full mx-8"></span>
                <span class="text-6xl md:text-8xl font-display font-black text-transparent bg-clip-text bg-gradient-to-r from-gray-200 to-gray-300 dark:from-white/5 dark:to-white/10 uppercase mx-8">INNOVATION</span>
                <span class="w-4 h-4 bg-brand-accent rounded-full mx-8"></span>
                <span class="text-6xl md:text-8xl font-display font-black text-transparent bg-clip-text bg-gradient-to-r from-gray-200 to-gray-300 dark:from-white/5 dark:to-white/10 uppercase mx-8">LEADERSHIP</span>
                <span class="w-4 h-4 bg-brand-accent rounded-full mx-8"></span>
                <span class="text-6xl md:text-8xl font-display font-black text-transparent bg-clip-text bg-gradient-to-r from-gray-200 to-gray-300 dark:from-white/5 dark:to-white/10 uppercase mx-8">PLN PUSDIKLAT</span>
                <span class="w-4 h-4 bg-brand-accent rounded-full mx-8"></span>
            </div>
        </div>
    </section>

    <!-- SECTION 2: INTERACTIVE POWER LINE (TIMELINE) -->
    <section id="programs" class="py-32 bg-[#f8fafc] dark:bg-[#030914] relative z-20 overflow-hidden transition-colors duration-700">
        
        <!-- Abstract Organics (Floating Globs Background) -->
        <div class="organic-orb w-[600px] h-[600px] top-10 left-[-100px]" style="--orb-color: rgba(0, 229, 255, 0.15)"></div>
        <div class="organic-orb w-[500px] h-[500px] bottom-10 right-[-50px] animation-delay-2000" style="--orb-color: rgba(59, 130, 246, 0.15)"></div>

        <div class="max-w-7xl mx-auto px-6 relative">
            
            <div class="text-center mb-32 reveal-on-scroll">
                <h2 class="text-5xl md:text-7xl font-display font-bold tracking-tight">
                    Ekosistem <br/>
                    <span class="bg-gradient-text bg-gradient-to-r from-cyan-500 to-blue-600">Tanpa Batas.</span>
                </h2>
                <p class="mt-8 text-xl text-gray-500 dark:text-gray-400 font-medium max-w-2xl mx-auto">Saksikan integrasi pembelajaran kelas dunia yang terhubung layaknya kelistrikan murni.</p>
            </div>

            <!-- The Timeline Container -->
            <div class="relative w-full max-w-5xl mx-auto" id="timeline-container">
                
                <!-- The Stem (Wire) -->
                <div class="timeline-stem">
                    <div class="timeline-progress" id="timeline-progress"></div>
                </div>

                <!-- Node 1 (Left aligned on Desktop) -->
                <div class="relative w-full md:w-1/2 md:pr-16 pl-12 md:pl-0 mb-32 text-left reveal-on-scroll">
                    <!-- Node Dot -->
                    <div class="timeline-node hidden md:block" style="right: -8px; left: auto;"></div>
                    <div class="timeline-node md:hidden"></div>
                    
                    <div class="timeline-content">
                        <div class="inline-flex w-16 h-16 rounded-2xl bg-cyan-100 dark:bg-cyan-900/30 items-center justify-center mb-6 text-cyan-600 dark:text-cyan-400">
                            <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
                        </div>
                        <h3 class="text-3xl font-display font-bold mb-4">Technical Simulation</h3>
                        <p class="text-gray-600 dark:text-gray-400 text-lg leading-relaxed">Pusat uji coba skala penuh dengan Micro Grid. Menguji sistem tenaga masa depan pada panel yang mereplika persis kondisi lapangan kelistrikan global.</p>
                    </div>
                </div>

                <!-- Node 2 (Right aligned on Desktop) -->
                <div class="relative w-full md:w-1/2 md:w-1/2 md:ml-auto md:pl-16 pl-12 mb-32 text-left reveal-on-scroll">
                    <!-- Node Dot -->
                    <div class="timeline-node"></div>
                    
                    <div class="timeline-content">
                        <div class="inline-flex w-16 h-16 rounded-2xl bg-blue-100 dark:bg-blue-900/30 items-center justify-center mb-6 text-blue-600 dark:text-blue-400">
                            <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                        </div>
                        <h3 class="text-3xl font-display font-bold mb-4">Leadership Hub</h3>
                        <p class="text-gray-600 dark:text-gray-400 text-lg leading-relaxed">Beroperasi serupa *think tank*. Menciptakan manajemen level tinggi yang adaptif untuk mengambil keputusan teknis berdampak global bagi masyarakat.</p>
                    </div>
                </div>

                <!-- Node 3 (Left aligned on Desktop) -->
                <div class="relative w-full md:w-1/2 md:pr-16 pl-12 md:pl-0 mb-16 text-left reveal-on-scroll">
                    <!-- Node Dot -->
                    <div class="timeline-node hidden md:block" style="right: -8px; left: auto;"></div>
                    <div class="timeline-node md:hidden"></div>
                    
                    <div class="timeline-content">
                        <div class="inline-flex w-16 h-16 rounded-2xl bg-purple-100 dark:bg-purple-900/30 items-center justify-center mb-6 text-purple-600 dark:text-purple-400">
                            <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" /></svg>
                        </div>
                        <h3 class="text-3xl font-display font-bold mb-4">Innovation Frontier</h3>
                        <p class="text-gray-600 dark:text-gray-400 text-lg leading-relaxed">Platform eksperimentasi batas akhir. Pengalaman ruang siber, data analitik tingkat lanjut, hingga rekayasa energi terbarukan dilakukan di sini.</p>
                    </div>
                </div>

            </div>
        </div>
    </section>

    <!-- SECTION 3: CTA -->
    <section id="cta" class="py-32 px-6 bg-white dark:bg-[#010409] relative overflow-hidden text-center z-20 border-t border-gray-100 dark:border-white/5 transition-colors duration-700">
        <!-- Antigravity Abstract Glows -->
        <div class="absolute inset-0 overflow-hidden pointer-events-none flex items-center justify-center">
            <div class="w-[800px] h-[800px] bg-brand-accent/5 dark:bg-brand-accent/10 rounded-full blur-[100px] absolute mix-blend-screen"></div>
            <div class="w-[600px] h-[600px] bg-blue-600/5 dark:bg-blue-600/10 rounded-full blur-[80px] absolute -translate-x-1/4 mix-blend-screen"></div>
        </div>
        
        <div class="max-w-4xl mx-auto relative z-10 reveal-on-scroll">
            <div class="inline-flex items-center space-x-2 bg-gray-100 dark:bg-white/5 border border-black/5 dark:border-white/10 rounded-full px-4 py-2 mb-8 backdrop-blur-md">
                <span class="w-2 h-2 rounded-full bg-brand-accent animate-pulse"></span>
                <span class="text-xs font-semibold tracking-wider uppercase">Masa Depan Kelistrikan Terbuka</span>
            </div>
            <h2 class="text-5xl md:text-7xl font-display font-bold mb-6 tracking-tight">Siap Bergabung<br>Ke Ekosistem Kami?</h2>
            <p class="text-xl text-gray-500 dark:text-gray-400 mb-12 max-w-2xl mx-auto font-medium">Jangan hanya melihat transformasi dari luarnya. Jadilah aktor utama yang menciptakannya bersama PLN Pusdiklat.</p>
            
            <button class="relative group px-10 py-5 rounded-full font-bold text-lg bg-gray-900 border border-gray-900 text-white dark:bg-white dark:border-white dark:text-brand-dark overflow-hidden shadow-2xl transition-all hover:scale-105 hover:shadow-cyan-500/20 active:scale-95">
                <span class="relative z-10 flex items-center">
                    Masuk ke Portal Pendaftaran
                    <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
                </span>
                <!-- Soft internal hover glow -->
                <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/20 to-transparent -translate-x-full group-hover:animate-[shimmer_1.5s_infinite]"></div>
            </button>
        </div>
    </section>

    <%- include('partials/footer') %>

    <!-- Scripts -->
    <!-- Preload Three.js for performance -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <!-- Post-processing for Bloom -->
    <script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/postprocessing/EffectComposer.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/postprocessing/RenderPass.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/postprocessing/ShaderPass.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/shaders/CopyShader.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/shaders/LuminosityHighPassShader.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/postprocessing/UnrealBloomPass.js"></script>
    
    <script src="/js/scene.js"></script>
    <script src="/js/main.js"></script>
    <script src="/js/scroll.js"></script>
</body>
</html>
