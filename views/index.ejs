<!DOCTYPE html>
<html lang="id" class="scroll-smooth">
<head>
    <%- include('partials/head') %>
</head>
<body class="bg-brand-light dark:bg-brand-dark text-gray-900 dark:text-white transition-colors duration-700 font-sans antialiased overflow-x-hidden selection:bg-brand-accent selection:text-brand-dark">

    <%- include('partials/navbar') %>

    <!-- ============================================ -->
    <!-- HERO SECTION (3D City Background Preserved) -->
    <!-- ============================================ -->
    <header id="hero" class="relative w-full min-h-[100vh] pt-[15vh] pb-10 flex items-start">
        <!-- 3D Canvas Container -->
        <div id="canvas-container" class="absolute inset-0 z-0 overflow-hidden"></div>

        <div class="relative z-10 max-w-7xl mx-auto px-6 w-full flex flex-col justify-start pointer-events-none">
            <div class="max-w-2xl pointer-events-auto">
                
                <h1 id="hero-heading" class="text-5xl md:text-7xl lg:text-8xl font-display font-bold leading-[1.1] mb-5 tracking-tight">
                    <span class="split-word inline-block overflow-hidden"><span class="split-inner inline-block">Membangun</span></span>
                    <span class="split-word inline-block overflow-hidden"><span class="split-inner inline-block">Talenta</span></span>
                    <br />
                    <span class="split-word inline-block overflow-hidden">
                        <span class="split-inner inline-block text-transparent bg-clip-text bg-gradient-to-r from-brand-pln to-brand-yellow dark:from-brand-accent dark:to-brand-yellow">Energi</span>
                    </span>
                    <span class="split-word inline-block overflow-hidden">
                        <span class="split-inner inline-block text-transparent bg-clip-text bg-gradient-to-r from-brand-yellow to-brand-pln dark:from-brand-yellow dark:to-brand-accent">Masa</span>
                    </span>
                    <span class="split-word inline-block overflow-hidden">
                        <span class="split-inner inline-block text-transparent bg-clip-text bg-gradient-to-r from-brand-pln to-brand-blue dark:from-brand-accent dark:to-blue-400">Depan</span>
                    </span>
                </h1>
                
                <p id="hero-desc" class="text-lg md:text-xl text-gray-700 dark:text-gray-300 mb-8 max-w-lg leading-relaxed font-medium opacity-0 translate-y-6">
                    Tempat pembelajaran, inovasi, dan transformasi bertemu. Ekosistem masa depan untuk membentuk pemimpin energi global.
                </p>
                
                <div id="hero-cta" class="flex flex-col sm:flex-row gap-4 opacity-0 translate-y-6">
                    <a href="#programs" class="group px-8 py-4 bg-brand-pln text-white dark:bg-white dark:text-brand-blue rounded-full font-bold text-center hover:scale-105 transition-all shadow-xl hover:shadow-brand-pln/30 relative overflow-hidden">
                        <span class="relative z-10">Jelajahi Pengalaman</span>
                        <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/20 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-700"></div>
                    </a>
                </div>
            </div>
        </div>

        <div class="absolute bottom-10 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center text-gray-600 dark:text-gray-300 pointer-events-none scroll-indicator">
            <span class="text-xs tracking-[0.3em] uppercase mb-2 font-medium">Scroll</span>
            <div class="w-6 h-10 rounded-full border-2 border-current flex justify-center pt-2">
                <div class="w-1.5 h-1.5 rounded-full bg-current animate-scroll-dot"></div>
            </div>
        </div>
    </header>



    <!-- ============================================ -->
    <!-- VIDEO SPOTLIGHT (SCALE ON SCROLL)           -->
    <!-- ============================================ -->
    <section id="spotlight-section" class="relative w-full bg-brand-light dark:bg-[#030914] transition-colors duration-700 h-[300vh]">
        <div class="sticky top-0 w-full h-screen flex flex-col items-center justify-center overflow-hidden">
            <div id="video-wrapper" class="relative z-10 w-[95%] md:w-[90%] max-w-[1400px] aspect-video flex items-center justify-center transform scale-[0.5] overflow-hidden shadow-[0_20px_60px_rgba(0,0,0,0.4)] transition-transform duration-75 ease-out will-change-transform pointer-events-auto rounded-[2rem] md:rounded-[3rem] border border-white/10 mx-auto bg-black">
                <div class="absolute inset-0 bg-brand-blue/5 mix-blend-overlay z-10 pointer-events-none"></div>
                <iframe 
                    class="w-full h-full pointer-events-none" 
                    src="https://www.youtube.com/embed/oXx5B8fxfyo?autoplay=1&mute=1&loop=1&playlist=oXx5B8fxfyo&controls=0&showinfo=0&modestbranding=1&rel=0&disablekb=1&playsinline=1" 
                    title="PLN Video" 
                    frameborder="0" 
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
                    allowfullscreen>
                </iframe>
            </div>
        </div>
    </section>

    <!-- ============================================ -->
    <!-- STATS COUNTER SECTION                       -->
    <!-- ============================================ -->
    <section id="stats" class="py-24 md:py-32 bg-white dark:bg-[#010409] relative z-20 border-t border-gray-100 dark:border-white/5 transition-colors duration-700 overflow-hidden">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] bg-brand-pln/5 dark:bg-brand-accent/5 rounded-full blur-[120px] pointer-events-none"></div>

        <div class="max-w-6xl mx-auto px-6 relative">
            <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-4">
                <div class="stat-item text-center md:border-r border-gray-200 dark:border-white/10">
                    <div class="text-5xl md:text-6xl lg:text-7xl font-display font-bold text-brand-pln dark:text-brand-accent mb-2">
                        <span class="counter" data-target="6700">0</span><span class="text-brand-yellow">+</span>
                    </div>
                    <p class="text-sm md:text-base text-gray-500 dark:text-gray-400 font-medium tracking-wide uppercase">Aset Pembangkit</p>
                </div>
                <div class="stat-item text-center md:border-r border-gray-200 dark:border-white/10">
                    <div class="text-5xl md:text-6xl lg:text-7xl font-display font-bold text-brand-pln dark:text-brand-accent mb-2">
                        <span class="counter" data-target="52000">0</span><span class="text-brand-yellow">+</span>
                    </div>
                    <p class="text-sm md:text-base text-gray-500 dark:text-gray-400 font-medium tracking-wide uppercase">Alumni Terlatih</p>
                </div>
                <div class="stat-item text-center md:border-r border-gray-200 dark:border-white/10">
                    <div class="text-5xl md:text-6xl lg:text-7xl font-display font-bold text-brand-pln dark:text-brand-accent mb-2">
                        <span class="counter" data-target="150">0</span><span class="text-brand-yellow">+</span>
                    </div>
                    <p class="text-sm md:text-base text-gray-500 dark:text-gray-400 font-medium tracking-wide uppercase">Program Aktif</p>
                </div>
                <div class="stat-item text-center">
                    <div class="text-5xl md:text-6xl lg:text-7xl font-display font-bold text-brand-pln dark:text-brand-accent mb-2">
                        <span class="counter" data-target="30">0</span><span class="text-brand-yellow">+</span>
                    </div>
                    <p class="text-sm md:text-base text-gray-500 dark:text-gray-400 font-medium tracking-wide uppercase">Tahun Pengalaman</p>
                </div>
            </div>
        </div>
    </section>

    <!-- ============================================ -->
    <!-- BENTO PREMIUM CARDS (3D Tilt)               -->
    <!-- ============================================ -->
    <section id="programs" class="py-32 bg-white dark:bg-[#010409] relative z-20 overflow-hidden transition-colors duration-700">
        <div class="max-w-7xl mx-auto px-6 relative">
            <div class="text-center mb-20">
                <h2 class="text-5xl md:text-7xl font-display font-bold tracking-tight gsap-reveal">
                    Ekosistem <br/>
                    <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-pln to-brand-yellow animate-gradient-shift bg-[length:200%_200%]">Tanpa Batas.</span>
                </h2>
                <p class="mt-6 text-lg text-gray-500 dark:text-gray-400 font-medium max-w-2xl mx-auto gsap-reveal">Saksikan integrasi pembelajaran kelas dunia yang terhubung layaknya kelistrikan murni.</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <div class="tilt-card group relative bg-[#f8fafc] dark:bg-[#0a1628] rounded-[2rem] p-10 border border-gray-200/50 dark:border-white/5 overflow-hidden flex flex-col h-full min-h-[380px] gsap-reveal transition-all duration-500 hover:shadow-2xl hover:shadow-brand-pln/10" style="transform-style:preserve-3d">
                    <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 bg-gradient-to-br from-brand-pln/5 via-transparent to-transparent pointer-events-none rounded-[2rem]"></div>
                    <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-brand-pln/20 to-brand-pln/5 flex items-center justify-center text-brand-pln mb-8 relative z-10 group-hover:scale-110 transition-transform duration-500">
                        <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
                    </div>
                    <h3 class="text-2xl font-bold mb-4 relative z-10">Technical Simulation</h3>
                    <p class="text-gray-500 dark:text-gray-400 text-base leading-relaxed relative z-10 flex-grow">Pusat uji coba skala penuh dengan Micro Grid. Menguji sistem tenaga masa depan pada panel yang mereplika persis kondisi lapangan.</p>
                    <div class="mt-8 inline-flex text-brand-pln font-semibold text-sm items-center gap-1 group-hover:gap-3 transition-all cursor-pointer relative z-10">
                        Eksplorasi <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
                    </div>
                </div>

                <div class="tilt-card group relative bg-[#f8fafc] dark:bg-[#0a1628] rounded-[2rem] p-10 border border-gray-200/50 dark:border-white/5 overflow-hidden flex flex-col h-full min-h-[380px] gsap-reveal transition-all duration-500 hover:shadow-2xl hover:shadow-brand-yellow/10" style="transform-style:preserve-3d">
                    <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 bg-gradient-to-br from-brand-yellow/5 via-transparent to-transparent pointer-events-none rounded-[2rem]"></div>
                    <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-brand-yellow/20 to-brand-yellow/5 flex items-center justify-center text-[#c49800] dark:text-brand-yellow mb-8 relative z-10 group-hover:scale-110 transition-transform duration-500">
                        <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                    </div>
                    <h3 class="text-2xl font-bold mb-4 relative z-10">Leadership Hub</h3>
                    <p class="text-gray-500 dark:text-gray-400 text-base leading-relaxed relative z-10 flex-grow">Menciptakan manajemen level tinggi yang adaptif untuk mengambil keputusan teknis berdampak global bagi masyarakat.</p>
                    <div class="mt-8 inline-flex text-[#c49800] dark:text-brand-yellow font-semibold text-sm items-center gap-1 group-hover:gap-3 transition-all cursor-pointer relative z-10">
                        Eksplorasi <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
                    </div>
                </div>

                <div class="tilt-card group relative bg-[#f8fafc] dark:bg-[#0a1628] rounded-[2rem] p-10 border border-gray-200/50 dark:border-white/5 overflow-hidden flex flex-col h-full min-h-[380px] gsap-reveal transition-all duration-500 hover:shadow-2xl hover:shadow-brand-blue/10" style="transform-style:preserve-3d">
                    <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 bg-gradient-to-br from-brand-blue/5 via-transparent to-transparent pointer-events-none rounded-[2rem]"></div>
                    <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-brand-blue/20 to-brand-blue/5 flex items-center justify-center text-brand-blue dark:text-blue-400 mb-8 relative z-10 group-hover:scale-110 transition-transform duration-500">
                        <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" /></svg>
                    </div>
                    <h3 class="text-2xl font-bold mb-4 relative z-10">Innovation Frontier</h3>
                    <p class="text-gray-500 dark:text-gray-400 text-base leading-relaxed relative z-10 flex-grow">Platform eksperimentasi batas akhir. Pengalaman ruang siber, data analitik tingkat lanjut, hingga rekayasa energi terbarukan.</p>
                    <div class="mt-8 inline-flex text-brand-blue dark:text-blue-400 font-semibold text-sm items-center gap-1 group-hover:gap-3 transition-all cursor-pointer relative z-10">
                        Eksplorasi <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
                    </div>
                </div>
            </div>
        </div>
    </section>



    <!-- ============================================ -->
    <!-- CTA SECTION PREMIUM                         -->
    <!-- ============================================ -->
    <section id="cta" class="py-32 md:py-40 px-6 bg-white dark:bg-[#010409] relative overflow-hidden text-center z-20 transition-colors duration-700">
        <div class="absolute inset-0 overflow-hidden pointer-events-none">
            <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[900px] h-[900px] bg-brand-accent/5 dark:bg-brand-accent/10 rounded-full blur-[120px] animate-blob"></div>
            <div class="absolute top-1/3 left-1/4 w-[500px] h-[500px] bg-brand-yellow/5 dark:bg-brand-yellow/8 rounded-full blur-[100px] animate-blob animation-delay-2000"></div>
            <div class="absolute bottom-1/4 right-1/4 w-[400px] h-[400px] bg-blue-600/5 dark:bg-blue-600/8 rounded-full blur-[80px] animate-blob animation-delay-4000"></div>
        </div>
        
        <div class="max-w-4xl mx-auto relative z-10">
            <div class="inline-flex items-center space-x-2 bg-gray-100/80 dark:bg-white/5 border border-black/5 dark:border-white/10 rounded-full px-5 py-2.5 mb-10 backdrop-blur-md gsap-reveal">
                <span class="w-2 h-2 rounded-full bg-brand-accent animate-pulse"></span>
                <span class="text-xs font-semibold tracking-[0.2em] uppercase">Masa Depan Kelistrikan Terbuka</span>
            </div>
            <h2 class="text-5xl md:text-7xl lg:text-8xl font-display font-bold mb-8 tracking-tight leading-[0.95] gsap-reveal">Siap Bergabung<br>Ke Ekosistem Kami?</h2>
            <p class="text-xl text-gray-500 dark:text-gray-400 mb-14 max-w-2xl mx-auto font-medium gsap-reveal">Jangan hanya melihat transformasi dari luarnya. Jadilah aktor utama yang menciptakannya bersama PLN Pusdiklat.</p>
            
            <div class="gsap-reveal">
                <button id="magnetic-btn" class="relative group px-12 py-6 rounded-full font-bold text-lg bg-brand-pln border-2 border-brand-pln text-white dark:bg-white dark:border-white dark:text-brand-dark overflow-hidden shadow-2xl transition-all duration-300 hover:scale-105 hover:shadow-brand-pln/40 active:scale-95">
                    <span class="relative z-10 flex items-center gap-2">
                        Masuk ke Portal Pendaftaran
                        <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
                    </span>
                    <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/20 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-700"></div>
                </button>
            </div>
        </div>
    </section>

    <%- include('partials/footer') %>

    <!-- Scripts -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/postprocessing/EffectComposer.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/postprocessing/RenderPass.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/postprocessing/ShaderPass.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/shaders/CopyShader.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/shaders/LuminosityHighPassShader.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/postprocessing/UnrealBloomPass.js"></script>
    
    <script src="/js/scene.js"></script>
    <script src="/js/main.js"></script>
    <script src="/js/scroll.js"></script>
</body>
</html>
