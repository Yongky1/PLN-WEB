<!DOCTYPE html>
<html lang="id" class="scroll-smooth">
<head>
    <%- include('partials/head') %>
    <style>
        .mat-card { transition: transform 0.25s ease, box-shadow 0.25s ease; }
        .mat-card:hover { transform: translateY(-4px); }

        #modal-overlay {
            background: rgba(0,0,0,0.72);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
        }

        #canvas-wrap {
            width: 50%;
            flex-shrink: 0;
            position: relative;
            background: linear-gradient(145deg, #050e1c 0%, #081b35 100%);
        }

        #modal-canvas {
            position: absolute;
            inset: 0;
            width: 100% !important;
            height: 100% !important;
            display: block;
            cursor: grab;
        }
        #modal-canvas:active { cursor: grabbing; }

        #info-wrap {
            width: 50%;
            flex-shrink: 0;
            overflow-y: auto;
            padding: 36px 32px;
        }

        .spec-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px 0;
            border-bottom: 1px solid rgba(255,255,255,0.07);
        }
        .spec-row:last-child { border-bottom: none; }

        @keyframes modalIn {
            from { opacity: 0; transform: scale(0.95) translateY(14px); }
            to   { opacity: 1; transform: scale(1) translateY(0); }
        }
        #modal-card { animation: modalIn 0.22s ease forwards; }

        .ctrl-pill {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 7px 16px;
            border-radius: 9999px;
            font-size: 12px;
            font-weight: 600;
            cursor: pointer;
            border: 1.5px solid;
            font-family: inherit;
            white-space: nowrap;
            transition: all 0.15s ease;
        }
        .ctrl-on  { background: rgba(0,229,255,0.15); border-color: rgba(0,229,255,0.5); color: #00E5FF; }
        .ctrl-off { background: rgba(255,255,255,0.07); border-color: rgba(255,255,255,0.18); color: rgba(255,255,255,0.65); }
        .ctrl-off:hover { background: rgba(255,255,255,0.13); color: #fff; }
    </style>
</head>
<body class="bg-[var(--color-pln-darker)] text-white font-sans antialiased overflow-x-hidden">


    <%- include('partials/navbar') %>


    <main class="pt-32 pb-24 px-6 bg-[var(--color-pln-darker)] min-h-screen">
        <div class="max-w-7xl mx-auto">
            <div class="mb-10">
                <span class="inline-block py-1 px-3 rounded-full bg-[var(--color-pln-yellow)]/10 text-[var(--color-pln-yellow)] text-[10px] font-semibold tracking-widest uppercase mb-3 border border-[var(--color-pln-yellow)]/30">
                    Katalog Material
                </span>
                <h1 class="text-3xl md:text-4xl font-bold mb-3">
                    Material <span class="text-[var(--color-pln-yellow)]">Jaringan PLN</span>
                </h1>
                <p class="text-sm md:text-base text-gray-600 dark:text-gray-400 max-w-2xl leading-relaxed">
                    Klik material untuk menampilkan visualisasi 3D interaktif beserta spesifikasi teknis lengkap.
                </p>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
                <% materialData.forEach(mat => { %>
                <div class="mat-card group relative rounded-2xl overflow-hidden bg-[var(--color-pln-gray)] shadow-sm hover:shadow-xl border border-white/10 cursor-pointer flex flex-col"
                     data-id="<%= mat.id %>">
                    <div class="w-full h-36 relative overflow-hidden flex items-center justify-center" style="background: <%= mat.bgGradient %>;">
                        <div class="absolute inset-0 opacity-25 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-[var(--color-pln-yellow)] via-transparent to-transparent group-hover:scale-150 transition-transform duration-700"></div>
                        <span class="relative z-10 text-5xl select-none" style="filter:drop-shadow(0 4px 12px rgba(0,0,0,0.4));"><%= mat.icon %></span>
                        <div class="absolute top-3 right-3">
                            <span class="text-[10px] font-bold uppercase tracking-wider px-2 py-0.5 rounded-full bg-blue-500/20 text-blue-600 dark:text-blue-300"><%= mat.categoryLabel %></span>
                        </div>
                    </div>
                    <div class="p-5 flex flex-col flex-grow">
                        <h3 class="text-base font-bold mb-1.5 text-white group-hover:text-[var(--color-pln-yellow)] transition-colors leading-tight"><%= mat.name %></h3>
                        <p class="text-gray-500 dark:text-gray-400 text-xs leading-relaxed mb-4 flex-grow"><%= mat.shortDesc %></p>
                        <div class="mt-auto border-t border-gray-100 dark:border-gray-800/60 pt-3 flex items-center justify-between">
                            <span class="text-[10px] font-mono text-gray-400 dark:text-gray-500"><%= mat.code %></span>
                            <span class="text-[10px] font-semibold text-[var(--color-pln-yellow)] flex items-center gap-1">
                                Lihat 3D <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
                            </span>
                        </div>
                    </div>
                </div>
                <% }); %>
            </div>
        </div>
    </main>

    <!-- MODAL -->
    <div id="modal-overlay" class="fixed inset-0 z-50 hidden items-center justify-center p-6">
        <div id="modal-card" class="relative w-full max-w-5xl rounded-3xl shadow-2xl border border-white/10 overflow-hidden bg-[#0d2238]" style="height: 520px;">

            <button id="btn-close" class="absolute top-4 right-4 z-30 p-2 rounded-full hover:bg-white/10 transition" style="background:rgba(0,0,0,0.4); color:#fff;">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>

            <div style="display:flex; height:100%;">

                <!-- KIRI 50%: 3D -->
                <div id="canvas-wrap">
                    <canvas id="modal-canvas"></canvas>

                    <div style="position:absolute; bottom:16px; left:0; right:0; display:flex; justify-content:center; gap:10px; z-index:10;">
                        <button id="btn-rotate" class="ctrl-pill ctrl-on">
                            <svg style="width:14px;height:14px;flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
                            Auto Putar: ON
                        </button>
                        <button id="btn-reset" class="ctrl-pill ctrl-off">⊙ Reset</button>
                    </div>

                    <div style="position:absolute; top:14px; left:50%; transform:translateX(-50%); background:rgba(0,0,0,0.45); color:rgba(255,255,255,0.4); font-size:11px; padding:4px 14px; border-radius:999px; white-space:nowrap; pointer-events:none;">
                        🖱 Drag · Scroll zoom
                    </div>
                </div>

                <!-- KANAN 50%: Info -->
                <div id="info-wrap">
                    <span id="modal-category" style="font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:1.2px; padding:3px 10px; border-radius:999px; background:rgba(0,229,255,0.12); color:#00E5FF; display:inline-block; margin-bottom:14px;"></span>

                    <div style="display:flex; align-items:center; gap:14px; margin-bottom:6px;">
                        <span id="modal-icon" style="font-size:38px; flex-shrink:0;"></span>
                        <div>
                            <p id="modal-code" style="font-size:10px; font-family:monospace; color:rgba(255,255,255,0.35); letter-spacing:1px; margin-bottom:3px;"></p>
                            <h2 id="modal-name" style="font-size:22px; font-weight:700; color:#fff; line-height:1.2; font-family:'Outfit',sans-serif;"></h2>
                        </div>
                    </div>

                    <p id="modal-desc" style="font-size:13px; color:rgba(255,255,255,0.55); line-height:1.75; margin-bottom:22px; padding-bottom:22px; border-bottom:1px solid rgba(255,255,255,0.08);"></p>

                    <p style="font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:1.2px; color:rgba(255,255,255,0.3); margin-bottom:12px;">Spesifikasi Teknis</p>
                    <div id="modal-specs"></div>
                </div>

            </div>
        </div>
    </div>

    <script>var __MATERIAL_DATA__ = <%- JSON.stringify(materialData) %>;</script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script src="/js/main.js"></script>
    <script src="/js/material.js"></script>
</body>
</html>
