<!DOCTYPE html>
<html lang="id" class="scroll-smooth overflow-x-hidden">
<head>
    <%- include('partials/head') %>
    <script type="module" src="https://ajax.googleapis.com/ajax/libs/model-viewer/3.4.0/model-viewer.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
</head>
<body class="antialiased" style="background-color: var(--color-bg-main); color: var(--color-text-primary);">

    <%- include('partials/navbar') %>

    <main style="padding-top:96px; padding-bottom:64px; min-height:100vh;" class="relative">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

            <!-- Header -->
            <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-8 mb-10 pb-8 border-b border-[var(--color-border)] relative">
                <div class="ambient-mesh mesh-split"></div>
                <div class="gsap-reveal">
                    <div class="mb-2">
                        <span class="text-sm font-semibold tracking-widest text-[var(--color-primary)] uppercase">Katalog Material · PLN</span>
                    </div>
                    <h1 class="text-4xl md:text-5xl font-extrabold brand-font mb-3 tracking-tight leading-tight text-[var(--color-text-primary)]">
                        Material Jaringan PLN
                    </h1>
                    <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed max-w-lg">
                        Klik pada material untuk menampilkan visualisasi 3D interaktif beserta spesifikasi teknis lengkap.
                    </p>
                </div>

                <!-- Search + Filter -->
                <div class="flex items-center gap-3 flex-shrink-0 min-w-[300px] lg:min-w-[380px]">
                    <div class="flex-1 relative">
                        <div class="absolute left-3.5 top-1/2 transform -translate-y-1/2 text-[var(--color-text-muted)] pointer-events-none">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
                        </div>
                        <input class="w-full bg-white border border-[var(--color-border)] rounded-xl py-2.5 pl-10 pr-4 text-sm text-[var(--color-text-primary)] placeholder-[var(--color-text-muted)] outline-none focus:border-[var(--color-primary)] focus:ring-2 focus:ring-[var(--color-primary)]/10 transition-all"
                            id="mat-search" type="text" placeholder="Cari material..." oninput="v3MatFilter()">
                    </div>
                    <div class="relative" id="mat-filter-dd">
                        <button type="button" class="flex items-center gap-2 bg-white border border-[var(--color-border)] rounded-xl py-2.5 px-4 text-xs font-semibold text-[var(--color-text-secondary)] hover:border-[var(--color-primary)] hover:text-[var(--color-primary)] transition-all cursor-pointer outline-none whitespace-nowrap" onclick="v3ToggleMatFilter()">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="opacity:.5"><path d="M3 6h18M6 12h12M10 18h4"/></svg>
                            <span id="mat-filter-label">Semua</span>
                            <svg class="w-3 h-3 transition-transform duration-200" id="mat-filter-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
                        </button>
                        <div id="mat-filter-menu" class="absolute top-full right-0 mt-2 min-w-[160px] rounded-xl bg-white border border-[var(--color-border)] shadow-xl z-50 hidden overflow-hidden">
                            <div class="p-1.5">
                                <div class="px-3 py-2 rounded-lg text-xs font-semibold cursor-pointer transition-colors hover:bg-[var(--color-primary)]/5 hover:text-[var(--color-primary)] text-[var(--color-primary)] bg-[var(--color-primary)]/5" onclick="v3SelectMatFilter('all','Semua')">Semua</div>
                                <% categories.forEach(function(cat) { %>
                                    <div class="px-3 py-2 rounded-lg text-xs font-semibold cursor-pointer transition-colors hover:bg-[var(--color-primary)]/5 hover:text-[var(--color-primary)] text-[var(--color-text-secondary)]" onclick="v3SelectMatFilter('<%= cat.id %>','<%= cat.name %>')"><%= cat.name %></div>
                                <% }); %>
                            </div>
                        </div>
                    </div>
                    <button type="button" id="mat-sort-btn" onclick="v3ToggleMatSort()"
                        class="flex items-center gap-2 bg-white border border-[var(--color-border)] rounded-xl py-2.5 px-4 text-xs font-semibold text-[var(--color-text-secondary)] hover:border-[var(--color-primary)] hover:text-[var(--color-primary)] transition-all cursor-pointer outline-none whitespace-nowrap">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h13M3 12h9M3 18h5"/><path d="M16 18l3 3 3-3M19 9V21"/></svg>
                        <span id="mat-sort-label">A→Z</span>
                    </button>
                </div>
            </div>

            <!-- Grid -->
            <% const validMaterials = materialData.filter(function(m) { return m.name && m.name.trim() !== ''; }); %>
            <div id="material-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 gsap-stagger-container">
                <% if (validMaterials.length === 0) { %>
                <div class="col-span-full flex flex-col items-center justify-center py-20 gap-4">
                    <div class="w-16 h-16 rounded-lg bg-[var(--color-bg-surface-alt)] flex items-center justify-center">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-text-muted)" stroke-width="1.5"><path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                    </div>
                    <span class="text-sm text-[var(--color-text-muted)]">Belum ada material yang tersedia.</span>
                </div>
                <% } %>

                <% validMaterials.forEach((mat, i) => { %>
                <div class="gsap-stagger-item mat-card-item" data-category="<%= mat.category %>">
                    <div class="mv-card" data-id="<%= mat.id %>">
                        <div class="mv-card-img">
                            <% if (mat.image) { %>
                                <img src="<%= mat.image %>" alt="<%= mat.name %>">
                            <% } else { %>
                                <div class="mv-card-img-placeholder">
                                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="<%= i % 2 === 0 ? 'var(--color-accent)' : 'var(--color-cyan)' %>" stroke-width="1.5" opacity="0.4">
                                        <path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
                                    </svg>
                                    <span style="font-size:10px; font-weight:700; color:var(--color-text-muted); letter-spacing:0.1em; text-transform:uppercase;">Material</span>
                                </div>
                            <% } %>
                        </div>
                        <div class="mv-card-body">
                            <div class="mv-card-title v3-card-title"><%= mat.name || '-' %></div>
                            <div class="mv-card-desc"><%= mat.description || 'Deskripsi belum tersedia.' %></div>
                            <div class="mv-card-divider"></div>
                            <div class="mv-card-stats">
                                <div class="mv-card-stat">
                                    <span class="mv-card-stat-label">Kategori</span>
                                    <span class="mv-card-stat-val" style="color:var(--color-accent);"><%= mat.categoryLabel || '-' %></span>
                                </div>
                                <div class="mv-card-stat">
                                    <span class="mv-card-stat-label">Kode</span>
                                    <span class="mv-card-stat-val" style="color:var(--color-cyan);"><%= mat.code || '—' %></span>
                                </div>
                                <div class="mv-go-btn">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                                </div>
                            </div>
                        </div>
                        <div class="mv-accent-line"></div>
                    </div>
                </div>
                <% }); %>
            </div>

            <!-- No results -->
            <div id="no-results" class="hidden flex-col items-center justify-center py-20 gap-4" style="display:none;">
                <div class="w-16 h-16 rounded-lg bg-[var(--color-bg-surface-alt)] flex items-center justify-center">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-text-muted)" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
                </div>
                <span class="text-sm text-[var(--color-text-muted)]">Tidak ada material untuk kategori ini.</span>
            </div>
        </div>
    </main>

    <%- include('partials/catalog-modal-material') %>

    <script id="material-data" type="text/template">
        <%- JSON.stringify(materialData) %>
    </script>
    <script>
        var __MATERIAL_DATA__ = JSON.parse(document.getElementById('material-data').textContent);
    </script>
    <%- include('partials/footer') %>
    <script src="/js/main.js"></script>
    <script src="/js/catalog-modal.js"></script>
    <script src="/js/material.js"></script>
    <script>
        var _matSort = 'none';
        var _matActiveFilter = 'all';
        (function() { var items = document.getElementById('material-grid').querySelectorAll('.mat-card-item'); items.forEach(function(el, i) { el.dataset.origIdx = i; }); })();

        function v3ToggleMatSort() {
            var lbl = document.getElementById('mat-sort-label');
            if (_matSort === 'none' || _matSort === 'desc') { _matSort = 'asc'; lbl.textContent = 'A→Z'; } else { _matSort = 'desc'; lbl.textContent = 'Z→A'; }
            v3SortMatGrid();
        }
        function v3SortMatGrid() {
            var grid = document.getElementById('material-grid');
            var items = Array.from(grid.querySelectorAll('.mat-card-item'));
            if (_matSort === 'none') { items.sort(function(a, b) { return a.dataset.origIdx - b.dataset.origIdx; }); }
            else { items.sort(function(a, b) { var na = (a.querySelector('.v3-card-title') || {}).textContent || ''; var nb = (b.querySelector('.v3-card-title') || {}).textContent || ''; return _matSort === 'asc' ? na.localeCompare(nb, 'id') : nb.localeCompare(na, 'id'); }); }
            items.forEach(function(el) { grid.appendChild(el); });
        }
        function v3ToggleMatFilter() { document.getElementById('mat-filter-menu').classList.toggle('hidden'); }
        function v3SelectMatFilter(value, label) {
            _matActiveFilter = value;
            document.getElementById('mat-filter-label').textContent = label;
            document.getElementById('mat-filter-menu').classList.add('hidden');
            v3MatFilter();
        }
        document.addEventListener('click', function(e) { var dd = document.getElementById('mat-filter-dd'); if (dd && !dd.contains(e.target)) { var menu = document.getElementById('mat-filter-menu'); if (menu) menu.classList.add('hidden'); } });
        function v3MatFilter() {
            var q = (document.getElementById('mat-search').value || '').toLowerCase().trim();
            var visible = 0;
            document.querySelectorAll('.mat-card-item').forEach(function(item) {
                var matchCat = _matActiveFilter === 'all' || item.dataset.category === _matActiveFilter;
                var nameEl = item.querySelector('.v3-card-title');
                var name = nameEl ? nameEl.textContent.toLowerCase() : '';
                var matchQ = q === '' || name.includes(q);
                var show = matchCat && matchQ;
                item.style.display = show ? '' : 'none';
                if (show) visible++;
            });
            var noResults = document.getElementById('no-results');
            if (noResults) { noResults.style.display = visible === 0 ? 'flex' : 'none'; noResults.classList.toggle('hidden', visible > 0); }
        }
        // Hover 3D badge
        document.querySelectorAll('.card-elevated[data-id]').forEach(function(card) {
            var badge = card.querySelector('.v3-3d-badge');
            if (!badge) return;
            card.addEventListener('mouseenter', function() { badge.style.opacity = '1'; });
            card.addEventListener('mouseleave', function() { badge.style.opacity = '0'; });
        });
        // GSAP
        document.addEventListener('DOMContentLoaded', function() {
            if (typeof gsap !== 'undefined' && typeof ScrollTrigger !== 'undefined') {
                gsap.registerPlugin(ScrollTrigger);
                gsap.to('.gsap-reveal', { y: 0, opacity: 1, duration: 1, stagger: 0.15, ease: 'power3.out', delay: 0.1 });
                gsap.from('.gsap-stagger-item', { scrollTrigger: { trigger: '#material-grid', start: 'top 85%' }, y: 50, opacity: 0, duration: 0.8, stagger: 0.08, ease: 'power3.out' });
            }
        });
    </script>
</body>
</html>