<!DOCTYPE html>
<html lang="id" class="scroll-smooth">
<head>
    <%- include('partials/head') %>
    <!-- Tambahkan library model-viewer khusus untuk halaman ini -->
    <script type="module" src="https://ajax.googleapis.com/ajax/libs/model-viewer/3.4.0/model-viewer.min.js"></script>
</head>
<body class="bg-[var(--color-pln-darker)] text-white font-sans antialiased overflow-x-hidden">

    <%- include('partials/navbar') %>

    <main class="pt-32 pb-24 px-4 sm:px-8 bg-[var(--color-pln-darker)] min-h-screen relative">
        <!-- Spotlight Backdrop -->
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[500px] bg-[var(--color-pln-yellow)]/5 rounded-full blur-[140px] pointer-events-none -z-10"></div>
        
        <div class="max-w-[1400px] mx-auto flex flex-col items-center">
            
            <!-- Header area -->
            <div class="w-full flex flex-col md:flex-row items-center justify-between gap-6 mb-10 pb-8 border-b border-white/5">
                <div class="flex flex-col items-start w-full md:w-auto">
                    <a href="/ModulKonstruksi" class="inline-flex items-center text-[11px] font-semibold uppercase tracking-[0.15em] text-white/50 hover:text-white transition-colors mb-4 group">
                        <svg class="w-4 h-4 mr-1.5 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
                        Kembali
                    </a>
                    <h1 class="text-3xl md:text-5xl font-['Space_Grotesk'] font-bold tracking-tight text-white/90">
                        <%= module.title %> 
                    </h1>
                </div>
                <div class="hidden md:flex flex-col items-end">
                    <span class="inline-flex items-center gap-2 py-1.5 px-4 rounded-full bg-white/5 text-white/70 text-[10px] font-bold tracking-[0.2em] uppercase border border-white/10 shadow-sm backdrop-blur-md">
                        <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-pln-yellow)] animate-pulse"></span>
                        Viewer Interaktif
                    </span>
                </div>
            </div>

            <!-- Data tersembunyi untuk modal JS -->
            <script type="application/json" id="module-assets-data">
                <%- JSON.stringify(module.assets || []) %>
            </script>

            <!-- Viewer and Info Grid layout (Apple Style presentation) -->
            <div class="w-full grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12">
                <!-- 3D Canvas (Mendasarkan 8 kolum) -->
                <div id="viewer-container" class="lg:col-span-8 relative w-full rounded-[2.5rem] overflow-hidden apple-glass-dark flex items-center justify-center group transition-all duration-500" style="height: 75vh; min-height: 500px;">
                    <!-- Radial Background Highlight (Gradient dari tengah) -->
                    <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-[#0A2045]/60 via-[#0A1222]/30 to-transparent pointer-events-none z-[-1]"></div>
                    
                    <!-- Hint Text (Minimalist Pill) -->
                    <div id="hint-text" class="absolute bottom-6 left-1/2 -translate-x-1/2 bg-[#1d1d1f]/80 backdrop-blur-2xl border border-white/10 text-white/80 text-[11px] font-medium tracking-wide px-5 py-2.5 rounded-full pointer-events-none z-10 opacity-70 group-hover:opacity-100 transition-opacity flex items-center gap-2 shadow-2xl">
                        <svg class="w-4 h-4 text-white/50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5M7.188 2.239l.777 2.897M5.136 7.965l-2.898-.777M13.95 4.05l-2.122 2.122m-5.657 5.656l-2.12 2.122"></path></svg>
                        <span>Rotasi 360&deg; | Zoom via Scroll</span>
                    </div>

                    <!-- Web Component Model Viewer -->
                    <model-viewer 
                        id="main-model-viewer"
                        src="" 
                        camera-controls 
                        auto-rotate
                        rotation-per-second="30deg"
                        interaction-prompt="none"
                        shadow-intensity="1.5"
                        environment-image="neutral"
                        exposure="1"
                        class="w-full h-full z-0 outline-none cursor-grab active:cursor-grabbing">
                        
                        <!-- Loading state custom -->
                        <div slot="poster" id="poster-container" class="absolute inset-0 flex flex-col items-center justify-center text-white/40 transition-all duration-500 bg-[#0A1929]/50 backdrop-blur-sm">
                            <div id="loading-spinner" class="animate-spin rounded-full h-10 w-10 border-2 border-t-[var(--color-pln-yellow)] border-r-[var(--color-pln-yellow)] border-b-transparent border-l-transparent mb-4"></div>
                            <span id="loading-text" class="text-xs uppercase tracking-[0.15em] font-semibold">Memuat Skema Spasial...</span>
                        </div>
                    </model-viewer>

                    <!-- Navigation Arrows (Variant Carousel) -->
                    <button id="viewer-prev-btn" onclick="prevVariant()" class="absolute left-6 top-1/2 -translate-y-1/2 w-12 h-12 bg-white/5 backdrop-blur-2xl rounded-full flex items-center justify-center text-white/50 hover:text-white hover:bg-white/10 transition-all hidden z-20 border border-white/5 shadow-lg group-hover:scale-105">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
                    </button>
                    <button id="viewer-next-btn" onclick="nextVariant()" class="absolute right-6 top-1/2 -translate-y-1/2 w-12 h-12 bg-white/5 backdrop-blur-2xl rounded-full flex items-center justify-center text-white/50 hover:text-white hover:bg-white/10 transition-all hidden z-20 border border-white/5 shadow-lg group-hover:scale-105">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                    </button>

                    <!-- Variant Display Name -->
                    <div id="viewer-variant-name" class="absolute top-6 left-1/2 -translate-x-1/2 px-6 py-2.5 bg-[#1d1d1f]/80 backdrop-blur-2xl text-white/90 text-[10px] font-bold rounded-full pointer-events-none z-10 hidden shadow-xl border border-white/10 uppercase tracking-[0.2em]">
                        Varian - 
                    </div>

                    <!-- Fullscreen Toggle Button -->
                    <button id="fullscreen-btn" onclick="toggleFullscreen()" title="Full Screen" class="absolute bottom-6 right-6 w-11 h-11 bg-[#1d1d1f]/60 backdrop-blur-2xl rounded-full flex items-center justify-center text-white/70 hover:text-white hover:bg-black/80 transition-all z-20 border border-white/10 shadow-xl group-hover:scale-105 opacity-80 hover:opacity-100">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4"></path></svg>
                    </button>
                </div>

                <!-- Info Cards (Mendasarkan 4 kolum sisi kanan) -->
                <div class="lg:col-span-4 flex flex-col gap-6" style="height: 75vh; min-height: 500px;">
                    <!-- Deskripsi Panel -->
                    <div class="apple-glass-light rounded-[2.5rem] p-8 flex-[2] flex flex-col min-h-0">
                        <h3 class="text-xs font-bold mb-4 text-[var(--color-pln-yellow)] uppercase tracking-[0.2em] font-['Inter'] shrink-0">Deskripsi Konstruksi</h3>
                        <div class="overflow-y-auto pr-2 custom-scrollbar flex-1 min-h-0">
                            <p class="text-white/80 text-sm leading-relaxed font-light font-['Inter'] break-words whitespace-pre-wrap"><%= module.description %></p>
                        </div>
                    </div>

                    <!-- Spesifikasi Panel -->
                    <div class="apple-glass-dark rounded-[2.5rem] px-8 pt-7 pb-6 flex flex-col flex-1 min-h-0 overflow-hidden">
                        <h3 class="text-xs font-bold mb-5 text-white/50 uppercase tracking-[0.2em] font-['Inter']">Spesifikasi Komponen</h3>
                        
                        <div class="flex flex-col justify-center flex-1 min-h-0">
                            <div class="flex items-center justify-between border-b border-white/5 py-4">
                                <span class="text-white/60 text-sm font-medium tracking-wide">Material</span>
                                <span class="font-['Space_Grotesk'] font-black text-3xl text-white"><%= module.materialCount %></span>
                            </div>
                            <div class="flex items-center justify-between py-4">
                                <span class="text-white/60 text-sm font-medium tracking-wide">Alat Pendukung</span>
                                <span class="font-['Space_Grotesk'] font-black text-3xl text-white"><%= module.equipmentCount %></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </main>

    <%- include('partials/footer') %>

    <!-- Scripts -->
    <script src="/js/main.js"></script>
    <script>
        // Logistics Viewer
        let currentAssets = [];
        let currentIndex = 0;

        document.addEventListener('DOMContentLoaded', () => {
            const modelViewer = document.getElementById('main-model-viewer');
            const spinner = document.getElementById('loading-spinner');
            const loadingText = document.getElementById('loading-text');
            const posterContainer = document.getElementById('poster-container');
            const hintText = document.getElementById('hint-text');

            if (modelViewer) {
                modelViewer.addEventListener('error', () => {
                    if (spinner) spinner.style.display = 'none';
                    if (hintText) hintText.style.display = 'none';
                    if (loadingText) loadingText.textContent = 'Objek 3D Tidak Tersedia';
                    if (posterContainer) {
                        posterContainer.classList.add('backdrop-blur-md', 'bg-white/40', 'dark:bg-black/40');
                    }
                });
            }

            // Inisialisasi Assets
            const assetsRaw = document.getElementById('module-assets-data').textContent;
            currentAssets = JSON.parse(assetsRaw) || [];
            
            const prevBtn = document.getElementById('viewer-prev-btn');
            const nextBtn = document.getElementById('viewer-next-btn');
            const variantName = document.getElementById('viewer-variant-name');

            if (currentAssets.length === 0) {
                if (loadingText) loadingText.textContent = 'Belum ada file 3D yang diunggah.';
                if (spinner) spinner.style.display = 'none';
            } else {
                loadVariant(0);
                
                if (currentAssets.length > 1) {
                    prevBtn.style.display = 'flex';
                    nextBtn.style.display = 'flex';
                    variantName.style.display = 'block';
                }
            }
        });

        function loadVariant(index) {
            if (index < 0 || index >= currentAssets.length) return;
            const viewer = document.getElementById('main-model-viewer');
            const variantName = document.getElementById('viewer-variant-name');
            const asset = currentAssets[index];
            
            viewer.src = asset.file || '';
            variantName.textContent = `Varian ${index + 1}/${currentAssets.length} : ${asset.name}`;
        }

        function nextVariant() {
            if (currentAssets.length <= 1) return;
            currentIndex = (currentIndex + 1) % currentAssets.length;
            loadVariant(currentIndex);
        }

        function prevVariant() {
            if (currentAssets.length <= 1) return;
            currentIndex = (currentIndex - 1 + currentAssets.length) % currentAssets.length;
            loadVariant(currentIndex);
        }

        // Fullscreen Toggle Interactivity
        function toggleFullscreen() {
            const container = document.getElementById('viewer-container');
            if (!document.fullscreenElement) {
                if (container.requestFullscreen) {
                    container.requestFullscreen().catch(err => {
                        console.error(`Error attempting to enable fullscreen: ${err.message} (${err.name})`);
                    });
                } else if (container.webkitRequestFullscreen) { /* Safari */
                    container.webkitRequestFullscreen();
                } else if (container.msRequestFullscreen) { /* IE11 */
                    container.msRequestFullscreen();
                }
            } else {
                if (document.exitFullscreen) {
                    document.exitFullscreen();
                } else if (document.webkitExitFullscreen) { /* Safari */
                    document.webkitExitFullscreen();
                } else if (document.msExitFullscreen) { /* IE11 */
                    document.msExitFullscreen();
                }
            }
        }
        
        // Handle fullscreen change styling adaptions
        document.addEventListener('fullscreenchange', (event) => {
            const container = document.getElementById('viewer-container');
            if (document.fullscreenElement) {
                container.style.borderRadius = "0px";
                container.style.border = "none";
            } else {
                container.style.borderRadius = "2.5rem";
                container.style.border = "1px solid rgba(255, 255, 255, 0.1)";
            }
        });
    </script>
</body>
</html>
