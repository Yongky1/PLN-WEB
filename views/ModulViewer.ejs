<!DOCTYPE html>
<html lang="id" class="scroll-smooth overflow-x-hidden">
<head>
    <%- include('partials/head') %>
    <!-- Tambahkan library model-viewer khusus untuk halaman ini -->
    <script type="module" src="https://ajax.googleapis.com/ajax/libs/model-viewer/3.4.0/model-viewer.min.js"></script>
    <style>
        .komponen-scroll-row {
            scroll-snap-type: x mandatory;
            -webkit-overflow-scrolling: touch;
            scrollbar-width: none;
        }
        .komponen-scroll-row::-webkit-scrollbar { display: none; }
        .komponen-scroll-row > * { scroll-snap-align: start; }
    </style>
</head>
<body class="bg-[var(--color-pln-darker)] text-white font-sans antialiased overflow-x-hidden">

    <%- include('partials/navbar') %>

    <main class="pt-32 pb-24 px-4 sm:px-8 bg-[var(--color-pln-darker)] min-h-screen relative overflow-x-hidden">
        <!-- Spotlight Backdrop -->
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] max-w-[100vw] h-[500px] bg-[var(--color-pln-yellow)]/5 rounded-full blur-[140px] pointer-events-none -z-10"></div>
        
        <div class="max-w-[1400px] mx-auto flex flex-col items-center">
            
            <!-- Header area -->
            <div class="w-full flex flex-col md:flex-row items-center justify-between gap-6 mb-10 pb-8 border-b border-white/5">
                <div class="flex flex-col items-start w-full md:w-auto">
                    <a href="/ModulKonstruksi" class="inline-flex items-center text-[11px] font-semibold uppercase tracking-[0.15em] text-white/50 hover:text-white transition-colors mb-4 group">
                        <svg class="w-4 h-4 mr-1.5 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
                        Kembali
                    </a>
                    <h1 class="text-3xl md:text-5xl font-['Space_Grotesk'] font-bold tracking-tight text-white/90">
                        <%= module.title %> 
                    </h1>
                </div>
                <div class="hidden md:flex flex-col items-end">
                    <span class="inline-flex items-center gap-2 py-1.5 px-4 rounded-full bg-white/5 text-white/70 text-[10px] font-bold tracking-[0.2em] uppercase border border-white/10 shadow-sm backdrop-blur-md">
                        <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-pln-yellow)] animate-pulse"></span>
                        Viewer Interaktif
                    </span>
                </div>
            </div>

            <!-- Data tersembunyi untuk modal JS -->
            <script type="application/json" id="module-assets-data">
                <%- JSON.stringify(module.assets || []) %>
            </script>

            <!-- Viewer and Info Grid layout (Apple Style presentation) -->
            <div class="w-full grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12">
                <!-- 3D Canvas (Mendasarkan 8 kolum) -->
                <div id="viewer-container" class="lg:col-span-8 relative w-full rounded-[2.5rem] overflow-hidden flex items-center justify-center group transition-all duration-500 shadow-[0_40px_80px_rgba(0,0,0,0.6),0_0_0_1px_rgba(255,255,255,0.08)] border border-white/10 min-h-[280px] md:h-[75vh] md:min-h-[500px]" style="background: radial-gradient(circle at 40% 40%, #0A2045 0%, #030812 100%);">
                    <!-- Ambient top glow -->
                    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-3/4 h-32 bg-[var(--color-pln-yellow)]/8 blur-[60px] pointer-events-none"></div>
                    
                    <!-- Hint Text (Minimalist Pill) -->
                    <div id="hint-text" class="absolute bottom-6 left-1/2 -translate-x-1/2 bg-[#1d1d1f]/80 backdrop-blur-2xl border border-white/10 text-white/80 text-[11px] font-medium tracking-wide px-5 py-2.5 rounded-full pointer-events-none z-10 opacity-70 group-hover:opacity-100 transition-opacity flex items-center gap-2 shadow-2xl">
                        <svg class="w-4 h-4 text-white/50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5M7.188 2.239l.777 2.897M5.136 7.965l-2.898-.777M13.95 4.05l-2.122 2.122m-5.657 5.656l-2.12 2.122"></path></svg>
                        <span>Rotasi 360&deg; | Zoom via Scroll</span>
                    </div>

                    <!-- Web Component Model Viewer -->
                    <model-viewer 
                        id="main-model-viewer"
                        src="" 
                        camera-controls 
                        auto-rotate
                        rotation-per-second="30deg"
                        interaction-prompt="none"
                        shadow-intensity="1.5"
                        environment-image="neutral"
                        exposure="1"
                        class="w-full h-full z-0 outline-none cursor-grab active:cursor-grabbing">
                        
                        <!-- Loading state custom -->
                        <div slot="poster" id="poster-container" class="absolute inset-0 flex flex-col items-center justify-center text-white/40 transition-all duration-500 bg-[#0A1929]/50 backdrop-blur-sm">
                            <div id="loading-spinner" class="animate-spin rounded-full h-10 w-10 border-2 border-t-[var(--color-pln-yellow)] border-r-[var(--color-pln-yellow)] border-b-transparent border-l-transparent mb-4"></div>
                            <span id="loading-text" class="text-xs uppercase tracking-[0.15em] font-semibold">Memuat Skema Spasial...</span>
                        </div>
                    </model-viewer>

                    <!-- Navigation Arrows (Variant Carousel) -->
                    <button id="viewer-prev-btn" onclick="prevVariant()" class="absolute left-3 md:left-6 top-1/2 -translate-y-1/2 w-10 h-10 md:w-12 md:h-12 bg-white/5 backdrop-blur-2xl rounded-full flex items-center justify-center text-white/50 hover:text-white hover:bg-white/10 transition-all hidden z-20 border border-white/5 shadow-lg group-hover:scale-105">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
                    </button>
                    <button id="viewer-next-btn" onclick="nextVariant()" class="absolute right-3 md:right-6 top-1/2 -translate-y-1/2 w-10 h-10 md:w-12 md:h-12 bg-white/5 backdrop-blur-2xl rounded-full flex items-center justify-center text-white/50 hover:text-white hover:bg-white/10 transition-all hidden z-20 border border-white/5 shadow-lg group-hover:scale-105">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                    </button>

                    <!-- Variant Display Name -->
                    <div id="viewer-variant-name" class="absolute top-6 left-1/2 -translate-x-1/2 px-6 py-2.5 bg-[#1d1d1f]/80 backdrop-blur-2xl text-white/90 text-[10px] font-bold rounded-full pointer-events-none z-10 hidden shadow-xl border border-white/10 uppercase tracking-[0.2em]">
                        Varian - 
                    </div>

                    <!-- Fullscreen Toggle Button -->
                    <button id="fullscreen-btn" onclick="toggleFullscreen()" title="Full Screen" class="absolute top-6 right-6 w-11 h-11 bg-[#1d1d1f]/60 backdrop-blur-2xl rounded-full flex items-center justify-center text-white/70 hover:text-white hover:bg-black/80 transition-all z-20 border border-white/10 shadow-xl group-hover:scale-105 opacity-100 md:opacity-0 md:group-hover:opacity-100">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4"></path></svg>
                    </button>
                </div>

                <!-- Info Cards (Mendasarkan 4 kolum sisi kanan) -->
                <div class="lg:col-span-4 flex flex-col gap-6 h-[500px] lg:h-[75vh] lg:min-h-[500px] w-full">
                    <!-- Deskripsi Panel -->
                    <div class="apple-glass-light rounded-[2rem] lg:rounded-[2.5rem] p-6 lg:p-8 flex-[2] flex flex-col min-h-0 w-full">
                        <h3 class="text-xs font-bold mb-4 text-[var(--color-pln-yellow)] uppercase tracking-[0.2em] font-['Inter'] shrink-0">Deskripsi Konstruksi</h3>
                        <div class="overflow-y-auto pr-2 custom-scrollbar flex-1 min-h-0">
                            <p class="text-white/80 text-sm leading-relaxed font-light font-['Inter'] break-words whitespace-pre-wrap"><%= module.description %></p>
                        </div>
                    </div>

                    <!-- Spesifikasi Panel -->
                    <div class="apple-glass-dark rounded-[2rem] lg:rounded-[2.5rem] p-6 lg:px-8 lg:pt-7 lg:pb-6 flex flex-col flex-1 min-h-0 overflow-hidden w-full">
                        <h3 class="text-xs font-bold mb-4 lg:mb-5 text-white/50 uppercase tracking-[0.2em] font-['Inter'] shrink-0">Spesifikasi Komponen</h3>
                        
                        <div class="flex flex-col justify-center flex-1 min-h-0">
                            <div class="flex items-center justify-between border-b border-white/5 py-4">
                                <span class="text-white/60 text-sm font-medium tracking-wide">Material</span>
                                <span class="font-['Space_Grotesk'] font-black text-3xl text-white"><%= module.materialCount %></span>
                            </div>
                            <div class="flex items-center justify-between py-4">
                                <span class="text-white/60 text-sm font-medium tracking-wide">Alat Pendukung</span>
                                <span class="font-['Space_Grotesk'] font-black text-3xl text-white"><%= module.equipmentCount %></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <!-- ===== SECTION: MATERIAL & PERALATAN ===== -->
        <% if ((module.materials && module.materials.length > 0) || (module.tools && module.tools.length > 0)) { %>
        <div class="w-full mt-20">

            <!-- Divider -->
            <div class="flex items-center gap-4 mb-14">
                <div class="flex-1 h-px bg-white/5"></div>
                <span class="text-[10px] font-bold uppercase tracking-[0.25em] text-white/20">Komponen Konstruksi</span>
                <div class="flex-1 h-px bg-white/5"></div>
            </div>

            <!-- ── MATERIAL ─────────────────────────────────── -->
            <% if (module.materials && module.materials.length > 0) { %>
            <div class="mb-16">
                <div class="flex flex-wrap items-center gap-3 mb-6">
                    <span class="inline-flex items-center gap-2 py-1.5 px-3 rounded-full bg-[var(--color-pln-yellow)]/10 text-[var(--color-pln-yellow)] text-[10px] font-bold tracking-[0.15em] uppercase border border-[var(--color-pln-yellow)]/20 shadow-[0_0_15px_rgba(255,213,0,0.1)]">
                        <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-pln-yellow)] animate-pulse"></span>
                        Katalog Material
                    </span>
                    <span class="text-[11px] font-semibold px-2.5 py-0.5 rounded-full bg-[var(--color-pln-yellow)]/8 text-[var(--color-pln-yellow)]/60 border border-[var(--color-pln-yellow)]/15"><%= module.materials.length %> item</span>
                </div>

                <!-- Horizontal Scroll Row -->
                <div class="komponen-scroll-row flex gap-5 overflow-x-auto pb-4">
                    <% module.materials.forEach(function(row) { %>
                    <% const m = row.material || {}; %>

                    <div class="group flex flex-col apple-glass-light rounded-[2rem] overflow-hidden hover:shadow-[0_30px_60px_-15px_rgba(255,255,255,0.2)] hover:border-white/40 hover:-translate-y-2 transition-all duration-500 cursor-default relative flex-shrink-0 w-[220px]">

                        <!-- Image Top -->
                        <div class="h-[140px] relative overflow-hidden bg-black/20">
                            <% if (m.image) { %>
                                <img src="<%= m.image %>" alt="<%= m.name %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out">
                            <% } else { %>
                                <div class="absolute inset-0" style="background: <%= m.bgGradient || 'linear-gradient(135deg,#1a2030 0%,#0d1520 100%)' %>;"></div>
                                <div class="absolute inset-0 bg-gradient-to-br from-black/10 to-black/30"></div>
                                <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(255,213,0,0.12)_0%,transparent_65%)] opacity-60 group-hover:opacity-100 transition-opacity duration-500"></div>
                                <div class="w-full h-full flex items-center justify-center relative z-10">
                                    <span class="text-5xl select-none group-hover:scale-110 transition-transform duration-500" style="filter:drop-shadow(0 6px 20px rgba(0,0,0,0.5));"><%= m.icon || '📦' %></span>
                                </div>
                            <% } %>

                            <!-- Category badge -->
                            <div class="absolute top-3 right-3 z-20">
                                <span class="inline-block px-2.5 py-1 bg-black/40 text-white/80 border border-white/10 text-[9px] font-bold rounded-full uppercase tracking-wider backdrop-blur-md">
                                    <%= m.categoryLabel || m.category || '' %>
                                </span>
                            </div>

                            <!-- Qty badge -->
                            <% if (row.quantity && row.quantity > 1) { %>
                            <div class="absolute bottom-3 left-3 z-20 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                                <span class="inline-flex items-center gap-1 text-[9px] font-bold px-2.5 py-1 rounded-full bg-[var(--color-pln-yellow)]/20 text-[var(--color-pln-yellow)] border border-[var(--color-pln-yellow)]/30 backdrop-blur-md uppercase tracking-wider">
                                    × <%= row.quantity %>
                                </span>
                            </div>
                            <% } %>
                        </div>

                        <!-- Content -->
                        <div class="p-5 flex-grow flex flex-col relative z-10 bg-gradient-to-t from-black/60 via-black/10 to-transparent">
                            <h3 class="text-[15px] font-bold mb-1.5 text-white/90 group-hover:text-[var(--color-pln-yellow)] transition-colors leading-snug font-['Space_Grotesk'] tracking-tight line-clamp-2">
                                <%= m.name || '-' %>
                            </h3>
                            <p class="text-white/40 text-[11px] leading-relaxed mb-5 font-['Inter'] line-clamp-2">
                                <%= m.shortDesc || m.description || '' %>
                            </p>
                            <div class="mt-auto flex justify-between items-end">
                                <div>
                                    <p class="text-[9px] uppercase tracking-wider text-white/40 mb-0.5 font-semibold">Kategori</p>
                                    <p class="text-[13px] font-bold text-[var(--color-pln-yellow)] font-['Outfit']"><%= m.categoryLabel || '-' %></p>
                                </div>
                                <div class="w-8 h-8 rounded-full bg-[var(--color-pln-yellow)]/10 flex items-center justify-center text-[var(--color-pln-yellow)] group-hover:bg-[var(--color-pln-yellow)] group-hover:text-black transition-colors shrink-0">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                                </div>
                            </div>
                        </div>
                    </div>
                    <% }); %>
                </div>
            </div>
            <% } %>

            <!-- ── PERALATAN ────────────────────────────────── -->
            <% if (module.tools && module.tools.length > 0) { %>
            <div>
                <div class="flex flex-wrap items-center gap-3 mb-6">
                    <span class="inline-flex items-center gap-2 py-1.5 px-3 rounded-full bg-[var(--color-pln-yellow)]/10 text-[var(--color-pln-yellow)] text-[10px] font-bold tracking-[0.15em] uppercase border border-[var(--color-pln-yellow)]/20 shadow-[0_0_15px_rgba(255,213,0,0.1)]">
                        <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-pln-yellow)] animate-pulse"></span>
                        Peralatan Lapangan
                    </span>
                    <span class="text-[11px] font-semibold px-2.5 py-0.5 rounded-full bg-[var(--color-pln-yellow)]/8 text-[var(--color-pln-yellow)]/60 border border-[var(--color-pln-yellow)]/15"><%= module.tools.length %> item</span>
                </div>

                <!-- Horizontal Scroll Row -->
                <div class="komponen-scroll-row flex gap-5 overflow-x-auto pb-4">
                    <% module.tools.forEach(function(row) { %>
                    <% const t = row.tool || {}; %>
                    <%
                        const catBadgeClass = t.category === 'k3'
                            ? 'bg-red-500/15 text-red-400 border-red-500/30'
                            : t.category === 'teknis'
                            ? 'bg-blue-500/15 text-blue-400 border-blue-500/30'
                            : 'bg-purple-500/15 text-purple-400 border-purple-500/30';
                    %>

                    <div class="group flex flex-col apple-glass-light rounded-[2rem] overflow-hidden hover:shadow-[0_30px_60px_-15px_rgba(255,255,255,0.2)] hover:border-white/40 hover:-translate-y-2 transition-all duration-500 cursor-default relative flex-shrink-0 w-[220px]">

                        <!-- Image Top -->
                        <div class="h-[140px] relative overflow-hidden bg-black/20">
                            <% if (t.image) { %>
                                <img src="<%= t.image %>" alt="<%= t.name %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out">
                                <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>
                            <% } else { %>
                                <div class="absolute inset-0" style="background: <%= t.bgGradient || 'linear-gradient(135deg,#1a2030 0%,#0d1520 100%)' %>;"></div>
                                <div class="absolute inset-0 bg-gradient-to-br from-black/10 to-black/30 group-hover:opacity-70 transition-opacity duration-500"></div>
                                <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(245,158,11,0.12)_0%,transparent_65%)] opacity-60 group-hover:opacity-100 transition-opacity duration-500"></div>
                                <div class="w-full h-full flex items-center justify-center opacity-20 group-hover:opacity-35 transition-opacity duration-500">
                                    <svg class="w-14 h-14 text-[var(--color-pln-yellow)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                    </svg>
                                </div>
                            <% } %>

                            <!-- Category badge -->
                            <div class="absolute top-3 right-3 flex flex-col gap-1.5 items-end z-10">
                                <span class="text-[9px] font-bold uppercase tracking-wider px-2.5 py-1 rounded-full border backdrop-blur-md <%= catBadgeClass %>">
                                    <%= t.categoryLabel || t.category || '' %>
                                </span>
                            </div>
                        </div>

                        <!-- Content -->
                        <div class="p-5 flex-grow flex flex-col relative z-10 bg-gradient-to-t from-black/60 via-black/10 to-transparent">
                            <h3 class="text-[15px] font-bold mb-1.5 text-white/90 group-hover:text-[var(--color-pln-yellow)] transition-colors leading-snug font-['Space_Grotesk'] tracking-tight line-clamp-2">
                                <%= t.name || '-' %>
                            </h3>
                            <p class="text-white/40 text-[11px] leading-relaxed mb-5 font-['Inter'] line-clamp-2">
                                <%= t.description || '' %>
                            </p>
                            <div class="mt-auto flex justify-between items-end">
                                <div class="flex items-center gap-3">
                                    <div>
                                        <p class="text-[9px] uppercase tracking-wider text-white/40 mb-0.5 font-semibold">Standar</p>
                                        <p class="text-[13px] font-bold text-[var(--color-pln-yellow)] font-['Outfit']"><%= t.standard || '-' %></p>
                                    </div>
                                    <div class="w-px h-6 bg-white/10"></div>
                                    <div>
                                        <p class="text-[9px] uppercase tracking-wider text-white/40 mb-0.5 font-semibold">Status</p>
                                        <p class="text-[13px] font-bold font-['Outfit'] <%= t.status === 'Wajib' ? 'text-red-400' : 'text-emerald-400' %>"><%= t.status || '-' %></p>
                                    </div>
                                </div>
                                <div class="w-8 h-8 rounded-full bg-[var(--color-pln-yellow)]/10 flex items-center justify-center text-[var(--color-pln-yellow)] group-hover:bg-[var(--color-pln-yellow)] group-hover:text-black transition-colors shrink-0">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                                </div>
                            </div>
                        </div>
                    </div>
                    <% }); %>
                </div>
            </div>
            <% } %>

        </div>
        <% } %>

    </main>

    <%- include('partials/footer') %>

    <!-- Scripts -->
    <script src="/js/main.js"></script>
    <script>
        // Logistics Viewer
        let currentAssets = [];
        let currentIndex = 0;

        document.addEventListener('DOMContentLoaded', () => {
            const modelViewer = document.getElementById('main-model-viewer');
            const spinner = document.getElementById('loading-spinner');
            const loadingText = document.getElementById('loading-text');
            const posterContainer = document.getElementById('poster-container');
            const hintText = document.getElementById('hint-text');

            // Hint text: ganti teks untuk pengguna touch
            if (hintText && 'ontouchstart' in window) {
                const span = hintText.querySelector('span');
                if (span) span.textContent = 'Geser untuk Rotasi · Pinch to Zoom';
            }

            if (modelViewer) {
                modelViewer.addEventListener('error', () => {
                    if (spinner) spinner.style.display = 'none';
                    if (hintText) hintText.style.display = 'none';
                    if (loadingText) loadingText.textContent = 'Objek 3D Tidak Tersedia';
                    if (posterContainer) {
                        posterContainer.classList.add('backdrop-blur-md', 'bg-white/40', 'dark:bg-black/40');
                    }
                });
            }

            // Inisialisasi Assets
            const assetsRaw = document.getElementById('module-assets-data').textContent;
            currentAssets = JSON.parse(assetsRaw) || [];
            
            const prevBtn = document.getElementById('viewer-prev-btn');
            const nextBtn = document.getElementById('viewer-next-btn');
            const variantName = document.getElementById('viewer-variant-name');

            if (currentAssets.length === 0) {
                if (loadingText) loadingText.textContent = 'Belum ada file 3D yang diunggah.';
                if (spinner) spinner.style.display = 'none';
            } else {
                loadVariant(0);
                
                if (currentAssets.length > 1) {
                    prevBtn.style.display = 'flex';
                    nextBtn.style.display = 'flex';
                    variantName.style.display = 'block';
                }
            }
        });

        function loadVariant(index) {
            if (index < 0 || index >= currentAssets.length) return;
            const viewer = document.getElementById('main-model-viewer');
            const variantName = document.getElementById('viewer-variant-name');
            const asset = currentAssets[index];
            
            viewer.src = asset.file || '';
            variantName.textContent = `Varian ${index + 1}/${currentAssets.length} : ${asset.name}`;
        }

        function nextVariant() {
            if (currentAssets.length <= 1) return;
            currentIndex = (currentIndex + 1) % currentAssets.length;
            loadVariant(currentIndex);
        }

        function prevVariant() {
            if (currentAssets.length <= 1) return;
            currentIndex = (currentIndex - 1 + currentAssets.length) % currentAssets.length;
            loadVariant(currentIndex);
        }

        // Fullscreen Toggle Interactivity
        function toggleFullscreen() {
            const container = document.getElementById('viewer-container');
            if (!document.fullscreenElement) {
                if (container.requestFullscreen) {
                    container.requestFullscreen().catch(err => {
                        console.error(`Error attempting to enable fullscreen: ${err.message} (${err.name})`);
                    });
                } else if (container.webkitRequestFullscreen) { /* Safari */
                    container.webkitRequestFullscreen();
                } else if (container.msRequestFullscreen) { /* IE11 */
                    container.msRequestFullscreen();
                }
            } else {
                if (document.exitFullscreen) {
                    document.exitFullscreen();
                } else if (document.webkitExitFullscreen) { /* Safari */
                    document.webkitExitFullscreen();
                } else if (document.msExitFullscreen) { /* IE11 */
                    document.msExitFullscreen();
                }
            }
        }
        
        // Handle fullscreen change styling adaptions
        document.addEventListener('fullscreenchange', (event) => {
            const container = document.getElementById('viewer-container');
            if (document.fullscreenElement) {
                container.style.borderRadius = "0px";
                container.style.border = "none";
            } else {
                container.style.borderRadius = "2.5rem";
                container.style.border = "1px solid rgba(255, 255, 255, 0.1)";
            }
        });
    </script>
</body>
</html>
