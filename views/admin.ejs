                                    <input id="material-shortdesc" type="text" placeholder="Deskripsi singkat yang tampil di kartu..." style="width:100%; padding:10px 14px; border-radius:10px; border:1px solid rgba(255,255,255,0.1); background:rgba(255,255,255,0.05); color:#1A2B4A; font-size:13px; font-family:inherit; outline:none; box-sizing:border-box;">
                                </div>
                                <div>
                                    <label style="font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:0.8px; color:#8899B0; display:block; margin-bottom:6px;">Deskripsi Lengkap</label>
                                    <textarea id="material-desc" placeholder="Penjelasan lengkap material, fungsi, dan cara penggunaannya..." rows="3" style="width:100%; padding:10px 14px; border-radius:10px; border:1px solid rgba(255,255,255,0.1); background:rgba(255,255,255,0.05); color:#1A2B4A; font-size:13px; font-family:inherit; outline:none; resize:vertical; box-sizing:border-box;"></textarea>
                                </div>
                                <div>
                                    <label style="font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:0.8px; color:#8899B0; display:block; margin-bottom:6px;">Spesifikasi Teknis</label>
                                    <div id="spec-rows" style="display:flex; flex-direction:column; gap:8px; margin-bottom:8px;">
                                        <div style="display:grid; grid-template-columns:1fr 1fr 32px; gap:8px; align-items:center;">
                                            <input type="text" placeholder="Nama spek (Diameter)" style="padding:9px 12px; border-radius:8px; border:1px solid rgba(255,255,255,0.1); background:rgba(255,255,255,0.05); color:#1A2B4A; font-size:12px; font-family:inherit; outline:none;">
                                            <input type="text" placeholder="Nilai (M20)" style="padding:9px 12px; border-radius:8px; border:1px solid rgba(255,255,255,0.1); background:rgba(255,255,255,0.05); color:#1A2B4A; font-size:12px; font-family:inherit; outline:none;">
                                            <button onclick="removeSpecRow(this)" style="width:32px; height:32px; border-radius:8px; background:rgba(239,68,68,0.1); border:1px solid rgba(239,68,68,0.2); color:#EF4444; cursor:pointer; font-size:14px; display:flex; align-items:center; justify-content:center; flex-shrink:0;">×</button>
                                        </div>
                                    </div>
                                    <button onclick="addSpecRow()" style="font-size:12px; color:rgba(255,255,255,0.4); border:none; background:none; cursor:pointer; padding:4px 0; font-family:inherit; display:flex; align-items:center; gap:6px;">
                                        <span style="font-size:16px; color:#0052A3;">+</span> Tambah Spesifikasi
                                    </button>
                                </div>
                                <div style="display:flex; gap:10px; padding-top:4px;">
                                    <button onclick="addMaterial()" style="padding:10px 24px; border-radius:10px; background:#00E5FF; color:#05101E; font-size:13px; font-weight:700; border:none; cursor:pointer; font-family:inherit;">Simpan Material</button>
                                    <button onclick="resetForm('material')" style="padding:10px 18px; border-radius:10px; background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1); color:#5A6F8F; font-size:13px; font-weight:500; cursor:pointer; font-family:inherit;">Reset</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- PAGE: TAMBAH TOOLS -->
            <div id="page-add-tools" class="page-section">
                <div class="content-scroll" style="padding:28px;">
                    <div style="max-width:720px;">
                        <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:24px;">
                            <div>
                                <h3 style="font-size:16px; font-weight:700; color:#1A2B4A;">Tambah Tools & Alat K3</h3>
                                <p style="font-size:12px; color:#8899B0; margin-top:3px;">Isi form di bawah untuk menambahkan alat baru ke katalog</p>
                            </div>
                            <span style="font-size:11px; font-weight:600; padding:4px 12px; border-radius:999px; background:rgba(245,158,11,0.1); color:#F59E0B; border:1px solid rgba(245,158,11,0.25);">Tools</span>
                        </div>

                        <div id="tools-list" style="display:flex; flex-direction:column; gap:10px; margin-bottom:20px;">
                            <div style="background:#fff; border:1px solid #E2E8F0; border-radius:14px; padding:16px 20px; display:flex; align-items:center; gap:16px;">
                                <div style="font-size:24px; flex-shrink:0;">⛑️</div>
                                <div style="flex:1;">
                                    <div style="font-size:13px; font-weight:600; color:#1A2B4A;">Helm Safety</div>
                                    <div style="font-size:11px; color:#8899B0; margin-top:2px;">Alat K3 · SNI 8400:2017 · Wajib</div>
                                </div>
                                <span style="font-size:11px; padding:3px 10px; border-radius:999px; background:rgba(239,68,68,0.1); color:#EF4444; font-weight:600;">K3</span>
                                <button onclick="removeRowFromDOM(this)" style="padding:6px 12px; border-radius:8px; background:rgba(239,68,68,0.1); border:1px solid rgba(239,68,68,0.25); color:#EF4444; font-size:11px; font-weight:600; cursor:pointer; font-family:inherit;">Hapus</button>
                            </div>
                            <div style="background:#fff; border:1px solid #E2E8F0; border-radius:14px; padding:16px 20px; display:flex; align-items:center; gap:16px;">
                                <div style="font-size:24px; flex-shrink:0;">🪜</div>
                                <div style="flex:1;">
                                    <div style="font-size:13px; font-weight:600; color:#1A2B4A;">Tangga Fiberglass</div>
                                    <div style="font-size:11px; color:#8899B0; margin-top:2px;">Alat Teknis · SPLN D3.013 · Wajib</div>
                                </div>
                                <span style="font-size:11px; padding:3px 10px; border-radius:999px; background:rgba(0,229,255,0.1); color:#0052A3; font-weight:600;">Teknis</span>
                                <button onclick="removeRowFromDOM(this)" style="padding:6px 12px; border-radius:8px; background:rgba(239,68,68,0.1); border:1px solid rgba(239,68,68,0.25); color:#EF4444; font-size:11px; font-weight:600; cursor:pointer; font-family:inherit;">Hapus</button>
                            </div>
                        </div>

                        <div style="background:rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.08); border-radius:16px; padding:24px;">
                            <h4 style="font-size:13px; font-weight:600; color:#1A2B4A; margin-bottom:18px; display:flex; align-items:center; gap:8px;">
                                <svg style="width:15px;height:15px;color:#F59E0B;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                                Tambah Alat Baru
                            </h4>
                            <div style="display:flex; flex-direction:column; gap:14px;">
                                <div style="display:grid; grid-template-columns:1fr 80px; gap:14px;">
                                    <div>
                                        <label style="font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:0.8px; color:#8899B0; display:block; margin-bottom:6px;">Nama Alat *</label>
                                        <input id="tools-name" type="text" placeholder="Contoh: Kunci Torsi" style="width:100%; padding:10px 14px; border-radius:10px; border:1px solid rgba(255,255,255,0.1); background:rgba(255,255,255,0.05); color:#1A2B4A; font-size:13px; font-family:inherit; outline:none; box-sizing:border-box;">
                                    </div>
                                    <div>
                                        <label style="font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:0.8px; color:#8899B0; display:block; margin-bottom:6px;">Ikon</label>
                                        <input id="tools-icon" type="text" placeholder="🔧" style="width:100%; padding:10px 14px; border-radius:10px; border:1px solid rgba(255,255,255,0.1); background:rgba(255,255,255,0.05); color:#1A2B4A; font-size:20px; font-family:inherit; outline:none; box-sizing:border-box;">
                                    </div>
                                </div>
                                <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:14px;">
                                    <div>
                                        <label style="font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:0.8px; color:#8899B0; display:block; margin-bottom:6px;">Kategori</label>
                                        <select id="tools-category" style="width:100%; padding:10px 14px; border-radius:10px; border:1px solid rgba(255,255,255,0.1); background:#0d1f35; color:#1A2B4A; font-size:13px; font-family:inherit; outline:none; box-sizing:border-box;">
                                            <option value="k3">Alat K3</option>
                                            <option value="teknis">Alat Teknis</option>
                                            <option value="pengukuran">Pengukuran</option>
                                        </select>
                                    </div>
                                    <div>
                                        <label style="font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:0.8px; color:#8899B0; display:block; margin-bottom:6px;">Standar</label>
                                        <input id="tools-standard" type="text" placeholder="SNI / IEC / ISO" style="width:100%; padding:10px 14px; border-radius:10px; border:1px solid rgba(255,255,255,0.1); background:rgba(255,255,255,0.05); color:#1A2B4A; font-size:13px; font-family:inherit; outline:none; box-sizing:border-box;">
                                    </div>
                                    <div>
                                        <label style="font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:0.8px; color:#8899B0; display:block; margin-bottom:6px;">Status</label>
                                        <select id="tools-status" style="width:100%; padding:10px 14px; border-radius:10px; border:1px solid rgba(255,255,255,0.1); background:#0d1f35; color:#1A2B4A; font-size:13px; font-family:inherit; outline:none; box-sizing:border-box;">
                                            <option>Wajib</option>
                                            <option>Situasional</option>
                                        </select>
                                    </div>
                                </div>
                                <div>
                                    <label style="font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:0.8px; color:#8899B0; display:block; margin-bottom:6px;">Deskripsi</label>
                                    <textarea id="tools-desc" placeholder="Jelaskan fungsi alat dan cara penggunaannya..." rows="3" style="width:100%; padding:10px 14px; border-radius:10px; border:1px solid rgba(255,255,255,0.1); background:rgba(255,255,255,0.05); color:#1A2B4A; font-size:13px; font-family:inherit; outline:none; resize:vertical; box-sizing:border-box;"></textarea>
                                </div>
                                <div>
                                    <label style="font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:0.8px; color:#8899B0; display:block; margin-bottom:6px;">Prosedur Penggunaan</label>
                                    <div id="procedure-rows" style="display:flex; flex-direction:column; gap:8px; margin-bottom:8px;">
                                        <div style="display:grid; grid-template-columns:24px 1fr 32px; gap:8px; align-items:center;">
                                            <span style="font-size:11px; font-weight:700; color:rgba(255,255,255,0.3); text-align:center;">1</span>
                                            <input type="text" placeholder="Langkah prosedur..." style="padding:9px 12px; border-radius:8px; border:1px solid rgba(255,255,255,0.1); background:rgba(255,255,255,0.05); color:#1A2B4A; font-size:12px; font-family:inherit; outline:none;">
                                            <button onclick="removeProcRow(this)" style="width:32px; height:32px; border-radius:8px; background:rgba(239,68,68,0.1); border:1px solid rgba(239,68,68,0.2); color:#EF4444; cursor:pointer; font-size:14px; display:flex; align-items:center; justify-content:center;">×</button>
                                        </div>
                                    </div>
                                    <button onclick="addProcRow()" style="font-size:12px; color:rgba(255,255,255,0.4); border:none; background:none; cursor:pointer; padding:4px 0; font-family:inherit; display:flex; align-items:center; gap:6px;">
                                        <span style="font-size:16px; color:#F59E0B;">+</span> Tambah Langkah
                                    </button>
                                </div>
                                <div style="display:flex; gap:10px; padding-top:4px;">
                                    <button onclick="addTools()" style="padding:10px 24px; border-radius:10px; background:#00E5FF; color:#05101E; font-size:13px; font-weight:700; border:none; cursor:pointer; font-family:inherit;">Simpan Alat</button>
                                    <button onclick="resetForm('tools')" style="padding:10px 18px; border-radius:10px; background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1); color:#5A6F8F; font-size:13px; font-weight:500; cursor:pointer; font-family:inherit;">Reset</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- PAGE: REPORTS -->
            <div id="page-reports" class="page-section">
                <div class="content-scroll" style="padding:28px;">
                    <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:16px; margin-bottom:24px;">
                        <div class="stat-card" style="text-align:center;">
                            <div style="font-size:36px; font-weight:700; color:#0052A3; font-family:'Outfit',sans-serif;">1,842</div>
                            <div style="font-size:13px; color:rgba(255,255,255,0.5); margin-top:6px;">Total Sesi Bulan Ini</div>
                        </div>
                        <div class="stat-card" style="text-align:center;">
                            <div style="font-size:36px; font-weight:700; color:#10B981; font-family:'Outfit',sans-serif;">68%</div>
                            <div style="font-size:13px; color:rgba(255,255,255,0.5); margin-top:6px;">Rata-rata Penyelesaian</div>
                        </div>
                        <div class="stat-card" style="text-align:center;">
                            <div style="font-size:36px; font-weight:700; color:#F59E0B; font-family:'Outfit',sans-serif;">24m</div>
                            <div style="font-size:13px; color:rgba(255,255,255,0.5); margin-top:6px;">Rata-rata Durasi Sesi</div>
                        </div>
                    </div>
                    <div style="background:#fff; border:1px solid #E2E8F0; border-radius:16px; padding:22px;">
                        <h3 style="font-size:14px; font-weight:600; color:#1A2B4A; margin-bottom:18px;">Penyelesaian per Modul</h3>
                        <div style="display:flex; flex-direction:column; gap:14px;">
                            <% const reports = [
                                { name:'Alat K3 Lapangan',         pct:91, users:198 },
                                { name:'Konstruksi Tiang Listrik',  pct:82, users:174 },
                                { name:'Gardu Distribusi',          pct:65, users:138 },
                                { name:'Material Jaringan',         pct:48, users:102 },
                                { name:'Tower SUTT 150kV',          pct:33, users: 70 },
                                { name:'Instalasi kWh Meter',       pct:27, users: 57 },
                            ]; %>
                            <% reports.forEach(r => { %>
                            <div style="display:grid; grid-template-columns:1fr 48px 100px 80px; align-items:center; gap:14px;">
                                <span style="font-size:13px; color:rgba(255,255,255,0.75);"><%= r.name %></span>
                                <span style="font-size:13px; font-weight:600; color:#0052A3; text-align:right;"><%= r.pct %>%</span>
                                <div class="progress-bar-bg"><div class="progress-bar-fill" style="width:<%= r.pct %>%;"></div></div>
                                <span style="font-size:11px; color:#8899B0; text-align:right;"><%= r.users %> peserta</span>
                            </div>
                            <% }); %>
                        </div>
                    </div>
                </div>
            </div>

            <!-- PAGE: SETTINGS -->
            <div id="page-settings" class="page-section">
                <div class="content-scroll" style="padding:28px;">
                    <div style="max-width:560px; display:flex; flex-direction:column; gap:16px;">

                        <div style="background:#fff; border:1px solid #E2E8F0; border-radius:16px; padding:22px;">
                            <h3 style="font-size:14px; font-weight:600; color:#1A2B4A; margin-bottom:18px;">Profil Administrator</h3>
                            <div style="display:flex; flex-direction:column; gap:14px;">
                                <div>
                                    <label style="font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:0.8px; color:#8899B0; display:block; margin-bottom:6px;">Nama Lengkap</label>
                                    <input type="text" value="Admin PLN" style="width:100%; padding:10px 14px; border-radius:10px; border:1px solid rgba(255,255,255,0.1); background:rgba(255,255,255,0.05); color:#1A2B4A; font-size:13px; font-family:inherit; outline:none;">
                                </div>
                                <div>
                                    <label style="font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:0.8px; color:#8899B0; display:block; margin-bottom:6px;">Email</label>
                                    <input type="email" value="admin@pln.co.id" style="width:100%; padding:10px 14px; border-radius:10px; border:1px solid rgba(255,255,255,0.1); background:rgba(255,255,255,0.05); color:#1A2B4A; font-size:13px; font-family:inherit; outline:none;">
                                </div>
                                <div>
                                    <label style="font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:0.8px; color:#8899B0; display:block; margin-bottom:6px;">Unit</label>
                                    <input type="text" value="PLN Pusdiklat Pusat" style="width:100%; padding:10px 14px; border-radius:10px; border:1px solid rgba(255,255,255,0.1); background:rgba(255,255,255,0.05); color:#1A2B4A; font-size:13px; font-family:inherit; outline:none;">
                                </div>
                                <button style="align-self:flex-start; padding:9px 22px; border-radius:10px; background:#00E5FF; color:#05101E; font-size:13px; font-weight:700; border:none; cursor:pointer; font-family:inherit;">Simpan Perubahan</button>
                            </div>
                        </div>

                        <div style="background:#fff; border:1px solid #E2E8F0; border-radius:16px; padding:22px;">
                            <h3 style="font-size:14px; font-weight:600; color:#1A2B4A; margin-bottom:18px;">Preferensi Sistem</h3>
                            <div style="display:flex; flex-direction:column; gap:16px;">
                                <div style="display:flex; align-items:center; justify-content:space-between;">
                                    <div>
                                        <div style="font-size:13px; color:rgba(255,255,255,0.8); font-weight:500;">Notifikasi Email</div>
                                        <div style="font-size:11px; color:#8899B0; margin-top:2px;">Terima notifikasi aktivitas via email</div>
                                    </div>
                                    <div id="toggle-notif" onclick="toggleSwitch(this)" style="width:42px; height:24px; border-radius:999px; background:#00E5FF; cursor:pointer; position:relative; transition:background 0.2s ease; flex-shrink:0;">
                                        <div style="position:absolute; top:3px; left:20px; width:18px; height:18px; border-radius:50%; background:#fff; transition:left 0.2s ease;"></div>
                                    </div>
                                </div>
                                <div style="display:flex; align-items:center; justify-content:space-between;">
                                    <div>
                                        <div style="font-size:13px; color:rgba(255,255,255,0.8); font-weight:500;">Log Aktivitas</div>
                                        <div style="font-size:11px; color:#8899B0; margin-top:2px;">Simpan riwayat aktivitas pengguna</div>
                                    </div>
                                    <div id="toggle-log" onclick="toggleSwitch(this)" style="width:42px; height:24px; border-radius:999px; background:#00E5FF; cursor:pointer; position:relative; transition:background 0.2s ease; flex-shrink:0;">
                                        <div style="position:absolute; top:3px; left:20px; width:18px; height:18px; border-radius:50%; background:#fff; transition:left 0.2s ease;"></div>
                                    </div>
                                </div>
                                <div style="display:flex; align-items:center; justify-content:space-between;">
                                    <div>
                                        <div style="font-size:13px; color:rgba(255,255,255,0.8); font-weight:500;">Mode Maintenance</div>
                                        <div style="font-size:11px; color:#8899B0; margin-top:2px;">Nonaktifkan akses pengguna sementara</div>
                                    </div>
                                    <div id="toggle-maint" onclick="toggleSwitch(this)" style="width:42px; height:24px; border-radius:999px; background:rgba(255,255,255,0.12); cursor:pointer; position:relative; transition:background 0.2s ease; flex-shrink:0;">
                                        <div style="position:absolute; top:3px; left:3px; width:18px; height:18px; border-radius:50%; background:#fff; transition:left 0.2s ease;"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <script src="/js/main.js"></script>
    <script src="/js/admin.js"></script>
</body>
</html>
