<!DOCTYPE html>
<html lang="id" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard Admin — PLN Pusdiklat</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@500;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/output.css">
    <link rel="stylesheet" href="/css/custom.css">
    <script>
        if (localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
        } else {
            document.documentElement.classList.remove('dark');
        }
    </script>
    <style>
        body { overflow: hidden; }

        .sidebar-link {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 14px;
            border-radius: 10px;
            font-size: 14px;
            font-weight: 500;
            color: #5A6F8F;
            cursor: pointer;
            transition: background 0.15s ease, color 0.15s ease;
            border: none;
            background: none;
            width: 100%;
            text-align: left;
            font-family: inherit;
        }
        .sidebar-link:hover {
            background: rgba(0,82,163,0.05);
            color: #1A2B4A;
        }
        .sidebar-link.active {
            background: rgba(0,82,163,0.08);
            color: #0052A3;
        }
        .sidebar-link.active .link-icon {
            color: #0052A3;
        }
        .link-icon {
            width: 18px;
            height: 18px;
            flex-shrink: 0;
            color: #8899B0;
        }

        .page-section { display: none; }
        .page-section.active { display: flex; flex-direction: column; flex: 1; overflow: hidden; }

        .stat-card {
            background: #fff;
            border: 1px solid #E2E8F0;
            border-radius: 16px;
            padding: 20px 22px;
            transition: border-color 0.2s ease, box-shadow 0.2s ease;
        }
        .stat-card:hover {
            border-color: rgba(0,82,163,0.25);
            box-shadow: 0 4px 16px rgba(0,82,163,0.06);
        }

        .table-row {
            display: grid;
            align-items: center;
            padding: 12px 16px;
            border-radius: 10px;
            transition: background 0.15s ease;
            font-size: 13px;
        }
        .table-row:hover { background: rgba(0,82,163,0.03); }

        .badge {
            display: inline-flex;
            align-items: center;
            padding: 3px 10px;
            border-radius: 999px;
            font-size: 11px;
            font-weight: 600;
        }
        .badge-green  { background: rgba(16,185,129,0.1); color: #059669; }
        .badge-yellow { background: rgba(245,158,11,0.1);  color: #D97706; }
        .badge-red    { background: rgba(239,68,68,0.1);  color: #DC2626; }
        .badge-blue   { background: rgba(0,82,163,0.08);  color: #0052A3; }

        .content-scroll { overflow-y: auto; flex: 1; }

        .progress-bar-bg {
            background: #E2E8F0;
            border-radius: 999px;
            height: 6px;
            overflow: hidden;
        }
        .progress-bar-fill {
            height: 100%;
            border-radius: 999px;
            background: linear-gradient(90deg, #0052A3, #00B4D8);
        }

        .activity-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            flex-shrink: 0;
            margin-top: 5px;
        }
    </style>
</head>
<body class="font-sans antialiased" style="display:flex; height:100vh; background:#F5F8FC; color:#1A2B4A;">

