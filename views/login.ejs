<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Space+Grotesk:wght@700;800&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --primary: #0052A3;
      --primary-light: #0070D4;
      --accent: #F5A623;
      --cyan: #00B4D8;
      --bg: #F5F8FC;
      --surface: #FFFFFF;
      --text: #1A2B4A;
      --text-secondary: #5A6F8F;
      --text-muted: #8899B0;
      --border: #E2E8F0;
      --error: #EF4444;
      --success: #10B981;
    }

    html, body {
      height: 100%;
      overflow: hidden;
      font-family: 'Inter', system-ui, sans-serif;
      background: var(--bg);
      color: var(--text);
    }

    .page { display: flex; width: 100vw; height: 100vh; }

    /* ── LEFT PANEL ── */
    .left {
      position: relative;
      flex: 1 1 55%;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 0 48px;
      overflow: hidden;
      background: linear-gradient(135deg, #00B4D8 0%, #0070D4 50%, #0052A3 100%);
    }

    .left::before {
      content: '';
      position: absolute;
      inset: 0;
      background-image: radial-gradient(rgba(255,255,255,0.06) 1px, transparent 1px);
      background-size: 44px 44px;
      pointer-events: none;
    }

    .left::after {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(circle at 20% 30%, rgba(0,180,216,0.15) 0%, transparent 40%),
        radial-gradient(circle at 80% 70%, rgba(245,166,35,0.12) 0%, transparent 45%);
      pointer-events: none;
    }

    .left-content {
      position: relative;
      z-index: 2;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 24px;
      text-align: center;
      animation: fadeInUp 0.8s ease;
      padding: 40px 48px 36px;
      border-radius: 24px;
      background: rgba(255,255,255,0.08);
      backdrop-filter: blur(16px) saturate(140%);
      -webkit-backdrop-filter: blur(16px) saturate(140%);
      border: 1px solid rgba(255,255,255,0.15);
      box-shadow: 0 8px 32px rgba(0,0,0,0.15);
    }

    .eyebrow {
      font-size: 12px;
      letter-spacing: 4px;
      text-transform: uppercase;
      color: var(--accent);
      font-weight: 700;
      margin-bottom: 12px;
    }

    h1.title {
      font-size: clamp(28px, 3.5vw, 44px);
      font-weight: 800;
      line-height: 1.15;
      color: #fff;
      font-family: 'Space Grotesk', sans-serif;
    }
    h1.title span { color: var(--accent); }

    .lead {
      font-size: 15px;
      color: rgba(255,255,255,0.65);
      line-height: 1.7;
      max-width: 360px;
    }

    .copyright {
      position: absolute;
      bottom: 20px;
      left: 0; right: 0;
      text-align: center;
      z-index: 2;
      font-size: 12px;
      color: rgba(255,255,255,0.3);
      letter-spacing: 2px;
    }

    /* Waves and power grid styling */
    .waves {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      z-index: 1;
    }
    .wave-svg {
      position: absolute;
      bottom: 0;
      width: 200%;
      height: 100%;
    }
    .wave-svg.w1 { animation: waveSlide1 18s linear infinite; opacity: 0.18; }
    .wave-svg.w2 { animation: waveSlide2 24s linear infinite; opacity: 0.10; }
    .wave-svg.w3 { animation: waveSlide1 30s linear infinite; opacity: 0.14; }

    /* power scene */
    .power-scene {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      z-index: 1;
    }
    .power-scene svg { width: 100%; height: 100%; display: block; }

    .cable { fill: none; stroke: rgba(255,255,255,0.55); stroke-width: 1.6; stroke-linecap: round; }
    .cable.thin { stroke: rgba(255,255,255,0.35); stroke-width: 1.2; }

    .spark-line {
      fill: none;
      stroke: var(--accent);
      stroke-width: 1.8;
      stroke-linecap: round;
      stroke-dasharray: 4 8;
      filter: drop-shadow(0 0 4px rgba(245,166,35,0.9));
      animation: spark 1.2s linear infinite;
      opacity: 0.85;
    }

    .insulator { animation: insulatorPulse 2.4s ease-in-out infinite; }
    .insulator.d1 { animation-delay: -0.4s; }
    .insulator.d2 { animation-delay: -0.8s; }
    .insulator.d3 { animation-delay: -1.2s; }
    .insulator.d4 { animation-delay: -1.6s; }

    .transformer-body { animation: transformerGlow 2.5s ease-in-out infinite; }

    .sun { animation: sunGlow 4s ease-in-out infinite; }

    .cloud { animation: floatCloud 12s ease-in-out infinite; }
    .cloud.c2 { animation: floatCloud 16s ease-in-out infinite; animation-delay: -2s; }

    .bird { animation: flyBird 6s ease-in-out infinite; }
    .bird.b2 { animation-delay: -1.5s; }
    .bird.b3 { animation-delay: -3s; }

    .blink-light.green {
      animation: blink 1.8s ease-in-out infinite;
      animation-delay: -0.5s;
      fill: #4cff8b;
      filter: drop-shadow(0 0 6px rgba(76,255,139,0.9));
    }

    /* ── RIGHT PANEL ── */
    .right {
      flex: 0 0 440px;
      background: var(--surface);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 40px 48px;
      position: relative;
      border-left: 1px solid var(--border);
      overflow: hidden;
    }

    .form-wrap {
      width: 100%;
      max-width: 340px;
      position: relative;
      z-index: 1;
      animation: fadeInUp 0.7s ease 0.2s backwards;
    }

    .badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: rgba(0,82,163,0.06);
      border: 1px solid rgba(0,82,163,0.12);
      border-radius: 24px;
      padding: 5px 14px;
      margin-bottom: 18px;
    }
    .dot {
      width: 7px; height: 7px;
      border-radius: 50%;
      background: var(--primary);
      animation: pulseDot 2s ease-in-out infinite;
    }
    .badge span {
      font-size: 11px;
      color: var(--primary);
      font-weight: 700;
      letter-spacing: 1.5px;
    }

    h2.heading {
      font-size: 28px;
      font-weight: 800;
      line-height: 1.2;
      margin-bottom: 8px;
      font-family: 'Space Grotesk', sans-serif;
      color: var(--text);
    }
    h2.heading span { color: var(--primary); }

    .subheading {
      font-size: 14px;
      color: var(--text-muted);
      font-weight: 400;
      margin-bottom: 28px;
    }

    /* error banner */
    .error-banner {
      display: none;
      background: rgba(239,68,68,0.08);
      border: 1px solid rgba(239,68,68,0.2);
      border-radius: 12px;
      padding: 10px 14px;
      font-size: 13px;
      color: var(--error);
      margin-bottom: 16px;
      animation: slideIn 0.2s ease;
    }
    .error-banner.show { display: block; }

    /* form */
    form { display: flex; flex-direction: column; gap: 16px; }

    .field { position: relative; }

    .field-box {
      position: relative;
      border-radius: 14px;
      border: 1.5px solid var(--border);
      background: var(--bg);
      transition: all 0.25s ease;
    }
    .field-box:focus-within {
      border-color: var(--primary);
      background: #fff;
      box-shadow: 0 0 0 3px rgba(0,82,163,0.08);
    }
    .field.error .field-box { border-color: var(--error); }

    .field-icon {
      position: absolute;
      left: 14px;
      top: 50%;
      transform: translateY(-50%);
      color: var(--text-muted);
      transition: color 0.2s;
      display: flex;
      pointer-events: none;
    }
    .field-box:focus-within .field-icon { color: var(--primary); }

    .field-label {
      position: absolute;
      left: 44px;
      top: 50%;
      transform: translateY(-50%);
      font-size: 14px;
      font-weight: 500;
      color: var(--text-muted);
      pointer-events: none;
      transition: all 0.2s ease;
    }
    .field-box.active .field-label,
    .field-box:focus-within .field-label {
      top: 8px;
      transform: none;
      font-size: 11px;
      color: var(--primary);
      font-weight: 600;
    }
    .field.error .field-label { color: var(--error); }

    .field-input {
      width: 100%;
      padding: 22px 16px 8px 44px;
      background: transparent;
      border: none;
      outline: none;
      color: var(--text);
      font-size: 15px;
      font-family: inherit;
      font-weight: 500;
    }
    .field-input.has-right { padding-right: 48px; }

    .toggle-pw {
      position: absolute;
      right: 14px;
      top: 50%;
      transform: translateY(-50%);
      background: none;
      border: none;
      cursor: pointer;
      color: var(--text-muted);
      padding: 4px;
      display: flex;
      transition: color 0.2s;
    }
    .toggle-pw.active { color: var(--primary); }

    .err-msg {
      font-size: 12px;
      color: var(--error);
      margin-top: 5px;
      margin-left: 16px;
      animation: slideIn 0.2s ease;
    }

    .row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-top: -4px;
    }

    .checkbox {
      display: flex;
      align-items: center;
      gap: 9px;
      cursor: pointer;
      user-select: none;
      font-size: 13px;
      color: var(--text-secondary);
      font-weight: 500;
    }
    .check-box {
      width: 18px; height: 18px;
      border-radius: 5px;
      border: 2px solid var(--border);
      background: transparent;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.2s ease;
      flex-shrink: 0;
    }
    .checkbox input { display: none; }
    .checkbox input:checked + .check-box {
      border-color: var(--primary);
      background: var(--primary);
    }
    .check-box svg { opacity: 0; transition: opacity 0.15s; }
    .checkbox input:checked + .check-box svg { opacity: 1; }

    .forgot {
      background: none;
      border: none;
      cursor: pointer;
      font-size: 13px;
      color: var(--primary);
      font-weight: 600;
      font-family: inherit;
      opacity: 0.85;
      transition: opacity 0.2s;
    }
    .forgot:hover { opacity: 1; }

    /* submit */
    .submit-btn {
      margin-top: 8px;
      padding: 15px 24px;
      border-radius: 14px;
      border: none;
      cursor: pointer;
      background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
      color: #fff;
      font-size: 15px;
      font-weight: 800;
      font-family: inherit;
      letter-spacing: 0.3px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      transition: transform 0.25s ease, box-shadow 0.25s ease;
      box-shadow: 0 4px 24px rgba(0,82,163,0.3);
    }
    .submit-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 32px rgba(0,82,163,0.4);
    }
    .submit-btn:disabled {
      cursor: not-allowed;
      opacity: 0.6;
      box-shadow: none;
      transform: none;
    }

    .spinner {
      width: 18px; height: 18px;
      border-radius: 50%;
      border: 2.5px solid rgba(255,255,255,0.3);
      border-top-color: #fff;
      animation: spinRing 0.7s linear infinite;
    }

    /* divider */
    .divider {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-top: 24px;
    }
    .divider .line { flex: 1; height: 1px; background: var(--border); }
    .divider .label {
      font-size: 12px;
      color: var(--text-muted);
      white-space: nowrap;
      letter-spacing: 1px;
    }

    /* keyframes */
    @keyframes fadeInUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes spinSlow { to { transform: rotate(360deg); } }
    @keyframes pulseDot {
      0%, 100% { box-shadow: 0 0 6px rgba(0,82,163,0.4); opacity: 1; }
      50% { box-shadow: 0 0 12px rgba(0,82,163,0.7); opacity: 0.7; }
    }
    @keyframes spinRing { to { transform: rotate(360deg); } }
    @keyframes slideIn {
      from { opacity: 0; transform: translateX(-4px); }
      to { opacity: 1; transform: translateX(0); }
    }
    @keyframes shake {
      0%, 100% { transform: translateX(0); }
      25% { transform: translateX(-6px); }
      75% { transform: translateX(6px); }
    }
    form.shake { animation: shake 0.4s ease; }

    /* wave animations */
    @keyframes waveSlide1 {
      from { transform: translateX(0); }
      to   { transform: translateX(-50%); }
    }
    @keyframes waveSlide2 {
      from { transform: translateX(-50%); }
      to   { transform: translateX(0); }
    }

    @keyframes spark {
      0%   { stroke-dashoffset: 0; }
      100% { stroke-dashoffset: -60; }
    }

    @keyframes insulatorPulse {
      0%, 100% { fill: rgba(245,166,35,0.7); filter: drop-shadow(0 0 3px rgba(245,166,35,0.7)); }
      50%       { fill: var(--accent); filter: drop-shadow(0 0 8px rgba(245,166,35,1)); }
    }

    @keyframes transformerGlow {
      0%, 100% { filter: drop-shadow(0 0 4px rgba(245,166,35,0.4)); }
      50%       { filter: drop-shadow(0 0 12px rgba(245,166,35,0.85)); }
    }

    @keyframes sunGlow {
      0%, 100% { filter: drop-shadow(0 0 12px rgba(255, 229, 156, 0.4)); }
      50%       { filter: drop-shadow(0 0 24px rgba(255, 229, 156, 0.85)); }
    }

    @keyframes floatCloud {
      0%, 100% { transform: translateX(0); }
      50%       { transform: translateX(15px); }
    }

    @keyframes flyBird {
      0% { transform: translate(0, 0); }
      50% { transform: translate(10px, -5px); }
      100% { transform: translate(0, 0); }
    }

    @keyframes blink {
      0%, 100% { opacity: 1; }
      50%       { opacity: 0.3; }
    }

    @media (max-width: 768px) {
      .left { display: none; }
      .right { flex: 1; border-left: none; }
    }
  </style>
</head>
<body>
  <div class="page">

    <!-- LEFT PANEL -->
    <div class="left">
      <div class="waves">
        <svg class="wave-svg w3" viewBox="0 0 2400 800" preserveAspectRatio="none">
          <path d="M0,560 C200,500 400,620 600,560 C800,500 1000,620 1200,560 C1400,500 1600,620 1800,560 C2000,500 2200,620 2400,560 L2400,800 L0,800 Z" fill="#3B82F6"/>
        </svg>
        <svg class="wave-svg w1" viewBox="0 0 2400 800" preserveAspectRatio="none">
          <path d="M0,620 C200,580 400,680 600,620 C800,560 1000,680 1200,620 C1400,560 1600,680 1800,620 C2000,560 2200,680 2400,620 L2400,800 L0,800 Z" fill="#60A5FA"/>
        </svg>
        <svg class="wave-svg w2" viewBox="0 0 2400 800" preserveAspectRatio="none">
          <path d="M0,680 C300,640 600,720 900,680 C1200,640 1500,720 1800,680 C2100,640 2400,720 2400,680 L2400,800 L0,800 Z" fill="#ffffff"/>
        </svg>
      </div>

      <div class="power-scene">
        <svg viewBox="0 0 1400 700" preserveAspectRatio="xMidYMid slice">
          <defs>
            <linearGradient id="sky-grad" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%"   stop-color="#0070D4"/>
              <stop offset="55%"  stop-color="#3AA6F2"/>
              <stop offset="80%"  stop-color="#80C8FE"/>
              <stop offset="100%" stop-color="#D4EFFF"/>
            </linearGradient>
          </defs>
          <!-- opaque sky background so waves don't bleed through -->
          <rect x="0" y="0" width="1400" height="700" fill="url(#sky-grad)"/>
          
          <!-- daytime clouds -->
          <path class="cloud" d="M 120,130 C 130,115 155,115 165,130 C 175,120 195,120 200,130 C 210,135 210,145 200,150 L 120,150 Z" fill="rgba(255,255,255,0.6)" filter="blur(2px)"/>
          <path class="cloud c2" d="M 850,90 C 865,70 900,70 915,90 C 930,78 955,78 962,90 C 975,98 975,110 962,118 L 850,118 Z" fill="rgba(255,255,255,0.5)" filter="blur(3px)"/>
          <path class="cloud" d="M 500,150 C 510,138 530,138 540,150 C 550,142 565,142 570,150 C 580,154 580,162 570,166 L 500,166 Z" fill="rgba(255,255,255,0.4)" filter="blur(2px)" style="animation-delay:-4s"/>

          <!-- daytime birds -->
          <path class="bird b1" d="M 280,90 Q 284,83 288,90 Q 292,83 296,90" fill="none" stroke="rgba(255,255,255,0.4)" stroke-width="1.5" stroke-linecap="round"/>
          <path class="bird b2" d="M 310,105 Q 313,99 316,105 Q 319,99 322,105" fill="none" stroke="rgba(255,255,255,0.4)" stroke-width="1.2" stroke-linecap="round"/>
          <path class="bird b3" d="M 260,115 Q 262,110 264,115 Q 266,110 268,115" fill="none" stroke="rgba(255,255,255,0.4)" stroke-width="1.0" stroke-linecap="round"/>

          <!-- glowing daytime sun -->
          <g class="sun">
            <circle cx="1199" cy="130" r="32" fill="#ffffff" filter="drop-shadow(0 0 16px #FFD700)"/>
            <circle cx="1199" cy="130" r="32" fill="#FFF200" opacity="0.6"/>
          </g>

          <!-- mountain silhouette (daytime blue hues) -->
          <path d="M0,500 L120,420 L240,460 L380,380 L520,440 L660,400 L820,470 L960,420 L1100,460 L1260,400 L1400,440 L1400,700 L0,700 Z" fill="#1C5E9E"/>
          <rect x="0" y="500" width="1400" height="200" fill="#14467A"/>
          <line x1="0" y1="500" x2="1400" y2="500" stroke="rgba(255,255,255,0.22)" stroke-width="0.8"/>

          <!-- POLE 1 (left) -->
          <g>
            <rect x="196" y="180" width="6" height="320" fill="#10356c"/>
            <rect x="197" y="180" width="2" height="320" fill="rgba(255,255,255,0.15)"/>
            <rect x="150" y="210" width="100" height="4" fill="#10356c"/>
            <rect x="160" y="245" width="80" height="4" fill="#10356c"/>
            <rect x="170" y="275" width="60" height="4" fill="#10356c"/>
            <line x1="170" y1="214" x2="199" y2="230" stroke="#10356c" stroke-width="2"/>
            <line x1="230" y1="214" x2="199" y2="230" stroke="#10356c" stroke-width="2"/>
            <circle class="insulator" cx="160" cy="210" r="4"/>
            <circle class="insulator d1" cx="199" cy="210" r="4"/>
            <circle class="insulator d2" cx="240" cy="210" r="4"/>
            <circle class="insulator d3" cx="170" cy="245" r="3.5"/>
            <circle class="insulator d4" cx="230" cy="245" r="3.5"/>
            <rect x="206" y="300" width="22" height="36" rx="3" fill="#0c2d59" stroke="#F5A623" stroke-width="0.8" opacity="0.95"/>
            <line x1="209" y1="308" x2="225" y2="308" stroke="rgba(245,166,35,0.6)" stroke-width="0.6"/>
            <line x1="209" y1="316" x2="225" y2="316" stroke="rgba(245,166,35,0.6)" stroke-width="0.6"/>
            <line x1="209" y1="324" x2="225" y2="324" stroke="rgba(245,166,35,0.6)" stroke-width="0.6"/>
          </g>

          <!-- POLE 2 (middle) -->
          <g>
            <rect x="696" y="180" width="6" height="320" fill="#10356c"/>
            <rect x="697" y="180" width="2" height="320" fill="rgba(255,255,255,0.15)"/>
            <rect x="650" y="210" width="100" height="4" fill="#10356c"/>
            <rect x="660" y="245" width="80" height="4" fill="#10356c"/>
            <rect x="670" y="275" width="60" height="4" fill="#10356c"/>
            <line x1="670" y1="214" x2="699" y2="230" stroke="#10356c" stroke-width="2"/>
            <line x1="730" y1="214" x2="699" y2="230" stroke="#10356c" stroke-width="2"/>
            <circle class="insulator d1" cx="660" cy="210" r="4"/>
            <circle class="insulator d2" cx="699" cy="210" r="4"/>
            <circle class="insulator d3" cx="740" cy="210" r="4"/>
            <circle class="insulator" cx="670" cy="245" r="3.5"/>
            <circle class="insulator d4" cx="730" cy="245" r="3.5"/>
          </g>

          <!-- POLE 3 (right) — shaft cut before substation -->
          <g>
            <rect x="1196" y="180" width="6" height="220" fill="#10356c"/>
            <rect x="1197" y="180" width="2" height="220" fill="rgba(255,255,255,0.15)"/>
            <rect x="1150" y="210" width="100" height="4" fill="#10356c"/>
            <rect x="1160" y="245" width="80" height="4" fill="#10356c"/>
            <rect x="1170" y="275" width="60" height="4" fill="#10356c"/>
            <line x1="1170" y1="214" x2="1199" y2="230" stroke="#10356c" stroke-width="2"/>
            <line x1="1230" y1="214" x2="1199" y2="230" stroke="#10356c" stroke-width="2"/>
            <circle class="insulator" cx="1160" cy="210" r="4"/>
            <circle class="insulator d1" cx="1199" cy="210" r="4"/>
            <circle class="insulator d2" cx="1240" cy="210" r="4"/>
            <circle class="insulator d3" cx="1170" cy="245" r="3.5"/>
            <circle class="insulator d4" cx="1230" cy="245" r="3.5"/>
            <circle class="insulator d2" cx="1199" cy="275" r="3"/>
          </g>

          <!-- CABLES -->
          <path class="cable" d="M 200 210 Q 100 235 0 215"/>
          <path class="cable" d="M 200 245 Q 100 268 0 250"/>
          <path class="cable thin" d="M 200 275 Q 100 298 0 282"/>
          <path class="cable" d="M 200 210 Q 450 245 700 210"/>
          <path class="cable" d="M 200 245 Q 450 280 700 245"/>
          <path class="cable thin" d="M 200 275 Q 450 305 700 275"/>
          <path class="cable" d="M 700 210 Q 950 240 1200 210"/>
          <path class="cable" d="M 700 245 Q 950 275 1200 245"/>
