      <div class="left-content">
        <div>
          <p class="eyebrow">PT PLN (Persero)</p>
          <h1 class="title">Pembelajaran 3D<br/><span>Web PLN</span></h1>
        </div>
        <p class="lead">Platform pembelajaran konstruksi jaringan tenaga listrik berbasis teknologi 3D interaktif.</p>
      </div>

      <p class="copyright">© 2026 PT PLN (Persero) · All Rights Reserved</p>
    </div>

    <!-- RIGHT PANEL -->
    <div class="right">
      <div class="form-wrap">

        <div class="badge">
          <span class="dot"></span>
          <span>PORTAL ADMIN</span>
        </div>

        <h2 class="heading">Selamat datang<br/><span>admin!</span></h2>
        <p class="subheading">Masuk untuk melanjutkan ke dashboard</p>

        <div id="error-banner" class="error-banner"></div>

        <form id="loginForm" novalidate>
          <!-- email -->
          <div class="field" id="emailField">
            <div class="field-box">
              <span class="field-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="2" y="4" width="20" height="16" rx="3"/><path d="m2 7 10 7 10-7"/>
                </svg>
              </span>
              <label class="field-label" for="email">Alamat Email</label>
              <input class="field-input" type="email" id="email" autocomplete="email" />
            </div>
            <p class="err-msg" id="emailErr" style="display:none"></p>
          </div>

          <!-- password -->
          <div class="field" id="passwordField">
            <div class="field-box">
              <span class="field-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                </svg>
              </span>
              <label class="field-label" for="password">Password</label>
              <input class="field-input has-right" type="password" id="password" autocomplete="current-password" />
              <button type="button" class="toggle-pw" id="togglePw" tabindex="-1">
                <svg id="eyeOff" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/>
                  <line x1="1" y1="1" x2="23" y2="23"/>
                </svg>
                <svg id="eyeOn" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none">
                  <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
                </svg>
              </button>
            </div>
            <p class="err-msg" id="passwordErr" style="display:none"></p>
          </div>

          <!-- remember + forgot -->
          <div class="row">
            <label class="checkbox">
              <input type="checkbox" id="remember" />
              <span class="check-box">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
              Ingat saya
            </label>
            <button type="button" class="forgot" tabindex="-1">Lupa sandi?</button>
          </div>

          <button type="submit" class="submit-btn" id="submitBtn">
            <span id="btnLabel">Masuk ke Dashboard</span>
            <div class="spinner" id="btnSpinner" style="display:none"></div>
          </button>
        </form>

        <div class="divider">
          <div class="line"></div>
          <span class="label">SISTEM INTERNAL</span>
          <div class="line"></div>
        </div>
      </div>
    </div>
  </div>

  <script>
    // ── Float Label Logic ──
    document.querySelectorAll('.field-input').forEach(function(inp) {
      function check() { inp.closest('.field-box').classList.toggle('active', inp.value.length > 0); }
      inp.addEventListener('input', check);
      inp.addEventListener('focus', check);
      inp.addEventListener('blur', check);
      check();
    });

    // ── Toggle Password ──
    (function() {
      var toggle = document.getElementById('togglePw');
      var pw = document.getElementById('password');
      var off = document.getElementById('eyeOff');
      var on = document.getElementById('eyeOn');
      toggle.addEventListener('click', function() {
        var show = pw.type === 'password';
        pw.type = show ? 'text' : 'password';
        off.style.display = show ? 'none' : '';
        on.style.display = show ? '' : 'none';
        toggle.classList.toggle('active', show);
      });
    })();

    // ── Form Submit ──
    (function() {
      var form = document.getElementById('loginForm');
      var emailInput = document.getElementById('email');
      var pwInput = document.getElementById('password');
      var banner = document.getElementById('error-banner');
      var submitBtn = document.getElementById('submitBtn');
      var btnLabel = document.getElementById('btnLabel');
      var btnSpinner = document.getElementById('btnSpinner');

      function showFieldErr(fieldId, errId, msg) {
        document.getElementById(fieldId).classList.add('error');
        var el = document.getElementById(errId);
        el.textContent = msg;
        el.style.display = 'block';
      }
      function clearErrs() {
        banner.className = 'error-banner';
        banner.textContent = '';
        ['emailField','passwordField'].forEach(function(id) { document.getElementById(id).classList.remove('error'); });
        ['emailErr','passwordErr'].forEach(function(id) { document.getElementById(id).style.display = 'none'; });
      }

      form.addEventListener('submit', function(e) {
        e.preventDefault();
        clearErrs();
        var email = emailInput.value.trim();
        var pw = pwInput.value;
        var hasErr = false;
        if (!email) { showFieldErr('emailField','emailErr','Email wajib diisi'); hasErr = true; }
        else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { showFieldErr('emailField','emailErr','Format email tidak valid'); hasErr = true; }
        if (!pw) { showFieldErr('passwordField','passwordErr','Password wajib diisi'); hasErr = true; }
        if (hasErr) { form.classList.add('shake'); setTimeout(function() { form.classList.remove('shake'); }, 450); return; }

        submitBtn.disabled = true;
        btnLabel.textContent = 'Memproses...';
        btnSpinner.style.display = '';

        fetch('/api/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: email, password: pw })
        })
        .then(function(res) { return res.json().then(function(data) { return { ok: res.ok, data: data }; }); })
        .then(function(result) {
          if (result.ok && result.data.token) {
            localStorage.setItem('token', result.data.token);
            return fetch('/set-session', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ token: result.data.token })
            });
          } else {
            throw new Error(result.data.message || result.data.error || 'Login gagal');
          }
        })
        .then(function(sessionRes) {
          if (sessionRes && sessionRes.ok) {
            window.location.href = '/admin';
          } else if (sessionRes) {
            throw new Error('Gagal mengatur sesi');
          }
        })
        .catch(function(err) {
          banner.textContent = err.message || 'Koneksi ke server gagal';
          banner.className = 'error-banner show';
          form.classList.add('shake');
          setTimeout(function() { form.classList.remove('shake'); }, 450);
        })
        .finally(function() {
          submitBtn.disabled = false;
          btnLabel.textContent = 'Masuk ke Dashboard';
          btnSpinner.style.display = 'none';
        });
      });
    })();
  </script>
</body>
</html>
