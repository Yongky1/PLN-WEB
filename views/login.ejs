<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Space+Grotesk:wght@700;800&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --primary: #0052A3;
      --primary-light: #0070D4;
      --accent: #F5A623;
      --cyan: #00B4D8;
      --bg: #F5F8FC;
      --surface: #FFFFFF;
      --text: #1A2B4A;
      --text-secondary: #5A6F8F;
      --text-muted: #8899B0;
      --border: #E2E8F0;
      --error: #EF4444;
      --success: #10B981;
    }

    html, body {
      height: 100%;
      overflow: hidden;
      font-family: 'Inter', system-ui, sans-serif;
      background: var(--bg);
      color: var(--text);
    }

    .page { display: flex; width: 100vw; height: 100vh; }

    /* ── LEFT PANEL ── */
    .left {
      position: relative;
      flex: 1 1 55%;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 0 48px;
      overflow: hidden;
      background: linear-gradient(135deg, #0052A3 0%, #003D7A 50%, #0A2A5C 100%);
    }

    .left::before {
      content: '';
      position: absolute;
      inset: 0;
      background-image: radial-gradient(rgba(255,255,255,0.06) 1px, transparent 1px);
      background-size: 44px 44px;
      pointer-events: none;
    }

    .left::after {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(circle at 20% 30%, rgba(0,180,216,0.15) 0%, transparent 40%),
        radial-gradient(circle at 80% 70%, rgba(245,166,35,0.12) 0%, transparent 45%);
      pointer-events: none;
    }

    .left-content {
      position: relative;
      z-index: 2;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 24px;
      text-align: center;
      animation: fadeInUp 0.8s ease;
      padding: 40px 48px 36px;
      border-radius: 24px;
      background: rgba(255,255,255,0.08);
      backdrop-filter: blur(16px) saturate(140%);
      -webkit-backdrop-filter: blur(16px) saturate(140%);
      border: 1px solid rgba(255,255,255,0.15);
      box-shadow: 0 8px 32px rgba(0,0,0,0.15);
    }

    .eyebrow {
      font-size: 12px;
      letter-spacing: 4px;
      text-transform: uppercase;
      color: var(--accent);
      font-weight: 700;
      margin-bottom: 12px;
    }

    h1.title {
      font-size: clamp(28px, 3.5vw, 44px);
      font-weight: 800;
      line-height: 1.15;
      color: #fff;
      font-family: 'Space Grotesk', sans-serif;
    }
    h1.title span { color: var(--accent); }

    .lead {
      font-size: 15px;
      color: rgba(255,255,255,0.65);
      line-height: 1.7;
      max-width: 360px;
    }

    .copyright {
      position: absolute;
      bottom: 20px;
      left: 0; right: 0;
      text-align: center;
      z-index: 2;
      font-size: 12px;
      color: rgba(255,255,255,0.3);
      letter-spacing: 2px;
    }

    /* Decorative floating shapes on left */
    .deco-shape {
      position: absolute;
      pointer-events: none;
      z-index: 1;
    }
    .deco-ring1 {
      top: 10%;
      right: 8%;
      width: 200px;
      height: 200px;
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 50%;
      animation: spinSlow 25s linear infinite;
    }
    .deco-ring2 {
      bottom: 15%;
      left: 5%;
      width: 160px;
      height: 160px;
      border: 1px solid rgba(0,180,216,0.12);
      border-radius: 50%;
      animation: spinSlow 20s linear infinite reverse;
    }

    /* ── RIGHT PANEL ── */
    .right {
      flex: 0 0 440px;
      background: var(--surface);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 40px 48px;
      position: relative;
      border-left: 1px solid var(--border);
      overflow: hidden;
    }

    .form-wrap {
      width: 100%;
      max-width: 340px;
      position: relative;
      z-index: 1;
      animation: fadeInUp 0.7s ease 0.2s backwards;
    }

    .badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: rgba(0,82,163,0.06);
      border: 1px solid rgba(0,82,163,0.12);
      border-radius: 24px;
      padding: 5px 14px;
      margin-bottom: 18px;
    }
    .dot {
      width: 7px; height: 7px;
      border-radius: 50%;
      background: var(--primary);
      animation: pulseDot 2s ease-in-out infinite;
    }
    .badge span {
      font-size: 11px;
      color: var(--primary);
      font-weight: 700;
      letter-spacing: 1.5px;
    }

    h2.heading {
      font-size: 28px;
      font-weight: 800;
      line-height: 1.2;
      margin-bottom: 8px;
      font-family: 'Space Grotesk', sans-serif;
      color: var(--text);
    }
    h2.heading span { color: var(--primary); }

    .subheading {
      font-size: 14px;
      color: var(--text-muted);
      font-weight: 400;
      margin-bottom: 28px;
    }

    /* error banner */
    .error-banner {
      display: none;
      background: rgba(239,68,68,0.08);
      border: 1px solid rgba(239,68,68,0.2);
      border-radius: 12px;
      padding: 10px 14px;
      font-size: 13px;
      color: var(--error);
      margin-bottom: 16px;
      animation: slideIn 0.2s ease;
    }
    .error-banner.show { display: block; }

    /* form */
    form { display: flex; flex-direction: column; gap: 16px; }

    .field { position: relative; }

    .field-box {
      position: relative;
      border-radius: 14px;
      border: 1.5px solid var(--border);
      background: var(--bg);
      transition: all 0.25s ease;
    }
    .field-box:focus-within {
      border-color: var(--primary);
      background: #fff;
      box-shadow: 0 0 0 3px rgba(0,82,163,0.08);
    }
    .field.error .field-box { border-color: var(--error); }

    .field-icon {
      position: absolute;
      left: 14px;
      top: 50%;
      transform: translateY(-50%);
      color: var(--text-muted);
      transition: color 0.2s;
      display: flex;
      pointer-events: none;
    }
    .field-box:focus-within .field-icon { color: var(--primary); }

    .field-label {
      position: absolute;
      left: 44px;
      top: 50%;
      transform: translateY(-50%);
      font-size: 14px;
      font-weight: 500;
      color: var(--text-muted);
      pointer-events: none;
      transition: all 0.2s ease;
    }
    .field-box.active .field-label,
    .field-box:focus-within .field-label {
      top: 8px;
      transform: none;
      font-size: 11px;
      color: var(--primary);
      font-weight: 600;
    }
    .field.error .field-label { color: var(--error); }

    .field-input {
      width: 100%;
      padding: 22px 16px 8px 44px;
      background: transparent;
      border: none;
      outline: none;
      color: var(--text);
      font-size: 15px;
      font-family: inherit;
      font-weight: 500;
    }
    .field-input.has-right { padding-right: 48px; }

    .toggle-pw {
      position: absolute;
      right: 14px;
      top: 50%;
      transform: translateY(-50%);
      background: none;
      border: none;
      cursor: pointer;
      color: var(--text-muted);
      padding: 4px;
      display: flex;
      transition: color 0.2s;
    }
    .toggle-pw.active { color: var(--primary); }

    .err-msg {
      font-size: 12px;
      color: var(--error);
      margin-top: 5px;
      margin-left: 16px;
      animation: slideIn 0.2s ease;
    }

    .row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-top: -4px;
    }

    .checkbox {
      display: flex;
      align-items: center;
      gap: 9px;
      cursor: pointer;
      user-select: none;
      font-size: 13px;
      color: var(--text-secondary);
      font-weight: 500;
    }
    .check-box {
      width: 18px; height: 18px;
      border-radius: 5px;
      border: 2px solid var(--border);
      background: transparent;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.2s ease;
      flex-shrink: 0;
    }
    .checkbox input { display: none; }
    .checkbox input:checked + .check-box {
      border-color: var(--primary);
      background: var(--primary);
    }
    .check-box svg { opacity: 0; transition: opacity 0.15s; }
    .checkbox input:checked + .check-box svg { opacity: 1; }

    .forgot {
      background: none;
      border: none;
      cursor: pointer;
      font-size: 13px;
      color: var(--primary);
      font-weight: 600;
      font-family: inherit;
      opacity: 0.85;
      transition: opacity 0.2s;
    }
    .forgot:hover { opacity: 1; }

    /* submit */
    .submit-btn {
      margin-top: 8px;
      padding: 15px 24px;
      border-radius: 14px;
      border: none;
      cursor: pointer;
      background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
      color: #fff;
      font-size: 15px;
      font-weight: 800;
      font-family: inherit;
      letter-spacing: 0.3px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      transition: transform 0.25s ease, box-shadow 0.25s ease;
      box-shadow: 0 4px 24px rgba(0,82,163,0.3);
    }
    .submit-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 32px rgba(0,82,163,0.4);
    }
    .submit-btn:disabled {
      cursor: not-allowed;
      opacity: 0.6;
      box-shadow: none;
      transform: none;
    }

    .spinner {
      width: 18px; height: 18px;
      border-radius: 50%;
      border: 2.5px solid rgba(255,255,255,0.3);
      border-top-color: #fff;
      animation: spinRing 0.7s linear infinite;
    }

    /* divider */
    .divider {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-top: 24px;
    }
    .divider .line { flex: 1; height: 1px; background: var(--border); }
    .divider .label {
      font-size: 12px;
      color: var(--text-muted);
      white-space: nowrap;
      letter-spacing: 1px;
    }

    /* keyframes */
    @keyframes fadeInUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes spinSlow { to { transform: rotate(360deg); } }
    @keyframes pulseDot {
      0%, 100% { box-shadow: 0 0 6px rgba(0,82,163,0.4); opacity: 1; }
      50% { box-shadow: 0 0 12px rgba(0,82,163,0.7); opacity: 0.7; }
    }
    @keyframes spinRing { to { transform: rotate(360deg); } }
    @keyframes slideIn {
      from { opacity: 0; transform: translateX(-4px); }
      to { opacity: 1; transform: translateX(0); }
    }
    @keyframes shake {
      0%, 100% { transform: translateX(0); }
      25% { transform: translateX(-6px); }
      75% { transform: translateX(6px); }
    }
    form.shake { animation: shake 0.4s ease; }

    @media (max-width: 768px) {
      .left { display: none; }
      .right { flex: 1; border-left: none; }
    }
  </style>
</head>
<body>
  <div class="page">

    <!-- LEFT PANEL -->
    <div class="left">
      <div class="deco-shape deco-ring1"></div>
      <div class="deco-shape deco-ring2"></div>

      <div class="left-content">
        <div>
          <p class="eyebrow">PT PLN (Persero)</p>
          <h1 class="title">Pembelajaran 3D<br/><span>Web PLN</span></h1>
        </div>
        <p class="lead">Platform pembelajaran konstruksi jaringan tenaga listrik berbasis teknologi 3D interaktif.</p>
      </div>

      <p class="copyright">© 2026 PT PLN (Persero) · All Rights Reserved</p>
    </div>

    <!-- RIGHT PANEL -->
    <div class="right">
      <div class="form-wrap">

        <div class="badge">
          <span class="dot"></span>
          <span>PORTAL ADMIN</span>
        </div>

        <h2 class="heading">Selamat datang<br/><span>admin!</span></h2>
        <p class="subheading">Masuk untuk melanjutkan ke dashboard</p>

        <div id="error-banner" class="error-banner"></div>

        <form id="loginForm" novalidate>
          <!-- email -->
          <div class="field" id="emailField">
            <div class="field-box">
              <span class="field-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="2" y="4" width="20" height="16" rx="3"/><path d="m2 7 10 7 10-7"/>
                </svg>
              </span>
              <label class="field-label" for="email">Alamat Email</label>
              <input class="field-input" type="email" id="email" autocomplete="email" />
            </div>
            <p class="err-msg" id="emailErr" style="display:none"></p>
          </div>

          <!-- password -->
          <div class="field" id="passwordField">
            <div class="field-box">
              <span class="field-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                </svg>
              </span>
              <label class="field-label" for="password">Password</label>
              <input class="field-input has-right" type="password" id="password" autocomplete="current-password" />
              <button type="button" class="toggle-pw" id="togglePw" tabindex="-1">
                <svg id="eyeOff" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/>
                  <line x1="1" y1="1" x2="23" y2="23"/>
                </svg>
                <svg id="eyeOn" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none">
                  <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
                </svg>
              </button>
            </div>
            <p class="err-msg" id="passwordErr" style="display:none"></p>
          </div>

          <!-- remember + forgot -->
          <div class="row">
            <label class="checkbox">
              <input type="checkbox" id="remember" />
              <span class="check-box">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
              Ingat saya
            </label>
            <button type="button" class="forgot" tabindex="-1">Lupa sandi?</button>
          </div>

          <button type="submit" class="submit-btn" id="submitBtn">
            <span id="btnLabel">Masuk ke Dashboard</span>
            <div class="spinner" id="btnSpinner" style="display:none"></div>
          </button>
        </form>

        <div class="divider">
          <div class="line"></div>
          <span class="label">SISTEM INTERNAL</span>
          <div class="line"></div>
        </div>
      </div>
    </div>
  </div>

  <script>
    // ── Float Label Logic ──
    document.querySelectorAll('.field-input').forEach(function(inp) {
      function check() { inp.closest('.field-box').classList.toggle('active', inp.value.length > 0); }
      inp.addEventListener('input', check);
      inp.addEventListener('focus', check);
      inp.addEventListener('blur', check);
      check();
    });

    // ── Toggle Password ──
    (function() {
      var toggle = document.getElementById('togglePw');
      var pw = document.getElementById('password');
      var off = document.getElementById('eyeOff');
      var on = document.getElementById('eyeOn');
      toggle.addEventListener('click', function() {
        var show = pw.type === 'password';
        pw.type = show ? 'text' : 'password';
        off.style.display = show ? 'none' : '';
        on.style.display = show ? '' : 'none';
        toggle.classList.toggle('active', show);
      });
    })();

    // ── Form Submit ──
    (function() {
      var form = document.getElementById('loginForm');
      var emailInput = document.getElementById('email');
      var pwInput = document.getElementById('password');
      var banner = document.getElementById('error-banner');
      var submitBtn = document.getElementById('submitBtn');
      var btnLabel = document.getElementById('btnLabel');
      var btnSpinner = document.getElementById('btnSpinner');

      function showFieldErr(fieldId, errId, msg) {
        document.getElementById(fieldId).classList.add('error');
        var el = document.getElementById(errId);
        el.textContent = msg;
        el.style.display = 'block';
      }
      function clearErrs() {
        banner.className = 'error-banner';
        banner.textContent = '';
        ['emailField','passwordField'].forEach(function(id) { document.getElementById(id).classList.remove('error'); });
        ['emailErr','passwordErr'].forEach(function(id) { document.getElementById(id).style.display = 'none'; });
      }

      form.addEventListener('submit', function(e) {
        e.preventDefault();
        clearErrs();
        var email = emailInput.value.trim();
        var pw = pwInput.value;
        var hasErr = false;
        if (!email) { showFieldErr('emailField','emailErr','Email wajib diisi'); hasErr = true; }
        else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { showFieldErr('emailField','emailErr','Format email tidak valid'); hasErr = true; }
        if (!pw) { showFieldErr('passwordField','passwordErr','Password wajib diisi'); hasErr = true; }
        if (hasErr) { form.classList.add('shake'); setTimeout(function() { form.classList.remove('shake'); }, 450); return; }

        submitBtn.disabled = true;
        btnLabel.textContent = 'Memproses...';
        btnSpinner.style.display = '';

        fetch('/api/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: email, password: pw })
        })
        .then(function(res) { return res.json().then(function(data) { return { ok: res.ok, data: data }; }); })
        .then(function(result) {
          if (result.ok && result.data.token) {
            localStorage.setItem('token', result.data.token);
            return fetch('/set-session', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ token: result.data.token })
            });
          } else {
            throw new Error(result.data.message || result.data.error || 'Login gagal');
          }
        })
        .then(function(sessionRes) {
          if (sessionRes && sessionRes.ok) {
            window.location.href = '/admin';
          } else if (sessionRes) {
            throw new Error('Gagal mengatur sesi');
          }
        })
        .catch(function(err) {
          banner.textContent = err.message || 'Koneksi ke server gagal';
          banner.className = 'error-banner show';
          form.classList.add('shake');
          setTimeout(function() { form.classList.remove('shake'); }, 450);
        })
        .finally(function() {
          submitBtn.disabled = false;
          btnLabel.textContent = 'Masuk ke Dashboard';
          btnSpinner.style.display = 'none';
        });
      });
    })();
  </script>
</body>
</html>
