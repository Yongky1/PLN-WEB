      </div>

      <div class="left-content">
        <div>
          <p class="eyebrow">PT PLN (Persero)</p>
          <h1 class="title">Pembelajaran 3D<br/><span>Web PLN</span></h1>
        </div>
        <p class="lead">Platform pembelajaran konstruksi jaringan tenaga listrik berbasis teknologi 3D interaktif.</p>
      </div>

      <p class="copyright">© 2026 PT PLN (Persero) · All Rights Reserved</p>
    </div>

    <!-- ── RIGHT PANEL ── -->
    <div class="right">
      <div class="form-wrap">

        <div class="badge">
          <span class="dot"></span>
          <span>PORTAL ADMIN</span>
        </div>

        <h2 class="heading">Selamat datang<br/><span>admin!</span></h2>
        <p class="subheading">Masuk untuk melanjutkan ke dashboard</p>

        <div id="error-banner" class="error-banner"></div>

        <form id="loginForm" novalidate>
          <!-- email -->
          <div class="field" id="emailField">
            <div class="field-box">
              <span class="field-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="2" y="4" width="20" height="16" rx="3"/><path d="m2 7 10 7 10-7"/>
                </svg>
              </span>
              <label class="field-label" for="email">Alamat Email</label>
              <input class="field-input" type="email" id="email" autocomplete="email" />
            </div>
            <p class="err-msg" id="emailErr" style="display:none"></p>
          </div>

          <!-- password -->
          <div class="field" id="passwordField">
            <div class="field-box">
              <span class="field-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                </svg>
              </span>
              <label class="field-label" for="password">Password</label>
              <input class="field-input has-right" type="password" id="password" autocomplete="current-password" />
              <button type="button" class="toggle-pw" id="togglePw" aria-label="Tampilkan password">
                <svg id="eyeIcon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/>
                  <line x1="1" y1="1" x2="23" y2="23"/>
                </svg>
              </button>
            </div>
            <p class="err-msg" id="passwordErr" style="display:none"></p>
          </div>

          <!-- remember + forgot -->
          <div class="row">
            <label class="checkbox">
              <input type="checkbox" id="remember" />
              <span class="check-box">
                <svg width="10" height="10" viewBox="0 0 12 12" fill="none" stroke="#001833" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="10 3 5 9 2 6"/>
                </svg>
              </span>
              <span>Ingat saya</span>
            </label>
            <button type="button" class="forgot">Lupa password?</button>
          </div>

          <!-- submit -->
          <button type="submit" class="submit-btn" id="submitBtn">
            <span id="btnLabel">Masuk ke Dashboard</span>
            <svg id="btnArrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </button>
        </form>

        <div class="divider">
          <span class="line"></span>
          <span class="label">VERSI 2.0 · 2026</span>
          <span class="line"></span>
        </div>
      </div>
    </div>
  </div>

  <script>
    // floating-label active state
    document.querySelectorAll('.field-input').forEach(input => {
      const box = input.closest('.field-box');
      const update = () => input.value.length > 0 ? box.classList.add('active') : box.classList.remove('active');
      input.addEventListener('input', update);
      input.addEventListener('blur', update);
      update();
    });

    // password show/hide
    const pwInput = document.getElementById('password');
    const toggle  = document.getElementById('togglePw');
    const eye     = document.getElementById('eyeIcon');
    toggle.addEventListener('click', () => {
      const visible = pwInput.type === 'text';
      pwInput.type = visible ? 'password' : 'text';
      toggle.classList.toggle('active', !visible);
      eye.innerHTML = visible
        ? '<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/>'
        : '<path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z"/><circle cx="12" cy="12" r="3"/>';
    });

    // form validation helpers
    const setError = (field, errEl, msg) => {
      if (msg) {
        field.classList.add('error');
        errEl.textContent = msg;
        errEl.style.display = 'block';
      } else {
        field.classList.remove('error');
        errEl.style.display = 'none';
      }
    };

    const emailIn   = document.getElementById('email');
    const emailErr  = document.getElementById('emailErr');
    const pwErr     = document.getElementById('passwordErr');
    const emailF    = document.getElementById('emailField');
    const pwF       = document.getElementById('passwordField');
    const btn       = document.getElementById('submitBtn');
    const btnLabel  = document.getElementById('btnLabel');
    const btnArrow  = document.getElementById('btnArrow');
    const errorBanner = document.getElementById('error-banner');
    const form      = document.getElementById('loginForm');

    emailIn.addEventListener('input', () => setError(emailF, emailErr, ''));
    pwInput.addEventListener('input', () => setError(pwF, pwErr, ''));

    form.addEventListener('submit', async e => {
      e.preventDefault();
      errorBanner.classList.remove('show');

      let ok = true;
      const email = emailIn.value.trim();
      if (!email) { setError(emailF, emailErr, 'Email wajib diisi'); ok = false; }
      else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { setError(emailF, emailErr, 'Format email tidak valid'); ok = false; }
      else setError(emailF, emailErr, '');

      const pw = pwInput.value;
      if (!pw) { setError(pwF, pwErr, 'Password wajib diisi'); ok = false; }
      else if (pw.length < 6) { setError(pwF, pwErr, 'Password minimal 6 karakter'); ok = false; }
      else setError(pwF, pwErr, '');

      if (!ok) {
        form.classList.remove('shake');
        void form.offsetWidth;
        form.classList.add('shake');
        return;
      }

      // loading state
      btn.disabled = true;
      btnLabel.textContent = 'Memverifikasi…';
      btnArrow.style.display = 'none';
      const sp = document.createElement('div');
      sp.className = 'spinner';
      btn.insertBefore(sp, btnLabel);

      try {
        const res = await fetch('/api/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, password: pw })
        });
        const result = await res.json();

        if (!res.ok) throw new Error(result.error || result.message || 'Login gagal');

        localStorage.setItem('auth_token', result.token);

        await fetch('/set-session', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ token: result.token })
        });

        window.location.href = '/admin';

      } catch (err) {
        sp.remove();
        btnLabel.textContent = 'Masuk ke Dashboard';
        btnArrow.style.display = '';
        btn.disabled = false;

        errorBanner.textContent = err.message;
        errorBanner.classList.add('show');
      }
    });
  </script>
</body>
</html>
