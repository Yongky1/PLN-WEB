<!DOCTYPE html>
<html lang="id" class="scroll-smooth">
<head>
    <%- include('partials/head') %>
</head>
<body class="bg-brand-light dark:bg-brand-dark text-gray-900 dark:text-white transition-colors duration-700 font-sans antialiased overflow-x-hidden selection:bg-brand-accent selection:text-brand-dark">

    <%- include('partials/navbar') %>

    <!-- Main Content -->
    <main class="pt-32 pb-24 px-6 bg-brand-light dark:bg-brand-dark transition-colors duration-700 min-h-screen">
        <div class="max-w-7xl mx-auto">
            <!-- Page Title -->
            <div class="mb-10 text-left">
                <span class="inline-block py-1 px-3 rounded-full bg-blue-100 dark:bg-blue-900/30 text-brand-blue dark:text-brand-accent text-[10px] font-semibold tracking-widest uppercase mb-3 border border-blue-200 dark:border-blue-800">
                    Pusat Pembelajaran 3D
                </span>
                <h1 class="text-3xl md:text-4xl font-display font-bold mb-3">
                    Modul <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-brand-accent dark:from-blue-400 dark:to-brand-accent">Konstruksi</span>
                </h1>
                <p class="text-sm md:text-base text-gray-600 dark:text-gray-400 max-w-2xl leading-relaxed">
                    Pilih modul pembelajaran virtual interaktif di bawah ini untuk memulai simulasi perakitan infrastruktur energi.
                </p>
            </div>

            <!-- Modules Grid Section -->
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
                
                <% modulesData.forEach(mod => { %>
                <!-- Module Card -->
                <a href="#" class="group block relative rounded-2xl overflow-hidden bg-white dark:bg-[#0d2238] shadow-sm hover:shadow-xl transition-all duration-300 border border-gray-100 dark:border-white/5 hover:-translate-y-1 flex flex-col">
                    
                    <!-- Cover Image -->
                    <div class="w-full h-32 bg-gray-50 dark:bg-gray-800/50 relative overflow-hidden flex items-center justify-center">
                        <% if (mod.image) { %>
                            <img src="<%= mod.image %>" alt="<%= mod.title %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700">
                        <% } else { %>
                            <!-- Placeholder -->
                            <div class="absolute inset-0 opacity-20 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-brand-accent via-transparent to-transparent group-hover:scale-150 transition-transform duration-700"></div>
                            <svg class="w-8 h-8 text-gray-300 dark:text-gray-600 group-hover:text-brand-accent transition-colors duration-500 z-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
                        <% } %>
                    </div>

                    <!-- Content Section -->
                    <div class="p-5 flex flex-col flex-grow">
                        <h3 class="text-base font-bold mb-1.5 text-gray-900 dark:text-white group-hover:text-brand-blue dark:group-hover:text-brand-accent transition-colors leading-tight">
                            <%= mod.title %>
                        </h3>
                        <p class="text-gray-500 dark:text-gray-400 text-xs leading-relaxed mb-4 flex-grow">
                            <%= mod.description %>
                        </p>
                        
                        <!-- Material & Peralatan List -->
                        <div class="mt-auto border-t border-gray-100 dark:border-gray-800/60 pt-3 flex flex-col gap-1.5">
                            <p class="text-xs text-gray-600 dark:text-gray-300 font-medium">Material : <%= mod.materialCount %></p>
                            <p class="text-xs text-gray-600 dark:text-gray-300 font-medium">Peralatan : <%= mod.equipmentCount %></p>
                        </div>
                    </div>
                </a>
                <% }); %>
            </div>
            
            <% if(modulesData.length === 0) { %>
                <div class="text-center py-20">
                    <p class="text-gray-500 dark:text-gray-400 text-sm">Belum ada modul yang tersedia.</p>
                </div>
            <% } %>

        </div>
    </main>

    <%- include('partials/footer') %>

    <!-- Scripts -->
    <script src="/js/main.js"></script>
</body>
</html>
