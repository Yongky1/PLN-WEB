<!DOCTYPE html>
<html lang="id" class="scroll-smooth overflow-x-hidden">
<head>
    <%- include('partials/head') %>
    <script type="module" src="https://ajax.googleapis.com/ajax/libs/model-viewer/3.4.0/model-viewer.min.js"></script>
    <style>
        /* Custom styles for premium bento & blueprint */
        .glass-panel {
            background: linear-gradient(135deg, rgba(255, 255, 255, 0.12) 0%, rgba(255, 255, 255, 0.03) 100%);
            backdrop-filter: blur(40px) saturate(150%);
            -webkit-backdrop-filter: blur(40px) saturate(150%);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-top-color: rgba(255, 255, 255, 0.3);
            border-left-color: rgba(255, 255, 255, 0.2);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.2), inset 0 1px 0 rgba(255, 255, 255, 0.1);
        }
        
        .card-active:hover {
            border-top-color: rgba(255, 213, 0, 0.5);
            border-left-color: rgba(255, 213, 0, 0.3);
            background: linear-gradient(135deg, rgba(255, 255, 255, 0.15) 0%, rgba(255, 213, 0, 0.05) 100%);
            box-shadow: 0 30px 60px rgba(0, 0, 0, 0.3), 0 0 40px rgba(255, 213, 0, 0.1), inset 0 1px 0 rgba(255, 255, 255, 0.2);
            transform: translateY(-4px) scale(1.01);
        }

        .blueprint-card {
            background: repeating-linear-gradient(
                45deg,
                rgba(255, 255, 255, 0.01) 0px,
                rgba(255, 255, 255, 0.01) 2px,
                transparent 2px,
                transparent 8px
            );
            border: 1px dashed rgba(255, 255, 255, 0.15);
        }
        .blueprint-card:hover {
            border-color: rgba(255, 213, 0, 0.4);
            background: rgba(255, 213, 0, 0.02);
        }

        /* modal viewer fix */
        #preview-modal.active { display: flex !important; }
        .preview-content { max-height: 90vh; overflow-y: auto; }
        .modal-viewer-area { height: 60vh; min-height: 400px; }
        @media (max-width: 640px) {
            .modal-viewer-area { height: 50vh; min-height: 250px; }
        }
    </style>
</head>
<body class="bg-[var(--color-pln-darker)] text-white font-sans antialiased overflow-x-hidden">


    <%- include('partials/navbar') %>

    <!-- Main Content -->
    <main class="pt-32 pb-24 px-4 sm:px-6 bg-[var(--color-pln-darker)] min-h-screen relative overflow-x-hidden">
        
        <!-- Subtle Ambient Glow -->
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] max-w-[100vw] h-[500px] bg-[var(--color-pln-yellow)]/5 rounded-full blur-[120px] pointer-events-none -z-10"></div>

        <div class="max-w-7xl mx-auto z-10 relative">
            
            <!-- Page Title & Sort (Hero) -->
            <div class="hero-content mb-16 text-left flex flex-col md:flex-row md:items-end justify-between gap-8 border-b border-white/5 pb-8">
                <div class="max-w-2xl">
                    <span class="inline-flex items-center gap-2 py-1.5 px-3 rounded-full bg-[var(--color-pln-yellow)]/10 text-[var(--color-pln-yellow)] text-[10px] font-bold tracking-[0.15em] uppercase mb-4 border border-[var(--color-pln-yellow)]/20 shadow-[0_0_15px_rgba(255,213,0,0.1)]">
                        <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-pln-yellow)] animate-pulse"></span>
                        Laboratorium 3D
                    </span>
                    <h1 class="text-4xl md:text-6xl font-black mb-4 font-['Space_Grotesk'] tracking-tight leading-tight">
                        Modul <span class="text-transparent bg-clip-text bg-gradient-to-r from-[var(--color-pln-yellow)] to-yellow-200">Konstruksi</span>
                    </h1>
                    <p class="text-sm md:text-base text-white/50 leading-relaxed font-light">
                        Pilih modul standar konstruksi jaringan di bawah ini untuk memulai simulasi dan interaksi komponen dalam ruang 3 dimensi.
                    </p>
                </div>
                
                <!-- Premium Select Dropdown -->
                <div class="relative w-full md:w-auto md:min-w-[220px]">
                    <form id="sort-form" method="GET" action="/ModulKonstruksi">
                        <div class="relative group">
                            <select name="sort" onchange="document.getElementById('sort-form').submit()" class="w-full appearance-none bg-black/20 backdrop-blur-md border border-white/10 rounded-2xl px-5 py-3.5 pr-10 text-sm font-semibold text-white/80 focus:outline-none focus:border-[var(--color-pln-yellow)]/50 focus:bg-black/40 transition-all cursor-pointer">
                                <option value="newest" class="bg-[#0b1a2e] text-white" <%= currentSort === 'newest' ? 'selected' : '' %>>Terbaru</option>
                                <option value="name_asc" class="bg-[#0b1a2e] text-white" <%= currentSort === 'name_asc' ? 'selected' : '' %>>Abjad (A - Z)</option>
                                <option value="name_desc" class="bg-[#0b1a2e] text-white" <%= currentSort === 'name_desc' ? 'selected' : '' %>>Abjad (Z - A)</option>
                            </select>
                            <div class="absolute inset-y-0 right-0 flex items-center px-4 pointer-events-none text-white/40 group-hover:text-white/80 transition-colors">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"></path></svg>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Modules Grid Section: ACTIVE -->
            <div class="mb-20 grid-container">
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 lg:gap-8">
                    <% if(activeModules.length === 0) { %>
                        <div class="col-span-full text-center py-16 glass-panel rounded-3xl">
                            <svg class="w-12 h-12 text-white/20 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
                            <p class="text-white/40 font-medium">Belum ada modul aktif yang dirilis ke publik.</p>
                        </div>
                    <% } %>
                    
                    <% activeModules.forEach(mod => { %>
                    <!-- App Store Style Active Card -->
                    <a href="/ModulKonstruksi/<%= mod.id %>" class="gsap-card group flex flex-col apple-glass-light rounded-[2.5rem] overflow-hidden hover:shadow-[0_30px_60px_-15px_rgba(255,255,255,0.2)] hover:border-white/40 hover:-translate-y-2 transition-all duration-500 cursor-pointer relative">
                        <!-- Image Container (Top Half) -->
                        <div class="h-[220px] relative overflow-hidden bg-black/20">
                            <% if (mod.image) { %>
                                <img src="<%= mod.image %>" alt="<%= mod.title %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out">
                            <% } else { %>
                                <div class="absolute inset-0 bg-gradient-to-br from-[#0b1a2e] to-[var(--color-pln-darker)]"></div>
                                <div class="w-full h-full flex items-center justify-center opacity-40">
                                    <svg class="w-12 h-12 text-[var(--color-pln-yellow)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
                                </div>
                            <% } %>
                        </div>

                        <!-- Content Area (Bottom Half) -->
                        <div class="p-6 md:p-8 flex-grow flex flex-col relative z-10 bg-gradient-to-t from-black/60 via-black/10 to-transparent">
                            <h3 class="text-xl md:text-2xl font-bold mb-2 text-white/90 group-hover:text-[var(--color-pln-yellow)] transition-colors leading-snug font-['Space_Grotesk'] tracking-tight">
                                <%= mod.title %>
                            </h3>
                            <p class="text-white/40 text-[13px] leading-relaxed mb-8 font-['Inter'] line-clamp-2">
                                <%= mod.description %>
                            </p>
                            
                            <div class="mt-auto flex justify-between items-end">
                                <!-- Stats -->
                                <div class="flex items-center gap-5">
                                    <div>
                                        <p class="text-[10px] uppercase tracking-wider text-white/40 mb-1 font-semibold">Material</p>
                                        <p class="text-base font-bold text-[var(--color-pln-yellow)] font-['Outfit']"><%= mod.materialCount %></p>
                                    </div>
                                    <div class="w-px h-8 bg-white/10"></div>
                                    <div>
                                        <p class="text-[10px] uppercase tracking-wider text-white/40 mb-1 font-semibold">Peralatan</p>
                                        <p class="text-base font-bold text-[var(--color-pln-yellow)] font-['Outfit']"><%= mod.equipmentCount %></p>
                                    </div>
                                </div>

                                <!-- Action Button -->
                                <div class="w-10 h-10 rounded-full bg-[var(--color-pln-yellow)]/10 flex items-center justify-center text-[var(--color-pln-yellow)] group-hover:bg-[var(--color-pln-yellow)] group-hover:text-black transition-colors">
                                    <svg class="w-5 h-5 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                                </div>
                            </div>
                        </div>
                    </a>
                    <% }); %>
                </div>
            </div>

            <!-- Modules Grid Section: INACTIVE / DRAFT (Blueprint) -->
            <% if(inactiveModules.length > 0) { %>
            <div class="pt-16 border-t border-white/5 grid-container-draft">
                <div class="flex items-center gap-3 mb-8">
                    <div class="w-8 h-[1px] bg-yellow-500/50"></div>
                    <h2 class="text-sm font-semibold text-yellow-500/80 uppercase tracking-[0.2em] font-['Space_Grotesk']">
                        Tahap Pengembangan
                    </h2>
                </div>
                
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
                    <% inactiveModules.forEach(mod => { %>
                    <!-- App Store Style Draft Card -->
                    <div onclick="openPreviewModal('<%= mod.id %>')" class="gsap-draft-card group relative rounded-3xl overflow-hidden apple-glass-dark hover:border-white/50 transition-all duration-300 cursor-pointer">
                        
                        <!-- Status Badge Overlay -->
                        <div class="absolute top-4 right-4 z-20">
                            <span class="inline-block px-3 py-1 bg-yellow-500/20 text-yellow-500 border border-yellow-500/30 text-[10px] font-bold rounded-full uppercase tracking-wider backdrop-blur-md">
                                <%= mod.status %>
                            </span>
                        </div>

                        <!-- Image Section -->
                        <div class="w-full h-32 bg-[#06101c] relative overflow-hidden flex items-center justify-center opacity-70 group-hover:opacity-100 transition-opacity duration-300">
                            <% if (mod.image) { %>
                                <img src="<%= mod.image %>" class="w-full h-full object-cover filter grayscale contrast-125 sepia-[.2] hue-rotate-180">
                            <% } else { %>
                                <svg class="w-8 h-8 text-white/20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
                            <% } %>
                        </div>

                        <!-- Content Section -->
                        <div class="p-6 md:p-8 flex flex-col flex-grow">
                            <h3 class="text-base font-bold mb-1.5 text-white/80 group-hover:text-yellow-400 transition-colors leading-snug font-['Space_Grotesk']">
                                <%= mod.title %>
                            </h3>
                            <p class="text-white/40 text-[11px] leading-relaxed mb-6 flex-grow line-clamp-2">
                                <%= mod.description %>
                            </p>
                            
                            <div class="mt-auto border-t border-white/10 pt-4 flex justify-between items-center">
                                <span class="text-[11px] text-white/50 group-hover:text-white/90 uppercase tracking-widest font-semibold flex items-center gap-2 transition-colors">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                                    Preview 3D
                                </span>
                            </div>
                        </div>

                        <!-- Data untuk modal JS -->
                        <script type="application/json" id="data-mod-<%= mod.id %>">
                            <%- JSON.stringify(mod.assets) %>
                        </script>
                        <input type="hidden" id="title-mod-<%= mod.id %>" value="<%= mod.title %>">
                    </div>
                    <% }); %>
                </div>
            </div>
            <% } %>

        </div>
    </main>

    <!-- Preview Modal (Draft Modules) -->
    <div id="preview-modal" class="fixed inset-0 z-50 hidden items-center justify-center p-4 bg-black/80 backdrop-blur-xl" style="display: none;">
        <div class="preview-content bg-[#0A1929]/90 border border-white/10 w-full max-w-4xl rounded-[2rem] overflow-hidden shadow-2xl flex flex-col relative backdrop-blur-2xl">
            
            <div class="px-6 py-5 border-b border-white/5 flex justify-between items-center bg-transparent">
                <div>
                    <h3 id="modal-title" class="text-xl font-bold text-white font-['Space_Grotesk']">Preview Modul</h3>
                    <p class="text-[10px] text-yellow-500 font-medium uppercase tracking-[0.15em] mt-1">Mode Preview Pengembangan</p>
                </div>
                <button onclick="closePreviewModal()" class="w-10 h-10 flex items-center justify-center bg-white/5 hover:bg-white/10 rounded-full transition-colors border border-white/5">
                    <svg class="w-5 h-5 text-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>

            <!-- Modal Body (3D Viewer) -->
            <div class="modal-viewer-area relative w-full flex-grow flex items-center justify-center p-4 overflow-hidden rounded-b-[2rem]" style="background: radial-gradient(circle at center, #0F1E3A 0%, #030812 100%);">
                <!-- Inner Glow Kaca Apple -->
                <div class="absolute inset-0 apple-glass-dark pointer-events-none mix-blend-overlay"></div>
                
                <model-viewer 
                    id="modal-model-viewer"
                    src="" 
                    camera-controls 
                    auto-rotate
                    rotation-per-second="30deg"
                    interaction-prompt="none"
                    shadow-intensity="1.5"
                    environment-image="neutral"
                    exposure="1"
                    class="w-full h-full z-0 outline-none cursor-grab active:cursor-grabbing">
                </model-viewer>

                <!-- Navigation Arrows (Variant Carousel) -->
                <button id="modal-prev-btn" onclick="prevVariant(event)" class="absolute left-2 sm:left-6 top-1/2 -translate-y-1/2 w-9 h-9 sm:w-12 sm:h-12 bg-white/5 backdrop-blur-md rounded-full flex items-center justify-center text-white hover:bg-[var(--color-pln-yellow)] hover:text-black transition-all hidden z-20 border border-white/10">
                    <svg class="w-4 h-4 sm:w-5 sm:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
                </button>
                <button id="modal-next-btn" onclick="nextVariant(event)" class="absolute right-2 sm:right-6 top-1/2 -translate-y-1/2 w-9 h-9 sm:w-12 sm:h-12 bg-white/5 backdrop-blur-md rounded-full flex items-center justify-center text-white hover:bg-[var(--color-pln-yellow)] hover:text-black transition-all hidden z-20 border border-white/10">
                    <svg class="w-4 h-4 sm:w-5 sm:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                </button>

                <!-- Variant Display Name -->
                <div id="modal-variant-name" class="absolute bottom-6 left-1/2 -translate-x-1/2 px-5 py-2.5 bg-black/80 backdrop-blur-xl border border-white/10 text-white/90 text-xs font-semibold rounded-full pointer-events-none z-10 hidden font-['Outfit'] tracking-wide">
                    Varian - 
                </div>

                <!-- Empty State -->
                <div id="modal-empty-state" class="absolute inset-0 flex flex-col items-center justify-center text-white/30 hidden z-10">
                    <svg class="w-16 h-16 mb-4 text-white/10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                    <span class="text-sm font-medium tracking-wide">Belum ada file 3D yang diunggah.</span>
                </div>
            </div>

        </div>
    </div>

    <%- include('partials/footer') %>

    <!-- Scripts -->
    <script src="/js/main.js"></script>
    <script>
        // GSAP Animations untuk tampilan premium
        if(typeof gsap !== 'undefined' && typeof ScrollTrigger !== 'undefined') {
            gsap.registerPlugin(ScrollTrigger);

            // Hero Section Animation
            gsap.from(".hero-content > div", {
                y: 40,
                opacity: 0,
                duration: 1.2,
                stagger: 0.2,
                ease: "power3.out",
                delay: 0.1
            });

            // Grid Active Cards Animation
            gsap.from(".gsap-card", {
                scrollTrigger: {
                    trigger: ".grid-container",
                    start: "top 85%",
                },
                y: 60,
                opacity: 0,
                duration: 1,
                stagger: 0.1,
                ease: "power4.out"
            });

            // Blueprint Draft Cards Animation
            gsap.from(".gsap-draft-card", {
                scrollTrigger: {
                    trigger: ".grid-container-draft",
                    start: "top 85%",
                },
                scale: 0.95,
                opacity: 0,
                duration: 0.8,
                stagger: 0.15,
                ease: "back.out(1.2)"
            });
        }

        // Logistics Modal Preview
        let currentAssets = [];
        let currentIndex = 0;

        function openPreviewModal(moduleId) {
            const modal = document.getElementById('preview-modal');
            const titleEl = document.getElementById('modal-title');
            const viewer = document.getElementById('modal-model-viewer');
            const emptyState = document.getElementById('modal-empty-state');
            const prevBtn = document.getElementById('modal-prev-btn');
            const nextBtn = document.getElementById('modal-next-btn');
            const variantName = document.getElementById('modal-variant-name');

            const titleRaw = document.getElementById(`title-mod-${moduleId}`).value;
            const assetsRaw = document.getElementById(`data-mod-${moduleId}`).textContent;
            
            titleEl.textContent = titleRaw;
            currentAssets = JSON.parse(assetsRaw) || [];
            currentIndex = 0;

            if (currentAssets.length === 0) {
                viewer.style.display = 'none';
                emptyState.style.display = 'flex';
                prevBtn.style.display = 'none';
                nextBtn.style.display = 'none';
                variantName.style.display = 'none';
            } else {
                viewer.style.display = 'block';
                emptyState.style.display = 'none';
                loadVariant(0);
                
                if (currentAssets.length > 1) {
                    prevBtn.style.display = 'flex';
                    nextBtn.style.display = 'flex';
                    variantName.style.display = 'block';
                } else {
                    prevBtn.style.display = 'none';
                    nextBtn.style.display = 'none';
                    variantName.style.display = 'none';
                }
            }

            modal.style.display = 'flex';
            document.body.style.overflow = 'hidden';
            setTimeout(() => modal.classList.add('active'), 10);
            
            if(typeof gsap !== 'undefined') {
                gsap.from(".preview-content", { y: 50, opacity: 0, duration: 0.6, ease: "power3.out" });
            }
        }

        function closePreviewModal() {
            const modal = document.getElementById('preview-modal');
            modal.classList.remove('active');
            setTimeout(() => {
                modal.style.display = 'none';
                document.body.style.overflow = '';
            }, 300);
        }

        function loadVariant(index) {
            if (index < 0 || index >= currentAssets.length) return;
            const viewer = document.getElementById('modal-model-viewer');
            const variantName = document.getElementById('modal-variant-name');
            const asset = currentAssets[index];
            
            viewer.src = asset.file || '';
            variantName.textContent = `Varian ${index + 1}/${currentAssets.length} : ${asset.name}`;
        }

        function nextVariant(e) {
            if(e) e.stopPropagation();
            if (currentAssets.length <= 1) return;
            currentIndex = (currentIndex + 1) % currentAssets.length;
            loadVariant(currentIndex);
        }

        function prevVariant(e) {
            if(e) e.stopPropagation();
            if (currentAssets.length <= 1) return;
            currentIndex = (currentIndex - 1 + currentAssets.length) % currentAssets.length;
            loadVariant(currentIndex);
        }
    </script>
</body>
</html>
