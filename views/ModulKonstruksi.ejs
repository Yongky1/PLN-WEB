<!DOCTYPE html>
<html lang="id" class="scroll-smooth">

<head>
    <%- include('partials/head') %>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
</head>

<body class="antialiased" style="background-color: var(--color-bg-main); color: var(--color-text-primary);">

    <%- include('partials/navbar') %>

    <main style="padding-top: 96px; padding-bottom: 64px; min-height: 100vh;" class="relative">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

            <!-- Header -->
            <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-8 mb-10 pb-8 border-b border-[var(--color-border)]">
                <!-- Left: Title + Subtitle -->
                <div class="gsap-reveal">
                    <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-[var(--color-primary)]/5 border border-[var(--color-primary)]/10 mb-4">
                        <div class="w-1.5 h-1.5 rounded-full bg-[var(--color-primary)] shadow-sm shadow-[var(--color-primary)]"></div>
                        <span class="text-[10px] font-bold tracking-[0.18em] text-[var(--color-primary)] uppercase">Laboratorium 3D · PLN</span>
                    </div>
                    <h1 class="text-4xl md:text-5xl font-extrabold brand-font mb-3 tracking-tight leading-tight">
                        <span class="text-[var(--color-text-primary)]">Modul </span><span class="gradient-text-blue">Konstruksi</span>
                    </h1>
                    <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed max-w-lg">
                        Pilih modul standar konstruksi jaringan untuk memulai simulasi interaktif dalam ruang 3 dimensi.
                    </p>
                </div>

                <!-- Right: Search + Sort -->
                <div class="flex items-center gap-3 flex-shrink-0 min-w-[300px] lg:min-w-[380px]">
                    <!-- Search -->
                    <div class="flex-1 relative">
                        <div class="absolute left-3.5 top-1/2 transform -translate-y-1/2 text-[var(--color-text-muted)] pointer-events-none">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
                        </div>
                        <input id="v3-search" type="text" placeholder="Cari modul konstruksi..."
                            oninput="v3FilterModules(this.value)"
                            class="w-full bg-white border border-[var(--color-border)] rounded-xl py-2.5 pl-10 pr-4 text-sm text-[var(--color-text-primary)] placeholder-[var(--color-text-muted)] outline-none focus:border-[var(--color-primary)] focus:ring-2 focus:ring-[var(--color-primary)]/10 transition-all" />
                    </div>
                    <!-- Sort -->
                    <form id="v3-sort-form" method="GET" action="/ModulKonstruksi" style="display:none;">
                        <input type="hidden" name="sort" id="v3-sort-hidden" value="<%= currentSort %>">
                    </form>
                    <div class="relative" id="v3-sort-dd">
                        <button type="button" onclick="v3ToggleDropdown('v3-sort-dd')"
                            class="flex items-center gap-2 bg-white border border-[var(--color-border)] rounded-xl py-2.5 px-4 text-xs font-semibold text-[var(--color-text-secondary)] hover:border-[var(--color-primary)] hover:text-[var(--color-primary)] transition-all cursor-pointer outline-none whitespace-nowrap">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="opacity-50"><path d="M3 6h18M6 12h12M10 18h4"/></svg>
                            <span id="v3-sort-label"><%= currentSort==='name_asc' ? 'A–Z' : currentSort==='name_desc' ? 'Z–A' : 'Terbaru' %></span>
                            <svg class="w-3 h-3 transition-transform duration-200" id="sort-chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
                        </button>
                        <div id="sort-dropdown-menu" class="absolute top-full right-0 mt-2 min-w-[140px] rounded-xl bg-white border border-[var(--color-border)] shadow-xl z-50 hidden overflow-hidden">
                            <div class="p-1.5">
                                <div class="px-3 py-2 rounded-lg text-xs font-semibold cursor-pointer transition-colors hover:bg-[var(--color-primary)]/5 hover:text-[var(--color-primary)] <%= currentSort === 'newest' ? 'text-[var(--color-primary)] bg-[var(--color-primary)]/5' : 'text-[var(--color-text-secondary)]' %>"
                                    onclick="v3SelectSort('newest','Terbaru')">Terbaru</div>
                                <div class="px-3 py-2 rounded-lg text-xs font-semibold cursor-pointer transition-colors hover:bg-[var(--color-primary)]/5 hover:text-[var(--color-primary)] <%= currentSort === 'name_asc' ? 'text-[var(--color-primary)] bg-[var(--color-primary)]/5' : 'text-[var(--color-text-secondary)]' %>"
                                    onclick="v3SelectSort('name_asc','A–Z')">Abjad A–Z</div>
                                <div class="px-3 py-2 rounded-lg text-xs font-semibold cursor-pointer transition-colors hover:bg-[var(--color-primary)]/5 hover:text-[var(--color-primary)] <%= currentSort === 'name_desc' ? 'text-[var(--color-primary)] bg-[var(--color-primary)]/5' : 'text-[var(--color-text-secondary)]' %>"
                                    onclick="v3SelectSort('name_desc','Z–A')">Abjad Z–A</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Module Grid -->
            <div id="v3-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 gsap-stagger-container">
                <% if (activeModules.length===0) { %>
                    <div class="col-span-full flex flex-col items-center justify-center py-20 gap-4">
                        <div class="w-16 h-16 rounded-2xl bg-[var(--color-bg-surface-alt)] border border-[var(--color-border)] flex items-center justify-center">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-text-muted)" stroke-width="1.5"><path d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
                        </div>
                        <span class="text-sm text-[var(--color-text-muted)]">Belum ada modul aktif yang dirilis ke publik.</span>
                    </div>
                <% } %>

                <% activeModules.forEach((mod, i) => { %>
                    <a href="/ModulKonstruksi/<%= mod.id %>" class="gsap-stagger-item group block" data-title="<%= mod.title.toLowerCase() %>">
                        <div class="card-elevated overflow-hidden h-full flex flex-col">
                            <!-- Image -->
                            <div class="aspect-[16/10] relative overflow-hidden bg-gradient-to-br from-[var(--color-bg-surface-alt)] to-[var(--color-bg-main)]">
                                <% if (mod.image) { %>
                                    <img src="<%= mod.image %>" alt="<%= mod.title %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700">
                                <% } else { %>
                                    <div class="w-full h-full flex flex-col items-center justify-center gap-2">
                                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="<%= i % 2 === 0 ? 'var(--color-primary)' : 'var(--color-cyan)' %>" stroke-width="1" opacity="0.3">
                                            <path d="M21 7.5l-2.25-1.313M21 7.5v2.25m0-2.25l-2.25 1.313M3 7.5l2.25-1.313M3 7.5l2.25 1.313M3 7.5v2.25m9 3l2.25-1.313M12 12.75l-2.25-1.313M12 12.75V15m0 6.75l2.25-1.313M12 21.75V19.5m0 2.25l-2.25-1.313m0-16.875L12 2.25l2.25 1.313M21 14.25v2.25l-2.25 1.313m-13.5 0L3 16.5v-2.25"/>
                                        </svg>
                                        <span class="text-[9px] font-bold tracking-[0.1em] text-[var(--color-text-muted)] uppercase">3D Model</span>
                                    </div>
                                <% } %>
                                <!-- Gradient overlay -->
                                <div class="absolute bottom-0 left-0 right-0 h-16 bg-gradient-to-t from-white/80 to-transparent pointer-events-none"></div>
                            </div>

                            <!-- Body -->
                            <div class="p-5 flex flex-col flex-grow">
                                <h3 class="text-base font-bold text-[var(--color-text-primary)] brand-font leading-snug mb-1.5 group-hover:text-[var(--color-primary)] transition-colors">
                                    <%= mod.title %>
                                </h3>
                                <p class="text-xs text-[var(--color-text-muted)] leading-relaxed line-clamp-2 mb-4">
                                    <%= mod.description %>
                                </p>
                                <div class="mt-auto">
                                    <div class="h-px bg-[var(--color-border-light)] mb-4"></div>
                                    <div class="flex items-center justify-between">
                                        <div class="flex gap-4">
                                            <div class="flex flex-col">
                                                <span class="text-[9px] font-bold tracking-[0.1em] text-[var(--color-text-muted)] uppercase">Material</span>
                                                <span class="text-lg font-bold text-[var(--color-primary)] brand-font"><%= mod.materialCount %></span>
                                            </div>
                                            <div class="w-px bg-[var(--color-border-light)]"></div>
                                            <div class="flex flex-col">
                                                <span class="text-[9px] font-bold tracking-[0.1em] text-[var(--color-text-muted)] uppercase">Peralatan</span>
                                                <span class="text-lg font-bold text-[var(--color-cyan)] brand-font"><%= mod.equipmentCount %></span>
                                            </div>
                                        </div>
                                        <!-- Arrow button -->
                                        <div class="w-9 h-9 rounded-xl bg-[var(--color-primary)]/8 flex items-center justify-center text-[var(--color-primary)] group-hover:bg-[var(--color-primary)] group-hover:text-white transition-all duration-300 group-hover:rotate-[-45deg] group-hover:scale-110">
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Bottom accent line -->
                            <div class="h-0.5 bg-gradient-to-r from-[var(--color-primary)] via-[var(--color-cyan)] to-[var(--color-accent)] transform scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left"></div>
                        </div>
                    </a>
                <% }) %>
            </div>

            <!-- No search results -->
            <div id="v3-no-results" class="hidden flex-col items-center justify-center py-20 gap-4">
                <div class="w-16 h-16 rounded-2xl bg-[var(--color-bg-surface-alt)] border border-[var(--color-border)] flex items-center justify-center">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-text-muted)" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
                </div>
                <span class="text-sm text-[var(--color-text-muted)]">Tidak ada modul yang cocok dengan pencarian.</span>
            </div>

        </div>
    </main>

    <%- include('partials/footer') %>

    <script src="/js/main.js"></script>
    <script>
        // Custom dropdown toggle
        function v3ToggleDropdown(id) {
            var menu = document.getElementById('sort-dropdown-menu');
            var chevron = document.getElementById('sort-chevron');
            menu.classList.toggle('hidden');
            chevron.style.transform = menu.classList.contains('hidden') ? '' : 'rotate(180deg)';
        }
        
        function v3SelectSort(value, label) {
            document.getElementById('v3-sort-hidden').value = value;
            document.getElementById('v3-sort-label').textContent = label;
            document.getElementById('sort-dropdown-menu').classList.add('hidden');
            document.getElementById('v3-sort-form').submit();
        }
        
        // Close dropdown on outside click
        document.addEventListener('click', function(e) {
            var dd = document.getElementById('v3-sort-dd');
            if (dd && !dd.contains(e.target)) {
                document.getElementById('sort-dropdown-menu').classList.add('hidden');
                document.getElementById('sort-chevron').style.transform = '';
            }
        });

        // Client-side search filter
        function v3FilterModules(query) {
            const grid = document.getElementById('v3-grid');
            const cards = grid.querySelectorAll('a[data-title]');
            const noResults = document.getElementById('v3-no-results');
            const q = query.toLowerCase().trim();
            let visible = 0;
            cards.forEach(function(card) {
                const title = (card.dataset.title || '');
                if (q === '' || title.includes(q)) {
                    card.style.display = '';
                    visible++;
                } else {
                    card.style.display = 'none';
                }
            });
            noResults.style.display = visible === 0 ? 'flex' : 'none';
        }

        // GSAP entrance animations
        document.addEventListener('DOMContentLoaded', function() {
            if (typeof gsap !== 'undefined' && typeof ScrollTrigger !== 'undefined') {
                gsap.registerPlugin(ScrollTrigger);
                gsap.to('.gsap-reveal', { y: 0, opacity: 1, duration: 1, stagger: 0.15, ease: 'power3.out', delay: 0.1 });
                gsap.from('.gsap-stagger-item', {
                    scrollTrigger: { trigger: '#v3-grid', start: 'top 85%' },
                    y: 50, opacity: 0, duration: 0.8, stagger: 0.08, ease: 'power3.out'
                });
            }
        });
    </script>
</body>

</html>