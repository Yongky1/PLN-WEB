{
  "name": "pln-pusdiklat",
  "version": "1.0.0",
  "main": "server.js",
  "scripts": {
    "dev:css": "npx @tailwindcss/cli -i ./public/css/style.css -o ./public/css/output.css --watch",
    "dev:server": "nodemon --env-file .env server.js",
    "dev": "npm-run-all --parallel dev:css dev:server",
    "build:css": "npx @tailwindcss/cli -i ./public/css/style.css -o ./public/css/output.css --minify",
    "start": "node --env-file .env server.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write ."
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "PLN Pusdiklat - Learning Management System",
  "dependencies": {
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "helmet": "^8.1.0",
    "morgan": "^1.10.1",
    "three": "^0.158.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/cli": "^4.2.2",
    "autoprefixer": "^10.4.27",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "nodemon": "^3.1.14",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.9",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.2"
  }
}
